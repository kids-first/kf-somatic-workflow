                        },
                        {
                            "source": "#strelka2_retain_fmt",
                            "id": "#strelka2/retain_fmt"
                        },
                        {
                            "source": "#strelka2_retain_info",
                            "id": "#strelka2/retain_info"
                        },
                        {
                            "source": "#run_cache_af",
                            "id": "#strelka2/run_cache_af"
                        },
                        {
                            "source": "#run_cache_existing",
                            "id": "#strelka2/run_cache_existing"
                        },
                        {
                            "source": "#/runtime_validator/run_strelka2",
                            "id": "#strelka2/run_strelka2"
                        },
                        {
                            "source": "#select_vars_mode",
                            "id": "#strelka2/select_vars_mode"
                        },
                        {
                            "source": "#strelka2_cores",
                            "id": "#strelka2/strelka2_cores"
                        },
                        {
