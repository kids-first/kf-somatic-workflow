                        {
                            "source": "#cadd_indels",
                            "id": "#strelka2/cadd_indels"
                        },
                        {
                            "source": "#cadd_snvs",
                            "id": "#strelka2/cadd_snvs"
                        },
                        {
                            "source": "#custom_enst",
                            "id": "#strelka2/custom_enst"
                        },
                        {
                            "source": "#dbnsfp",
                            "id": "#strelka2/dbnsfp"
                        },
                        {
                            "source": "#dbnsfp_fields",
                            "id": "#strelka2/dbnsfp_fields"
                        },
                        {
                            "source": "#disable_hotspot_annotation",
                            "id": "#strelka2/disable_hotspot_annotation"
                        },
                        {
                            "source": "#disable_vep_annotation",
                            "id": "#strelka2/disable_vep_annotation"
                        },
                        {
                            "source": "#echtvar_anno_zips",
                            "id": "#strelka2/echtvar_anno_zips"
                        },
                        {
                            "source": "#/runtime_validator/out_exome_flag",
                            "id": "#strelka2/exome_flag"
                        },
                        {
                            "source": "#extra_arg",
                            "id": "#strelka2/extra_arg"
                        },
                        {
                            "source": "#gatk_filter_expression",
                            "id": "#strelka2/gatk_filter_expression"
                        },
                        {
                            "source": "#gatk_filter_name",
                            "id": "#strelka2/gatk_filter_name"
                        },
                        {
                            "source": "#genomic_hotspots",
                            "id": "#strelka2/genomic_hotspots"
                        },
                        {
                            "source": [
                                "#/prepare_regions_padded/prescatter_bedgz",
                                "#/prepare_regions_unpadded/prescatter_bedgz"
                            ],
                            "valueFrom": "$(self.some(function(e) { return e != null }) ? self.filter(function(e) { return e != null })[0] : null)\n",
                            "id": "#strelka2/hg38_strelka_bed"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "id": "#strelka2/indexed_reference_fasta"
                        },
                        {
                            "source": "#input_normal_aligned",
                            "id": "#strelka2/input_normal_aligned"
                        },
                        {
                            "source": "#input_normal_name",
                            "id": "#strelka2/input_normal_name"
                        },
                        {
                            "source": "#input_tumor_aligned",
                            "id": "#strelka2/input_tumor_aligned"
                        },
                        {
                            "source": "#input_tumor_name",
                            "id": "#strelka2/input_tumor_name"
                        },
                        {
