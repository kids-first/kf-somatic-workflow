                    ],
                    "doc": "BED or INTERVALLIST file containing a set of genomic regions to remove from the calling regions for CNV calling only!",
                    "id": "#cnv_blacklist_regions",
                    "https://sevenbridges.comsuggestedValue": {
                        "class": "File",
                        "path": "file:///home/ubuntu/volume/ICA/kf-somatic-workflow/workflow/663d2bcc27374715fccd8c6d",
                        "name": "#cnv_blacklist_regions/somatic-hg38_CNV_and_centromere_blacklist.hg38liftover.list"
                    }
                },
                {
                    "type": "File",
                    "doc": "refFlat.txt file",
                    "id": "#cnvkit_annotation_file",
                    "https://sevenbridges.comsuggestedValue": {
                        "class": "File",
                        "path": "file:///home/ubuntu/volume/ICA/kf-somatic-workflow/workflow/5f500135e4b0370371c051c1",
                        "name": "#cnvkit_annotation_file/refFlat_HG38.txt"
                    }
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#cnvkit_sex/cnvkit_sex",
                            "symbols": [
                                "#/cnvkit_sex/cnvkit_sex/x",
                                "#/cnvkit_sex/cnvkit_sex/y"
                            ]
                        }
                    ],
                    "doc": "Sex, for simplicity x for female y for male",
                    "default": "x",
                    "id": "#cnvkit_sex"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "for WGS mode, input Y. leave blank for WXS/hybrid mode",
                    "id": "#cnvkit_wgs_mode"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
