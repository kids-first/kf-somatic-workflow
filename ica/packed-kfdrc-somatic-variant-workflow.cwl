                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_ann"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with FORMAT fields that you want to keep",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_fmt"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with INFO fields that you want to keep, i.e. for consensus `MQ,MQ0,CAL,Hotspot`",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_info"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the allele frequency flags for cache",
                    "default": true,
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/run_cache_af"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the check_existing flag for cache",
                    "default": true,
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/run_cache_existing"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Create stats file? Disable for speed",
                    "default": false,
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/run_stats"
                },
                {
                    "type": "string",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 1000,
                    "doc": "Increase or decrease to balance speed and memory usage",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_buffer_size"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "tar gzipped cache from ensembl/local converted cache",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_cache",
                    "https://sevenbridges.comsuggestedValue": {
                        "class": "File",
                        "path": "file:///home/ubuntu/volume/ICA/kf-somatic-workflow/kf-annotation-tools/workflows/6332f8e47535110eb79c794f",
                        "name": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_cache/homo_sapiens_merged_vep_105_indexed_GRCh38.tar.gz"
                    }
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "Number of cores to use. May need to increase for really large inputs",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_cores"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 32,
                    "doc": "In GB, may need to increase this value depending on the size/complexity of input",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_ram"
                }
            ],
            "outputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc-somatic-snv-annot-workflow.cwl/rename_protected/renamed_files",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/annotated_protected"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc-somatic-snv-annot-workflow.cwl/rename_public/renamed_files",
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/annotated_public"
                }
            ],
            "steps": [
                {
                    "run": "#add_strelka2_fields.cwl",
                    "when": "$(inputs.run_tool_flag)",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/input_normal_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/normal_name"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/output_basename"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/add_common_fields",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/run_tool_flag"
                        },
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/stripped_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/normalized_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/filtered_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/input_vcf"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/strelka2_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/input_tumor_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/tumor_name"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/output"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields"
                },
                {
                    "when": "$(inputs.strip_info != null)",
                    "run": "#bcftools_strip_ann.cwl",
                    "in": [
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/normalized_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/filtered_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/input_vcf"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/output_basename"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_columns",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/strip_info"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/stripped_vcf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info"
                },
                {
                    "when": "$(inputs.echtvar_zips != null)",
                    "run": "#echtvar_anno.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/echtvar_anno_zips",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/echtvar_anno_gnomad/echtvar_zips"
                        },
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/output_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/output",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/stripped_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/normalized_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/filtered_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/input_vcf"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/echtvar_anno_gnomad/input_vcf"
                        },
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name"
                            ],
                            "valueFrom": "$(self[0]).$(self[1]).echtvar_annotated.vcf.gz\n",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/echtvar_anno_gnomad/output_filename"
                        },
                        {
                            "valueFrom": "$(1 == 1)\n",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/echtvar_anno_gnomad/tbi"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/echtvar_anno_gnomad/annotated_vcf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/echtvar_anno_gnomad"
                },
                {
                    "run": "#gatk_variant_filter.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_filter_expression",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter/filter_expression"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_filter_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter/filter_name"
                        },
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/echtvar_anno_gnomad/annotated_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/output_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/output",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/stripped_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/normalized_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/filtered_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/input_vcf"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter/output_basename"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/indexed_reference_fasta",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter/reference"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter/gatk_soft_filtered_vcf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter"
                },
                {
                    "run": "#bcftools_filter_vcf.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_public_filter",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hard_filter_vcf/include_expression"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/hotspots_vcf",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hard_filter_vcf/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hard_filter_vcf/output_basename"
                        },
                        {
                            "valueFrom": "z",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hard_filter_vcf/output_type"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/hard_filter_vcf/filtered_vcf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hard_filter_vcf"
                },
                {
                    "run": "#hotspots_annotation.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/disable_hotspot_annotation",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/disable_hotspot_annotation"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/genomic_hotspots",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/genomic_hotspots"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/gatk_add_soft_filter/gatk_soft_filtered_vcf",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/output_basename"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/protein_indel_hotspots",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/protein_indels"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/protein_snv_hotspots",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/protein_snvs"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/hotspots_vcf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation"
                },
                {
                    "run": "#kf_mskcc_vcf2maf.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/custom_enst",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/custom_enst"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/hotspots_vcf",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/maf_center",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/maf_center"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/input_normal_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/normal_id"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/output_basename"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/indexed_reference_fasta",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/reference"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_ann",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/retain_ann"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_fmt",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/retain_fmt"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_info",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/retain_info"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/tool_name"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/input_tumor_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/tumor_id"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/output_maf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected"
                },
                {
                    "run": "#kf_mskcc_vcf2maf.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/custom_enst",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/custom_enst"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/hard_filter_vcf/filtered_vcf",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/maf_center",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/maf_center"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/input_normal_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/normal_id"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/output_basename"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/indexed_reference_fasta",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/reference"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_ann",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/retain_ann"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_fmt",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/retain_fmt"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/retain_info",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/retain_info"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/tool_name"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/input_tumor_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/tumor_id"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/output_maf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public"
                },
                {
                    "when": "$(inputs.disable_norm == false)",
                    "run": "#normalize_vcf.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/disable_norm",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/disable_norm"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/indexed_reference_fasta",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/indexed_reference_fasta"
                        },
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/filtered_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/input_vcf"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/output_basename"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/normalized_vcf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf"
                },
                {
                    "when": "$(inputs.include_expression != null)",
                    "run": "#bcftools_filter_vcf.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_prefilter_csv",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/include_expression"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/input_vcf",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/output_basename"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/filtered_vcf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf"
                },
                {
                    "run": "#generic_rename_outputs.cwl",
                    "label": "Rename Protected Outputs",
                    "in": [
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/hotspots_annotation/hotspots_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_protected/output_maf"
                            ],
                            "valueFrom": "$([self[0], self[0].secondaryFiles[0], self[1]])\n",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/rename_protected/input_files"
                        },
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name"
                            ],
                            "valueFrom": "${\n  var prefix = self[0] + '.' + self[1] + '.norm.annot.protected';\n  return [\n    prefix + '.vcf.gz',\n    prefix + '.vcf.gz.tbi',\n    prefix + '.maf'\n  ];\n}\n",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/rename_protected/rename_to"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/rename_protected/renamed_files"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/rename_protected"
                },
                {
                    "run": "#generic_rename_outputs.cwl",
                    "label": "Rename Public Outputs",
                    "in": [
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/hard_filter_vcf/filtered_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/kfdrc_vcf2maf_public/output_maf"
                            ],
                            "valueFrom": "$([self[0], self[0].secondaryFiles[0], self[1]])\n",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/rename_public/input_files"
                        },
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name"
                            ],
                            "valueFrom": "${\n  var prefix = self[0] + '.' + self[1] + '.norm.annot.public';\n  return [\n    prefix + '.vcf.gz',\n    prefix + '.vcf.gz.tbi',\n    prefix + '.maf'\n  ];\n}\n",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/rename_public/rename_to"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/rename_public/renamed_files"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/rename_public"
                },
                {
                    "when": "$(inputs.disable_annotation == false)",
                    "run": "#variant_effect_predictor_105.cwl",
                    "in": [
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_buffer_size",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/buffer_size"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_cache",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/cache"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/cadd_indels",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/cadd_indels"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/cadd_snvs",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/cadd_snvs"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_cores",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/cores"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/dbnsfp",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/dbnsfp"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/dbnsfp_fields",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/dbnsfp_fields"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/disable_vep_annotation",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/disable_annotation"
                        },
                        {
                            "source": [
                                "#kfdrc-somatic-snv-annot-workflow.cwl/add_standard_fields/output",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/bcftools_strip_info/stripped_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/normalize_vcf/normalized_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/prefilter_vcf/filtered_vcf",
                                "#kfdrc-somatic-snv-annot-workflow.cwl/input_vcf"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/input_vcf"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/merged",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/merged"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/output_basename",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/output_basename"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_ram",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/ram"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/indexed_reference_fasta",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/reference"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/run_cache_af",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/run_cache_af"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/run_cache_existing",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/run_cache_existing"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/run_stats",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/run_stats"
                        },
                        {
                            "source": "#kfdrc-somatic-snv-annot-workflow.cwl/tool_name",
                            "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf/output_vcf"
                    ],
                    "id": "#kfdrc-somatic-snv-annot-workflow.cwl/vep_annotate_vcf"
                }
            ],
            "https://sevenbridges.comlicense": "Apache License 2.0",
            "https://sevenbridges.compublisher": "KFDRC",
            "https://sevenbridges.comlinks": [
                {
                    "id": "#v1.2.4",
                    "label": "github-release"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc_cnvkit_sub_wf.cwl",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "SubworkflowFeatureRequirement"
                },
                {
                    "class": "StepInputExpressionRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "doc": "refFlat.txt file",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/annotation_file"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "b allele germline vcf, if available",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/b_allele_vcf"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Regions of the genome over which CNVkit should not perform resequencing. CNVkit refers to these regions as inaccessible.",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/blacklist_regions"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "target regions for WES. These are the bait regions.",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/capture_regions"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "If running using an existing .cnn, supply here",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_cnn_input"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/input_normal_aligned"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/input_tumor_aligned"
                },
                {
                    "type": "string",
                    "doc": "For theta2 input",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/normal_sample_name"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/output_basename"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_cnvkit_sub_wf.cwl/sex/sex",
                            "symbols": [
                                "#kfdrc_cnvkit_sub_wf.cwl/sex/sex/x",
                                "#kfdrc_cnvkit_sub_wf.cwl/sex/sex/y"
                            ]
                        }
                    ],
                    "doc": "Sex, for simplicity x for female y for male",
                    "default": "x",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/sex"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/threads"
                },
                {
                    "type": "string",
                    "doc": "For seg file output and theta2 input",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/tumor_sample_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "for WGS mode, input Y. leave blank for hybrid mode",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/wgs_mode"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_calls",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_calls"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_cnn",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_cnn_output"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_cnr",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_cnr"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_cns",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_cns"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_diagram",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_diagram"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_gainloss",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_gainloss"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_metrics",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_metrics"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_scatter",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_scatter_plot"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_seg",
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_seg"
                }
            ],
            "steps": [
                {
                    "run": "#cnvkit_access.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/blacklist_regions",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/access/exclude"
                        },
                        {
                            "valueFrom": "$(200)",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/access/min_gap_size"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/reference",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/access/reference_fasta"
                        }
                    ],
                    "out": [
                        "#kfdrc_cnvkit_sub_wf.cwl/access/bed"
                    ],
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/access"
                },
                {
                    "run": "#cnvkit_batch.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/access/bed",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/access"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/annotation_file",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/annotation_file"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/b_allele_vcf",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/b_allele_vcf"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/capture_regions",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/capture_regions"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/cnvkit_cnn_input",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/cnvkit_cnn"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/input_normal_aligned",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/input_control"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/input_tumor_aligned",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/input_sample"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/output_basename"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/reference",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/reference"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/sex",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/sex"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/threads",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/threads"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/tumor_sample_name",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/tumor_sample_name"
                        },
                        {
                            "source": "#kfdrc_cnvkit_sub_wf.cwl/wgs_mode",
                            "id": "#kfdrc_cnvkit_sub_wf.cwl/batch/wgs_mode"
                        }
                    ],
                    "out": [
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_cnr",
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_calls",
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_cns",
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_scatter",
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_diagram",
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_metrics",
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_gainloss",
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_seg",
                        "#kfdrc_cnvkit_sub_wf.cwl/batch/output_cnn"
                    ],
                    "id": "#kfdrc_cnvkit_sub_wf.cwl/batch"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc_controlfreec_sub_wf.cwl",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "SubworkflowFeatureRequirement"
                },
                {
                    "class": "StepInputExpressionRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "germline calls, needed for BAF.  VarDict input recommended.  Tool will prefilter for germline and pass if expression given",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/b_allele"
                },
                {
                    "type": "File",
                    "doc": "BED containing the regions over which Control-FREEC should be run. For WXS, these are the bait intervals.",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/calling_regions"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_controlfreec_sub_wf.cwl/cfree_sex/sex",
                            "symbols": [
                                "#kfdrc_controlfreec_sub_wf.cwl/cfree_sex/sex/XX",
                                "#kfdrc_controlfreec_sub_wf.cwl/cfree_sex/sex/XY"
                            ]
                        }
                    ],
                    "doc": "If known, XX for female, XY for male",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/cfree_sex"
                },
                {
                    "type": "float",
                    "default": 0.05,
                    "doc": "Coefficient of variantion to set window size.  Default 0.05 recommended",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/coeff_var"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "TRUE or FALSE to have ControlFreec estimate normal contam",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/contamination_adjustment"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "GEM mappability file to make read count adjustments with",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/gem_mappability_file"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "doc": "Reference FASTA file and associated FAI index.",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/indexed_reference_fasta"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/input_normal_aligned"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/input_tumor_aligned"
                },
                {
                    "type": "string",
                    "doc": "Sample name to put into the converted seg file",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/input_tumor_name"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Normal cpn file from previous run. If used, will override bam use",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/mate_copynumber_file_control"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Tumor cpn file from previous run. If used, will override bam use",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/mate_copynumber_file_sample"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_control/mate_orientation_control",
                            "symbols": [
                                "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_control/mate_orientation_control/0",
                                "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_control/mate_orientation_control/FR",
                                "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_control/mate_orientation_control/RF",
                                "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_control/mate_orientation_control/FF"
                            ]
                        }
                    ],
                    "default": "FR",
                    "doc": "0 (for single ends), RF (Illumina mate-pairs), FR (Illumina paired-ends), FF (SOLiD mate-pairs)",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_control"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_sample/mate_orientation_sample",
                            "symbols": [
                                "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_sample/mate_orientation_sample/0",
                                "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_sample/mate_orientation_sample/FR",
                                "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_sample/mate_orientation_sample/RF",
                                "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_sample/mate_orientation_sample/FF"
                            ]
                        }
                    ],
                    "default": "FR",
                    "doc": "0 (for single ends), RF (Illumina mate-pairs), FR (Illumina paired-ends), FF (SOLiD mate-pairs)",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_sample"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Use if you want to detect sublones. Recommend 20 for WGS, 30 for WXS",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/min_subclone_presence"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/output_basename"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "int"
                    },
                    "doc": "Array of ploidy possibilities for ControlFreeC to try",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ploidy"
                },
                {
                    "type": "int",
                    "doc": "Number of threads to run controlfreec.  Going above 16 is not recommended, there is no apparent added value",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/threads"
                },
                {
                    "type": {
                        "type": "enum",
                        "name": "#kfdrc_controlfreec_sub_wf.cwl/wgs_or_wxs/wgs_or_wxs",
                        "symbols": [
                            "#kfdrc_controlfreec_sub_wf.cwl/wgs_or_wxs/wgs_or_wxs/WGS",
                            "#kfdrc_controlfreec_sub_wf.cwl/wgs_or_wxs/wgs_or_wxs/WXS"
                        ]
                    },
                    "doc": "Select if this run is WGS or WXS",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/wgs_or_wxs"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputSource": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_baf",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ctrlfreec_baf"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_bam_ratio",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ctrlfreec_bam_ratio"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_controlfreec_sub_wf.cwl/convert_ratio_to_seg/ctrlfreec_ratio2seg",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ctrlfreec_bam_seg"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_cnvs",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ctrlfreec_cnvs"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_config",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ctrlfreec_config"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_info",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ctrlfreec_info"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_pngs",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ctrlfreec_pngs"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_pval",
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/ctrlfreec_pval"
                }
            ],
            "steps": [
                {
                    "run": "#awk_chrlen_builder.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/calling_regions",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/awk_chrlen_builder/input_intervals"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/b_allele",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/awk_chrlen_builder/input_variants"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/indexed_reference_fasta",
                            "valueFrom": "$(self.secondaryFiles.filter(function(e) { return e.basename.search(/.fai$/) != -1 })[0])\n",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/awk_chrlen_builder/reference_fai"
                        }
                    ],
                    "out": [
                        "#kfdrc_controlfreec_sub_wf.cwl/awk_chrlen_builder/chrlen"
                    ],
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/awk_chrlen_builder"
                },
                {
                    "run": "#control-freec-11-6-sbg.cwl",
                    "hints": [
                        {
                            "class": "sbg:AWSInstanceType",
                            "value": "c5.4xlarge"
                        }
                    ],
                    "in": [
                        {
                            "source": [
                                "#kfdrc_controlfreec_sub_wf.cwl/wgs_or_wxs",
                                "#kfdrc_controlfreec_sub_wf.cwl/calling_regions"
                            ],
                            "valueFrom": "$(self[0] == 'WXS' ? self[1] : null)\n",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/capture_regions"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/awk_chrlen_builder/chrlen",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/chr_len"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/coeff_var",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/coeff_var"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/contamination_adjustment",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/contamination_adjustment"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/gem_mappability_file",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/gem_mappability_file"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/mate_copynumber_file_control",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/mate_copynumber_file_control"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/mate_copynumber_file_sample",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/mate_copynumber_file_sample"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/input_normal_aligned",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/mate_file_control"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/input_tumor_aligned",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/mate_file_sample"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_control",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/mate_orientation_control"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/mate_orientation_sample",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/mate_orientation_sample"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/threads",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/max_threads"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/min_subclone_presence",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/min_subclone_presence"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_normal_mini_pileup/pileup",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/mini_pileup_control"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_tumor_mini_pileup/pileup",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/mini_pileup_sample"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/ploidy",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/ploidy"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/reference"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/cfree_sex",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/sex"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/b_allele",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/snp_file"
                        }
                    ],
                    "out": [
                        "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/cnvs",
                        "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/cnvs_pvalue",
                        "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/config_script",
                        "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/pngs",
                        "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/ratio",
                        "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/sample_BAF",
                        "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/info_txt"
                    ],
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c"
                },
                {
                    "run": "#control_freec_mini_pileup.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/input_normal_aligned",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_normal_mini_pileup/input_reads"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_normal_mini_pileup/reference"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/b_allele",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_normal_mini_pileup/snp_vcf"
                        },
                        {
                            "valueFrom": "$(16)",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_normal_mini_pileup/threads"
                        }
                    ],
                    "out": [
                        "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_normal_mini_pileup/pileup"
                    ],
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_normal_mini_pileup"
                },
                {
                    "run": "#control_freec_mini_pileup.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/input_tumor_aligned",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_tumor_mini_pileup/input_reads"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_tumor_mini_pileup/reference"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/b_allele",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_tumor_mini_pileup/snp_vcf"
                        },
                        {
                            "valueFrom": "$(16)",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_tumor_mini_pileup/threads"
                        }
                    ],
                    "out": [
                        "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_tumor_mini_pileup/pileup"
                    ],
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/controlfreec_tumor_mini_pileup"
                },
                {
                    "run": "#ubuntu_ratio2seg.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/ratio",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/convert_ratio_to_seg/ctrlfreec_ratio"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/convert_ratio_to_seg/output_basename"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/indexed_reference_fasta",
                            "valueFrom": "$(self.secondaryFiles.filter(function(e) { return e.basename.search(/.fai$/) != -1 })[0])\n",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/convert_ratio_to_seg/reference_fai"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/input_tumor_name",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/convert_ratio_to_seg/sample_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_controlfreec_sub_wf.cwl/convert_ratio_to_seg/ctrlfreec_ratio2seg"
                    ],
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/convert_ratio_to_seg"
                },
                {
                    "run": "#ubuntu_rename_outputs.cwl",
                    "in": [
                        {
                            "source": [
                                "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/cnvs",
                                "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/cnvs_pvalue",
                                "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/config_script",
                                "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/ratio",
                                "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/sample_BAF",
                                "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/info_txt"
                            ],
                            "pickValue": "all_non_null",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/input_files"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/control_free_c/pngs",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/input_pngs"
                        },
                        {
                            "source": "#kfdrc_controlfreec_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/output_basename"
                        }
                    ],
                    "out": [
                        "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_cnvs",
                        "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_pval",
                        "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_config",
                        "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_pngs",
                        "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_bam_ratio",
                        "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_baf",
                        "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs/ctrlfreec_info"
                    ],
                    "id": "#kfdrc_controlfreec_sub_wf.cwl/rename_outputs"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl",
            "label": "KFDRC GATK CNV Somatic Pair Workflow",
            "doc": "# KFDRC GATK CNV Somatic Pair Workflow\n\n![data service logo](https://github.com/d3b-center/d3b-research-workflows/raw/master/doc/kfdrc-logo-sm.png)\n\nThe Kids First Data Resource Center GATK CNV Somatic Pair Workflow is a direct\nport of the GATK best practices workflow WDL. Workflow for running the GATK CNV\npipeline on a matched pair (normal sample optional). Supports both WGS and WES.\n\n## Generalized steps:\n\n- prepares a genomic intervals list with PreprocessIntervals\n- collects read coverage counts across the preprocessed intervals\n- collects counts of reference versus alternate alleles with\n  CollectAllelicCounts\n- annotate the preprocessed intervals\n- denoises read coverage data against the PoN with DenoiseReadCounts using\n  principal component analysis\n- plots the results of standardizing and denoising copy ratios against the PoN\n- incorporates copy ratio and allelic counts data to group contiguous copy\n  ratio and allelic counts segments with ModelSegments using kernel\nsegmentation and Markov-chain Monte Carlo\n- calls amplification, deletion and neutral events for the segmented copy\n  ratios\n- plots the results of segmentation and estimated allele-specific copy ratios\n\n## Notes from GATK:\n\n- The intervals argument (`input_intervals` and/or `input_interval_list`) is\n  required for both WGS and WES workflows and accepts formats compatible with\nthe GATK -L argument. These intervals will be padded on both sides by the\namount specified by `padding` (default 250) and split into bins of length\nspecified by `bin_length` (default 1000; specify 0 to skip binning, e.g., for\nWES).  For WGS, the intervals should simply cover the autosomal chromosomes\n(sex chromosomes may be included, but care should be taken to 1) avoid creating\npanels of mixed sex, and 2) denoise case samples only with panels containing\nonly individuals of the same sex as the case samples).\n- Intervals can be blacklisted from coverage collection and all downstream\n  steps by using the blacklist intervals argument (`input_exclude_intervals`\nand/or `input_exclude_intervals_list`), which accepts formats compatible with\nthe GATK -XL argument. This may be useful for excluding centromeric regions,\netc. from analysis.  Alternatively, these regions may be manually filtered from\nthe final callset.\n- The sites file (common_sites) should be a Picard or GATK-style interval list.\n  This is a list of sites of known variation at which allelic counts will be\ncollected for use in modeling minor-allele fractions.\n- To run `gatk_funcotatesegments.cwl` you must set `run_funcotatesegments` to\n  `True` and provide at least `funcotator_data_sources_tgz` and\n`funcotator_ref_version`\n\n### Other Resources\n\ndockerfiles: https://github.com/d3b-center/bixtools\n",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "SubworkflowFeatureRequirement"
                },
                {
                    "class": "StepInputExpressionRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 100,
                    "doc": "Max memory in GB to allocate to CollectAllelicCounts",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/allelic_counts_max_mem"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Size of bins (in bp) for coverage collection. For WGS, use default. For WES, set this value to 0 to skip binning.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/bin_length"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Threshold on z-score of non-log2 copy ratio used for calling segments.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/calling_copy_ratio_z_score_threshold"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/collect_counts_format/collect_counts_format",
                            "symbols": [
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/collect_counts_format/collect_counts_format/HDF5",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/collect_counts_format/collect_counts_format/TSV"
                            ]
                        }
                    ],
                    "doc": "Desired format of outputs from CollectReadCounts.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/collect_counts_format"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "doc": "Picard or GATK-style interval list of common sites to use for collecting allelic counts.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/common_sites",
                    "https://sevenbridges.comfileTypes": "INTERVALS, INTERVAL_LIST, LIST, BED, VCF, VCF.GZ"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Path to read-count PoN created by the panel workflow. Significantly reduces quality of calling if not provided!",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/count_panel_of_normals",
                    "https://sevenbridges.comfileTypes": "HDF5"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string"
                        }
                    ],
                    "doc": "Annotations to include in all annotated variants if the annotation is not specified in the data sources (in the format :). This will add the specified annotation to every annotated variant if it is not already present.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_annotation_default"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string"
                        }
                    ],
                    "doc": "Override values for annotations (in the format :). Replaces existing annotations of the given name with given values.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_annotation_override"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Path to tar.gz containing the data sources for Funcotator to create annotations.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_data_sources_tgz",
                    "https://sevenbridges.comfileTypes": "TAR, TAR.GZ, TGZ",
                    "https://sevenbridges.comsuggestedValue": {
                        "class": "File",
                        "path": "file:///home/ubuntu/volume/ICA/kf-somatic-workflow/sub_workflows/60e5f8636a504e4e0c6408d8",
                        "name": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_data_sources_tgz/funcotator_dataSources.v1.6.20190124s.tar.gz"
                    }
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string"
                        }
                    ],
                    "doc": "Fields that should not be rendered in the final output. Only exact name matches will be excluded.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_exclude_field"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "The minimum number of bases for a variant to be annotated as a segment. Recommended to be changed only for use with FuncotateSegments. If you encounter 'Variant context does not represent a copy number segment' error, set this value lower than the length of the failed segment.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_minimum_segment_size"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_ref_version/funcotator_ref_version",
                            "symbols": [
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_ref_version/funcotator_ref_version/hg19",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_ref_version/funcotator_ref_version/hg38",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_ref_version/funcotator_ref_version/b37"
                            ]
                        }
                    ],
                    "default": "hg38",
                    "doc": "The version of the Human Genome reference to use (e.g. hg19, hg38, etc.). This will correspond to a sub-folder of each data source corresponding to that data source for the given reference.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_ref_version"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string"
                        }
                    ],
                    "doc": "A set of transcript IDs to use for annotation to override selected transcript.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_transcript_list"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "File to use as a list of transcripts (one transcript ID per line, version numbers are ignored)",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/funcotator_transcript_list_file"
                },
                {
                    "type": [
                        "null",
                        {
