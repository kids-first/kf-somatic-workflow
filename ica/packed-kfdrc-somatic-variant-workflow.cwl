                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#/lancet/lancet_protected_outputs",
                    "id": "#lancet_protected_outputs"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
