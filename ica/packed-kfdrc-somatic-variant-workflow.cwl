                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of segmentation-smoothing iterations per MCMC model refit. (Increasing this will decrease runtime, but the final number of segments may be higher. Setting this to 0 will completely disable model refitting between iterations.)",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/number_of_smoothing_iterations_per_fit"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Threshold on z-score of non-log2 copy ratio used for determining outlier copy-neutral segments. If non-log2 copy ratio z-score is above this threshold for a copy-neutral segment, it is considered an outlier and not used in the calculation of the length-weighted mean and standard deviation used for calling.",
                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/outlier_neutral_segment_copy_ratio_z_score_threshold"
                },
