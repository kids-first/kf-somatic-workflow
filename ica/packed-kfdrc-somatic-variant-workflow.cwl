                    ],
                    "doc": "One or more genomic intervals to exclude from processing. Use this input when providing the intervals as strings.",
                    "inputBinding": {
                        "position": 2
                    },
                    "id": "#gatk_collectreadcounts.cwl/input_exclude_intervals"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
