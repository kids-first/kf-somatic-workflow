                        "prefix": "-XL"
                    },
                    "id": "#gatk_collectreadcounts.cwl/input_exclude_interval_list"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
