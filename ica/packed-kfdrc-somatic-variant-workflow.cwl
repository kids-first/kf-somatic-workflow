                            "id": "#strelka2/protein_indel_hotspots"
                        },
                        {
                            "source": "#protein_snv_hotspots",
                            "id": "#strelka2/protein_snv_hotspots"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "valueFrom": "$(self.secondaryFiles.filter(function(e) { return e.basename.search(/.dict$/) != -1 })[0])\n",
                            "id": "#strelka2/reference_dict"
                        },
                        {
