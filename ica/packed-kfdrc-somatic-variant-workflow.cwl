                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/call_copy_ratio_segments_normal/called_segments",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_normal/denoised_plot",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_normal/delta_mad",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_normal/denoised_mad",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_normal/scaled_delta_mad",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_normal/standardized_mad",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_modeled_segments_normal/output"
