                    "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/input_interval_list",
                    "https://sevenbridges.comfileTypes": "INTERVALS, INTERVAL_LIST, LIST, BED, VCF, VCF.GZ"
