                    "id": "#gatk_cnv_funcotated_called_gene_list_file_tumor"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputSource": "#/gatk_cnv/called_copy_ratio_segments_normal",
                    "doc": "Called copy-ratio-segments file. This is a tab-separated values (TSV) file with a SAM-style header containing a read group sample name, a sequence dictionary, a row specifying the column headers contained in CalledCopyRatioSegmentCollection.CalledCopyRatioSegmentTableColumn, and the corresponding entry rows.",
                    "id": "#gatk_copy_ratio_segments_normal"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputSource": "#/gatk_cnv/called_copy_ratio_segments_tumor",
                    "doc": "Called copy-ratio-segments file. This is a tab-separated values (TSV) file with a SAM-style header containing a read group sample name, a sequence dictionary, a row specifying the column headers contained in CalledCopyRatioSegmentCollection.CalledCopyRatioSegmentTableColumn, and the corresponding entry rows.",
                    "id": "#gatk_copy_ratio_segments_tumor"
                },
                {
                    "type": "File",
