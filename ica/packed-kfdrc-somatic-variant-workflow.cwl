            "outputs": [
                {
                    "type": "File",
                    "outputSource": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/reheadered_vcf",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2_prepass_vcf"
