                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/model_segments_tumor/modeled_segments",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/model_segments_tumor/modeled_segments_begin",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/model_segments_tumor/normal_het_allelic_counts",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/call_copy_ratio_segments_tumor/called_legacy_segments",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/call_copy_ratio_segments_tumor/called_segments",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_tumor/denoised_plot",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_tumor/delta_mad",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_tumor/denoised_mad",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_tumor/scaled_delta_mad",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/plot_denoised_copy_ratios_tumor/standardized_mad",
