                        "int"
                    ],
                    "default": 5000,
                    "doc": "Increase or decrease to balance speed and memory usage",
                    "id": "#vep_buffer_size"
                },
                {
                    "type": "File",
                    "doc": "tar gzipped cache from ensembl/local converted cache",
                    "id": "#vep_cache",
                    "https://sevenbridges.comsuggestedValue": {
                        "class": "File",
                        "path": "file:///home/ubuntu/volume/ICA/kf-somatic-workflow/workflow/6332f8e47535110eb79c794f",
                        "name": "#vep_cache/homo_sapiens_merged_vep_105_indexed_GRCh38.tar.gz"
                    }
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "Number of cores to use. May need to increase for really large inputs",
