        {
            "class": "CommandLineTool",
            "id": "#control_freec_mini_pileup.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "images.sbgenomics.com/vojislav_varjacic/control-freec-11-6:v1"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 10000,
                    "coresMin": "$(inputs.threads)"
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-c"
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": true,
                    "valueFrom": "set -eo pipefail;\n$(inputs.snp_vcf == null ? \"echo No vcf provided, skipping >&2 && exit 0\" : \"echo Creating pileup >&2\");\nzcat $(inputs.snp_vcf != null ? inputs.snp_vcf.path : \"\") | grep -v \"#\" | awk {'printf (\"%s\\t%s\\t%s\\t%s\\t%s\\n\", $1,$2-1,$2,$4,$5)'} > snps.bed;\n/opt/sambamba_0.5.9/sambamba_v0.5.9 mpileup -t $(inputs.threads) -o $(inputs.input_reads.nameroot).miniPileup $(inputs.input_reads.path) --samtools -f $(inputs.reference.path) -d 8000 -Q 0 -q 1 -l snps.bed"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".bai",
                            "required": false
                        }
                    ],
                    "id": "#control_freec_mini_pileup.cwl/input_reads"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#control_freec_mini_pileup.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Germline vcf with sites to filter pileup on. Made optional to skip if needed during pipeline run",
                    "id": "#control_freec_mini_pileup.cwl/snp_vcf"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "id": "#control_freec_mini_pileup.cwl/threads"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "$(inputs.input_reads.nameroot).miniPileup"
                    },
                    "id": "#control_freec_mini_pileup.cwl/pileup"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_Mutect2.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 6000,
                    "coresMin": 3
                }
            ],
            "baseCommand": [
                "/gatk",
                "Mutect2"
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "--java-options \"-Xmx6000m\" -R $(inputs.reference.path) -I $(inputs.input_tumor_aligned.path) -I $(inputs.input_normal_aligned.path) -tumor $(inputs.input_tumor_name) -normal $(inputs.input_normal_name) --disable-read-filter MateOnSameContigOrNoMappedMateReadFilter -L $(inputs.interval_list.path) --germline-resource $(inputs.af_only_gnomad_vcf.path) --f1r2-tar-gz $(inputs.input_tumor_aligned.nameroot).$(inputs.interval_list.nameroot).f1r2_counts.tar.gz ${\n  var arg = \"-O \" + inputs.input_tumor_aligned.nameroot + \".\" + inputs.interval_list.nameroot + \".Mutect2.vcf.gz\"\n  if (inputs.exome_flag == 'Y'){\n    arg += \" --disable-adaptive-pruning\"\n  }\n  return arg\n}"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#gatk_Mutect2.cwl/af_only_gnomad_vcf"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Y if exome/capture, defaults to WGS",
                    "id": "#gatk_Mutect2.cwl/exome_flag"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "doc": "normal BAM or CRAM",
                    "id": "#gatk_Mutect2.cwl/input_normal_aligned"
                },
                {
                    "type": "string",
                    "id": "#gatk_Mutect2.cwl/input_normal_name"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "doc": "tumor BAM or CRAM",
                    "id": "#gatk_Mutect2.cwl/input_tumor_aligned"
                },
                {
                    "type": "string",
                    "id": "#gatk_Mutect2.cwl/input_tumor_name"
                },
                {
                    "type": "File",
                    "id": "#gatk_Mutect2.cwl/interval_list"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.dict",
                            "required": null
                        },
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#gatk_Mutect2.cwl/reference"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.f1r2_counts.tar.gz"
                    },
                    "id": "#gatk_Mutect2.cwl/f1r2_counts"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#gatk_Mutect2.cwl/mutect2_vcf"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.stats"
                    },
                    "id": "#gatk_Mutect2.cwl/mutect_stats"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_bedtointervallist.cwl",
            "doc": "Converts a BED file to a Picard Interval List.  This tool provides easy\nconversion from BED to the Picard interval_list format which is required by\nmany Picard processing tools. Note that the coordinate system of BED files is\nsuch that the first base or position in a sequence is numbered \"0\", while in\ninterval_list files it is numbered \"1\"\n",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.max_memory * 1000)",
                    "coresMin": "$(inputs.cores)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.4.0.0"
                }
            ],
            "baseCommand": [
                "gatk",
                "BedToIntervalList"
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 2,
                    "doc": "Minimum reserved number of CPU cores for the task.",
                    "id": "#gatk_bedtointervallist.cwl/cores"
                },
                {
                    "type": "File",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--INPUT"
                    },
                    "doc": "The input BED file.",
                    "id": "#gatk_bedtointervallist.cwl/input_bed"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "GB of RAM to allocate to the task.",
                    "id": "#gatk_bedtointervallist.cwl/max_memory"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "default": "out.interval_list",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--OUTPUT"
                    },
                    "doc": "The output Picard Interval List.",
                    "id": "#gatk_bedtointervallist.cwl/output_filename"
                },
                {
                    "type": "File",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--SEQUENCE_DICTIONARY"
                    },
                    "doc": "The sequence dictionary, or BAM/VCF/IntervalList from which a dictionary can be extracted.",
                    "id": "#gatk_bedtointervallist.cwl/reference_dict"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--SORT",
                        "valueFrom": "$(self ? \"true\" : \"false\")"
                    },
                    "doc": "If true, sort the output interval list before writing it.",
                    "id": "#gatk_bedtointervallist.cwl/sort"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": false,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--UNIQUE",
                        "valueFrom": "$(self ? \"true\" : \"false\")"
                    },
                    "doc": "If true, unique the output interval list by merging overlapping regions, before writing it (implies sort=true).",
                    "id": "#gatk_bedtointervallist.cwl/unique"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "$(inputs.output_filename)"
                    },
                    "id": "#gatk_bedtointervallist.cwl/output"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_calculatecontamination.cwl",
            "label": "GATK Calculate Contamination",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 4000,
                    "coresMin": 2
                }
            ],
            "baseCommand": [
                "/gatk",
                "CalculateContamination"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "--java-options \"-Xmx4000m\" -I $(inputs.tumor_pileup.path) --matched-normal $(inputs.normal_pileup.path) -O $(inputs.output_basename).contamination.table --tumor-segmentation $(inputs.output_basename).segmentation.table"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#gatk_calculatecontamination.cwl/normal_pileup"
                },
                {
                    "type": "string",
                    "id": "#gatk_calculatecontamination.cwl/output_basename"
                },
                {
                    "type": "File",
                    "id": "#gatk_calculatecontamination.cwl/tumor_pileup"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.contamination.table"
                    },
                    "id": "#gatk_calculatecontamination.cwl/contamination_table"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.segmentation.table"
                    },
                    "id": "#gatk_calculatecontamination.cwl/segmentation_table"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_callcopyratiosegments.cwl",
            "doc": "Calls copy-ratio segments as amplified, deleted, or copy-number neutral.",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.max_memory*1000)",
                    "coresMin": "$(inputs.cpu)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.2.4.1"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "$( inputs.copy_ratio_segments ? 'gatk' : 'echo gatk' )"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "CallCopyRatioSegments"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "prefix": "-O",
                    "valueFrom": "${var pre = inputs.output_prefix ? inputs.output_prefix : inputs.copy_ratio_segments ? inputs.copy_ratio_segments.nameroot : 'output'; return pre+'.called.seg'}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Threshold on z-score of non-log2 copy ratio used for calling segments.",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--calling-copy-ratio-z-score-threshold"
                    },
                    "id": "#gatk_callcopyratiosegments.cwl/calling_copy_ratio_z_score_threshold"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing copy-ratio segments (.cr.seg output of ModelSegments).",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "-I"
                    },
                    "id": "#gatk_callcopyratiosegments.cwl/copy_ratio_segments"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "Number of CPUs to allocate to this task.",
                    "id": "#gatk_callcopyratiosegments.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "Maximum GB of RAM to allocate for this tool.",
                    "id": "#gatk_callcopyratiosegments.cwl/max_memory"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Lower bound on non-log2 copy ratio used for determining copy-neutral segments.",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--neutral-segment-copy-ratio-lower-bound"
                    },
                    "id": "#gatk_callcopyratiosegments.cwl/neutral_segment_copy_ratio_lower_bound"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Upper bound on non-log2 copy ratio used for determining copy-neutral segments.",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--neutral-segment-copy-ratio-upper-bound"
                    },
                    "id": "#gatk_callcopyratiosegments.cwl/neutral_segment_copy_ratio_upper_bound"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Threshold on z-score of non-log2 copy ratio used for determining outlier copy-neutral segments. If non-log2 copy ratio z-score is above this threshold for a copy-neutral segment, it is considered an outlier and not used in the calculation of the length-weighted mean and standard deviation used for calling.",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--outlier-neutral-segment-copy-ratio-z-score-threshold"
                    },
                    "id": "#gatk_callcopyratiosegments.cwl/outlier_neutral_segment_copy_ratio_z_score_threshold"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to use as the prefix for the outputs.",
                    "id": "#gatk_callcopyratiosegments.cwl/output_prefix"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*called.igv.seg"
                    },
                    "id": "#gatk_callcopyratiosegments.cwl/called_legacy_segments"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.called.seg"
                    },
                    "id": "#gatk_callcopyratiosegments.cwl/called_segments"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_collectalleliccounts.cwl",
            "doc": "Collects reference and alternate allele counts at specified sites. The alt count is defined as the total count minus the ref count, and the alt nucleotide is defined as the non-ref base with the highest count, with ties broken by the order of the bases in AllelicCountCollector#BASES. Only reads that pass the specified read filters and bases that exceed the specified minimum-base-quality will be counted. Notes: The input interval list to this file should be either a dbSNP VCF+TBI or the germline VCF+TBI from of the normal inputBAM.",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.max_memory*1000)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.2.4.1"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "$( inputs.input_aligned_reads ? 'gatk' : 'echo gatk' )"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "prefix": "--java-options",
                    "valueFrom": "$(\"\\\"-Xmx\"+Math.floor(inputs.max_memory*1000/1.074 - 1)+\"M\\\"\")"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "valueFrom": "CollectAllelicCounts"
                },
                {
                    "position": 3,
                    "shellQuote": false,
