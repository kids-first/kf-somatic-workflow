                    "out": [
                        "#/theta2_purity/theta2_adjusted_cns",
                        "#/theta2_purity/theta2_adjusted_seg",
                        "#/theta2_purity/theta2_subclonal_results",
                        "#/theta2_purity/theta2_subclonal_cns",
