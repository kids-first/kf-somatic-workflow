                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "${\n  if (inputs.input_vcf == null){\n    return \"echo No vcf provided, skipping >&2 && exit 0;\";\n  }\n  else{\n    return \"echo Filtering vcf >&2 && \";\n  }\n} /gatk --java-options \"-Xmx7000m\" SelectVariants --exclude-filtered TRUE -select-type SNP $(inputs.input_vcf != null ? \"-V \" + inputs.input_vcf.path : \"\") -O snp_pass.vcf.gz\n/gatk VariantFiltration --java-options \"-Xmx7000m\" --filter-name GATK_QD --filter-expression \"QD < 2.0\" --filter-name GATK_FS --filter-expression \"FS > 60.0\" --filter-name GATK_MQ --filter-expression \"MQ < 40.0\" --filter-name GATK_MQRankSum --filter-expression \"MQRankSum < -12.5\" --filter-name GATK_ReadPosRankSum --filter-expression \"ReadPosRankSum < -8.0\" --filter-name KFDRC_DP10 --filter-expression \"DP < 10\" -V snp_pass.vcf.gz -O $(inputs.output_basename).gatk.hardfiltered.vcf.gz\n/gatk SelectVariants --exclude-filtered TRUE -V $(inputs.output_basename).gatk.hardfiltered.vcf.gz -O $(inputs.output_basename).gatk.hardfiltered.PASS.vcf.gz"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#gatk_filter_germline_variant.cwl/input_vcf"
                },
                {
                    "type": "string",
                    "id": "#gatk_filter_germline_variant.cwl/output_basename"
                },
                {
                    "type": "File",
                    "id": "#gatk_filter_germline_variant.cwl/reference_fasta"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.gatk.hardfiltered.PASS.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#gatk_filter_germline_variant.cwl/filtered_pass_vcf"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.gatk.hardfiltered.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#gatk_filter_germline_variant.cwl/filtered_vcf"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_filtermutectcalls.cwl",
            "label": "GATK Filter Mutect2",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${ return inputs.max_memory * 1000 }",
                    "coresMin": 2
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "gatk FilterMutectCalls --java-options \"-Xmx${return Math.floor(inputs.max_memory*1000/1.074-1)}m\" -V $(inputs.mutect_vcf.path) -O $(inputs.output_basename).mutect2_filtered.vcf.gz -R $(inputs.reference.path) --contamination-table $(inputs.contamination_table.path) --tumor-segmentation $(inputs.segmentation_table.path) --ob-priors $(inputs.ob_priors.path) --filtering-stats $(inputs.output_basename).mutect2_filtered.txt --stats $(inputs.mutect_stats.path)"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#gatk_filtermutectcalls.cwl/contamination_table"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "GB of memory to allocate to the task",
                    "id": "#gatk_filtermutectcalls.cwl/max_memory"
                },
                {
                    "type": "File",
                    "id": "#gatk_filtermutectcalls.cwl/mutect_stats"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#gatk_filtermutectcalls.cwl/mutect_vcf"
                },
                {
                    "type": "File",
                    "id": "#gatk_filtermutectcalls.cwl/ob_priors"
                },
                {
                    "type": "string",
                    "id": "#gatk_filtermutectcalls.cwl/output_basename"
                },
                {
                    "type": "File",
                    "id": "#gatk_filtermutectcalls.cwl/reference"
                },
                {
                    "type": "File",
                    "id": "#gatk_filtermutectcalls.cwl/segmentation_table"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.mutect2_filtered.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#gatk_filtermutectcalls.cwl/filtered_vcf"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.mutect2_filtered.txt"
                    },
                    "id": "#gatk_filtermutectcalls.cwl/stats_table"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_funcotatesegments.cwl",
            "doc": "Functional annotation for segment files.",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "coresMin": "$(inputs.cpu)",
                    "ramMin": "$(inputs.max_memory*1000)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.2.4.1"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "mkdir datasources_dir && DATA_SOURCES_FOLDER=\"$PWD/datasources_dir\" && $( inputs.run_funcotatesegments ? 'tar xvzf '+inputs.data_sources_tgz.path+' -C datasources_dir --strip-components 1 && gatk' : 'echo gatk' )"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "prefix": "--java-options",
                    "valueFrom": "$(\"\\\"-Xmx\"+Math.floor(inputs.max_memory*1000/1.074 - 1)+\"M\\\"\")"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "valueFrom": "FuncotateSegments"
                },
                {
                    "position": 3,
                    "shellQuote": false,
                    "prefix": "--data-sources-path",
                    "valueFrom": "$DATA_SOURCES_FOLDER"
                },
                {
                    "position": 3,
                    "shellQuote": false,
                    "prefix": "-O",
                    "valueFrom": "${var pre = inputs.output_prefix ? inputs.output_prefix : inputs.segments ? inputs.segments.nameroot : 'output'; var ext = 'funcotated.tsv'; return pre+'.'+ext}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "If true, adds a command line header line to created VCF files.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--add-output-vcf-command-line"
                    },
                    "id": "#gatk_funcotatesegments.cwl/add_output_vcf_command_line"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
                                "prefix": "--annotation-default"
                            }
                        }
                    ],
                    "doc": "Annotations to include in all annotated variants if the annotation is not specified in the data sources (in the format :). This will add the specified annotation to every annotated variant if it is not already present.",
                    "inputBinding": {
                        "position": 3
                    },
                    "id": "#gatk_funcotatesegments.cwl/annotation_default"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
                                "prefix": "--annotation-override"
                            }
                        }
                    ],
                    "doc": "Override values for annotations (in the format :). Replaces existing annotations of the given name with given values.",
                    "inputBinding": {
                        "position": 3
                    },
                    "id": "#gatk_funcotatesegments.cwl/annotation_override"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "CPUs to allocate to this tool.",
                    "id": "#gatk_funcotatesegments.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "If true, create a VCF index when writing a coordinate-sorted VCF file.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--create-output-variant-index"
                    },
                    "id": "#gatk_funcotatesegments.cwl/create_output_variant_index"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "If true, create a a MD5 digest any VCF file created.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--create-output-variant-md5"
                    },
                    "id": "#gatk_funcotatesegments.cwl/create_output_variant_md5"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "TGZ File containing prebuild data sources folder.",
                    "id": "#gatk_funcotatesegments.cwl/data_sources_tgz"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "If true, don't cache bam indexes, this will reduce memory requirements but may harm performance if many intervals are specified. Caching is automatically disabled if there are no intervals specified.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--disable-bam-index-caching"
                    },
                    "id": "#gatk_funcotatesegments.cwl/disable_bam_index_caching"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Read filters to be disabled before analysis.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--disable-read-filter"
                    },
                    "id": "#gatk_funcotatesegments.cwl/disable_read_filter"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "If specified, do not check the sequence dictionaries from our inputs for compatibility. Use at your own risk!",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--disable-sequence-dictionary-validation"
                    },
                    "id": "#gatk_funcotatesegments.cwl/disable_sequence_dictionary_validation"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Disable all tool default read filters (WARNING: many tools will not function correctly without their default read filters on)",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--disable-tool-default-read-filters"
                    },
                    "id": "#gatk_funcotatesegments.cwl/disable_tool_default_read_filters"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
                                "prefix": "--exclude-field"
                            }
                        }
                    ],
                    "doc": "Fields that should not be rendered in the final output. Only exact name matches will be excluded.",
                    "inputBinding": {
                        "position": 3
                    },
                    "id": "#gatk_funcotatesegments.cwl/exclude_field"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "One or more genomic intervals to exclude from processing. Use this input when providing interval list files or other file based inputs.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "-XL"
                    },
                    "id": "#gatk_funcotatesegments.cwl/exclude_interval_list"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
                                "prefix": "-XL"
                            }
                        }
                    ],
                    "inputBinding": {
                        "position": 3
                    },
                    "id": "#gatk_funcotatesegments.cwl/exclude_intervals"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Amount of padding (in bp) to add to each interval you are excluding.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "-ixp"
                    },
                    "id": "#gatk_funcotatesegments.cwl/interval_exclusion_padding"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "One or more genomic intervals over which to operate. Use this input when providing interval list files or other file based inputs.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "-L"
                    },
                    "id": "#gatk_funcotatesegments.cwl/interval_list"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_funcotatesegments.cwl/interval_merging_rule/interval_merging_rule",
                            "symbols": [
                                "#gatk_funcotatesegments.cwl/interval_merging_rule/interval_merging_rule/ALL",
                                "#gatk_funcotatesegments.cwl/interval_merging_rule/interval_merging_rule/OVERLAPPING_ONLY"
                            ]
                        }
                    ],
                    "doc": "By default, the program merges abutting intervals (i.e. intervals that are directly side-by-side but do not actually overlap) into a single continuous interval. However you can change this behavior if you want them to be treated as separate intervals instead.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "-imr"
                    },
                    "id": "#gatk_funcotatesegments.cwl/interval_merging_rule"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Amount of padding (in bp) to add to each interval you are including.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "-ip"
                    },
                    "id": "#gatk_funcotatesegments.cwl/interval_padding"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_funcotatesegments.cwl/interval_set_rule/interval_set_rule",
                            "symbols": [
                                "#gatk_funcotatesegments.cwl/interval_set_rule/interval_set_rule/UNION",
                                "#gatk_funcotatesegments.cwl/interval_set_rule/interval_set_rule/INTERSECTION"
                            ]
                        }
                    ],
                    "doc": "By default, the program will take the UNION of all intervals specified using -L and/or -XL. However, you can change this setting for -L, for example if you want to take the INTERSECTION of the sets instead. E.g. to perform the analysis only on chromosome 1 exomes, you could specify -L exomes.intervals -L 1 --interval-set-rule INTERSECTION. However, it is not possible to modify the merging approach for intervals passed using -XL (they will always be merged using UNION). Note that if you specify both -L and -XL, the -XL interval set will be subtracted from the -L interval set.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "-isr"
                    },
                    "id": "#gatk_funcotatesegments.cwl/interval_set_rule"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
                                "prefix": "-L"
                            }
                        }
                    ],
                    "doc": "One or more genomic intervals over which to operate. Use this input when providing the intervals as strings.",
                    "inputBinding": {
                        "position": 3
                    },
                    "id": "#gatk_funcotatesegments.cwl/intervals"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Lenient processing of VCF files",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--lenient"
                    },
                    "id": "#gatk_funcotatesegments.cwl/lenient"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of base-pairs to cache when querying variants. Can be overridden in individual data source configuration files.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--lookahead-cache-bp"
                    },
                    "id": "#gatk_funcotatesegments.cwl/lookahead_cache_bp"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "Maximum GB of RAM to allocate for this tool.",
                    "id": "#gatk_funcotatesegments.cwl/max_memory"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 150,
                    "doc": "Advanced Argument: The minimum number of bases for a variant to be annotated as a segment. Recommended to be changed only for use with FuncotateSegments.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--min-num-bases-for-segment-funcotation"
                    },
                    "id": "#gatk_funcotatesegments.cwl/minimum_segment_size"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_funcotatesegments.cwl/output_file_format/output_file_format",
                            "symbols": [
                                "#gatk_funcotatesegments.cwl/output_file_format/output_file_format/MAF",
                                "#gatk_funcotatesegments.cwl/output_file_format/output_file_format/SEG",
                                "#gatk_funcotatesegments.cwl/output_file_format/output_file_format/VCF"
                            ]
                        }
                    ],
                    "default": "SEG",
                    "doc": "The output file format. Either VCF or MAF. Please note that MAF output for germline use case VCFs is unsupported.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--output-file-format"
                    },
                    "id": "#gatk_funcotatesegments.cwl/output_file_format"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to use as the prefix for the outputs.",
                    "id": "#gatk_funcotatesegments.cwl/output_prefix"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string"
                        }
                    ],
                    "doc": "Read filters to be applied before analysis",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--read-filter"
                    },
                    "id": "#gatk_funcotatesegments.cwl/read_filter"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File",
                            "inputBinding": {
                                "prefix": "--read-index"
                            }
                        }
                    ],
                    "doc": "Indices to use for the read inputs. If specified, an index must be provided for every read input and in the same order as the read inputs. If this argument is not specified, the path to the index for each input will be inferred automatically.",
                    "inputBinding": {
                        "position": 3
                    },
                    "id": "#gatk_funcotatesegments.cwl/read_index"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_funcotatesegments.cwl/read_validation_stringency/read_validation_stringency",
                            "symbols": [
                                "#gatk_funcotatesegments.cwl/read_validation_stringency/read_validation_stringency/SILENT",
                                "#gatk_funcotatesegments.cwl/read_validation_stringency/read_validation_stringency/STRICT",
                                "#gatk_funcotatesegments.cwl/read_validation_stringency/read_validation_stringency/LENIENT"
                            ]
                        }
                    ],
                    "doc": "Validation stringency for all SAM/BAM/CRAM/SRA files read by this program. The default stringency value SILENT can improve performance when processing a BAM file in which variable-length data (read, qualities, tags) do not otherwise need to be decoded.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--read-validation-stringency"
                    },
                    "id": "#gatk_funcotatesegments.cwl/read_validation_stringency"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_funcotatesegments.cwl/ref_version/ref_version",
                            "symbols": [
                                "#gatk_funcotatesegments.cwl/ref_version/ref_version/hg19",
                                "#gatk_funcotatesegments.cwl/ref_version/ref_version/hg38",
                                "#gatk_funcotatesegments.cwl/ref_version/ref_version/b37"
                            ]
                        }
                    ],
                    "doc": "The version of the Human Genome reference to use (e.g. hg19, hg38, etc.). This will correspond to a sub-folder of each data source corresponding to that data source for the given reference.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--ref-version"
                    },
                    "id": "#gatk_funcotatesegments.cwl/ref_version"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Reference fasta",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai"
                        }
                    ],
                    "inputBinding": {
                        "position": 3,
                        "prefix": "-R"
                    },
                    "id": "#gatk_funcotatesegments.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Ignore/drop variants that have been filtered in the input. These variants will not appear in the output file.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--remove-filtered-variants"
                    },
                    "id": "#gatk_funcotatesegments.cwl/remove_filtered_variants"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "If not true, this tool will produce no outputs.",
                    "id": "#gatk_funcotatesegments.cwl/run_funcotatesegments"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input segment file (tab-separated values). Must have a call column.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--segments"
                    },
                    "id": "#gatk_funcotatesegments.cwl/segments"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Use the given sequence dictionary as the master/canonical sequence dictionary. Must be a .dict file.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--sequence-dictionary"
                    },
                    "id": "#gatk_funcotatesegments.cwl/sequence_dictionary"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "If true, don't emit genotype fields when writing vcf file output.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--sites-only-vcf-output"
                    },
                    "id": "#gatk_funcotatesegments.cwl/sites_only_vcf_output"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
                                "prefix": "--transcript-list"
                            }
                        }
                    ],
                    "doc": "A set of transcript IDs to use for annotation to override selected transcript.",
                    "inputBinding": {
                        "position": 3
                    },
                    "id": "#gatk_funcotatesegments.cwl/transcript_list"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "File to use as a list of transcripts (one transcript ID per line, version numbers are ignored)",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--transcript-list"
                    },
                    "id": "#gatk_funcotatesegments.cwl/transcript_list_file"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_funcotatesegments.cwl/transcript_selection_mode/transcript_selection_mode",
                            "symbols": [
                                "#gatk_funcotatesegments.cwl/transcript_selection_mode/transcript_selection_mode/ALL",
                                "#gatk_funcotatesegments.cwl/transcript_selection_mode/transcript_selection_mode/BEST_EFFECT",
                                "#gatk_funcotatesegments.cwl/transcript_selection_mode/transcript_selection_mode/CANONICAL"
                            ]
                        }
                    ],
                    "doc": "Method of detailed transcript selection. This will select the transcript for detailed annotation (CANONICAL, ALL, or BEST_EFFECT).",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--transcript-selection-mode"
                    },
                    "id": "#gatk_funcotatesegments.cwl/transcript_selection_mode"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "A VCF file containing variants",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--variant"
                    },
                    "id": "#gatk_funcotatesegments.cwl/variant"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.funcotated.tsv.gene_list.txt"
                    },
                    "id": "#gatk_funcotatesegments.cwl/funcotated_gene_list_tsv"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.funcotated.tsv"
                    },
                    "id": "#gatk_funcotatesegments.cwl/funcotated_seg_simple_tsv"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_gatherpileupsummaries.cwl",
            "label": "GATK Merge Pileups",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 4000,
                    "coresMin": 2
                }
            ],
            "baseCommand": [
                "/gatk",
                "GatherPileupSummaries"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "--java-options \"-Xmx3000m\" --sequence-dictionary $(inputs.reference_dict.path) -O $(inputs.output_basename).$(inputs.tool_name).merged.pileup.table "
                }
            ],
            "inputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File",
                        "inputBinding": {
                            "prefix": "-I"
                        }
                    },
                    "inputBinding": {
                        "position": 1
                    },
                    "id": "#gatk_gatherpileupsummaries.cwl/input_tables"
                },
                {
                    "type": "string",
                    "id": "#gatk_gatherpileupsummaries.cwl/output_basename"
                },
                {
                    "type": "File",
                    "id": "#gatk_gatherpileupsummaries.cwl/reference_dict"
                },
                {
                    "type": "string",
                    "id": "#gatk_gatherpileupsummaries.cwl/tool_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.merged.pileup.table"
                    },
                    "id": "#gatk_gatherpileupsummaries.cwl/merged_table"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_getpileupsummaries.cwl",
            "label": "GATK Pileup",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${ return inputs.max_memory * 1000 }",
                    "coresMin": 2
                }
            ],
            "baseCommand": [
                "/gatk",
                "GetPileupSummaries"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "--java-options \"-Xmx${return Math.floor(inputs.max_memory*1000/1.074-1)}m\" -I $(inputs.aligned_reads.path) -V $(inputs.exac_common_vcf.path) -L $(inputs.interval_list.path) -R $(inputs.reference.path) -O $(inputs.aligned_reads.nameroot).pileupsummary.table"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "id": "#gatk_getpileupsummaries.cwl/aligned_reads"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#gatk_getpileupsummaries.cwl/exac_common_vcf"
                },
                {
                    "type": "File",
                    "id": "#gatk_getpileupsummaries.cwl/interval_list"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 2,
                    "doc": "Maximum memory in GB for GATK GetPileupSummaries to use",
                    "id": "#gatk_getpileupsummaries.cwl/max_memory"
                },
                {
                    "type": "File",
                    "id": "#gatk_getpileupsummaries.cwl/reference"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.pileupsummary.table"
                    },
                    "id": "#gatk_getpileupsummaries.cwl/pileup_table"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_intervallisttobed.cwl",
            "doc": "Converts an Picard IntervalList file to a BED file.\n",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.ram * 1000)",
                    "coresMin": "$(inputs.cpu)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.4.0.0"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "gatk IntervalListToBed"
                },
                {
                    "position": 10,
                    "shellQuote": false,
                    "prefix": "&&",
                    "valueFrom": "bgzip --stdout --threads  $(inputs.cpu)"
                },
                {
                    "position": 19,
                    "shellQuote": false,
                    "valueFrom": "$(inputs.output_filename) > $(inputs.output_filename).gz"
                },
                {
                    "position": 20,
                    "shellQuote": false,
                    "prefix": "&&",
                    "valueFrom": "tabix --preset bed"
                },
                {
                    "position": 28,
                    "shellQuote": false,
                    "valueFrom": "$(inputs.output_filename).gz"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 22,
                        "prefix": "--begin"
                    },
                    "doc": "column number for region start [4]",
                    "id": "#gatk_intervallisttobed.cwl/begin"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 22,
                        "prefix": "--comment"
                    },
                    "doc": "skip comment lines starting with CHAR [null]",
                    "id": "#gatk_intervallisttobed.cwl/comment"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 2,
                    "doc": "Minimum reserved number of CPU cores for the task.",
                    "id": "#gatk_intervallisttobed.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 22,
                        "prefix": "--csi"
                    },
                    "doc": "generate CSI index for VCF (default is TBI)",
                    "id": "#gatk_intervallisttobed.cwl/csi"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 22,
                        "prefix": "--end"
                    },
                    "doc": "column number for region end (if no end, set INT to -b) [5]",
                    "id": "#gatk_intervallisttobed.cwl/end"
                },
                {
                    "type": "File",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--INPUT"
                    },
                    "doc": "Input IntervalList file.",
                    "id": "#gatk_intervallisttobed.cwl/input_intervallist"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 22,
                        "prefix": "--min-shift"
                    },
                    "doc": "set minimal interval size for CSI indices to 2^INT [14]",
                    "id": "#gatk_intervallisttobed.cwl/min_shift"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--offset"
                    },
                    "doc": "decompress at virtual file pointer (0-based uncompressed offset)",
                    "id": "#gatk_intervallisttobed.cwl/offset"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "default": "out.bed",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--OUTPUT"
                    },
                    "doc": "The output Picard Interval List.",
                    "id": "#gatk_intervallisttobed.cwl/output_filename"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "GB of RAM to allocate to the task.",
                    "id": "#gatk_intervallisttobed.cwl/ram"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--SCORE"
                    },
                    "doc": "The score, between 0-1000, to output for each interval in the BED file.",
                    "id": "#gatk_intervallisttobed.cwl/score"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 22,
                        "prefix": "--sequence"
                    },
                    "doc": "column number for sequence names (suppressed by -p) [1]",
                    "id": "#gatk_intervallisttobed.cwl/sequence"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--size"
                    },
                    "doc": "decompress INT bytes (uncompressed size)",
                    "id": "#gatk_intervallisttobed.cwl/size"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 22,
                        "prefix": "--skip-lines"
                    },
                    "doc": "skip first INT lines [0]",
                    "id": "#gatk_intervallisttobed.cwl/skip_lines"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--SORT",
                        "valueFrom": "$(self ? \"true\" : \"false\")"
                    },
                    "doc": "If true, sort the output interval list before writing it.",
                    "id": "#gatk_intervallisttobed.cwl/sort"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 22,
                        "prefix": "--zero-based"
                    },
                    "doc": "coordinates are zero-based",
                    "id": "#gatk_intervallisttobed.cwl/zero_based"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "$(inputs.output_filename)"
                    },
                    "id": "#gatk_intervallisttobed.cwl/outbed"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        },
                        {
                            "pattern": ".csi",
                            "required": false
                        }
                    ],
                    "outputBinding": {
                        "glob": "$(inputs.output_filename).gz"
                    },
                    "id": "#gatk_intervallisttobed.cwl/outbedgz"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_intervallisttools.cwl",
            "doc": "This tool offers multiple interval list file manipulation capabilities,\nincluding: sorting, merging, subtracting, padding, and other set-theoretic\noperations. The default action is to merge and sort the intervals provided in\nthe INPUTs. Other options, e.g. interval subtraction, are controlled by the\narguments.\n",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.max_memory * 1000)",
                    "coresMin": "$(inputs.cpu)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.4.0.0"
                }
            ],
            "baseCommand": [
                "gatk",
                "IntervalListTools"
            ],
            "arguments": [
                {
                    "position": 10,
                    "prefix": "&&",
                    "shellQuote": false,
                    "valueFrom": "if [ $(inputs.subdivision_mode) = null ]; then echo \"Ouptuts not scattered\"; else find ./temp_* -name *interval_list | sed 'p;s#temp_\\([0-9]\\+\\).*#\\1_scattered.interval_list#' | xargs -P $(inputs.cpu) -n 2 mv; fi"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_intervallisttools.cwl/action/action",
                            "symbols": [
                                "#gatk_intervallisttools.cwl/action/action/CONCAT",
                                "#gatk_intervallisttools.cwl/action/action/UNION",
                                "#gatk_intervallisttools.cwl/action/action/INTERSECT",
                                "#gatk_intervallisttools.cwl/action/action/SUBTRACT",
                                "#gatk_intervallisttools.cwl/action/action/SYMDIFF",
                                "#gatk_intervallisttools.cwl/action/action/OVERLAPS"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "--ACTION",
                        "position": 2
                    },
                    "doc": "Action to take on inputs.  Default value: CONCAT. CONCAT (The concatenation of\nall the intervals in all the INPUTs, no sorting or merging of\noverlapping/abutting intervals implied. Will result in a possibly unsorted list\nunless requested otherwise.) UNION (Like CONCATENATE but with UNIQUE and SORT\nimplied, the result being the set-wise union of all INPUTS, with overlapping\nand abutting intervals merged into one.) INTERSECT (The sorted and merged set\nof all loci that are contained in all of the INPUTs.) SUBTRACT (Subtracts the\nintervals in SECOND_INPUT from those in INPUT. The resulting loci are those in\nINPUT that are not in SECOND_INPUT.) SYMDIFF (Results in loci that are in INPUT\nor SECOND_INPUT but are not in both.) OVERLAPS (Outputs the entire intervals\nfrom INPUT that have bases which overlap any interval from SECOND_INPUT. Note\nthat this is different than INTERSECT in that each original interval is either\nemitted in its entirety, or not at all.)\n",
                    "id": "#gatk_intervallisttools.cwl/action"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--BREAK_BANDS_AT_MULTIPLES_OF"
                    },
                    "doc": "If set to a positive value will create a new interval list with the original intervals broken up at integer multiples of this value. Set to 0 to NOT break up intervals.",
                    "id": "#gatk_intervallisttools.cwl/break_bands_at_multiples_of"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--COUNT_OUTPUT"
                    },
                    "doc": "File to which to print count of bases or intervals in final output interval list.  When not set, value indicated by OUTPUT_VALUE will be printed to stdout.  If this parameter is set, OUTPUT_VALUE must not be NONE.",
                    "id": "#gatk_intervallisttools.cwl/count_output_name"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 2,
                    "doc": "Minimum reserved number of CPU cores for the task.",
                    "id": "#gatk_intervallisttools.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": false,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--INCLUDE_FILTERED",
                        "valueFrom": "$(self ? \"true\" : \"false\")"
                    },
                    "doc": "Whether to include filtered variants in the vcf when generating an interval list from vcf.",
                    "id": "#gatk_intervallisttools.cwl/include_filtered"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File",
                        "inputBinding": {
                            "prefix": "--INPUT"
                        }
                    },
                    "inputBinding": {
                        "position": 2
                    },
                    "doc": "One or more interval lists. If multiple interval lists are provided the output\nis theresult of merging the inputs.\n",
                    "id": "#gatk_intervallisttools.cwl/input"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--INVERT",
                        "valueFrom": "$(self ? \"true\" : \"false\")"
                    },
                    "doc": "Produce the inverse list of intervals, that is, the regions in the genome that are <br>not</br> covered by any of the input intervals. Will merge abutting intervals first.  Output will be sorted.",
                    "id": "#gatk_intervallisttools.cwl/invert"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "GB of RAM to allocate to the task.",
                    "id": "#gatk_intervallisttools.cwl/max_memory"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "default": "out.interval_list",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--OUTPUT",
                        "valueFrom": "$(inputs.subdivision_mode != null ? \".\" : self)"
                    },
                    "doc": "The output interval list file to write (if SCATTER_COUNT == 1) or the directory into which to write the scattered interval sub-directories (if SCATTER_COUNT > 1).",
                    "id": "#gatk_intervallisttools.cwl/output_name"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_intervallisttools.cwl/output_value/output_value",
                            "symbols": [
                                "#gatk_intervallisttools.cwl/output_value/output_value/NONE",
                                "#gatk_intervallisttools.cwl/output_value/output_value/BASES",
                                "#gatk_intervallisttools.cwl/output_value/output_value/INTERVALS"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "--OUTPUT_VALUE",
                        "position": 2
                    },
                    "doc": "What value to output to COUNT_OUTPUT file or stdout (for scripting).  If\nCOUNT_OUTPUT is provided, this parameter must not be NONE.\n",
                    "id": "#gatk_intervallisttools.cwl/output_value"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--PADDING"
                    },
                    "doc": "The amount to pad each end of the intervals by before other operations are undertaken.  Negative numbers are allowed and indicate intervals should be shrunk. Resulting intervals < 0 bases long will be removed. Padding is applied to the interval lists (both INPUT and SECOND_INPUT, if provided) before the ACTION is performed.",
                    "id": "#gatk_intervallisttools.cwl/padding"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--SCATTER_CONTENT"
                    },
                    "doc": "When scattering with this argument, each of the resultant files will (ideally) have this amount of 'content', which  means either base-counts or interval-counts depending on SUBDIVISION_MODE. When provided, overrides SCATTER_COUNT.",
                    "id": "#gatk_intervallisttools.cwl/scatter_content"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 1,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--SCATTER_COUNT"
                    },
                    "doc": "The number of files into which to scatter the resulting list by locus; in some situations, fewer intervals may be emitted.",
                    "id": "#gatk_intervallisttools.cwl/scatter_count"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File",
                            "inputBinding": {
                                "prefix": "--SECOND_INPUT"
                            }
                        }
                    ],
                    "inputBinding": {
                        "position": 2
                    },
                    "doc": "Second set of intervals for SUBTRACT and DIFFERENCE operations. This argument\nmay be specified 0 or more times.\n",
                    "id": "#gatk_intervallisttools.cwl/second_input"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--SORT",
                        "valueFrom": "$(self ? \"true\" : \"false\")"
                    },
                    "doc": "If true, sort the output interval list before writing it.",
                    "id": "#gatk_intervallisttools.cwl/sort"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_intervallisttools.cwl/subdivision_mode/subdivision_mode",
                            "symbols": [
                                "#gatk_intervallisttools.cwl/subdivision_mode/subdivision_mode/INTERVAL_SUBDIVISION",
                                "#gatk_intervallisttools.cwl/subdivision_mode/subdivision_mode/BALANCING_WITHOUT_INTERVAL_SUBDIVISION",
                                "#gatk_intervallisttools.cwl/subdivision_mode/subdivision_mode/BALANCING_WITHOUT_INTERVAL_SUBDIVISION_WITH_OVERFLOW",
                                "#gatk_intervallisttools.cwl/subdivision_mode/subdivision_mode/INTERVAL_COUNT",
                                "#gatk_intervallisttools.cwl/subdivision_mode/subdivision_mode/INTERVAL_COUNT_WITH_DISTRIBUTED_REMAINDER"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "--SUBDIVISION_MODE",
                        "position": 2
                    },
                    "doc": "The mode used to scatter the interval list:\n- INTERVAL_SUBDIVISION (Scatter the interval list into similarly sized interval\n  lists (by base count), breaking up intervals as needed.)\n- BALANCING_WITHOUT_INTERVAL_SUBDIVISION (Scatter the interval list into\n  similarly sized interval lists (by base count), but without breaking up\n  intervals.)\n- BALANCING_WITHOUT_INTERVAL_SUBDIVISION_WITH_OVERFLOW (Scatter the interval\n  list into similarly sized interval lists (by base count), but without\n  breaking up intervals. Will overflow current interval list so that the\n  remaining lists will not have too many bases to deal with.)\n- INTERVAL_COUNT (Scatter the interval list into similarly sized interval lists\n  (by interval count, not by base count). Resulting interval lists will contain\n  the same number of intervals except for the last, which contains the\n  remainder.)\n- INTERVAL_COUNT_WITH_DISTRIBUTED_REMAINDER (Scatter the interval list into\n  similarly sized interval lists (by interval count, not by base count).\n  Resulting interval lists will contain similar number of intervals.)\n",
                    "id": "#gatk_intervallisttools.cwl/subdivision_mode"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": false,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--UNIQUE",
                        "valueFrom": "$(self ? \"true\" : \"false\")"
                    },
                    "doc": "If true, unique the output interval list by merging overlapping regions, before writing it (implies sort=true).",
                    "id": "#gatk_intervallisttools.cwl/unique"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "$(inputs.count_output_name)"
                    },
                    "id": "#gatk_intervallisttools.cwl/count_output"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "$(inputs.subdivision_mode != null ? \"*.interval_list\" : inputs.output_name)"
                    },
                    "id": "#gatk_intervallisttools.cwl/output"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_learnorientationbias.cwl",
            "label": "GATK Learn Bias",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${ return inputs.max_memory * 1000 }",
                    "coresMin": 2
                }
            ],
            "baseCommand": [
                "/gatk",
                "LearnReadOrientationModel"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "--java-options \"-Xmx${return Math.floor(inputs.max_memory*1000/1.074-1)}m\" -O $(inputs.output_basename).$(inputs.tool_name).f1r2_bias.tar.gz "
                }
            ],
            "inputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File",
                        "inputBinding": {
                            "prefix": "-I"
                        }
                    },
                    "inputBinding": {
                        "position": 1
                    },
                    "id": "#gatk_learnorientationbias.cwl/input_tgz"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "Maximum memory in GB for GATK LearnReadOrientationModel",
                    "id": "#gatk_learnorientationbias.cwl/max_memory"
                },
                {
                    "type": "string",
                    "id": "#gatk_learnorientationbias.cwl/output_basename"
                },
                {
                    "type": "string",
                    "id": "#gatk_learnorientationbias.cwl/tool_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.f1r2_bias.tar.gz"
                    },
                    "id": "#gatk_learnorientationbias.cwl/f1r2_bias"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_mergemutectstats.cwl",
            "label": "GATK Merge Stats",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 4000,
                    "coresMin": 2
                }
            ],
            "baseCommand": [
                "/gatk",
                "MergeMutectStats"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "--java-options \"-Xmx3000m\" -O $(inputs.output_basename).Mutect2.merged.stats "
                }
            ],
            "inputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File",
                        "inputBinding": {
                            "prefix": "--stats"
                        }
                    },
                    "inputBinding": {
                        "position": 1
                    },
                    "id": "#gatk_mergemutectstats.cwl/input_stats"
                },
                {
                    "type": "string",
                    "id": "#gatk_mergemutectstats.cwl/output_basename"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.merged.stats"
                    },
                    "id": "#gatk_mergemutectstats.cwl/merged_stats"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_mergevcfs.cwl",
            "label": "GATK Merge VCF",
            "doc": "Merge input vcfs",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 4000,
                    "coresMin": 2
                }
            ],
            "baseCommand": [
                "/gatk",
                "MergeVcfs"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "--java-options \"-Xmx2000m\" --TMP_DIR=./TMP --CREATE_INDEX=true --SEQUENCE_DICTIONARY=$(inputs.reference_dict.path) ${\n  var cmd = \"--OUTPUT=\" + inputs.output_basename + \".\" + inputs.tool_name + \".merged.vcf.gz \"\n  if (typeof inputs.silent_flag !== 'undefined' && inputs.silent_flag == 1){\n    cmd += \"--VALIDATION_STRINGENCY SILENT\"\n  }\n  return cmd\n}"
                }
            ],
            "inputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File",
                        "inputBinding": {
                            "prefix": "-I"
                        }
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "inputBinding": {
                        "position": 1
                    },
                    "id": "#gatk_mergevcfs.cwl/input_vcfs"
                },
                {
                    "type": "string",
                    "id": "#gatk_mergevcfs.cwl/output_basename"
                },
                {
                    "type": "File",
                    "id": "#gatk_mergevcfs.cwl/reference_dict"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "id": "#gatk_mergevcfs.cwl/silent_flag"
                },
                {
                    "type": "string",
                    "id": "#gatk_mergevcfs.cwl/tool_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.merged.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#gatk_mergevcfs.cwl/merged_vcf"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_modelsegments.cwl",
            "doc": "Models segmented copy ratios from denoised read counts and segmented minor-allele fractions from allelic counts",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "coresMin": "$(inputs.cpu)",
                    "ramMin": "$(inputs.max_memory*1000)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.2.4.1"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "$( inputs.denoised_copy_ratios ? 'gatk' : 'echo gatk' )"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "prefix": "--java-options",
                    "valueFrom": "$(\"\\\"-Xmx\"+Math.floor(inputs.max_memory*1000/1.074 - 1)+\"M\\\"\")"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "valueFrom": "ModelSegments"
                },
                {
                    "position": 3,
                    "shellQuote": false,
                    "prefix": "--output",
                    "valueFrom": "."
                },
                {
                    "position": 3,
                    "shellQuote": false,
                    "prefix": "--output-prefix",
                    "valueFrom": "${var pre = inputs.output_prefix ? inputs.output_prefix : inputs.denoised_copy_ratios ? inputs.denoised_copy_ratios.nameroot.split('.').slice(0,-1).join('.') : inputs.allelic_counts ? inputs.allelic_counts.nameroot.split('.').slice(0,-1).join('.') : 'output_ModelSegments'; return pre}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing allelic counts (output of CollectAllelicCounts).",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--allelic-counts"
                    },
                    "id": "#gatk_modelsegments.cwl/allelic_counts"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "Number of CPUs to allocate to this task.",
                    "id": "#gatk_modelsegments.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing denoised copy ratios (output of DenoiseReadCounts).",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--denoised-copy-ratios"
                    },
                    "id": "#gatk_modelsegments.cwl/denoised_copy_ratios"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Maximum base-error rate for genotyping and filtering homozygous allelic counts, if available. The likelihood for an allelic count to be generated from a homozygous site will be integrated from zero base-error rate up to this value. Decreasing this value will increase the number of sites assumed to be heterozygous for modeling.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--genotyping-base-error-rate"
                    },
                    "id": "#gatk_modelsegments.cwl/genotyping_base_error_rate"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Log-ratio threshold for genotyping and filtering homozygous allelic counts, if available. Increasing this value will increase the number of sites assumed to be heterozygous for modeling.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--genotyping-homozygous-log-ratio-threshold"
                    },
                    "id": "#gatk_modelsegments.cwl/genotyping_homozygous_log_ratio_threshold"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Dimension of the kernel approximation. A subsample containing this number of data points will be used to construct the approximation for each chromosome. If the total number of data points in a chromosome is greater than this number, then all data points in the chromosome will be used. Time complexity scales quadratically and space complexity scales linearly with this parameter.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--kernel-approximation-dimension"
                    },
                    "id": "#gatk_modelsegments.cwl/kernel_approximation_dimension"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Relative scaling S of the kernel K_AF for allele-fraction segmentation to the kernel K_CR for copy-ratio segmentation. If multidimensional segmentation is performed, the total kernel used will be K_CR + S * K_AF.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--kernel-scaling-allele-fraction"
                    },
                    "id": "#gatk_modelsegments.cwl/kernel_scaling_allele_fraction"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Variance of Gaussian kernel for allele-fraction segmentation, if performed. If zero, a linear kernel will be used.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--kernel-variance-allele-fraction"
                    },
                    "id": "#gatk_modelsegments.cwl/kernel_variance_allele_fraction"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Variance of Gaussian kernel for copy-ratio segmentation, if performed. If zero, a linear kernel will be used.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--kernel-variance-copy-ratio"
                    },
                    "id": "#gatk_modelsegments.cwl/kernel_variance_copy_ratio"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "Maximum GB of RAM to allocate for this tool.",
                    "id": "#gatk_modelsegments.cwl/max_memory"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Maximum number of segments allowed per chromosome.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--maximum-number-of-segments-per-chromosome"
                    },
                    "id": "#gatk_modelsegments.cwl/maximum_number_of_segments_per_chromosome"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Maximum number of iterations allowed for segmentation smoothing.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--maximum-number-of-smoothing-iterations"
                    },
                    "id": "#gatk_modelsegments.cwl/maximum_number_of_smoothing_iterations"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Minimum total count for filtering allelic counts in the case sample, if available. The default value of zero is appropriate for matched-normal mode; increase to an appropriate value for case-only mode.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--minimum-total-allele-count-case"
                    },
                    "id": "#gatk_modelsegments.cwl/minimum_total_allele_count_case"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Minimum total count for filtering allelic counts in the matched-normal sample, if available.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--minimum-total-allele-count-normal"
                    },
                    "id": "#gatk_modelsegments.cwl/minimum_total_allele_count_normal"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Alpha hyperparameter for the 4-parameter beta-distribution prior on segment minor-allele fraction. The prior for the minor-allele fraction f in each segment is assumed to be Beta(alpha, 1, 0, 1/2). Increasing this hyperparameter will reduce the effect of reference bias at the expense of sensitivity.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--minor-allele-fraction-prior-alpha"
                    },
                    "id": "#gatk_modelsegments.cwl/minor_allele_fraction_prior_alpha"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing allelic counts for a matched normal (output of CollectAllelicCounts).",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--normal-allelic-counts"
                    },
                    "id": "#gatk_modelsegments.cwl/normal_allelic_counts"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of burn-in samples to discard for allele-fraction model.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--number-of-burn-in-samples-allele-fraction"
                    },
                    "id": "#gatk_modelsegments.cwl/number_of_burn_in_samples_allele_fraction"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of burn-in samples to discard for copy-ratio model.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--number-of-burn-in-samples-copy-ratio"
                    },
                    "id": "#gatk_modelsegments.cwl/number_of_burn_in_samples_copy_ratio"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Factor A for the penalty on the number of changepoints per chromosome for segmentation. Adds a penalty of the form A * C * [1 + log (N / C)], where C is the number of changepoints in the chromosome, to the cost function for each chromosome. Must be non-negative.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--number-of-changepoints-penalty-factor"
                    },
                    "id": "#gatk_modelsegments.cwl/number_of_changepoints_penalty_factor"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Total number of MCMC samples for allele-fraction model.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--number-of-samples-allele-fraction"
                    },
                    "id": "#gatk_modelsegments.cwl/number_of_samples_allele_fraction"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Total number of MCMC samples for copy-ratio model.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--number-of-samples-copy-ratio"
                    },
                    "id": "#gatk_modelsegments.cwl/number_of_samples_copy_ratio"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of segmentation-smoothing iterations per MCMC model refit. (Increasing this will decrease runtime, but the final number of segments may be higher. Setting this to 0 will completely disable model refitting between iterations.)",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--number-of-smoothing-iterations-per-fit"
                    },
                    "id": "#gatk_modelsegments.cwl/number_of_smoothing_iterations_per_fit"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to use as the prefix for the outputs.",
                    "id": "#gatk_modelsegments.cwl/output_prefix"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Number of 10% equal-tailed credible-interval widths to use for allele-fraction segmentation smoothing.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--smoothing-credible-interval-threshold-allele-fraction"
                    },
                    "id": "#gatk_modelsegments.cwl/smoothing_credible_interval_threshold_allele_fraction"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Number of 10% equal-tailed credible-interval widths to use for copy-ratio segmentation smoothing.",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--smoothing-credible-interval-threshold-copy-ratio"
                    },
                    "id": "#gatk_modelsegments.cwl/smoothing_credible_interval_threshold_copy_ratio"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "int",
                            "inputBinding": {
                                "prefix": "--window-size"
                            }
                        }
                    ],
                    "doc": "Window sizes to use for calculating local changepoint costs. For each window size, the cost for each data point to be a changepoint will be calculated assuming that the point demarcates two adjacent segments of that size. Including small (large) window sizes will increase sensitivity to small (large) events. Duplicate values will be ignored.",
                    "inputBinding": {
                        "position": 3
                    },
                    "id": "#gatk_modelsegments.cwl/window_size"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.af.igv.seg"
                    },
                    "id": "#gatk_modelsegments.cwl/allele_fraction_legacy_segments"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.modelFinal.af.param"
                    },
                    "id": "#gatk_modelsegments.cwl/allele_fraction_parameters"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.modelBegin.af.param"
                    },
                    "id": "#gatk_modelsegments.cwl/allele_fraction_parameters_begin"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.cr.igv.seg"
                    },
                    "id": "#gatk_modelsegments.cwl/copy_ratio_legacy_segments"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.cr.seg"
                    },
                    "id": "#gatk_modelsegments.cwl/copy_ratio_only_segments"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.modelFinal.cr.param"
                    },
                    "id": "#gatk_modelsegments.cwl/copy_ratio_parameters"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.modelBegin.cr.param"
                    },
                    "id": "#gatk_modelsegments.cwl/copy_ratio_parameters_begin"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.hets.tsv"
                    },
                    "id": "#gatk_modelsegments.cwl/het_allelic_counts"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.modelFinal.seg"
                    },
                    "id": "#gatk_modelsegments.cwl/modeled_segments"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.modelBegin.seg"
                    },
                    "id": "#gatk_modelsegments.cwl/modeled_segments_begin"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.hets.normal.tsv"
                    },
                    "id": "#gatk_modelsegments.cwl/normal_het_allelic_counts"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_plotdenoisedcopyratios.cwl",
            "doc": "Creates plots of denoised copy ratios",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.max_memory*1000)",
                    "coresMin": "$(inputs.cpu)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.2.4.1"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "$( inputs.denoised_copy_ratios ? 'gatk' : 'echo gatk' )"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "PlotDenoisedCopyRatios"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "prefix": "--output",
                    "valueFrom": "."
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "prefix": "--output-prefix",
                    "valueFrom": "${var pre = inputs.output_prefix ? inputs.output_prefix : inputs.denoised_copy_ratios ? inputs.denoised_copy_ratios.nameroot.split('.').slice(0,-1).join('.') : 'plotdenoisecr'; return pre}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 2,
                    "doc": "Number of CPUs to allocate to this task.",
                    "id": "#gatk_plotdenoisedcopyratios.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing denoised copy ratios (output of DenoiseReadCounts).",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--denoised-copy-ratios"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/denoised_copy_ratios"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "doc": "Maximum GB of RAM to allocate for this tool.",
                    "id": "#gatk_plotdenoisedcopyratios.cwl/max_memory"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Threshold length (in bp) for contigs to be plotted. Contigs with lengths less than this threshold will not be plotted. This can be used to filter out mitochondrial contigs, unlocalized contigs, etc.",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--minimum-contig-length"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/minimum_contig_length"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to use as the prefix for the outputs.",
                    "id": "#gatk_plotdenoisedcopyratios.cwl/output_prefix"
                },
                {
                    "type": "File",
                    "doc": "Use the given sequence dictionary as the master/canonical sequence dictionary. Must be a .dict file.",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--sequence-dictionary"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/sequence_dictionary"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing standardized copy ratios (output of DenoiseReadCounts).",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--standardized-copy-ratios"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/standardized_copy_ratios"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.deltaMAD.txt"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/delta_mad"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.denoisedMAD.txt"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/denoised_mad"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.denoised.png"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/denoised_plot"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.scaledDeltaMAD.txt"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/scaled_delta_mad"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.standardizedMAD.txt"
                    },
                    "id": "#gatk_plotdenoisedcopyratios.cwl/standardized_mad"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_plotmodeledsegments.cwl",
            "doc": "Creates plots of denoised and segmented copy-ratio and minor-allele-fraction estimates",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.max_memory*1000)",
                    "coresMin": "$(inputs.cpu)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.2.4.1"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "$( inputs.denoised_copy_ratios ? 'gatk' : 'echo gatk' )"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "PlotModeledSegments"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "prefix": "--output",
                    "valueFrom": "."
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "prefix": "--output-prefix",
                    "valueFrom": "${var pre = inputs.output_prefix ? inputs.output_prefix : inputs.segments ? inputs.segments.nameroot : 'plotsegments'; return pre}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing allelic counts at heterozygous sites (.hets.tsv output of ModelSegments).",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--allelic-counts"
                    },
                    "id": "#gatk_plotmodeledsegments.cwl/allelic_counts"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 2,
                    "doc": "Number of CPUs to allocate to this task.",
                    "id": "#gatk_plotmodeledsegments.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing denoised copy ratios (output of DenoiseReadCounts).",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--denoised-copy-ratios"
                    },
                    "id": "#gatk_plotmodeledsegments.cwl/denoised_copy_ratios"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "doc": "Maximum GB of RAM to allocate for this tool.",
                    "id": "#gatk_plotmodeledsegments.cwl/max_memory"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Threshold length (in bp) for contigs to be plotted. Contigs with lengths less than this threshold will not be plotted. This can be used to filter out mitochondrial contigs, unlocalized contigs, etc.",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--minimum-contig-length"
                    },
                    "id": "#gatk_plotmodeledsegments.cwl/minimum_contig_length"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to use as the prefix for the outputs.",
                    "id": "#gatk_plotmodeledsegments.cwl/output_prefix"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Input file containing modeled segments (output of ModelSegments).",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--segments"
                    },
                    "id": "#gatk_plotmodeledsegments.cwl/segments"
                },
                {
                    "type": "File",
                    "doc": "Use the given sequence dictionary as the master/canonical sequence dictionary. Must be a .dict file.",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--sequence-dictionary"
                    },
                    "id": "#gatk_plotmodeledsegments.cwl/sequence_dictionary"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.modeled.png"
                    },
                    "id": "#gatk_plotmodeledsegments.cwl/output"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_preprocessintervals.cwl",
            "doc": "Prepares bins for coverage collection",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.max_memory*1000)",
                    "coresMin": "$(inputs.cpu)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "broadinstitute/gatk:4.2.4.1"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "gatk --java-options -Xmx$(Math.floor(inputs.max_memory*1000/1.074 - 1))M PreprocessIntervals"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "prefix": "-O",
                    "valueFrom": "${var pre = inputs.output_prefix ? inputs.output_prefix : 'output'; return pre+'.preprocessed_intervals.interval_list'}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "prefix": "--bin-length"
                    },
                    "id": "#gatk_preprocessintervals.cwl/bin_length"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 1,
                    "doc": "Number of CPUs to allocate to this task.",
                    "id": "#gatk_preprocessintervals.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "doc": "One or more genomic intervals to exclude from processing. Use this input when providing interval list files or other file based inputs.",
                    "inputBinding": {
                        "prefix": "-XL"
                    },
                    "id": "#gatk_preprocessintervals.cwl/input_exclude_interval_list"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
                                "prefix": "-XL"
                            }
                        }
                    ],
                    "doc": "One or more genomic intervals to exclude from processing. Use this input when providing the intervals as strings.",
                    "inputBinding": {
                        "position": 0
                    },
                    "id": "#gatk_preprocessintervals.cwl/input_exclude_intervals"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "doc": "One or more genomic intervals over which to operate. Use this input when providing interval list files or other file based inputs.",
                    "inputBinding": {
                        "prefix": "-L"
                    },
                    "id": "#gatk_preprocessintervals.cwl/input_interval_list"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string",
                            "inputBinding": {
                                "prefix": "-L"
                            }
                        }
                    ],
                    "doc": "One or more genomic intervals over which to operate. Use this input when providing the intervals as strings.",
                    "inputBinding": {
                        "position": 0
                    },
                    "id": "#gatk_preprocessintervals.cwl/input_intervals"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Amount of padding (in bp) to add to each interval you are excluding.",
                    "inputBinding": {
                        "prefix": "-ixp"
                    },
                    "id": "#gatk_preprocessintervals.cwl/interval_exclusion_padding"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_preprocessintervals.cwl/interval_merging_rule/interval_merging_rule",
                            "symbols": [
                                "#gatk_preprocessintervals.cwl/interval_merging_rule/interval_merging_rule/ALL",
                                "#gatk_preprocessintervals.cwl/interval_merging_rule/interval_merging_rule/OVERLAPPING_ONLY"
                            ]
                        }
                    ],
                    "doc": "By default, the program merges abutting intervals (i.e. intervals that are directly side-by-side but do not actually overlap) into a single continuous interval. However you can change this behavior if you want them to be treated as separate intervals instead.",
                    "inputBinding": {
                        "prefix": "-imr"
                    },
                    "id": "#gatk_preprocessintervals.cwl/interval_merging_rule"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Amount of padding (in bp) to add to each interval you are including.",
                    "inputBinding": {
                        "prefix": "-ip"
                    },
                    "id": "#gatk_preprocessintervals.cwl/interval_padding"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_preprocessintervals.cwl/interval_set_rule/interval_set_rule",
                            "symbols": [
                                "#gatk_preprocessintervals.cwl/interval_set_rule/interval_set_rule/UNION",
                                "#gatk_preprocessintervals.cwl/interval_set_rule/interval_set_rule/INTERSECTION"
                            ]
                        }
                    ],
                    "doc": "By default, the program will take the UNION of all intervals specified using -L and/or -XL. However, you can change this setting for -L, for example if you want to take the INTERSECTION of the sets instead. E.g. to perform the analysis only on chromosome 1 exomes, you could specify -L exomes.intervals -L 1 --interval-set-rule INTERSECTION. However, it is not possible to modify the merging approach for intervals passed using -XL (they will always be merged using UNION). Note that if you specify both -L and -XL, the -XL interval set will be subtracted from the -L interval set.",
                    "inputBinding": {
                        "prefix": "-isr"
                    },
                    "id": "#gatk_preprocessintervals.cwl/interval_set_rule"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "doc": "Maximum GB of RAM to allocate for this tool.",
                    "id": "#gatk_preprocessintervals.cwl/max_memory"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to use as the prefix for the outputs.",
                    "id": "#gatk_preprocessintervals.cwl/output_prefix"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Length (in bp) of the padding regions on each side of the intervals.",
                    "inputBinding": {
                        "prefix": "--padding"
                    },
                    "id": "#gatk_preprocessintervals.cwl/padding"
                },
                {
                    "type": "File",
                    "doc": "Reference fasta",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-R"
                    },
                    "id": "#gatk_preprocessintervals.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Use the given sequence dictionary as the master/canonical sequence dictionary. Must be a .dict file.",
                    "inputBinding": {
                        "prefix": "--sequence-dictionary"
                    },
                    "id": "#gatk_preprocessintervals.cwl/sequence_dictionary"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*interval_list"
                    },
                    "id": "#gatk_preprocessintervals.cwl/output"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_selectvariants.cwl",
            "label": "GATK Select PASS",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 8000,
                    "coresMin": 4
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entryname": "select_pass.sh",
                            "entry": "#!/usr/bin/env bash\n\nset -eo pipefail\n\nif [[ $(inputs.mode) = gatk ]]\nthen\n  /gatk SelectVariants --java-options \"-Xmx8000m\" --exclude-filtered TRUE -V $(inputs.input_vcf.path) -O $(inputs.output_basename).$(inputs.tool_name).PASS.vcf.gz\nelif [[ $(inputs.mode) = grep ]]\nthen\n  zcat $(inputs.input_vcf.path) | grep -E \"^#|PASS\" | bgzip > $(inputs.output_basename).$(inputs.tool_name).PASS.vcf.gz && tabix $(inputs.output_basename).$(inputs.tool_name).PASS.vcf.gz\nelse\n  echo \"$(inputs.mode) is not a valid mode. Choices are gatk or grep\" >&2 && exit 1\nfi\n"
                        }
                    ]
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-x",
                "select_pass.sh"
            ],
            "inputs": [
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#gatk_selectvariants.cwl/input_vcf"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#gatk_selectvariants.cwl/mode/select_vars_mode",
                            "symbols": [
                                "#gatk_selectvariants.cwl/mode/select_vars_mode/gatk",
                                "#gatk_selectvariants.cwl/mode/select_vars_mode/grep"
                            ]
                        }
                    ],
                    "doc": "Choose 'gatk' for SelectVariants tool, or 'grep' for grep expression",
                    "default": "gatk",
                    "id": "#gatk_selectvariants.cwl/mode"
                },
                {
                    "type": "string",
                    "id": "#gatk_selectvariants.cwl/output_basename"
                },
                {
                    "type": "string",
                    "id": "#gatk_selectvariants.cwl/tool_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.PASS.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#gatk_selectvariants.cwl/pass_vcf"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_sortvcf.cwl",
            "label": "GATK Merge VCF",
            "doc": "Merge input vcfs",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 6000,
                    "coresMin": 4
                }
            ],
            "baseCommand": [
                "/gatk",
                "SortVcf"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "--java-options \"-Xmx6g\" -O $(inputs.output_basename).$(inputs.tool_name).merged.vcf --SEQUENCE_DICTIONARY $(inputs.reference_dict.path) --CREATE_INDEX false"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "valueFrom": "\n&& cat $(inputs.output_basename).$(inputs.tool_name).merged.vcf | uniq | bgzip > $(inputs.output_basename).$(inputs.tool_name).merged.vcf.gz && tabix $(inputs.output_basename).$(inputs.tool_name).merged.vcf.gz"
                }
            ],
            "inputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File",
                        "inputBinding": {
                            "prefix": "-I"
                        }
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "position": 1
                    },
                    "id": "#gatk_sortvcf.cwl/input_vcfs"
                },
                {
                    "type": "string",
                    "id": "#gatk_sortvcf.cwl/output_basename"
                },
                {
                    "type": "File",
                    "id": "#gatk_sortvcf.cwl/reference_dict"
                },
                {
                    "type": "string",
                    "id": "#gatk_sortvcf.cwl/tool_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.merged.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#gatk_sortvcf.cwl/merged_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#lancet.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${return inputs.ram * 1000}",
                    "coresMin": 6
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/lancet:1.0.7"
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-c"
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "set -eo pipefail\n/lancet-1.0.7/lancet --tumor $(inputs.input_tumor_bam.path) --normal $(inputs.input_normal_bam.path) --ref $(inputs.reference.path) --bed $(inputs.bed.path) --num-threads 6 --window-size $(inputs.window) --padding $(inputs.padding) --max-indel-len 50 > $(inputs.input_tumor_bam.nameroot).$(inputs.bed.nameroot).vcf || (echo 'active region filter failed, trying without' && /lancet-1.0.7/lancet --tumor $(inputs.input_tumor_bam.path) --normal $(inputs.input_normal_bam.path) --ref $(inputs.reference.path) --bed $(inputs.bed.path) --num-threads 6 --window-size $(inputs.window) --active-region-off --padding $(inputs.padding) --max-indel-len 50 > $(inputs.input_tumor_bam.nameroot).$(inputs.bed.nameroot).vcf)"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#lancet.cwl/bed"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "id": "#lancet.cwl/input_normal_bam"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "id": "#lancet.cwl/input_tumor_bam"
                },
                {
                    "type": "string",
                    "id": "#lancet.cwl/output_basename"
                },
                {
                    "type": "int",
                    "doc": "If WGS (less likely), recommend 25, if exome+, recommend half window size",
                    "id": "#lancet.cwl/padding"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 12,
                    "doc": "Adjust in rare circumstances in which 12 GB is not enough",
                    "id": "#lancet.cwl/ram"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.dict",
                            "required": null
                        },
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#lancet.cwl/reference"
                },
                {
                    "type": "int",
                    "doc": "window size for lancet.  default is 600, recommend 500 for WGS, 600 for exome+",
                    "id": "#lancet.cwl/window"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.vcf"
                    },
                    "id": "#lancet.cwl/lancet_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#manta.cwl",
            "label": "Manta sv caller",
            "doc": "Calls structural variants.  Tool designed to pick correct run mode based on if tumor, normal, or both crams are given",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${ return inputs.ram * 1000 }",
                    "coresMin": "$(inputs.cores)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/manta:1.4.0"
                }
            ],
            "baseCommand": [
                "/manta-1.4.0.centos6_x86_64/bin/configManta.py"
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "${\n  var std = \" --ref \" + inputs.reference.path + \" --callRegions \" + inputs.hg38_strelka_bed.path + \" --runDir=./ && ./runWorkflow.py -m local -j \" + inputs.cores + \" \";\n  var mv = \" && mv results/variants/\";\n  if (typeof inputs.input_tumor_cram === 'undefined' || inputs.input_tumor_cram === null){\n    var mv_cmd = mv + \"diploidSV.vcf.gz \" +  inputs.output_basename + \".manta.diploidSV.vcf.gz\" + mv + \"diploidSV.vcf.gz.tbi \" + inputs.output_basename + \".manta.diploidSV.vcf.gz.tbi\" + mv + \"candidateSmallIndels.vcf.gz \" + inputs.output_basename + \".manta.candidateSmallIndels.vcf.gz\" + mv + \"candidateSmallIndels.vcf.gz.tbi \" + inputs.output_basename + \".manta.candidateSmallIndels.vcf.gz.tbi\";\n    return \"--bam \".concat(inputs.input_normal_cram.path, std, mv_cmd);\n  }\n  else if (typeof inputs.input_normal_cram === 'undefined' || inputs.input_normal_cram === null){\n    var mv_cmd = mv + \"tumorSV.vcf.gz \" + inputs.output_basename + \".manta.tumorSV.vcf.gz\" + mv + \"tumorSV.vcf.gz.tbi \" + inputs.output_basename + \".manta.tumorSV.vcf.gz.tbi\" + mv + \"candidateSmallIndels.vcf.gz \" + inputs.output_basename + \".manta.candidateSmallIndels.vcf.gz\" + mv + \"candidateSmallIndels.vcf.gz.tbi \" + inputs.output_basename + \".manta.candidateSmallIndels.vcf.gz.tbi\";\n    return \"--tumorBam \" + inputs.input_tumor_cram.path + std + mv_cmd;\n  }\n  else{\n    var mv_cmd = mv + \"somaticSV.vcf.gz \" + inputs.output_basename + \".manta.somaticSV.vcf.gz\" + mv + \"somaticSV.vcf.gz.tbi \" + inputs.output_basename + \".manta.somaticSV.vcf.gz.tbi\" + mv + \"candidateSmallIndels.vcf.gz \" + inputs.output_basename + \".manta.candidateSmallIndels.vcf.gz\" + mv + \"candidateSmallIndels.vcf.gz.tbi \" + inputs.output_basename + \".manta.candidateSmallIndels.vcf.gz.tbi\";\n    return \"--tumorBam \" + inputs.input_tumor_cram.path + \" --normalBam \" + inputs.input_normal_cram.path + std + mv_cmd;\n  }\n}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 18,
                    "id": "#manta.cwl/cores"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#manta.cwl/hg38_strelka_bed"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        },
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        }
                    ],
                    "id": "#manta.cwl/input_normal_cram"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        },
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        }
                    ],
                    "id": "#manta.cwl/input_tumor_cram"
                },
                {
                    "type": "string",
                    "id": "#manta.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 10,
                    "doc": "GB of RAM an instance must have to run the task",
                    "id": "#manta.cwl/ram"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.dict",
                            "required": null
                        },
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#manta.cwl/reference"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*SV.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#manta.cwl/output_sv"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*SmallIndels.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#manta.cwl/small_indels"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#prepare_aa.cwl",
            "doc": "This tool prepares input for amplicon architect analysis",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "jluebeck/prepareaa:v0.1203.10"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": "$(inputs.threads)"
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entry": "$(inputs.data_repo)",
                            "writable": true
                        },
                        {
                            "entryname": "setup_vars.sh",
                            "entry": "export AA_DATA_REPO=$(inputs.data_repo.basename)\nif [ ${ return inputs.mosek_license_file ? \"MOSEK_YES\" : null; } != null ];\nthen \nmkdir licenses && cp ${ return inputs.mosek_license_file ? inputs.mosek_license_file.path : \"\"; } licenses \\\n&& export MOSEKLM_LICENSE_FILE=$PWD/licenses;\nfi\nif [ ${ return inputs.ref_cache ? \"REF_CACHE_YES\" : null; } != null ];\nthen\ntar -xzf ${ return inputs.ref_cache ? inputs.ref_cache.path : ''; } && export REF_CACHE=\"$PWD/ref/cache/%2s/%2s/%s\"\nfi"
                        }
                    ]
                },
                {
                    "class": "EnvVarRequirement",
                    "envDef": [
                        {
                            "envValue": "/home/programs/AmpliconArchitect-master/src",
                            "envName": "AA_SRC"
                        },
                        {
                            "envValue": "/home/programs/AmpliconClassifier-main",
                            "envName": "AC_SRC"
                        }
                    ]
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": ". ./setup_vars.sh && touch $AA_DATA_REPO/coverage.stats"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "&& /home/programs/PrepareAA-master/PrepareAA.py"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "doc": "Converted CNVkit cns-to-bed file",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--cnv_bed"
                    },
                    "id": "#prepare_aa.cwl/cnv_bed"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#prepare_aa.cwl/data_ref_version/wgs_mode",
                            "symbols": [
                                "#prepare_aa.cwl/data_ref_version/wgs_mode/GRCh38",
                                "#prepare_aa.cwl/data_ref_version/wgs_mode/hg19",
                                "#prepare_aa.cwl/data_ref_version/wgs_mode/GRCh37",
                                "#prepare_aa.cwl/data_ref_version/wgs_mode/mm10",
                                "#prepare_aa.cwl/data_ref_version/wgs_mode/GRCm38"
                            ]
                        }
                    ],
                    "doc": "Genome version in data repo to use",
                    "default": "GRCh38",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--ref"
                    },
                    "id": "#prepare_aa.cwl/data_ref_version"
                },
                {
                    "type": "Directory",
                    "doc": "Un-tarred reference obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/",
                    "id": "#prepare_aa.cwl/data_repo"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "This tool uses some software that requires a license file, if run_aa flag given. You can get a personal or institutional one from https://www.mosek.com/license/request/.",
                    "id": "#prepare_aa.cwl/mosek_license_file"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "For cram input, provide tar ball of output of running misc/seq_cache_populate.pl from samtools on the reference fasta",
                    "id": "#prepare_aa.cwl/ref_cache"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Flag to just go ahead and run amplicon amplifier right after",
                    "default": false,
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--run_AA"
                    },
                    "id": "#prepare_aa.cwl/run_aa"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Flag to just go ahead and run amplicon classifier right after",
                    "default": false,
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--run_AC"
                    },
                    "id": "#prepare_aa.cwl/run_ac"
                },
                {
                    "type": "string",
                    "doc": "Sample name",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "-s"
                    },
                    "id": "#prepare_aa.cwl/sample"
                },
                {
                    "type": "File",
                    "doc": "tumor bam file",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--sorted_bam"
                    },
                    "id": "#prepare_aa.cwl/sorted_bam"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Num threads to use",
                    "default": 8,
                    "inputBinding": {
                        "position": 1,
                        "prefix": "-t"
                    },
                    "id": "#prepare_aa.cwl/threads"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*_AA_CNV_SEEDS.bed"
                    },
                    "id": "#prepare_aa.cwl/aa_cnv_seeds"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_classification/*_amplicon_classification_profiles.tsv"
                    },
                    "id": "#prepare_aa.cwl/amplicon_classification_profiles"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "data_repo/coverage.stats"
                    },
                    "id": "#prepare_aa.cwl/coverage_stats"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*_AA_results/*_cycles.txt"
                    },
                    "id": "#prepare_aa.cwl/cycles"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_classification/*_ecDNA_counts.tsv"
                    },
                    "id": "#prepare_aa.cwl/ecDNA_cts"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_classification/*_gene_list.tsv"
                    },
                    "id": "#prepare_aa.cwl/gene_list"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*_AA_results/*_graph.txt"
                    },
                    "id": "#prepare_aa.cwl/graph"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_AA_results/*_summary.txt"
                    },
                    "id": "#prepare_aa.cwl/summary"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*_AA_results/*.pdf"
                    },
                    "id": "#prepare_aa.cwl/sv_pdf"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*_AA_results/*.png"
                    },
                    "id": "#prepare_aa.cwl/sv_png"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#runtime_validator.cwl",
            "doc": "Additional validation for user inputs.",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "echo \"Validating Inputs\""
                }
            ],
            "inputs": [
                {
                    "type": "boolean",
                    "doc": "Set to false to disable Amplicon Architect. Always disabled for WXS!",
                    "id": "#runtime_validator.cwl/amplicon_architect"
                },
                {
                    "type": "boolean",
                    "doc": "B Allele file is present. Warning: B Allele is required to run GATK CNV!",
                    "id": "#runtime_validator.cwl/b_allele_present"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable CNVkit. Warning: CNVkit is required to run both Amplicon Architect and Theta2!",
                    "id": "#runtime_validator.cwl/cnvkit"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Entering Y will run cnvkit in WGS mode, otherwise it will run in hybrid mode. Defaults to Y in wgs mode.",
                    "id": "#runtime_validator.cwl/cnvkit_wgs_mode"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable ControlFreeC.",
                    "id": "#runtime_validator.cwl/controlfreec"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Whether to run in exome mode for callers.",
                    "id": "#runtime_validator.cwl/exome_flag"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable GATK CNV.",
                    "id": "#runtime_validator.cwl/gatk_cnv"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Flag to intersect germline calls on padded regions.  Use N if you want to skip this. Defaults to N in WGS mode.",
                    "id": "#runtime_validator.cwl/i_flag"
                },
                {
                    "type": "boolean",
                    "doc": "True for WGS; False for WXS.",
                    "id": "#runtime_validator.cwl/is_wgs"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable Lancet.",
                    "id": "#runtime_validator.cwl/lancet"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Recommend 0 if interval file padded already, half window size if not. Recommended: 0 for WXS; 300 for WGS",
                    "id": "#runtime_validator.cwl/lancet_padding"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "window size for lancet.  default is 600, recommend 500 for WGS, 600 for exome+",
                    "id": "#runtime_validator.cwl/lancet_window"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable Manta.",
                    "id": "#runtime_validator.cwl/manta"
                },
                {
                    "type": "boolean",
                    "doc": "Mosek file is present. Warning: Mosek file is required to run Amplicon Architect!",
                    "id": "#runtime_validator.cwl/mosek_present"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable Mutect2. Warning: Mutect2 or Strelka2 is required to run Lancet in WGS mode!",
                    "id": "#runtime_validator.cwl/mutect2"
                },
                {
                    "type": "boolean",
                    "doc": "GATK CNV PON file is present. Warning: Panel of Normals is required to run GATK CNV!",
                    "id": "#runtime_validator.cwl/pon_present"
                },
                {
                    "type": "boolean",
                    "doc": "Set to true if you're providing one mutect2 and/or strelka vcfs to run lancet alone in WGS mode",
                    "id": "#runtime_validator.cwl/preexisting_vcf"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable Strelka2. Warning: Strelka2 or Mutect2 is required to run Lancet in WGS mode!",
                    "id": "#runtime_validator.cwl/strelka2"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable Theta2.",
                    "id": "#runtime_validator.cwl/theta2"
                },
                {
                    "type": "boolean",
                    "doc": "Set to false to disable Vardict. Warning: Vardict is required to run Theta2!",
                    "id": "#runtime_validator.cwl/vardict"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Padding to add to input intervals, recommend 0 if intervals already padded such as in WXS, 150 if not such as in WGS",
                    "id": "#runtime_validator.cwl/vardict_padding"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "outputBinding": {
                        "outputEval": "${\n  if (inputs.cnvkit_wgs_mode) { return inputs.cnvkit_wgs_mode }\n  else if (inputs.is_wgs) { return 'Y' }\n  else if (!inputs.is_wgs) { return 'N' }\n}"
                    },
                    "id": "#runtime_validator.cwl/out_cnvkit_wgs_mode"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "outputBinding": {
                        "outputEval": "${\n  if (inputs.exome_flag) { return inputs.exome_flag }\n  else if (inputs.is_wgs) { return 'N' }\n  else if (!inputs.is_wgs) { return 'Y' }\n}"
                    },
                    "id": "#runtime_validator.cwl/out_exome_flag"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "outputBinding": {
                        "outputEval": "${\n  if (inputs.i_flag) { return inputs.i_flag }\n  else if (inputs.is_wgs) { return 'N' }\n  else if (!inputs.is_wgs) { return null }\n}"
                    },
                    "id": "#runtime_validator.cwl/out_i_flag"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "outputBinding": {
                        "outputEval": "${\n  if (inputs.lancet_padding) { return inputs.lancet_padding }\n  else if (inputs.is_wgs) { return 300 }\n  else if (!inputs.is_wgs) { return 0 }\n}"
                    },
                    "id": "#runtime_validator.cwl/out_lancet_padding"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "outputBinding": {
                        "outputEval": "${\n  if (inputs.lancet_window) { return inputs.lancet_window }\n  else if (inputs.is_wgs) { return 500 }\n  else if (!inputs.is_wgs) { return 600 }\n}"
                    },
                    "id": "#runtime_validator.cwl/out_lancet_window"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "outputBinding": {
                        "outputEval": "${\n  if (inputs.vardict_padding) { return inputs.vardict_padding }\n  else if (inputs.is_wgs) { return 150 }\n  else if (!inputs.is_wgs) { return 0 }\n}"
                    },
                    "id": "#runtime_validator.cwl/out_vardict_padding"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "$(inputs.is_wgs)"
                    },
                    "id": "#runtime_validator.cwl/out_wgs"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "${\n  if (!inputs.amplicon_architect || !inputs.is_wgs) {\n    return false;\n  }\n  if (!inputs.cnvkit) {\n    throw new Error('Amplicon Architect cannot be run without CNVkit!');\n  }\n  if (!inputs.mosek_present) {\n    throw new Error('Amplicon Architect cannot be run without Mosek file!');\n  }\n  return true;\n}"
                    },
                    "id": "#runtime_validator.cwl/run_amplicon_architect"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "$(inputs.cnvkit)"
                    },
                    "id": "#runtime_validator.cwl/run_cnvkit"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "$(inputs.controlfreec)"
                    },
                    "id": "#runtime_validator.cwl/run_controlfreec"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "${\n  if (!inputs.gatk_cnv) {\n    return false;\n  }\n  if (!inputs.pon_present) {\n    throw new Error('Running GATK CNV requires a Panel of Normals!');\n  }\n  if (!inputs.b_allele_present) {\n    throw new Error('Running GATK CNV requires a B Allele file!');\n  }\n  return true;\n}"
                    },
                    "id": "#runtime_validator.cwl/run_gatk_cnv"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "${\n  if (!inputs.lancet || !inputs.is_wgs) {\n    return inputs.lancet;\n  }\n  if (!(inputs.mutect2 || inputs.strelka2 || inputs.preexisting_vcf)) {\n    throw new Error('Running Lancet in WGS Mode requires either Mutect2 or Strelka2!');\n  }\n  return true;\n}"
                    },
                    "id": "#runtime_validator.cwl/run_lancet"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "$(inputs.manta)"
                    },
                    "id": "#runtime_validator.cwl/run_manta"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "$(inputs.mutect2)"
                    },
                    "id": "#runtime_validator.cwl/run_mutect2"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "$(inputs.strelka2)"
                    },
                    "id": "#runtime_validator.cwl/run_strelka2"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "${\n  if (!inputs.theta2) {\n    return false;\n  }\n  if (!(inputs.vardict && inputs.cnvkit)) {\n    throw new Error('Running Theta2 requires both Vardict and CNVkit!');\n  }\n  return true;\n  }"
                    },
                    "id": "#runtime_validator.cwl/run_theta2"
                },
                {
                    "type": "boolean",
                    "outputBinding": {
                        "outputEval": "$(inputs.vardict)"
                    },
                    "id": "#runtime_validator.cwl/run_vardict"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#samtools_calmd.cwl",
            "doc": "Recalculate MD tags from input",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/samtools:1.9"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 12000,
                    "coresMin": "$(inputs.threads)"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "samtools calmd -@ $(inputs.threads) -b --reference $(inputs.reference.path) $(inputs.input_reads.path) > $(inputs.input_reads.nameroot).bam; samtools index -@ $(inputs.threads) $(inputs.input_reads.nameroot).bam $(inputs.input_reads.nameroot).bai"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#samtools_calmd.cwl/input_reads"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai"
                        }
                    ],
                    "id": "#samtools_calmd.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "id": "#samtools_calmd.cwl/threads"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.bam"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai"
                        }
                    ],
                    "id": "#samtools_calmd.cwl/bam_file"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#strelka2.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 10000,
                    "coresMin": "$(inputs.cores)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/strelka"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "${\n  if (inputs.extra_arg){\n    var cmd = \"sed  -e 's/extraVariantCallerArguments.*/extraVariantCallerArguments = \"\n    + inputs.extra_arg + \"/' /strelka-2.9.3.centos6_x86_64/bin/configureStrelkaSomaticWorkflow.py.ini > config.ini && \"\n    return cmd\n  }\n  else{\n    return \"\";\n  }\n} /strelka-2.9.3.centos6_x86_64/bin/configureStrelkaSomaticWorkflow.py --normalBam $(inputs.input_normal_aligned.path) --tumorBam $(inputs.input_tumor_aligned.path) --ref $(inputs.reference.path) --callRegions $(inputs.hg38_strelka_bed.path) $(inputs.manta_small_indels && inputs.use_manta_small_indels ? '--indelCandidates ' + inputs.manta_small_indels.path : '') ${\n  var arg = \"--runDir=./\";\n  if (inputs.exome_flag == 'Y'){\n    arg += \" --exome\"\n  }\n  return arg\n} ${\n  if (inputs.extra_arg){\n    return \"--config config.ini\"\n  }\n  else{\n    return \"\"\n  }\n} && ./runWorkflow.py -m local -j $(inputs.cores)"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "id": "#strelka2.cwl/cores"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Y if exome/capture, defaults to WGS",
                    "id": "#strelka2.cwl/exome_flag"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Add special options to config file, i.e. --max-input-depth 1000",
                    "id": "#strelka2.cwl/extra_arg"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "label": "gzipped bed file",
                    "id": "#strelka2.cwl/hg38_strelka_bed"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "doc": "normal BAM or CRAM",
                    "id": "#strelka2.cwl/input_normal_aligned"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "doc": "tumor BAM or CRAM",
                    "id": "#strelka2.cwl/input_tumor_aligned"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "Small indels file from a Manta run",
                    "id": "#strelka2.cwl/manta_small_indels"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.dict",
                            "required": null
                        },
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#strelka2.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": false,
                    "doc": "Should the program use the small indels file? Defaults to false",
                    "id": "#strelka2.cwl/use_manta_small_indels"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "results/variants/*.indels.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#strelka2.cwl/output_indel"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "results/variants/*.snvs.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#strelka2.cwl/output_snv"
                }
            ]
        },
        {
            "requirements": [
                {
                    "class": "DockerRequirement",
                    "dockerPull": "ubuntu:18.04"
                },
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "class": "CommandLineTool",
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "$( inputs.output_file ? 'tar' : 'echo tar' )"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": true,
                    "inputBinding": {
                        "prefix": "--create",
                        "position": 1
                    },
                    "id": "#tar.cwl/create"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "default": true,
                    "inputBinding": {
                        "prefix": "--gzip",
                        "position": 1
                    },
                    "id": "#tar.cwl/gzip"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "inputBinding": {
                        "position": 2
                    },
                    "id": "#tar.cwl/input_files"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "prefix": "--file",
                        "position": 1
                    },
                    "id": "#tar.cwl/output_file"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "$(inputs.output_file)"
                    },
                    "id": "#tar.cwl/output"
                }
            ],
            "id": "#tar.cwl",
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#theta2_purity.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/theta2:0.7.1"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 32000,
                    "coresMin": 8
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-c"
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "set -eo pipefail\n/THetA/bin/RunTHetA --TUMOR_FILE $(inputs.tumor_snp.path) --NORMAL_FILE $(inputs.normal_snp.path) --OUTPUT_PREFIX $(inputs.output_basename) --NUM_PROCESSES 8 --MIN_FRAC $(inputs.min_frac) $(inputs.interval_count.path) || (echo \"Theta2 failed, likely due to insufficient copy number variation to calculate purity, or due to an input error, skipping >&2\"; exit 0;)"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#theta2_purity.cwl/interval_count"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Minimum fraction of genome with copy number alterations.  Default is 0.05",
                    "default": 0.05,
                    "id": "#theta2_purity.cwl/min_frac"
                },
                {
                    "type": "File",
                    "id": "#theta2_purity.cwl/normal_snp"
                },
                {
                    "type": "string",
                    "id": "#theta2_purity.cwl/output_basename"
                },
                {
                    "type": "File",
                    "id": "#theta2_purity.cwl/tumor_snp"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.BEST.results"
                    },
                    "id": "#theta2_purity.cwl/best_results"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.n2.graph.pdf"
                    },
                    "id": "#theta2_purity.cwl/n2_graph"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.n2.results"
                    },
                    "id": "#theta2_purity.cwl/n2_results"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.n2.withBounds"
                    },
                    "id": "#theta2_purity.cwl/n2_withBounds"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.n3.graph.pdf"
                    },
                    "id": "#theta2_purity.cwl/n3_graph"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.n3.results"
                    },
                    "id": "#theta2_purity.cwl/n3_results"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.n3.withBounds"
                    },
                    "id": "#theta2_purity.cwl/n3_withBounds"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#ubuntu_ratio2seg.cwl",
            "requirements": [
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/python:2.7.13"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 1000,
                    "coresMin": 1
                },
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "baseCommand": [
                "python",
                "-c"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": true,
                    "valueFrom": "\nimport math\n\nfai = open(\"$(inputs.reference_fai.path)\")\nh = {}\nfor line in fai:\n    f = line.split(chr(9))\n    if f == \"chrM\":\n        break\n    f[0] = f[0].replace(\"chr\",\"\")\n    h[f[0]] = f[1]\nfai.close()\n\nsmp = \"$(inputs.sample_name)\"\n\nratio_file = open(\"$(inputs.ctrlfreec_ratio.path)\")\nout = open(\"$(inputs.output_basename).controlfreec.seg\", \"w\")\nout.write(chr(9).join([\"ID\",\"chrom\",\"loc.start\",\"loc.end\",\"num.mark\",\"seg.mean\"]) + chr(10))\nhead = next(ratio_file)\ncount = 0\nfor line in ratio_file:\n    data = line.rstrip(chr(10)).split(chr(9))\n    (chrom, pos, ratio, meanRatio) = (data[0], data[1], data[2], data[3])\n    if float(meanRatio) == -1:\n        continue\n    count += 1\n    if count == 1:\n        start = pos\n        seg_ratio = meanRatio\n        on_chr = chrom\n    else:\n        if chrom != on_chr:\n            out.write(chr(9).join((smp, \"chr\" + on_chr, start, h[on_chr], str(count))) + chr(9))\n            if float(seg_ratio) != 0:\n                out.write(str(math.log(float(seg_ratio), 2)) + chr(10))\n            else:\n                out.write(str(math.log(float(seg_ratio) + 1, 2)) + chr(10))\n            start = pos\n            seg_ratio = meanRatio\n            on_chr = chrom\n            count = 1\n        elif meanRatio != seg_ratio:\n            out.write(chr(9).join((smp, \"chr\" + chrom, start, str(int(pos)-1), str(count))) + chr(9))\n            if float(seg_ratio) != 0:\n                out.write(str(math.log(float(seg_ratio), 2)) + chr(10))\n            else:\n                out.write(str(math.log(float(seg_ratio) + 1, 2)) + chr(10))\n            start = pos\n            seg_ratio = meanRatio\n            count = 1\nratio_file.close()\nout.close()\n"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#ubuntu_ratio2seg.cwl/ctrlfreec_ratio"
                },
                {
                    "type": "string",
                    "id": "#ubuntu_ratio2seg.cwl/output_basename"
                },
                {
                    "type": "File",
                    "id": "#ubuntu_ratio2seg.cwl/reference_fai"
                },
                {
                    "type": "string",
                    "id": "#ubuntu_ratio2seg.cwl/sample_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.seg"
                    },
                    "id": "#ubuntu_ratio2seg.cwl/ctrlfreec_ratio2seg"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#ubuntu_rename_outputs.cwl",
            "doc": "Rename contrfreeec outputs",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/ubuntu:18.04"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 1000,
                    "coresMin": 2
                },
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "${\n    var cmd = \"\";\n    for (var i=0; i < inputs.input_files.length; i++){\n      if (inputs.input_files[i] != null){\n        var basename = inputs.input_files[i].basename;\n        var fname = basename.replace(\"bam_\", \"\");\n        var parts = fname.split(\".\");\n        parts.shift();\n        var check = fname.substr(fname.length - 10);\n        if (check == \"config.txt\") {\n            cmd += \"cp \" + inputs.input_files[i].path + \" \" + inputs.output_basename + \".controlfreec.config.txt;\";\n        } else {\n        fname = inputs.output_basename + \".controlfreec.\" + parts.join(\".\");\n        cmd += \" cp \" + inputs.input_files[i].path + \" \" + fname + \";\";\n        }\n      }\n      else{\n        cmd += \"echo A null file was detected, skipping >&2;\"\n      }\n    }\n  for (var j=0; j < inputs.input_pngs.length; j++){\n      var nameroot = inputs.input_pngs[j].nameroot;\n      var fname = nameroot.replace(\"bam_\", \"\");\n      fname = fname.replace(\".txt\", \"\");\n      var parts = fname.split(\".\");\n      parts.shift();\n      fname = inputs.output_basename + \".controlfreec.\" + parts.join(\".\") + \".png\";\n      cmd += \" cp \" + inputs.input_pngs[j].path + \" \" + fname + \";\";\n      }\n    return cmd;\n}"
                }
            ],
            "inputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/input_files"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/input_pngs"
                },
                {
                    "type": "string",
                    "id": "#ubuntu_rename_outputs.cwl/output_basename"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.BAF.txt"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_baf"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.ratio.txt"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_bam_ratio"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.CNVs"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_cnvs"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.config.txt"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_config"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.info.txt"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_info"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.control.cpn"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_normal_cpn"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*.png"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_pngs"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.CNVs.p.value.txt"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_pval"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.sample.cpn"
                    },
                    "id": "#ubuntu_rename_outputs.cwl/ctrlfreec_tumor_cpn"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "id": "#untar_gzip.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "ubuntu:20.04"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 4000,
                    "coresMin": 4
                }
            ],
            "class": "CommandLineTool",
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "mkdir $(inputs.out_dir_name) && tar"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "valueFrom": "-xzf"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "doc": "Input gzipped tarball to unpack",
                    "inputBinding": {
                        "position": 2
                    },
                    "id": "#untar_gzip.cwl/input_tar"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "name of output dir",
                    "default": "untar_output",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "-C",
                        "shellQuote": false
                    },
                    "id": "#untar_gzip.cwl/out_dir_name"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "Directory"
                    ],
                    "outputBinding": {
                        "glob": "$(inputs.out_dir_name)"
                    },
                    "id": "#untar_gzip.cwl/output"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#vardictjava.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${return inputs.ram * 1000}",
                    "coresMin": "$(inputs.cpus)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/vardict:1.7.0"
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-c"
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": true,
                    "valueFrom": "set -eo pipefail; export VAR_DICT_OPTS='\"-Xms768m\" \"-Xmx$(Math.floor(inputs.ram/1.074 - 1))g\"'; /VarDict-1.7.0/bin/VarDict -G $(inputs.reference.path) -f $(inputs.min_vaf) -th $(inputs.cpus) --nosv -N $(inputs.output_basename) -b '$(inputs.input_tumor_bam.path)|$(inputs.input_normal_bam.path)' -z -c 1 -S 2 -E 3 -g 4 -F 0x700 -Q 10 -V 0.01 -x $(inputs.padding) $(inputs.bed.path) > vardict_results.txt && cat vardict_results.txt | /VarDict-1.7.0/bin/testsomatic.R > vardict_r_test_results.txt && cat vardict_r_test_results.txt | /VarDict-1.7.0/bin/var2vcf_paired.pl -N '$(inputs.input_tumor_name)|$(inputs.input_normal_name)' -f $(inputs.min_vaf) -M -m 4.25 > $(inputs.output_basename).result.vcf && cat $(inputs.output_basename).result.vcf | perl -e 'while(<>){if ($_ =~ /^#/){print $_;} else{@a = split /\\t/,$_; if($a[3] =~ /[KMRYSWBVHDXkmryswbvhdx]/){$a[3] = \"N\";} if($a[4] =~ /[KMRYSWBVHDXkmryswbvhdx]/){$a[4] = \"N\";} if($a[3] ne $a[4]){print join(\"\\t\", @a);}}}' > $(inputs.output_basename).canonical_base_only.$(inputs.bed.nameroot).vcf && bgzip  $(inputs.output_basename).canonical_base_only.$(inputs.bed.nameroot).vcf && tabix  $(inputs.output_basename).canonical_base_only.$(inputs.bed.nameroot).vcf.gz"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#vardictjava.cwl/bed"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "id": "#vardictjava.cwl/cpus"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".bai",
                            "required": false
                        }
                    ],
                    "id": "#vardictjava.cwl/input_normal_bam"
                },
                {
                    "type": "string",
                    "id": "#vardictjava.cwl/input_normal_name"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".bai",
                            "required": false
                        }
                    ],
                    "id": "#vardictjava.cwl/input_tumor_bam"
                },
                {
                    "type": "string",
                    "id": "#vardictjava.cwl/input_tumor_name"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Recommend 0.05",
                    "default": 0.05,
                    "id": "#vardictjava.cwl/min_vaf"
                },
                {
                    "type": "string",
                    "id": "#vardictjava.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Padding to add to input intervals, recommened 0 if intervals already padded, 150 if not",
                    "default": 150,
                    "id": "#vardictjava.cwl/padding"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "In GB",
                    "id": "#vardictjava.cwl/ram"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.dict",
                            "required": null
                        },
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#vardictjava.cwl/reference"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#vardictjava.cwl/vardict_vcf"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#main",
            "label": "Kids First DRC Somatic Variant Workflow",
            "doc": "# Kids First DRC Somatic Variant Workflow\n\n<p align=\"center\">\n  <img src=\"https://github.com/d3b-center/d3b-research-workflows/raw/master/doc/kfdrc-logo-sm.png\">\n</p>\n\nThis repository contains the Kids First Data Resource Center (DRC) Somatic Variant Workflow, which includes somatic variant (SNV), copy number variation (CNV), and structural variant (SV) calls.\nThe [somatic variant workflow](./workflow/kfdrc-somatic-variant-workflow.cwl) takes aligned cram input and performs somatic variant calling using Strelka2, Mutect2, Lancet, and VarDict Java, CNV estimation using Control-FREEC, CNVkit, and GATK, and SV calls using Manta.\nFor whole genome sequencing data, the workflow will also predict extra chromosomal DNA (ecDNA) using AmpliconArchitect\nSomatic variant call results are annotated with hotspots, assigned population frequencies using gnomAD AF, calculated gene models using Variant Effect Predictor (VEP), then added an additional MAF output using a modified version of Memorial Sloan Kettering Cancer Center's (MSKCC) vcf2maf.\nSee [annotation workflow doc](./docs/kfdrc_annotation_wf.md) for more details on annotation.\n\nIf you would like to run this workflow using the CAVATICA public app, a basic primer on running public apps can be found [here](https://www.notion.so/d3b/Starting-From-Scratch-Running-Cavatica-af5ebb78c38a4f3190e32e67b4ce12bb).\nAlternatively, if you'd like to run it locally using `cwltool`, a basic primer on that can be found [here](https://www.notion.so/d3b/Starting-From-Scratch-Running-CWLtool-b8dbbde2dc7742e4aff290b0a878344d) and combined with app-specific info from the readme below.\nThis workflow is the current production workflow, equivalent to this [CAVATICA public app](https://cavatica.sbgenomics.com/public/apps#cavatica/apps-publisher/kfdrc-somatic-variant-workflow).\n\n\n## Somatic Variant Workflow Callers\n\n| Caller                                                  | [CNV](#cnv-estimators) | [SNV](#snv-callers) | [SV](#sv-callers) | [ecDNA](#ecdna-prediction) |\n|---------------------------------------------------------|:----------------------:|:-------------------:|:-----------------:|:--------------------------:|\n| [AmpliconArchitect](./docs/kfdrc_amplicon_architect.md) |                        |                     |                   |              x             |\n| CNVkit                                                  |            x           |                     |                   |                            |\n| Control-FREEC                                           |            x           |                     |                   |                            |\n| [GATK CNV](./docs/kfdrc_gatk_cnv_somatic_pair_wf.md)    |            x           |                     |                   |                            |\n| [Lancet](./docs/kfdrc_lancet_sub_wf.md)                 |                        |          x          |                   |                            |\n| Manta                                                   |                        |                     |         x         |                            |\n| [Mutect2](./docs/kfdrc_mutect2_sub_wf.md)               |                        |          x          |                   |                            |\n| [Strelka2](./docs/kfdrc_strelka2_subworkflow.md)        |                        |          x          |                   |                            |\n| THeTa2                                                  |                        |                     |         x         |                            |\n| [VarDict](./docs/kfdrc_vardict_sub_wf.md)               |                        |          x          |                   |                            |\n\n### SNV Callers\n\n- [Strelka2](https://github.com/Illumina/strelka/tree/v2.9.3) `v2.9.3`, from Illumina, calls SNVs and insertions/deletions (INDEL)\n  - See the [subworkflow doc](./docs/kfdrc_strelka2_subworkflow.md) for more information\n- [Mutect2](https://gatk.broadinstitute.org/hc/en-us/articles/360036730411-Mutect2) `v4.1.1.0`, from the Broad Institute, calls SNVs, multi-nucleotide variants (MNV: equal length substitutions over 1 base long), and INDELs\n  - See the [subworkflow doc](./docs/kfdrc_mutect2_sub_wf.md) for more information\n- [Lancet](https://github.com/nygenome/lancet/releases/tag/v1.0.7) `v1.0.7`, from the New York Genome Center (NYGC), calls SNVs, MNVs, and INDELs\n  - See the [subworkflow doc](./docs/kfdrc_lancet_sub_wf.md) for more information\n- [VarDict Java](https://github.com/AstraZeneca-NGS/VarDictJava/tree/1.7.0) `v1.7.0`, from AstraZeneca, calls SNVs, MNVs, INDELs and more\n  - See the [subworkflow doc](./docs/kfdrc_vardict_sub_wf.md) for more information\n\n#### SNV Consensus Calling\n\nEach caller has a different approach to variant calling, and together one can glean confident results. To synthesize the results from these four callers we have developed a [consensus calling workflow](./workflow/kfdrc_consensus_calling.cwl). For details, please refer to the [workflow documentation](./docs/kfdrc-consensus-calling.md).\n\n#### SNV Annotation\n\nSomatic variant call results are annotated with hotspots, assigned population frequencies using gnomAD AF, calculated gene models using VEP, then added an additional MAF output using a modified version of MSKCC vcf2maf.\n\nThe somatic annotation workflow is included in this repository as a submodule [found here](./kf-annotation-tools/workflows/kfdrc-somatic-snv-annot-workflow.cwl). To get the necessary files when downloading the repository, make sure use recursive flag for git clone: `git clone --recursive`. For details on the workflow and its components, please refer to the [workflow documentation](./kf-annotation-tools/docs/SOMATIC_SNV_ANNOT_README.md). The source repository for the annotation workflows can be [found here](https://github.com/kids-first/kf-annotation-tools).\n\n### SV Callers\n\n- [Manta](https://github.com/Illumina/manta/tree/v1.4.0) `v1.4.0`, from Illumina, is used to call SVs. Output is also in VCF format, with calls filtered on `PASS`.\n\n#### SV Annotation\n\n- [AnnotSV](https://github.com/lgmgeo/AnnotSV/releases/tag/v3.1.1) `v3.1.1`, from Universit\u00e9 de Strasbourg, is used to annotate the calls in the Manta PASS VCF.\n\n### CNV Estimators\n\n- [Control-FREEC](https://github.com/BoevaLab/FREEC/tree/v11.6) `v11.6`, from the Bioinformatics Laboratory of Institut Curie and Boeva Lab, detects copy-number changes and allelic imbalances (including LOH)\n   - The tool portion of the workflow is a port from the [Velsera](https://velsera.com/) team, with a slight tweak in image outputs\n   - Also, the workflow wrapper limits what inputs and outputs are used based on our judgement of utility\n- [CNVkit](https://cnvkit.readthedocs.io/en/v0.9.3/) `v0.9.3`, from UCSF, infers and visualizes copy number\n- [THeTa2](https://github.com/kids-first/THetA/tree/v0.7.1) `v0.7.1`, from Brown University and CHOP D3b, is used to inform and adjust copy number calls from CNVkit with purity estimations\n- [GATK CNV](https://gatk.broadinstitute.org/hc/en-us/articles/360035531152--How-to-Call-common-and-rare-germline-copy-number-variants) `v4.2.4.1`, from the Broad Institute, calls somatic CNVs using a Panel of Normals (PON) created using [this workflow](./workflows/kfdrc_gatk_create_cnv_pon_wf.cwl)\n   - Read more about our the workflow and our PON recommendations in the [subworkflow doc](./docs/kfdrc_gatk_create_cnv_pon_wf.md)\n\n#### Copy Number Genotype Estimation Using B-Allele Frequency\n\nControl-FREEC and CNVkit can take advantage of B-Allele Frequency (BAF) integration for copy number genotype estimation and increased CNV accuracy. That is done using the following process:\n1. create a gVCF using either:\n   - [Sentieon Alignment and gVCF Workflow](https://github.com/kids-first/kf-alignment-workflow/blob/master/workflows/kfdrc_sentieon_alignment_wf.cwl)\n      - For details, please refer to the [workflow documentation](https://github.com/kids-first/kf-alignment-workflow/blob/master/docs/KFDRC_SENTIEON_ALIGNMENT_GVCF_WORKFLOW_README.md)\n      - To run on CAVATICA, see our [public app](https://cavatica.sbgenomics.com/public/apps/cavatica/apps-publisher/kfdrc-sentieon-alignment-workflow)\n   - [BWA Alignment and GATK HaplotypeCaller Workflow](https://github.com/kids-first/kf-alignment-workflow/blob/master/workflows/kfdrc_alignment_wf.cwl)\n      - For details, please refer to the [workflow documentation](https://github.com/kids-first/kf-alignment-workflow/blob/master/readme.md)\n      - To run on CAVATICA, see our [public app](https://cavatica.sbgenomics.com/public/apps/cavatica/apps-publisher/kfdrc-alignment-workflow)\n2. create a VCF by perform genotype refinement on the gVCF:\n   - [Single Sample Genotyping Workflow](https://github.com/kids-first/kf-germline-workflow/blob/master/workflows/kfdrc-single-sample-genotyping-wf.cwl)\n      - To run on CAVATICA, see our [public app](https://cavatica.sbgenomics.com/public/apps#cavatica/apps-publisher/kfdrc-single-sample-genotyping-wf/)\n3. Pass that VCF to the `b_allele` workflow input\n\n### ecDNA Prediction\n- [AmpliconArchitect](https://github.com/AmpliconSuite/AmpliconSuite-pipeline/blob/master/documentation/GUIDE.md), from UCSD, is used to predict ecDNAs\n   - Workflow documentation available [here](./docs/kfdrc_amplicon_architect.md)\n\n\n## Running Whole Genome Sequencing (WGS) or Whole Exome Sequencing (WXS)\n\nThe somatic variant workflow is designed to be able to process either WGS or\nWXS inputs. This functionality comes from usage of the `wgs_or_wxs` input enum.\nDepending on what is provided for this input, the tool will set the appropriate\ndefault values and check that the user has provided the correct inputs. For\nexample, if the user sets the input to WGS the `lancet_padding` value will be\nset to 300; alternatively, if the user sets the input to WXS the\n`lancet_padding` value will be defaulted to 0. In either case, the user can\noverride the defaults simply by providing their own value for `lancet_padding`\nin the inputs.\n\nThe `wgs_or_wxs` flag also plays an integral role in the preparation of\nintervals throughout the pipeline.\n\n## Calling Intervals, in short\n\nIn order to perform variant calling, the user must provide some of these intervals:\n- `calling_regions`: genomic regions over which the SNV and SV callers will be run\n- `blacklist_regions`: genomic regions to remove from the SNV and SV calling regions\n- `coding_sequence_regions`: genomic regions covering the coding sequence regions of the genome to which the input BAM/CRAM/SAM was aligned\n- `cnv_blacklist_regions`: genomic regions to remove from the CNV calling regions\n\nThe calling is the base calling regions for the sample. These regions are\nfurther modified by the two blacklist files. The blacklist regions first\nremoved from the calling regions and the resulting regions are what are passed\nto callers. SNV and SV callers receive the regions that are `calling_regions`\nwith `blacklist_regions` removed. CNV callers receive the regions that are\n`calling_regions` with `cnv_blacklist_regions` removed.\n\nIn general, what is expected of the user to provide for these intervals is:\n- WGS\n   - `calling_regions`: Whole genome calling regions (for GATK these are the regions of the FASTA on `chr1-22,X,Y` where there is no span of more than 200 Ns; for completeness we add `chrM`)\n   - `blacklist_regions`: Regions that the user is confident are of no interest to SNV and SV calling, if any. Telomeres, centromeres, high signal regions, repetitive regions, etc.\n   - `cnv_blacklist_regions`: Regions of the `calling_regions` the user is confident are of no interest to CNV calling, if any. These regions include chrM, telomeres, centromeres, high signal regions, repetitive regions, etc.\n   - `coding_sequence_regions`: Regions of the genome that GENCODE defines as CDS; can be determined from [their GTF](https://www.gencodegenes.org/human/)\n- WXS\n   - `calling_regions`: The experimental bait capture regions\n   - `blacklist_regions`: Regions of the `calling_regions` that the user is confident are of no interest to SNV and SV calling, if any\n   - `cnv_blacklist_regions` Regions of the capture region that the user is confident are of no interest to CNV calling, if any\n   - `coding_sequence_regions`: This input is not used in WXS runs. Providing it does nothing\n\nThe coding sequence regions are only relevant for calling WGS data using\nLancet. Presenting Lancet with intervals spanning the whole genome will lead to\nextreme runtime and cost. By starting from an limited calling region and\nsupplementing with calls from Mutect2 and/or Strelka2, Lancet is able to run on\nthe scale of hours rather than days.\n\nThere's a lot more to talk about with intervals, how they are prepared, and\nsome finer details. If you are interested, see our [interval preparation walkthrough](./docs/interval_preparation_walkthrough.md).\n\n## Partial Workflow Runs\n\nBy default, the workflow will attempt to run every caller. However, the user can modify this behavior using various inputs.\nThese inputs, and their behavior, are as follows:\n- `wgs_or_wxs`: WGS or WXS mode.\n    - WXS mode disables AmpliconArchitect, even if `run_amplicon_architect` is set to true\n    - Activates appropriate interval processing\n- `run_vardict`: Set to false to disable VarDict.\n    - **Warning!** Enabling THeTa2 with VarDict disabled will throw an error!\n- `run_mutect2`: Set to false to disable Mutect2.\n    - **Warning!** Enabling Lancet in WGS mode with Mutect2 and Strelka2 disabled will throw an error!\n- `run_strelka2`: Set to false to disable Strelka2.\n    - **Warning!** Enabling Lancet in WGS mode with Strelka2 and Mutect2 disabled will throw an error!\n- `run_lancet`: Set to false to disable Lancet.\n- `run_controlfreec`: Set to false to disable Control-FREEC.\n- `run_cnvkit`: Set to false to disable CNVkit.\n    - **Warning!** Enabling AmpliconArchitect with CNVkit disabled will throw an error!\n    - **Warning!** Enabling THeTa2 with CNVkit disabled will throw an error!\n- `run_amplicon_architect`: Set to false to disable AmpliconArchitect.\n- `run_theta2`: Set to false to disable THeTa2.\n- `run_manta`: Set to false to disable Manta.\n- `run_gatk_cnv`: Set to false to disable GATK CNV.\n\nThe first step of the workflow will check the user inputs and throw errors for impossible scenarios:\n- Enabling Lancet in WGS without enabling either Mutect2 or Strelka2 or user providing existing calls to the `lancet_input_vcf` input\n- Enabling AmpliconArchitect without enabling CNVkit or providing the Mosek config file\n- Enabling THeTa2 without enabling both VarDict and CNVkit\n- Enabling GATK CNV without providing a Panel of Normals\n\n# Tips to Run:\n\n1. For input cram files, be sure to have indexed them beforehand\n\n1. When in doubt, all of our reference files can be obtained from here: https://cavatica.sbgenomics.com/u/kfdrc-harmonization/kf-references/\n\n1. For Control-FREEC, it is highly recommended that you supply a VCF file with germline calls, GATK HaplotypeCaller recommended. Please also make sure the index for this file is available. Also, a range of input ploidy possibilities for the inputs are needed. You can simply use `2`, or put in a range, as an array, like 2, 3, 4. For mate orientation, you will need to specify, the drop down and tool doc explains your options.\n\n1. As a CAVATICA app, default references for hg38 are already pre-populated, as well as some default settings - i.e., number of threads, coefficient of variation input for Control-FREEC, and `PASS` filter tool mode.\n\n1. If running Lancet for WGS, and you have existing variant calls that you'd like to use from a previous Strelka2 and/or Mutect2 run for example, provide them to `lancet_input_vcf` input. Otherwise you _must_ also enable `run_strelka2` and/or `run_mutect2`\n\n1. `select_vars_mode`: On occasion, using GATK's `SelectVariants` tool will fail, so a simple `grep` mode on `PASS` can be used instead.\nRelated, `bcftools_filter_vcf` is built in as a convenience in case your b allele frequency file has not been filtered on `PASS`.\nYou can use the `include_expression` `Filter=\"PASS\"` to achieve this.\n\n1. The `SM:` sample IDs in the input alignment files **must** match `input_tumor_name` and `input_normal_name`. If you need the output VCF sample names to differ from the input, enter what is currently in `SM:` into the `old_tumor_name` and `old_normal_name` fields, and enter the desired sample names in `input_tumor_name` and `input_normal_name`. The workflow will rename the samples in the VCF for you.\n\n1. Our reference inputs can be obtained with an account [from CAVATICA](https://cavatica.sbgenomics.com/u/kfdrc-harmonization/kf-references/). Below are some directions on how to make them:\n   - `reference_fasta`: [Homo_sapiens_assembly38.fasta](https://console.cloud.google.com/storage/browser/genomics-public-data/resources/broad/hg38/v0?pli=1) - need a valid google account, this is a link to the resource bundle from Broad GATK\n   - `reference_dict`: [Homo_sapiens_assembly38.dict](https://console.cloud.google.com/storage/browser/genomics-public-data/resources/broad/hg38/v0?pli=1) - need a valid google account, this is a link to the resource bundle from Broad GATK\n   - `calling_regions`: [wgs_calling_regions.hg38.interval_list](https://console.cloud.google.com/storage/browser/genomics-public-data/resources/broad/hg38/v0?pli=1) - need a valid google account, this is a link to the resource bundle from Broad GATK. **To create our canonical calling intervals, edit this file by leaving only entries related to chr1-22,X,Y,M. M may need to be added.**\n   - `cnv_blacklist_regions`: `somatic-hg38_CNV_and_centromere_blacklist.hg38liftover.list` Blacklist regions that include centromeres to exclude from CNV calling\n   - `coding_sequence_regions`: `GRCh38.gencode.v31.CDS.merged.bed` For Lancet WGS, it's highly recommended to use CDS bed as the starting point and supplement with the regions of calls from Strelka2 & Mutect2. Our CDS regions were obtained from GENCODE, [release 31](https://www.gencodegenes.org/human/release_31.html) using this GTF file [gencode.v31.primary_assembly.annotation.gtf.gz](ftp://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_31/gencode.v31.primary_assembly.annotation.gtf.gz) and parsing features for `UTR`, `start codon`, `stop codon`, and `exon`, then using bedtools sort and merge after converting coordinates into bed format.\n   - `cnvkit_annotation_file`: [refFlat_HG38.txt](http://hgdownload.soe.ucsc.edu/goldenPath/hg38/database/refFlat.txt.gz) gunzip this file from UCSC\n   - `af_only_gnomad_vcf`: [af-only-gnomad.hg38.vcf.gz](https://console.cloud.google.com/storage/browser/gatk-best-practices/somatic-hg38) - need a valid google account, this is a link to the best practices google bucket from Broad GATK.\n   - `exac_common_vcf`: [small_exac_common_3.hg38.vcf.gz](https://console.cloud.google.com/storage/browser/gatk-best-practices/somatic-hg38) - need a valid google account, this is a link to the best practices google bucket from Broad GATK.\n   - `vep_cache`: `homo_sapiens_merged_vep_105_indexed_GRCh38.tar.gz` from [VEP release 105](https://ftp.ensembl.org/pub/release-105/variation/indexed_vep_cache/) - variant effect predictor cache. Current production workflow uses this version.\n   - `genomic_hotspots`: `tert.bed`. Tab-delimited BED formatted file(s) containing hg38 genomic positions corresponding to hotspots\n   - `protein_snv_hotspots`: [kfdrc_protein_snv_cancer_hotspots_20240718.txt](https://www.cancerhotspots.org/files/hotspots_v2.xls). Column-name-containing, tab-delimited file(s) containing protein names and amino acid positions corresponding to hotspots. Recommend pulling the two relevant columns for SNVs only, and convert to TSV\n   - `protein_indel_hotspots`: [protein_indel_cancer_hotspots_v2.ENS105_liftover.tsv](https://www.cancerhotspots.org/files/hotspots_v2.xls). Column-name-containing, tab-delimited file(s) containing protein names and amino acid position ranges corresponding to hotspots.\n   - `echtvar_anno_zips`: `gnomad_3_1_1.vwb_subset.echtvar_0_1_9.zip`.Echtvar annotation ZIP file. For more info on how this file was created, see our [Ectvar documentation](./docs/echtvar_gnomad_annotation.md).\n   - `custom_enst`: `kf_isoform_override.tsv`. As of VEP 104, several genes have had their canonical transcripts redefined. While the VCF will have all possible isoforms, this affects MAF file output and may results in representative protein changes that defy historical expectations\n   - `funcotator_data_sources_tgz`: [funcotator_dataSources.v1.6.20190124s.tar.gz](https://console.cloud.google.com/storage/browser/broad-public-datasets/funcotator) - need a valid google account, this is a link to pre-packaged datasources from the Broad Institute. Any of the tar.gz files will do.\n   - `annotsv_annotations_dir_tgz`: [annotsv_311_annotations_dir.tgz] - These annotations are simply those from the install-human-annotation installation process run during AnnotSV installation. Specifically these are the annotations installed with v3.1.1 of the software. Newer or older annotations can be slotted in here as needed.\n   - `aa_data_repo`: [GRCh38_indexed.tar.gz](https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/) - AmpliconArchitect reference TAR ball. Only needed/used if input is WGS\n   - `mosek_license_file`: [mosek.lic](https://www.mosek.com/license/request/) - required if AmpliconArchitect is run. License is good for one year and is renewable\n\n1. There are some flags that we set as defaults. Feel free to alter these if your experiment calls for something else:\n   - `cfree_coeff_var`: 0.05\n   - `cfree_contamination_adjustment`: FALSE\n   - `bcftools_public_filter`: `'FILTER=\"PASS\"|INFO/HotSpotAllele=1'`. This phrase will allow `PASS` only **or** `HotSpotAllele` variants into the public version of variant call output.\n   - `disable_hotspot_annotation`: false\n   - `maf_center`: `\".\"`. Sequencing center of variant called\n   - `aa_data_ref_version`: `\"GRCh38\"`. Genome reference version used\n\n1. There are some flags that need to be set by the user at runtime. These are our recommendations:\n   - `gatk_filter_name`: `[\"NORM_DP_LOW\", \"GNOMAD_AF_HIGH\"]`. These correspond to the recommended filter expression.\n   - `gatk_filter_expression`: `[\"vc.getGenotype('<input_normal_name> ').getDP() <= 7\"), \"gnomad_3_1_1_AF != '.' && gnomad_3_1_1_AF > 0.001  && gnomad_3_1_1_FILTER=='PASS'\"]`. Array of filter expressions to establish criteria to tag variants with. See [annotation subworkflow docs](./docs/kfdrc_annotation_subworkflow.md) for a more detailed explanation. For more information on filter expressions, see the [GATK JEXL docs](https://gatk.broadinstitute.org/hc/en-us/articles/360036730071-VariantFiltration).\n   - `extra_arg`: This can be used to add special params to Strelka2. It is currently more of an \"unsticking param\". For edge cases where strelka2 seems to hang, setting this to `--max-input-depth 10000` can balance performance and consistency in results\n\n1. Output files (Note, all VCF files that don't have an explicit index output have index files output as as secondary file.  In other words, they will be captured at the end of the workflow):\n    - Simple variant callers\n        - Strelka2\n            - `strelka2_prepass_vcf`: Combined SNV + INDEL file with renamed Sample IDs. Has all soft `FILTER` values generated by variant caller\n            - `strelka2_protected_outputs`: Array of files containing MAF format of PASS hits, `PASS` VCF with annotation pipeline soft `FILTER`-added values, and VCF index\n            - `strelka2_public_outputs`: Same as above, except MAF and VCF have had entries with soft `FILTER` values removed\n        - Mutect2\n            - `mutect2_filtered_vcf`: VCF with SNV, MNV, and INDEL variant calls. Contains all soft `FILTER` values generated by variant caller. Use this file if you believe important variants are being left out when using the algorithm's `PASS` filter\n            - `mutect2_protected_outputs`: Array of files containing MAF format of PASS hits, `PASS` VCF with annotation pipeline soft `FILTER`-added values, and VCF index\n            - `mutect2_public_outputs`: Same as above, except MAF and VCF have had entries with soft `FILTER` values removed\n        - VarDict Java\n            - `vardict_prepass_vcf`: VCF with SNV, MNV, and INDEL variant calls. Contains all soft `FILTER` values generated by variant caller. Use this file if you believe important variants are being left out when using the algorithm's `PASS` filter\n            - `vardict_protected_outputs`: Array of files containing MAF format of PASS hits, `PASS` VCF with annotation pipeline soft `FILTER`-added values, and VCF index\n            - `vardict_public_outputs`: Same as above, except MAF and VCF have had entries with soft `FILTER` values removed\n        - Lancet\n            - `lancet_prepass_vcf`: VCF with SNV, MNV, and INDEL variant calls. Contains all soft `FILTER` values generated by variant caller, Use this file if you believe important variants are being left out when using the algorithm's `PASS` filter\n            - `lancet_protected_outputs`: Array of files containing MAF format of PASS hits, `PASS` VCF with annotation pipeline soft `FILTER`-added values, and VCF index\n            - `lancet_public_outputs`: Same as above, except MAF and VCF have had entries with soft `FILTER` values removed\n    - Structural variant callers\n        - Manta\n            - `manta_pass_vcf`: SV call filtered on `PASS`, from manta\n            - `manta_pass_tbi`: Index file of above bgzipped VCF\n            - `manta_prepass_vcf`: SV results with all `FILTER` categories for manta. Use this file if you believe important variants are being left out when using the algorithm's `PASS` filter\n            - `annotsv_annotated_calls`: This file contains all records from the `manta_pass_vcf` that AnnotSV could annotate.\n            - `annotsv_unannotated_calls`: This file contains all records from the `manta_pass_vcf` that AnnotSV could not annotate.\n    - Copy number variation callers\n        - ControlFREEC\n            - `ctrlfreec_pval`: CNV calls with copy number and p value confidence, a qualitative \"gain, loss, neutral\" assignment, and genotype with uncertainty assigned from Control-FREEC.  See author manual for more details.\n            - `ctrlfreec_config`: Config file used to run Control-FREEC.  Has some useful information on what parameters were used to run the tool.\n            - `ctrlfreec_pngs`: Plots of BAF log2 ratio and ratio of tumor/normal copy number coverage.  Pink line in the middle of ratio plots is the median ratio.\n            - `ctrlfreec_bam_ratio`: BAM ratio text file.  Contain ratio, median ratio (used to inform `ctrlfreec_pval`), CNV estimates, BAF estimate, and genotype estimate.\n            - `ctrlfreec_bam_seg`: In-house generated SEG file based on ratio file.  Provided as a convenience for compatibility with tools that require inputs in legacy microarray format.\n            - `ctrlfreec_baf`: BAF estimations.\n            - `ctrlfreec_info`: Contains useful run time information, like ploidy used for analysis, and window size\n        - CNVkit\n            - `cnvkit_cnr`: Copy number ratio\n            - `cnvkit_cnn_output`: Normal/control sample copy number\n            - `cnvkit_calls`: Tumor/sample copy number\n            - `cnvkit_metrics`: Basic SEG count and call stats\n            - `cnvkit_gainloss`: Per-gene log2 ratio\n            - `cnvkit_seg`: Classic microarray-style SEG file\n            - `theta2_calls`: Purity-adjusted CNVkit copy number calls based on THeTa2 results\n            - `theta2_seg`: Purity-adjusted CNVkit SEG file based on THeTa2 results\n            - `theta2_subclonal_results`: THeTa2 subclone purity results\n            - `theta2_subclonal_cns`: THeTa2 sublone CNS\n            - `theta2_subclone_seg`: THeTa2 subclone SEG file\n        - GATK CNV\n            - `gatk_copy_ratio_segments_tumor`: Called copy-ratio-segments file for the tumor sample. This is a tab-separated values (TSV) file with SAM-style header containing a read group sample name, a sequence dictionary, a row specifying the column headers output by `CallCopyRatioSegments` and the corresponding entry rows.\n            - `gatk_copy_ratio_segments_normal`: Called copy-ratio-segments file for the normal sample. This is a tab-separated values (TSV) file with SAM-style header containing a read group sample name, a sequence dictionary, a row specifying the column headers output by `CallCopyRatioSegments` and the corresponding entry rows.\n            - `gatk_cnv_denoised_tumor_plot`: Denoised-plot file that covers the entire range of the copy ratios\n            - `gatk_cnv_denoised_normal_plot`: Denoised-plot file that covers the entire range of the copy ratios\n            - `gatk_cnv_funcotated_called_file_tumor`: TSV where each row is a segment and the annotations are the covered genes and which genes+exon is overlapped by the segment breakpoints.\n            - `gatk_cnv_funcotated_called_gene_list_file_tumor`: TSV where each row is a gene and the annotations are the covered genes and which genes+exon is overlapped by the segment breakpoints.\n    - ecDNA Prediction\n        - `aa_summary`: Summary for all amplicons detected by AmpliconArchitect\n        - `aa_cycles`: Text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant source) and their copy counts\n        - `aa_graph`: A text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n        - `aa_sv_png`: PNG image file displaying the SV view of AmpliconArchitect\n        - `aa_classification_profiles`: abstract classification of the amplicon\n\n1. Docker images - the workflow tools will automatically pull them, but as a convenience are listed below:\n    - `Strelka2`: pgc-images.sbgenomics.com/d3b-bixu/strelka\n    - `add common fields to Strelka2`: pgc-images.sbgenomics.com/d3b-bixu/add-strelka2-fields:1.0.0\n    - `Mutect2` and `GATK SNV` tools: pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0\n    - `GATK CNV`: broadinstitute/gatk:4.2.4.1\n    - `Lancet`: pgc-images.sbgenomics.com/d3b-bixu/lancet:1.0.7\n    - `VarDict Java`: pgc-images.sbgenomics.com/d3b-bixu/vardict:1.7.0\n    - `Control-FREEC`: images.sbgenomics.com/vojislav_varjacic/control-freec-11-6:v1\n    - `CNVkit`: images.sbgenomics.com/milos_nikolic/cnvkit:0.9.3\n    - `THetA2`: pgc-images.sbgenomics.com/d3b-bixu/theta2:0.7.1\n    - `samtools`: pgc-images.sbgenomics.com/d3b-bixu/samtools:1.9\n    - `Variant Effect Predictor`: ensemblorg/ensembl-vep:release_105.0\n    - `Kids Fist VCF2MAF`: pgc-images.sbgenomics.com/d3b-bixu/kf_vcf2maf:v1.0.3\n    - `Manta`: pgc-images.sbgenomics.com/d3b-bixu/manta:1.4.0\n    - `bcftools` and `vcftools`: pgc-images.sbgenomics.com/d3b-bixu/bvcftools:latest\n    - `annotsv`: pgc-images.sbgenomics.com/d3b-bixu/annotsv:3.1.1\n    - `AmpliconArchitect`: jluebeck/prepareaa:v0.1203.10\n    - `Echtvar`: pgc-images.sbgenomics.com/d3b-bixu/echtvar:0.1.9\n\n1. For highly complex samples, some tools have shown themselves to require memory allocation adjustments:\n   Manta, GATK LearnReadOrientationModel, GATK GetPileupSummaries, GATK FilterMutectCalls and VarDict.\n   Optional inputs exist to expand the memory allocation for these jobs: manta_memory, learnorientation_memory,\n   getpileup_memory, filtermutectcalls_memory, and vardict_ram, respectively.\n   For the java tools (VarDict and GATK), these values represent limits on the memory that can\n   be used for the respective jobs. Tasks will go to these values and not exceed it. They may succeed or fail,\n   but they will not exceed the limit established. The memory allocations for these is hardcapped. The memory\n   allocation option for Manta, conversely, is a soft cap. The memory requested will be allocated for the job\n   on a particular machine but once the task is running on the machine it may exceed that requested value. For example,\n   if Manta's memory allocation is set to 10 GB it will have 10 GB allocated to it at task creation, but, if the\n   task ends up running on a machine with more memory available, the task may use it. Setting a value here for Manta\n   will not prevent Manta from taking more than that value. The memory usage in Manta is limited by the machine hardware.\n   As such the option for Manta memory allocation is described as soft cap. For more information on Manta resource\n   usage see their [documentation](https://github.com/Illumina/manta/blob/master/docs/userGuide/README.md#runtime-hardware-requirements).\n\n1. The optional `b_allele` file can be generated using our [Single Sample Genotyping Workflow](#copy-number-genotype-estimation-using-b-allele-frequency).\n\n## Other Resources\n- dockerfiles: https://github.com/d3b-center/bixtools\n",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "SubworkflowFeatureRequirement"
                },
                {
                    "class": "StepInputExpressionRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "StepInputExpressionRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#aa_data_ref_version/aa_data_ref_version",
                            "symbols": [
                                "#/aa_data_ref_version/aa_data_ref_version/GRCh38",
                                "#/aa_data_ref_version/aa_data_ref_version/hg19",
                                "#/aa_data_ref_version/aa_data_ref_version/GRCh37",
                                "#/aa_data_ref_version/aa_data_ref_version/mm10",
                                "#/aa_data_ref_version/aa_data_ref_version/GRCm38"
                            ]
                        }
                    ],
                    "doc": "Genome version in data repo to use",
                    "default": "GRCh38",
                    "id": "#aa_data_ref_version"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Reference tar ball obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/",
                    "id": "#aa_data_repo",
                    "https://sevenbridges.comsuggestedValue": {
                        "class": "File",
                        "path": "file:///home/ubuntu/volume/ICA/kf-somatic-workflow/workflow/62fcf4d40d34597148589e14",
                        "name": "#aa_data_repo/GRCh38_indexed.tar.gz"
                    }
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "TAR.GZ'd Directory containing annotations for AnnotSV",
                    "id": "#annotsv_annotations_dir_tgz",
                    "https://sevenbridges.comfileTypes": "TAR, TAR.GZ, TGZ",
                    "https://sevenbridges.comsuggestedValue": {
                        "class": "File",
                        "path": "file:///home/ubuntu/volume/ICA/kf-somatic-workflow/workflow/6328ab26d01163633dabcc2e",
                        "name": "#annotsv_annotations_dir_tgz/annotsv_311_plus_ens105_annotations_dir.tgz"
                    }
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": true
                        }
                    ],
                    "doc": "germline calls, needed for BAF.  GATK HC VQSR input recommended.  Tool will prefilter for germline and pass if expression given",
                    "id": "#b_allele"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Will hard filter final result to create a public version",
                    "default": "FILTER=\"PASS\"|INFO/HotSpotAllele=1",
                    "id": "#bcftools_public_filter"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "BED or INTERVALLIST file containing a set of genomic regions to remove from the calling regions for SNV and SV calling.",
                    "id": "#blacklist_regions"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD indel annotations",
                    "id": "#cadd_indels"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD SNV annotations",
                    "id": "#cadd_snvs"
                },
                {
                    "type": "File",
                    "doc": "BED or INTERVALLIST file containing a set of genomic regions over which the callers will be run. For WGS, this should be the wgs_calling_regions.interval_list. For WXS, the user must provide the appropriate regions for their analysis.",
                    "id": "#calling_regions"
                },
                {
                    "type": [
                        "null",
