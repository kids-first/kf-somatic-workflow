                        "null",
                        "File"
                    ],
                    "outputSource": "#/gatk_cnv/funcotated_called_file_tumor",
                    "doc": "TSV where each row is a segment and the annotations are the covered genes and which genes+exon is overlapped by the segment breakpoints.",
                    "id": "#gatk_cnv_funcotated_called_file_tumor"
                },
                {
                    "type": [
                        "null",
