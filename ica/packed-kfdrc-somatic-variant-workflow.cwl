{
    "$graph": [
        {
            "class": "CommandLineTool",
            "id": "#add_strelka2_fields.cwl",
            "doc": "This tool will run a Python script that takes a Strelka2 tumor-normal VCF and adds\n    canonical fields like GT and AD",
            "requirements": [
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/add-strelka2-fields:1.0.0"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${ return inputs.ram * 1000 }",
                    "coresMin": "$(inputs.cores)"
                },
                {
                    "class": "ShellCommandRequirement"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "$(inputs.run_tool_flag ? \">&2 /usr/bin/add_strelka2_fields.py\" : \">&2 echo 'User opted to skip adding fields to vcf' && exit 0;\")"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "id": "#add_strelka2_fields.cwl/cores"
                },
                {
                    "type": "string",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--normal_name"
                    },
                    "id": "#add_strelka2_fields.cwl/normal_name"
                },
                {
                    "type": "string",
                    "inputBinding": {
                        "position": 4,
                        "prefix": "--output_basename"
                    },
                    "id": "#add_strelka2_fields.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "RAM requirement in GB",
                    "id": "#add_strelka2_fields.cwl/ram"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "When run as part of a workflow, can skip",
                    "default": false,
                    "id": "#add_strelka2_fields.cwl/run_tool_flag"
                },
                {
                    "type": "File",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--strelka2_vcf"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#add_strelka2_fields.cwl/strelka2_vcf"
                },
                {
                    "type": "string",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--tumor_name"
                    },
                    "id": "#add_strelka2_fields.cwl/tumor_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.gz",
                        "outputEval": "$( inputs.run_tool_flag ? self : inputs.strelka2_vcf)"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#add_strelka2_fields.cwl/output"
                }
            ],
            "$namespaces": {
                "sbg": "https://sevenbridges.com"
            }
        },
        {
            "class": "CommandLineTool",
            "id": "#bcftools_filter_vcf.cwl",
            "doc": "More generic tool to take in an include expression and optionally an exclude expresssion to filter a vcf",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/bcftools:1.20"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": 8
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entryname": "run_filter.sh",
                            "entry": "#!/usr/bin/env bash\nset -xeo pipefail\n\ncommand=cat\nif [[ $(inputs.sample_name) != null ]]\nthen\n  command=\"bcftools view --threads $(inputs.threads) -s $(inputs.sample_name)\"\nfi\n$command $(inputs.input_vcf.path) \\\n  | bcftools view \\\n    --threads $(inputs.threads) \\\n    -O $(inputs.output_type) \\\n    -o $(inputs.output_basename).bcf_filtered.$(inputs.output_type == \"v\" ? \"vcf\" : inputs.output_type == \"z\" ? \"vcf.gz\" : inputs.output_type == \"b\" ? \"bcf.gz\" : \"bcf\") \\\n    $(inputs.exclude_expression == null ? \"\" : \"--exclude \" + \"'\" + inputs.exclude_expression + \"'\") \\\n    $(inputs.include_expression == null ? \"\" : \"--include \" + \"'\" + inputs.include_expression + \"'\") \\\n    $(inputs.filter_expression == null ? \"\" : \"-f \" + inputs.filter_expression)\nif [[ $(inputs.output_type) == z ]]\nthen\n  tabix $(inputs.output_basename).bcf_filtered.vcf.gz\nfi\n"
                        }
                    ]
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "/bin/bash run_filter.sh"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "See bcftools docs for valid expression. Can't be used at the same time as include_expression.  Use double quotes when a string needs to be quoted",
                    "id": "#bcftools_filter_vcf.cwl/exclude_expression"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Add values from FILTER field to subset on",
                    "id": "#bcftools_filter_vcf.cwl/filter_expression"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "See bcftools docs for valid expression. Can't be used at the same time as exclude_expression. Use double quotes when a string needs to be quoted",
                    "id": "#bcftools_filter_vcf.cwl/include_expression"
                },
                {
                    "type": "File",
                    "id": "#bcftools_filter_vcf.cwl/input_vcf"
                },
                {
                    "type": "string",
                    "id": "#bcftools_filter_vcf.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#bcftools_filter_vcf.cwl/output_type/output_type",
                            "symbols": [
                                "#bcftools_filter_vcf.cwl/output_type/output_type/u",
                                "#bcftools_filter_vcf.cwl/output_type/output_type/b",
                                "#bcftools_filter_vcf.cwl/output_type/output_type/v",
                                "#bcftools_filter_vcf.cwl/output_type/output_type/z"
                            ]
                        }
                    ],
                    "default": "z",
                    "id": "#bcftools_filter_vcf.cwl/output_type"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of samples if user wishes to apply filtering to and output specific samples",
                    "id": "#bcftools_filter_vcf.cwl/sample_name"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 4,
                    "id": "#bcftools_filter_vcf.cwl/threads"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "$(inputs.output_type == \"v\" || inputs.output_type == \"u\" ? \"*.[bv]cf\" : \"*.[bv]cf.gz\")\n"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "id": "#bcftools_filter_vcf.cwl/filtered_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#bcftools_strip_ann.cwl",
            "doc": "Quick tool to strip info from vcf file before re-annotation",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": 8
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/vcfutils:latest"
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-c"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "set -eo pipefail\n(bcftools annotate -x $(inputs.strip_info) $(inputs.input_vcf.path) --threads 8 -O z -o $(inputs.output_basename).$(inputs.tool_name).INFO_stripped.vcf.gz && tabix $(inputs.output_basename).$(inputs.tool_name).INFO_stripped.vcf.gz) || (echo \"Check errors, likely does not have INFO, trying to pass input instead\" >&2; cp $(inputs.input_vcf.path) .; cp $(inputs.input_vcf.secondaryFiles[0].path)  .;)"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#bcftools_strip_ann.cwl/input_vcf"
                },
                {
                    "type": "string",
                    "id": "#bcftools_strip_ann.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "If given, remove previous annotation information based on INFO file, i.e. to strip VEP info, use INFO/ANN",
                    "id": "#bcftools_strip_ann.cwl/strip_info"
                },
                {
                    "type": "string",
                    "id": "#bcftools_strip_ann.cwl/tool_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#bcftools_strip_ann.cwl/stripped_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#echtvar_anno.cwl",
            "doc": "annotate a VCF/BCF with one or more echtvar files",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/echtvar:0.2.0"
                },
                {
                    "class": "ResourceRequirement",
                    "coresMin": "$(inputs.cpu)",
                    "ramMin": "$(inputs.ram * 1000)"
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "echtvar anno"
                },
                {
                    "position": 10,
                    "prefix": "&&",
                    "shellQuote": false,
                    "valueFrom": "bcftools index --threads $(inputs.cpu)"
                },
                {
                    "position": 19,
                    "shellQuote": false,
                    "valueFrom": "$(inputs.output_filename)"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "doc": "CPUs to allocate to this task.",
                    "id": "#echtvar_anno.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--csi"
                    },
                    "doc": "generate CSI-format index for VCF/BCF files [default]",
                    "id": "#echtvar_anno.cwl/csi"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File",
                            "inputBinding": {
                                "prefix": "-e"
                            }
                        }
                    ],
                    "inputBinding": {
                        "position": 2
                    },
                    "doc": "echtvar files to annotate with. can be specified many times",
                    "id": "#echtvar_anno.cwl/echtvar_zips"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--force"
                    },
                    "doc": "overwrite index if it already exists",
                    "id": "#echtvar_anno.cwl/force"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "-i"
                    },
                    "doc": "expression that determines which variants to keep in output",
                    "id": "#echtvar_anno.cwl/include_expression"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        },
                        {
                            "pattern": ".csi",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "position": 8
                    },
                    "doc": "input vcf or bcf",
                    "id": "#echtvar_anno.cwl/input_vcf"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--min-shift"
                    },
                    "doc": "set minimal interval size for CSI indices to 2^INT [14]",
                    "id": "#echtvar_anno.cwl/min_shift"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--nrecords"
                    },
                    "doc": "print number of records based on existing index file",
                    "id": "#echtvar_anno.cwl/nrecords"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "default": "annotated.vcf.gz",
                    "inputBinding": {
                        "position": 9
                    },
                    "doc": "path to bcf/vcf.gz output file (determined by extension)",
                    "id": "#echtvar_anno.cwl/output_filename"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "GB of RAM to allocate to this task.",
                    "id": "#echtvar_anno.cwl/ram"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--stats"
                    },
                    "doc": "print per contig stats based on existing index file",
                    "id": "#echtvar_anno.cwl/stats"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--tbi"
                    },
                    "doc": "generate TBI-format index for VCF files",
                    "id": "#echtvar_anno.cwl/tbi"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        },
                        {
                            "pattern": ".csi",
                            "required": false
                        }
                    ],
                    "outputBinding": {
                        "glob": "$(inputs.output_filename)"
                    },
                    "id": "#echtvar_anno.cwl/annotated_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#gatk_variant_filter.cwl",
            "doc": "Simple tool add a FILTER tag based on criteria",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": 8
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/gatk:4.1.1.0"
                }
            ],
            "baseCommand": [
                "/gatk",
                "VariantFiltration"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "-O $(inputs.output_basename).$(inputs.tool_name).gatk.soft_filtered.vcf.gz ${\n  var args = \"\";\n  for (var i = 0; i < inputs.filter_name.length; i++){\n    args += \"--filter-name \\\"\" + inputs.filter_name[i] + \"\\\" --filter-expression \\\"\" + inputs.filter_expression[i] + \"\\\" \";\n  }\n  return args\n}"
                }
            ],
            "inputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "Array of filter expressions to establish criteria to tag variants with. See https://gatk.broadinstitute.org/hc/en-us/articles/360036730071-VariantFiltration for clues",
                    "id": "#gatk_variant_filter.cwl/filter_expression"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "Array of names for each filter tag to add",
                    "id": "#gatk_variant_filter.cwl/filter_name"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "inputBinding": {
                        "position": 0,
                        "prefix": "-V"
                    },
                    "id": "#gatk_variant_filter.cwl/input_vcf"
                },
                {
                    "type": "string",
                    "id": "#gatk_variant_filter.cwl/output_basename"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.dict",
                            "required": null
                        },
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "inputBinding": {
                        "position": 0,
                        "prefix": "-R"
                    },
                    "id": "#gatk_variant_filter.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of compression/decompression threads",
                    "default": 4,
                    "id": "#gatk_variant_filter.cwl/threads"
                },
                {
                    "type": "string",
                    "id": "#gatk_variant_filter.cwl/tool_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#gatk_variant_filter.cwl/gatk_soft_filtered_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#generic_rename_outputs.cwl",
            "doc": "Simple tool to rename inputs",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": 8
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "${\n    var out = \"renamed/\"\n    var cmd = \"mkdir \" + out + \";\";\n    for (var i = 0; i < inputs.input_files.length; i++) {\n      cmd += \"cp \" + inputs.input_files[i].path + \" \" + out + inputs.rename_to[i] + \";\"\n    }\n    return cmd;\n}"
                }
            ],
            "inputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "doc": "Files to rename",
                    "id": "#generic_rename_outputs.cwl/input_files"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "List of new file names",
                    "id": "#generic_rename_outputs.cwl/rename_to"
                }
            ],
            "outputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "renamed/*.*"
                    },
                    "id": "#generic_rename_outputs.cwl/renamed_files"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#hotspots_annotation.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.ram * 1000)",
                    "coresMin": "$(inputs.cores)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "quay.io/biocontainers/pysam:0.21.0--py310h41dec4a_1"
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entryname": "hotspot.py",
                            "entry": "#!/usr/bin/env python3\n\nimport argparse\nimport csv\nimport gzip\nimport math\nimport os\nimport pysam\nimport re\n\ndef parse_command():\n    \"\"\"Function to parse the command line input\n    Args:\n        None\n    Return:\n        Namespace: returns the args as a standard Namespace object\n    \"\"\"\n    parser = argparse.ArgumentParser(description='Flag HotSpots in VCF using one or more Hotspot File Inputs')\n    required_options = parser.add_argument_group('required arguments')\n    hotspot_options = parser.add_argument_group('hotspot file input arguments')\n    advanced_options = parser.add_argument_group('advanced user arguments')\n    hotspot_options.add_argument('--genomic_hotspots',\n        nargs='*',\n        help=\"Tab-delimited BED-formatted (chrom, zero-based chromStart, non-inclusive chromEnd) file(s) containing hg38 genomic positions corresponding to hotspots\")\n    hotspot_options.add_argument('--protein_snvs',\n        nargs='*',\n        help=\"Column name-labeled, tab-delimited file(s) containing HUGO-formatted protein names and VEP-formatted positions <start_aa_pos> for SNV hotspots\")\n    hotspot_options.add_argument('--protein_indels',\n        nargs='*',\n        help=\"Column name-labeled, tab-delimited file(s) containing HUGO-formatted protein names and VEP-formatted positions <start_aa_pos>-<end_aa_pos> for INDEL hotspots\")\n    required_options.add_argument('--vcf',\n        required=True,\n        help='Input VCF or VCF.GZ file')\n    advanced_options.add_argument('--protein_colname',\n        default='Hugo_Symbol',\n        metavar='Hugo_Symbol',\n        help='Overrides the column name in the protein_hotspots file(s) that contains the protein name information')\n    advanced_options.add_argument('--position_colname',\n        default='Amino_Acid_Position',\n        metavar='Amino_Acid_Position',\n        help='Overrides the column name in the protein_hotspots file(s) that contains the HGVSp short information')\n    advanced_options.add_argument('--csq_field',\n        default='SYMBOL',\n        metavar='SYMBOL',\n        help='Overrides the name of the CSQ field that matches the values found in the protein_colname of the protein_hotspots input(s)')\n    advanced_options.add_argument('--csq_pos',\n        default='HGVSp',\n        choices=['HGVSp', 'Protein_position'],\n        help='Overrides the name of the CSQ field that stores protein position information')\n    advanced_options.add_argument('--csq_allele',\n        default='ALLELE_NUM',\n        metavar='ALLELE_NUM',\n        help='Overrides the name of the CSQ field that stores allele number information')\n    advanced_options.add_argument('--csq_impact',\n        default='IMPACT',\n        metavar='IMPACT',\n        help='Overrides the name of the CSQ field that stores impact information')\n    advanced_options.add_argument('--csq_class',\n        default='VARIANT_CLASS',\n        metavar='VARIANT_CLASS',\n        help='Overrides the name of the CSQ field that stores variant class information')\n    parser.add_argument('--output_basename',\n        help=\"String to use as base name for output file\")\n    args = parser.parse_args()\n    exit = False\n    reasons = []\n    if not args.protein_snvs and not args.protein_indels and not args.genomic_hotspots:\n        exit = True\n        reasons.append(\"Must provide a protein_snvs, protein_indels, or genomic_hotspots file(s)\")\n    if not os.path.isfile(args.vcf):\n        exit = True\n        reasons.append(\"{} is not a file.\".format(args.vcf))\n    if exit:\n        raise FileNotFoundError(\"{}{}\".format(chr(10),chr(10).join(reasons)))\n    if not args.vcf.endswith(\".vcf.gz\") and not args.vcf.endswith(\".vcf\"):\n        raise ValueError(\"{}{} is not a VCF or VCF.GZ\".format(chr(10),args.vcf))\n    else:\n        return args\n\ndef csq_sanity(field,value):\n    \"\"\"Small sanity check for two different feature fields\n    Args:\n        field (str): string denoting the CSQ field\n        value (str): value to compare against the field for sanity\n    Return:\n        str: Info about the CSQ field and hotspot value\n    \"\"\"\n    if (field == \"Gene\" and not value.startswith(\"ENSG\")) or (field == \"Feature\" and not value.startswith(\"ENST\")):\n        return \"CSQ field: {} potentially mismatches hotspot format: {}\".format(field,value)\n    else:\n        return \"CSQ field: {}; Example hotspot: {}\".format(field,value)\n\ndef process_genomic_positions(infile,hs_dict=None):\n    \"\"\"Function to parse a tab-delimited BED file and return a dict of its positions\n    Args:\n        infile (file): BED-formatted tab-delimited file containing hg38 genomic coordinates\n        hs_dict (dict): dict of key: chromosome and value: list of genomic range tuples\n    Return:\n        dict: returns an dict list of key: chromosome and value: list of (chromStart,chromEnd) tuples\n    \"\"\"\n    if hs_dict is None:\n        hs_dict = {}\n    opener = gzip.open if infile.endswith('.gz') else open\n    with opener(infile,'rt') as fh:\n        rd = csv.reader(fh, delimiter=chr(9))\n        for row in rd:\n            if not row: # skip empty rows\n                continue\n            if not row[0].startswith('chr'):\n                continue # skip non-body rows\n            chrom, chromstart, chromend = row[:3]\n            if chrom not in hs_dict:\n                hs_dict[chrom] = []\n            if (chromstart, chromend) not in hs_dict[chrom]:\n                hs_dict[chrom].append((chromstart, chromend))\n    return hs_dict\n\ndef process_protein_and_position(infile,protein_colname=\"Hugo_Symbol\",position_colname=\"Amino_Acid_Position\",variant_class=\"SNV\",hs_dict=None):\n    \"\"\"Function to parse a column-name-labeled, tab-delimited file and return protein names and positions\n    Args:\n        infile (file): Tab-delimited MAF file containing hotspot information\n        protein_colname (string): Name of the column that contains the Hugo Symbol values\n        position_colname (string): Name of the column that contains the positions of protein changes\n        variant_class (string): description of the variants in the infile (SNV or INDEL)\n        hs_dict (dict): dict of key: protein name and values: unique HGVSp short names\n    Return:\n        dict: returns key: protein name and values: unique protein positions\n    \"\"\"\n    if hs_dict is None:\n        hs_dict = {}\n    opener = gzip.open if infile.endswith('.gz') else open\n    with opener(infile,'rt') as fh:\n        rd = csv.reader(fh, delimiter=chr(9))\n        header = []\n        for row in rd:\n            if not row:\n                continue # skip empty rows\n            if row[0].startswith('#'):\n                continue # skip commented rows\n            if not header:\n                header = row\n                continue\n            hugo = row[header.index(protein_colname)]\n            if hugo not in hs_dict:\n                hs_dict[hugo] = {\"splices\":[],\"INDEL\":[],\"SNV\":[]}\n            pos = row[header.index(position_colname)]  # Three different types: solo positions (22), ranges (22-25), hgvsp_shorts (X128_splice)\n            if 'splice' in pos: # handle splice values\n                hs_dict[hugo]['splices'].append(pos)\n            else:\n                m = re.search(r\"^(\\d+|\\?)-?(\\d+|\\?)?$\", pos)\n                aa_start = m[2] if m[1] == '?' else m[1]\n                aa_end = m[2] if m[2] and m[2] != '?' else aa_start\n                aa_range = (int(aa_start),int(aa_end)+1)\n                if aa_range not in hs_dict[hugo][variant_class]:\n                    hs_dict[hugo][variant_class].append(aa_range)\n    return hs_dict\n\ndef create_splice_hgvsp_short(csq_record,csq_items,cons_field=\"Consequence\",cdna_field=\"HGVSc\"):\n    \"\"\"Function that will take a csq_record and the csq_items and return an HGVSp_Short value (minus the leading p.)\n       if it is a splice variant and coding DNA reference sequence.\n    Args:\n        csq_record (str): String containing a single CSQ annotation produced by VEP\n        csq_items (list): List containing the labels for the individual fields of the CSQ annotation\n        cons_field (str): Name of the field in the CSQ where Consequence information can be found\n        cdna_field (str): Name of the field in the CSQ where HGVSc information can be found\n    Return:\n        string: If the record is a coding DNA splice variant, return a modified HGVSp_Short value otherwise return an empty string\n    \"\"\"\n    cons = csq_record.split('|')[csq_items.index(cons_field)]\n    short = '' # Base value to return if we don't meet criteria\n    if \"splice_acceptor_variant\" in cons or \"splice_donor_variant\" in cons: # Only perform on splice variants\n        cdna_pos = csq_record.split('|')[csq_items.index(cdna_field)]\n        m = re.search(r\"c\\.(-?\\d+)\",cdna_pos) # Search for coding DNA reference sequence\n        if m: # If we match\n            cdna_val = max(1, int(m[1])) # Set zero/negative cDNA values (positions in the 5' UTR) to 1\n            pro_val = math.ceil(cdna_val / 3) # Convert cDNA to protein position\n            short = \"X{}_splice\".format(pro_val)\n        elif cdna_pos:\n            print(\"Warning! Could not process HGVSc: {} of CSQ:{}{}{}\".format(cdna_pos,chr(10),chr(9),csq_record))\n        else:\n            print(\"Warning! No HGVSc value in CSQ:{}{}{}\".format(chr(10),chr(9),csq_record))\n    return short\n\ndef interpret_protein_position(pro_pos_key, pro_pos_value):\n    \"\"\"Function that takes the protein position key (field name) and value to determine the AA position start/end of the event.\n    Args:\n        pro_pos_key (str): The name of the field from which pro_pos_value was derived.\n        pro_pos_value (str): The value that contains the relevant protein position information.\n    Return:\n        int: The AA start position (inclusive) of the event or None if not determinable\n        int: The AA end position (inclusive) of the event or None if not determinable\n    \"\"\"\n    pos_start = None\n    pos_end = None\n    if pro_pos_key == \"Protein_position\":\n        pro_pos = pro_pos_value.split('/')[0]\n        m = re.search(r\"^(\\d+|\\?)-?(\\d+|\\?)?$\", pro_pos)\n        if m:\n            pos_start = int(m[2]) if m[1] == '?' else int(m[1])\n            pos_end = int(m[2]) if m[2] and m[2] != '?' else pos_start\n        else:\n            print(\"Warning! Couldn't process position: {} from key: {}\".format(pro_pos_value, pro_pos_key))\n    elif pro_pos_key == \"HGVSp\":\n        m = re.search(\"^[A-Z0-9_.]+:p\\.([A-Z][a-z]{2})(?P<start>[1-9?][0-9]*)_?(?:([A-Z][a-z]{2})(?P<end>[1-9?][0-9]*))?\", pro_pos_value)\n        if m:\n            pos_start = int(m.group('start'))\n            pos_end = int(m.group('end')) if m.group('end') else pos_start\n        else:\n            print(\"Warning! Couldn't process position: {} from key: {}\".format(pro_pos_value, pro_pos_key))\n    else:\n        print(\"Warning! This program is not capable of interpreting proteins from key: {}!\".format(pro_pos_key))\n    return pos_start, pos_end\n\ndef process_vcf(infile,outfile,genomic_hs,hugo_hs,fid,pos='HGVSp',allele='ALLELE_NUM',impact='IMPACT',variant_class='VARIANT_CLASS'):\n    \"\"\"Function to take the input VCF and add INFO annotations for the ALT alleles that correspond to genomic or protein hotspots\n    Args:\n        infile (file): Path to the VCF(.GZ) file\n        outfile (str): String name for the output file that will be made in the fuction\n        genomic_hs (dict): Dict of hg38 genomic coordinate-based hotspots with keys: chrom and values: (chromStart, chromEnd)\n        hugo_hs (dict): Dict of protein-based hotspots with keys: protein name and values: unique lists of HGVSp_short strings\n        fid (str): the name of the CSQ_FIELD that is being used as the ID in the hslist; commonly Hugo Symbols: SYMBOL, Ensembl Gene IDs: Gene, or Ensembl Transcript IDs: Feature\n        pos (str): the name of the CSQ_FIELD that contains the protein position annotation\n        allele (str): the name of the CSQ_FIELD that contains the allele number annotation\n        impact (str): the name of the CSQ_FIELD that contains the impact assessment\n        variant_class (str): the name of the CSQ_FIELD that contains variant class information\n    Return:\n        file: A VCF.GZ file is written to Args.outfile\n        int: total_hotspots_found The total number of hotspot annotations in the file\n    \"\"\"\n    vcfin = pysam.VariantFile(infile)\n    vcfin.header.info.add(\"HotSpotAllele\",'A','Integer',\"Is the corresponding ALT allele on a hotspot (0 for false; 1 for true).\")\n    vcfout = pysam.VariantFile(outfile,'w',header=vcfin.header)\n    csq_items = vcfin.header.info[\"CSQ\"].description.split(' Format: ')[1].split('|')\n    flagged = []\n    total_hotspots_found = 0\n    for rec in vcfin.fetch():\n        genomic_hotspot_found = False\n        if rec.chrom in genomic_hs:\n            for region in genomic_hs[rec.chrom]:\n                region_range = range(int(region[0]),int(region[1]))\n                if sufficient_overlap(range(rec.start,rec.stop),region_range,len(region_range)): # only marking exact matches\n                    flagged.append(\"Chromosome:{} Start:{} End:{}\".format(rec.chrom,region[0],region[1]))\n                    genomic_hotspot_found = True\n                    break\n        if genomic_hotspot_found: # if it's a genomic hotspot it will be a hotspot regardless of the CSQ fields so don't check them\n            total_hotspots_found += len(rec.alts)\n            hotspot_array = [1] * len(rec.alts) # there should only be one alt but set for all\n        else:\n            hotspot_alleles = []\n            for i in rec.info['CSQ']:\n                field_id = i.split('|')[csq_items.index(fid)]\n                imp = i.split('|')[csq_items.index(impact)]\n                if imp == 'LOW': # only check if CSQ is not low impact\n                    continue\n                splice_short = create_splice_hgvsp_short(i,csq_items) # Get HGVSp_Short value for DNA coding splice variants\n                if splice_short: # if we have a splice site we either flag it and break the loop or continue to the next CSQ without checking protein positions\n                    if field_id in hugo_hs and splice_short in hugo_hs[field_id]['splices']:\n                        flagged.append(\"Hugo_Symbol:{} HGVSp_Short:{}\".format(field_id,splice_short))\n                        hotspot_alleles.append(i.split('|')[csq_items.index(allele)])\n                        break\n                    else:\n                        continue\n                protein_pos = i.split('|')[csq_items.index(pos)]\n                if not protein_pos:\n                    continue # No protein position to interpret. Continue to next CSQ\n                protein_start, protein_end = interpret_protein_position(pos, protein_pos)\n                if protein_start is None or protein_end is None:\n                    continue # Protein positions could not be interpreted. Continue to next CSQ\n                protein_range = (protein_start, protein_end + 1) # Convert inclusive to non-inclusive end\n                var_class = i.split('|')[csq_items.index(variant_class)]\n                var_class = 'INDEL' if var_class not in ['SNV', 'substitution'] else 'SNV'\n                if field_id in hugo_hs and protein_range in hugo_hs[field_id][var_class]: # Flag all exact matches\n                    flagged.append(\"Hugo_Symbol:{} AA_Start:{} AA_End:{}\".format(field_id,protein_range[0],protein_range[1]-1)) # remove inclusive end for reporting\n                    hotspot_alleles.append(i.split('|')[csq_items.index(allele)])\n                    break\n                elif var_class == 'INDEL' and field_id in hugo_hs: # Backup check for inexact matches\n                    for r in hugo_hs[field_id][var_class]:\n                        # Single AA varaints must have complete overlap with hotspot region\n                        # Multi AA variants can be off by one (start 1 AA before or end 1 AA after hotspot)\n                        # Erring on the side of caution as HGVSp notation is highly complex\n                        if sufficient_overlap(protein_range, r, max(1, protein_range[1] - protein_range[0] - 1)):\n                            flagged.append(\"Hugo_Symbol:{} AA_Start:{} AA_End:{}\".format(field_id,protein_range[0],protein_range[1]-1))\n                            hotspot_alleles.append(i.split('|')[csq_items.index(allele)])\n                            break\n            hotspot_allele_nums = set(hotspot_alleles)\n            hotspot_array = [0] * len(rec.alts)\n            for i in hotspot_allele_nums:\n                total_hotspots_found += 1\n                hotspot_array[int(i)-1] = 1\n        rec.info[\"HotSpotAllele\"] = tuple(hotspot_array)\n        vcfout.write(rec)\n    if flagged:\n        print(\"#####{}{}HotSpots Annotated:\".format(chr(10),chr(10)))\n        print(chr(10).join(flagged),chr(10))\n    return total_hotspots_found\n\ndef build_output_name(inpath,outbase=None):\n    \"\"\"Builds an VCF.GZ output filename based on the input (VCF/VCF.GZ) name and given output base name\n    Args:\n        inpath (str): Path to the input VCF(.GZ) file\n        outbase (str): Given output base name string\n    Return:\n        str: Filename in the format <output_basename>.<input_nameroot>.hotspots.vcf.gz\n    \"\"\"\n    basename_split = inpath.split('/')[-1].split('.')\n    inroot = basename_split[:basename_split.index('vcf')]\n    if outbase:\n        return outbase + '.' + '.'.join(inroot) + '.hotspots.vcf.gz'\n    else:\n        return '.'.join(inroot) + '.hotspots.vcf.gz'\n\ndef sufficient_overlap(x,y,overlap=2):\n    \"\"\"Function to determine if there is sufficient overlap between two lists\n    Args:\n        x (list): List containing first range\n        y (list): List containing second range\n        overlap (int): Minimum acceptable overlap between the two lists\n    Return:\n        boolean: True if there is sufficient overlap between x and y; False otherwise\n    \"\"\"\n    return len(range(max(x[0], y[0]), min(x[-1], y[-1])+1)) >= overlap\n\ndef main():\n    args = parse_command()\n    genomic_hs = {}\n    if args.genomic_hotspots:\n        for genomic_hotspot_file in args.genomic_hotspots:\n            genomic_hs = process_genomic_positions(genomic_hotspot_file,hs_dict=genomic_hs)\n    hugo_hs = {}\n    if args.protein_snvs:\n        for hugo_hotspot_file in args.protein_snvs:\n            hugo_hs = process_protein_and_position(hugo_hotspot_file,args.protein_colname,args.position_colname,variant_class=\"SNV\",hs_dict=hugo_hs)\n    if args.protein_indels:\n        for hugo_hotspot_file in args.protein_indels:\n            hugo_hs = process_protein_and_position(hugo_hotspot_file,args.protein_colname,args.position_colname,variant_class=\"INDEL\",hs_dict=hugo_hs)\n    output_name = build_output_name(args.vcf,args.output_basename)\n    numhs = process_vcf(args.vcf,output_name,genomic_hs,hugo_hs,args.csq_field,args.csq_pos,args.csq_allele,args.csq_impact,args.csq_class)\n    pysam.tabix_index(output_name, preset=\"vcf\", force=True)\n    print(\"Total Hotspots Annotated: {}\".format(numhs))\n\nif __name__ == '__main__':\n    main()\n"
                        }
                    ]
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "$(inputs.disable_hotspot_annotation ? \">&2 echo 'User elected to skip hotspot annotation' && exit 0;\" : \">&2 python hotspot.py\")"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "doc": "CPU cores to allocate to this task.",
                    "id": "#hotspots_annotation.cwl/cores"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--csq_allele"
                    },
                    "doc": "Overrides the name of the CSQ field that stores allele number information",
                    "id": "#hotspots_annotation.cwl/csq_allele"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--csq_class"
                    },
                    "doc": "Overrides the name of the CSQ field that stores variant class information",
                    "id": "#hotspots_annotation.cwl/csq_class"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--csq_field"
                    },
                    "doc": "Overrides the name of the CSQ field that matches the values found in the protein_colname of the protein_hotspots input(s)",
                    "id": "#hotspots_annotation.cwl/csq_field"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--csq_impact"
                    },
                    "doc": "Overrides the name of the CSQ field that stores impact information",
                    "id": "#hotspots_annotation.cwl/csq_impact"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#hotspots_annotation.cwl/csq_pos/csq_pos",
                            "symbols": [
                                "#hotspots_annotation.cwl/csq_pos/csq_pos/HGVSp",
                                "#hotspots_annotation.cwl/csq_pos/csq_pos/Protein_position"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--csq_pos"
                    },
                    "doc": "Overrides the name of the CSQ field that stores protein position information. Currently capable of processing Protein_position or HGVSp.\n",
                    "id": "#hotspots_annotation.cwl/csq_pos"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Disable Hotspot Annotation and skip this task.",
                    "id": "#hotspots_annotation.cwl/disable_hotspot_annotation"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--genomic_hotspots",
                        "shellQuote": false
                    },
                    "doc": "Tab-delimited BED-formatted (chrom, zero-based chromStart, non-inclusive chromEnd) file(s) containing hg38 genomic positions corresponding to hotspots",
                    "id": "#hotspots_annotation.cwl/genomic_hotspots"
                },
                {
                    "type": "File",
                    "inputBinding": {
                        "position": 99,
                        "prefix": "--vcf",
                        "shellQuote": false
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VCF file to annotate hotspots.",
                    "id": "#hotspots_annotation.cwl/input_vcf"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 10,
                        "prefix": "--output_basename",
                        "shellQuote": false
                    },
                    "doc": "String to use as basename for output file",
                    "id": "#hotspots_annotation.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--position_colname"
                    },
                    "doc": "Overrides the column name in the protein_hotspots file(s) that contains the HGVSp short information",
                    "id": "#hotspots_annotation.cwl/position_colname"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--protein_colname"
                    },
                    "doc": "Overrides the column name in the protein_hotspots file(s) that contains the protein name information",
                    "id": "#hotspots_annotation.cwl/protein_colname"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--protein_indels",
                        "shellQuote": false
                    },
                    "doc": "Column name-labeled, tab-delimited file(s) containing HUGO-formatted protein names and VEP-formatted positions <start_aa_pos> for SNV hotspots",
                    "id": "#hotspots_annotation.cwl/protein_indels"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--protein_snvs",
                        "shellQuote": false
                    },
                    "doc": "Column name-labeled, tab-delimited file(s) containing HUGO-formatted protein names and VEP-formatted positions <start_aa_pos>-<end_aa_pos> for INDEL hotspots",
                    "id": "#hotspots_annotation.cwl/protein_snvs"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "GB of RAM to allocate to this task.",
                    "id": "#hotspots_annotation.cwl/ram"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.gz",
                        "outputEval": "$(inputs.disable_hotspot_annotation ? inputs.input_vcf : self)"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#hotspots_annotation.cwl/hotspots_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#kf_mskcc_vcf2maf.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": 8
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/kf_vcf2maf:v1.0.3"
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entryname": "vcf2maf.pl",
                            "entry": "#!/usr/bin/env perl\n\n# vcf2maf - Convert a VCF into a MAF by mapping each variant to only one of all possible gene isoforms\n\nuse strict;\nuse warnings;\nuse IO::File;\nuse Getopt::Long qw( GetOptions );\nuse Pod::Usage qw( pod2usage );\nuse File::Copy qw( move );\nuse File::Path qw( mkpath );\nuse Config;\nuse Text::Wrap;\n\n# Set any default paths and constants\nmy ( $tumor_id, $normal_id ) = ( \"TUMOR\", \"NORMAL\" );\nmy ( $vep_path, $vep_data, $vep_forks, $buffer_size, $any_allele, $inhibit_vep, $online, $vep_custom, $vep_config, $vep_overwrite  ) = ( \"$ENV{HOME}/miniconda3/bin\", \"$ENV{HOME}/.vep\", 4, 5000, 0, 0, 0, \"\", \"\", 0 );\nmy ( $ref_fasta ) = ( \"$ENV{HOME}/.vep/homo_sapiens/102_GRCh37/Homo_sapiens.GRCh37.dna.toplevel.fa.gz\" );\nmy ( $species, $ncbi_build, $cache_version, $maf_center, $retain_info, $retain_fmt, $retain_ann, $min_hom_vaf, $max_subpop_af ) = ( \"homo_sapiens\", \"GRCh37\", \"\", \".\", \"\", \"\", \"\", 0.7, 0.0004 );\nmy $perl_bin = $Config{perlpath};\n\n# Set default formatting for any output command lines:\n$Text::Wrap::huge = 'overflow';\n$Text::Wrap::separator = \" \\\\$/\";\n\n# Find out if samtools and tabix are properly installed, and warn the user if it's not\nmy ( $samtools ) = map{chomp; $_}`which samtools`;\n( $samtools and -e $samtools ) or die \"ERROR: Please install samtools, and make sure it's in your PATH\\n\";\nmy ( $tabix ) = map{chomp; $_}`which tabix`;\n( $tabix and -e $tabix ) or die \"ERROR: Please install tabix, and make sure it's in your PATH\\n\";\n\n# Hash to convert 3-letter amino-acid codes to their 1-letter codes\nmy %aa3to1 = qw( Ala A Arg R Asn N Asp D Asx B Cys C Glu E Gln Q Glx Z Gly G His H Ile I Leu L\n    Lys K Met M Phe F Pro P Ser S Thr T Trp W Tyr Y Val V Xxx X Ter * );\n\n# Prioritize Sequence Ontology terms in order of severity, as estimated by Ensembl:\n# https://ensembl.org/info/genome/variation/prediction/predicted_data.html\nsub GetEffectPriority {\n    my ( $effect ) = @_;\n    $effect = '' unless( defined $effect );\n    my %effectPriority = (\n        'transcript_ablation' => 1, # A feature ablation whereby the deleted region includes a transcript feature\n        'exon_loss_variant' => 1, # A sequence variant whereby an exon is lost from the transcript\n        'splice_donor_variant' => 2, # A splice variant that changes the 2 base region at the 5' end of an intron\n        'splice_acceptor_variant' => 2, # A splice variant that changes the 2 base region at the 3' end of an intron\n        'stop_gained' => 3, # A sequence variant whereby at least one base of a codon is changed, resulting in a premature stop codon, leading to a shortened transcript\n        'frameshift_variant' => 3, # A sequence variant which causes a disruption of the translational reading frame, because the number of nucleotides inserted or deleted is not a multiple of three\n        'stop_lost' => 3, # A sequence variant where at least one base of the terminator codon (stop) is changed, resulting in an elongated transcript\n        'start_lost' => 4, # A codon variant that changes at least one base of the canonical start codon\n        'initiator_codon_variant' => 4, # A codon variant that changes at least one base of the first codon of a transcript\n        'disruptive_inframe_insertion' => 5, # An inframe increase in cds length that inserts one or more codons into the coding sequence within an existing codon\n        'disruptive_inframe_deletion' => 5, # An inframe decrease in cds length that deletes bases from the coding sequence starting within an existing codon\n        'conservative_inframe_insertion' => 5, # An inframe increase in cds length that inserts one or more codons into the coding sequence between existing codons\n        'conservative_inframe_deletion' => 5, # An inframe decrease in cds length that deletes one or more entire codons from the coding sequence but does not change any remaining codons\n        'inframe_insertion' => 5, # An inframe non synonymous variant that inserts bases into the coding sequence\n        'inframe_deletion' => 5, # An inframe non synonymous variant that deletes bases from the coding sequence\n        'protein_altering_variant' => 5, # A sequence variant which is predicted to change the protein encoded in the coding sequence\n        'missense_variant' => 6, # A sequence variant, that changes one or more bases, resulting in a different amino acid sequence but where the length is preserved\n        'conservative_missense_variant' => 6, # A sequence variant whereby at least one base of a codon is changed resulting in a codon that encodes for a different but similar amino acid. These variants may or may not be deleterious\n        'rare_amino_acid_variant' => 6, # A sequence variant whereby at least one base of a codon encoding a rare amino acid is changed, resulting in a different encoded amino acid\n        'transcript_amplification' => 7, # A feature amplification of a region containing a transcript\n        'splice_region_variant' => 8, # A sequence variant in which a change has occurred within the region of the splice site, either within 1-3 bases of the exon or 3-8 bases of the intron\n        'start_retained_variant' => 9, # A sequence variant where at least one base in the start codon is changed, but the start remains\n        'stop_retained_variant' => 9, # A sequence variant where at least one base in the terminator codon is changed, but the terminator remains\n        'synonymous_variant' => 9, # A sequence variant where there is no resulting change to the encoded amino acid\n        'incomplete_terminal_codon_variant' => 10, # A sequence variant where at least one base of the final codon of an incompletely annotated transcript is changed\n        'coding_sequence_variant' => 11, # A sequence variant that changes the coding sequence\n        'mature_miRNA_variant' => 11, # A transcript variant located with the sequence of the mature miRNA\n        'exon_variant' => 11, # A sequence variant that changes exon sequence\n        '5_prime_UTR_variant' => 12, # A UTR variant of the 5' UTR\n        '5_prime_UTR_premature_start_codon_gain_variant' => 12, # snpEff-specific effect, creating a start codon in 5' UTR\n        '3_prime_UTR_variant' => 12, # A UTR variant of the 3' UTR\n        'non_coding_exon_variant' => 13, # A sequence variant that changes non-coding exon sequence\n        'non_coding_transcript_exon_variant' => 13, # snpEff-specific synonym for non_coding_exon_variant\n        'non_coding_transcript_variant' => 14, # A transcript variant of a non coding RNA gene\n        'nc_transcript_variant' => 14, # A transcript variant of a non coding RNA gene (older alias for non_coding_transcript_variant)\n        'intron_variant' => 14, # A transcript variant occurring within an intron\n        'intragenic_variant' => 14, # A variant that occurs within a gene but falls outside of all transcript features. This occurs when alternate transcripts of a gene do not share overlapping sequence\n        'INTRAGENIC' => 14, # snpEff-specific synonym of intragenic_variant\n        'NMD_transcript_variant' => 15, # A variant in a transcript that is the target of NMD\n        'upstream_gene_variant' => 16, # A sequence variant located 5' of a gene\n        'downstream_gene_variant' => 16, # A sequence variant located 3' of a gene\n        'TFBS_ablation' => 17, # A feature ablation whereby the deleted region includes a transcription factor binding site\n        'TFBS_amplification' => 17, # A feature amplification of a region containing a transcription factor binding site\n        'TF_binding_site_variant' => 17, # A sequence variant located within a transcription factor binding site\n        'regulatory_region_ablation' => 17, # A feature ablation whereby the deleted region includes a regulatory region\n        'regulatory_region_amplification' => 17, # A feature amplification of a region containing a regulatory region\n        'regulatory_region_variant' => 17, # A sequence variant located within a regulatory region\n        'regulatory_region' =>17, # snpEff-specific effect that should really be regulatory_region_variant\n        'feature_elongation' => 18, # A sequence variant that causes the extension of a genomic feature, with regard to the reference sequence\n        'feature_truncation' => 18, # A sequence variant that causes the reduction of a genomic feature, with regard to the reference sequence\n        'intergenic_variant' => 19, # A sequence variant located in the intergenic region, between genes\n        'intergenic_region' => 19, # snpEff-specific effect that should really be intergenic_variant\n        '' => 20\n    );\n    unless( defined $effectPriority{$effect} ) {\n        warn \"WARNING: Unrecognized effect \\\"$effect\\\". Assigning lowest priority!\\n\";\n        return 20;\n    }\n    return $effectPriority{$effect};\n}\n\n# Prioritize the transcript biotypes that variants are annotated to, based on disease significance:\n# All possible biotypes are defined here: https://www.gencodegenes.org/pages/biotypes.html\nsub GetBiotypePriority {\n    my ( $biotype ) = @_;\n    $biotype = '' unless( defined $biotype );\n    my %biotype_priority = (\n        'protein_coding' => 1, # Contains an open reading frame (ORF)\n        'LRG_gene' => 2, # Gene in a \"Locus Reference Genomic\" region known to have disease-related sequence variations\n        'IG_C_gene' => 2, # Immunoglobulin (Ig) variable chain genes imported or annotated according to the IMGT\n        'IG_D_gene' => 2, # Immunoglobulin (Ig) variable chain genes imported or annotated according to the IMGT\n        'IG_J_gene' => 2, # Immunoglobulin (Ig) variable chain genes imported or annotated according to the IMGT\n        'IG_LV_gene' => 2, # Immunoglobulin (Ig) variable chain genes imported or annotated according to the IMGT\n        'IG_V_gene' => 2, # Immunoglobulin (Ig) variable chain genes imported or annotated according to the IMGT\n        'TR_C_gene' => 2, # T-cell receptor (TcR) genes imported or annotated according to the IMGT\n        'TR_D_gene' => 2, # T-cell receptor (TcR) genes imported or annotated according to the IMGT\n        'TR_J_gene' => 2, # T-cell receptor (TcR) genes imported or annotated according to the IMGT\n        'TR_V_gene' => 2, # T-cell receptor (TcR) genes imported or annotated according to the IMGT\n        'miRNA' => 3, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'snRNA' => 3, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'snoRNA' => 3, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'ribozyme' => 3, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'tRNA' => 3, #Added by Y. Boursin\n        'sRNA' => 3, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'scaRNA' => 3, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'rRNA' => 3, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'scRNA' => 3, # Non-coding RNA predicted using sequences from Rfam and miRBase\n        'lincRNA' => 3, # Long, intervening noncoding (linc) RNAs, that can be found in evolutionarily conserved, intergenic regions\n        'lncRNA' => 3, # Replaces 3prime_overlapping_ncRNA, antisense, bidirectional_promoter_lncRNA, lincRNA, macro_lncRNA, non_coding, processed_transcript, sense_intronic and sense_overlapping\n        'bidirectional_promoter_lncrna' => 3, # A non-coding locus that originates from within the promoter region of a protein-coding gene, with transcription proceeding in the opposite direction on the other strand\n        'bidirectional_promoter_lncRNA' => 3, # A non-coding locus that originates from within the promoter region of a protein-coding gene, with transcription proceeding in the opposite direction on the other strand\n        'known_ncrna' => 4,\n        'vaultRNA' => 4, # Short non coding RNA genes that form part of the vault ribonucleoprotein complex\n        'macro_lncRNA' => 4, # unspliced lncRNAs that are several kb in size\n        'Mt_tRNA' => 4, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'Mt_rRNA' => 4, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'antisense' => 5, # Has transcripts that overlap the genomic span (i.e. exon or introns) of a protein-coding locus on the opposite strand\n        'antisense_RNA' => 5, # Alias for antisense (Y. Boursin)\n        'sense_intronic' => 5, # Long non-coding transcript in introns of a coding gene that does not overlap any exons\n        'sense_overlapping' => 5, # Long non-coding transcript that contains a coding gene in its intron on the same strand\n        '3prime_overlapping_ncrna' => 5, # Transcripts where ditag and/or published experimental data strongly supports the existence of short non-coding transcripts transcribed from the 3'UTR\n        '3prime_overlapping_ncRNA' => 5, # Transcripts where ditag and/or published experimental data strongly supports the existence of short non-coding transcripts transcribed from the 3'UTR\n        'misc_RNA' => 5, # Non-coding RNA predicted using sequences from RFAM and miRBase\n        'non_coding' => 5, # Transcript which is known from the literature to not be protein coding\n        'regulatory_region' => 6, # A region of sequence that is involved in the control of a biological process\n        'disrupted_domain' => 6, # Otherwise viable coding region omitted from this alternatively spliced transcript because the splice variation affects a region coding for a protein domain\n        'processed_transcript' => 6, # Doesn't contain an ORF\n        'TEC' => 6, # To be Experimentally Confirmed. This is used for non-spliced EST clusters that have polyA features. This category has been specifically created for the ENCODE project to highlight regions that could indicate the presence of protein coding genes that require experimental validation, either by 5' RACE or RT-PCR to extend the transcripts, or by confirming expression of the putatively-encoded peptide with specific antibodies\n        'TF_binding_site' => 7, # A region of a nucleotide molecule that binds a Transcription Factor or Transcription Factor complex\n        'CTCF_binding_site' =>7, # A transcription factor binding site with consensus sequence CCGCGNGGNGGCAG, bound by CCCTF-binding factor\n        'promoter_flanking_region' => 7, # A region immediately adjacent to a promoter which may or may not contain transcription factor binding sites\n        'enhancer' => 7, # A cis-acting sequence that increases the utilization of (some) eukaryotic promoters, and can function in either orientation and in any location (upstream or downstream) relative to the promoter\n        'promoter' => 7, # A regulatory_region composed of the TSS(s) and binding sites for TF_complexes of the basal transcription machinery\n        'open_chromatin_region' => 7, # A DNA sequence that in the normal state of the chromosome corresponds to an unfolded, un-complexed stretch of double-stranded DNA\n        'retained_intron' => 7, # Alternatively spliced transcript believed to contain intronic sequence relative to other, coding, variants\n        'nonsense_mediated_decay' => 7, # If the coding sequence (following the appropriate reference) of a transcript finishes >50bp from a downstream splice site then it is tagged as NMD. If the variant does not cover the full reference coding sequence then it is annotated as NMD if NMD is unavoidable i.e. no matter what the exon structure of the missing portion is the transcript will be subject to NMD\n        'non_stop_decay' => 7, # Transcripts that have polyA features (including signal) without a prior stop codon in the CDS, i.e. a non-genomic polyA tail attached directly to the CDS without 3' UTR. These transcripts are subject to degradation\n        'ambiguous_orf' => 7, # Transcript believed to be protein coding, but with more than one possible open reading frame\n        'pseudogene' => 8, # Have homology to proteins but generally suffer from a disrupted coding sequence and an active homologous gene can be found at another locus. Sometimes these entries have an intact coding sequence or an open but truncated ORF, in which case there is other evidence used (for example genomic polyA stretches at the 3' end) to classify them as a pseudogene. Can be further classified as one of the following\n        'processed_pseudogene' => 8, # Pseudogene that lack introns and is thought to arise from reverse transcription of mRNA followed by reinsertion of DNA into the genome\n        'polymorphic_pseudogene' => 8, # Pseudogene owing to a SNP/DIP but in other individuals/haplotypes/strains the gene is translated\n        'retrotransposed' => 8, # Pseudogene owing to a reverse transcribed and re-inserted sequence\n        'translated_processed_pseudogene' => 8, # Pseudogenes that have mass spec data suggesting that they are also translated\n        'translated_unprocessed_pseudogene' => 8, # Pseudogenes that have mass spec data suggesting that they are also translated\n        'transcribed_processed_pseudogene' => 8, # Pseudogene where protein homology or genomic structure indicates a pseudogene, but the presence of locus-specific transcripts indicates expression\n        'transcribed_unprocessed_pseudogene' => 8, # Pseudogene where protein homology or genomic structure indicates a pseudogene, but the presence of locus-specific transcripts indicates expression\n        'transcribed_unitary_pseudogene' => 8, #Pseudogene where protein homology or genomic structure indicates a pseudogene, but the presence of locus-specific transcripts indicates expression\n        'unitary_pseudogene' => 8, # A species specific unprocessed pseudogene without a parent gene, as it has an active orthologue in another species\n        'unprocessed_pseudogene' => 8, # Pseudogene that can contain introns since produced by gene duplication\n        'Mt_tRNA_pseudogene' => 8, # Non-coding RNAs predicted to be pseudogenes by the Ensembl pipeline\n        'tRNA_pseudogene' => 8, # Non-coding RNAs predicted to be pseudogenes by the Ensembl pipeline\n        'snoRNA_pseudogene' => 8, # Non-coding RNAs predicted to be pseudogenes by the Ensembl pipeline\n        'snRNA_pseudogene' => 8, # Non-coding RNAs predicted to be pseudogenes by the Ensembl pipeline\n        'scRNA_pseudogene' => 8, # Non-coding RNAs predicted to be pseudogenes by the Ensembl pipeline\n        'rRNA_pseudogene' => 8, # Non-coding RNAs predicted to be pseudogenes by the Ensembl pipeline\n        'misc_RNA_pseudogene' => 8, # Non-coding RNAs predicted to be pseudogenes by the Ensembl pipeline\n        'miRNA_pseudogene' => 8, # Non-coding RNAs predicted to be pseudogenes by the Ensembl pipeline\n        'IG_C_pseudogene' => 8, # Inactivated immunoglobulin gene\n        'IG_D_pseudogene' => 8, # Inactivated immunoglobulin gene\n        'IG_J_pseudogene' => 8, # Inactivated immunoglobulin gene\n        'IG_V_pseudogene' => 8, # Inactivated immunoglobulin gene\n        'TR_J_pseudogene' => 8, # Inactivated immunoglobulin gene\n        'TR_V_pseudogene' => 8, # Inactivated immunoglobulin gene\n        'artifact' => 9, # Used to tag mistakes in the public databases (Ensembl/SwissProt/Trembl)\n        '' => 10\n    );\n    unless( defined $biotype_priority{$biotype} ) {\n        warn \"WARNING: Unrecognized biotype \\\"$biotype\\\". Assigning lowest priority!\\n\";\n        return 10;\n    }\n    return $biotype_priority{$biotype};\n}\n\n# Check for missing or crappy arguments\nunless( @ARGV and $ARGV[0] =~ m/^-/ ) {\n    pod2usage( -verbose => 0, -message => \"$0: Missing or invalid arguments!\\n\", -exitval => 2 );\n}\n\n# Parse options and print usage if there is a syntax error, or if usage was explicitly requested\nmy ( $man, $help, $verbose ) = ( 0, 0, 0 );\nmy ( $input_vcf, $output_maf, $tmp_dir, $custom_enst_file );\nmy ( $vcf_tumor_id, $vcf_normal_id, $remap_chain );\nGetOptions(\n    'help!' => \\$help,\n    'man!' => \\$man,\n    'verbose!' => \\$verbose,\n    'input-vcf=s' => \\$input_vcf,\n    'output-maf=s' => \\$output_maf,\n    'tmp-dir=s' => \\$tmp_dir,\n    'tumor-id=s' => \\$tumor_id,\n    'normal-id=s' => \\$normal_id,\n    'vcf-tumor-id=s' => \\$vcf_tumor_id,\n    'vcf-normal-id=s' => \\$vcf_normal_id,\n    'custom-enst=s' => \\$custom_enst_file,\n    'ref-fasta=s' => \\$ref_fasta,\n    'species=s' => \\$species,\n    'ncbi-build=s' => \\$ncbi_build,\n    'cache-version=s' => \\$cache_version,\n    'maf-center=s' => \\$maf_center,\n    'retain-info=s' => \\$retain_info,\n    'retain-fmt=s' => \\$retain_fmt,\n    'retain-ann=s' => \\$retain_ann,\n    'min-hom-vaf=s' => \\$min_hom_vaf,\n    'remap-chain=s' => \\$remap_chain,\n    'max-subpop-af=f' => \\$max_subpop_af\n) or pod2usage( -verbose => 1, -input => \\*DATA, -exitval => 2 );\npod2usage( -verbose => 1, -input => \\*DATA, -exitval => 0 ) if( $help );\npod2usage( -verbose => 2, -input => \\*DATA, -exitval => 0 ) if( $man );\n\n# Check if required arguments are missing or problematic\n( defined $input_vcf and defined $output_maf ) or die \"ERROR: Both input-vcf and output-maf must be defined!\\n\";\n( -s $input_vcf ) or die \"ERROR: Provided --input-vcf is missing or empty: $input_vcf\\n\";\n( -s $ref_fasta ) or die \"ERROR: Provided --ref-fasta is missing or empty: $ref_fasta\\n\";\n( $input_vcf !~ m/\\.(gz|bz2|bcf)$/ ) or die \"ERROR: Unfortunately, --input-vcf cannot be in a compressed format\\n\";\n\n# Unless specified, assume that the VCF uses the same sample IDs that the MAF will contain\n$vcf_tumor_id = $tumor_id unless( $vcf_tumor_id );\n$vcf_normal_id = $normal_id unless( $vcf_normal_id );\n\n# Load up the custom isoform overrides if provided:\nmy %custom_enst;\nif( $custom_enst_file ) {\n    ( -s $custom_enst_file ) or die \"ERROR: Provided --custom-enst file is missing or empty: $custom_enst_file\\n\";\n    warn \"STATUS: Reading --custom-enst $custom_enst_file...\\n\" if( $verbose );\n    %custom_enst = map{chomp; ( $_, 1 )}`grep -v ^# $custom_enst_file | cut -f1`;\n}\n\n# Create a folder for the intermediate VCFs if user-defined, or default to the input VCF's folder\nif( defined $tmp_dir ) {\n    mkpath( $tmp_dir ) unless( -d $tmp_dir );\n}\nelse {\n    $tmp_dir = substr( $input_vcf, 0, rindex( $input_vcf, \"/\" )) if( $input_vcf =~ m/\\// );\n    $tmp_dir = \".\" unless( $tmp_dir ); # In case the input VCF is in the current working directory\n}\n\n# Also figure out the base name of the input VCF, cuz we'll be naming a lot of files based on that\nmy $input_name = substr( $input_vcf, rindex( $input_vcf, \"/\" ) + 1 );\n$input_name =~ s/(\\.vcf)*$//;\n\n# If the VCF contains SVs, split the breakpoints into separate lines before passing to VEP\nmy ( $split_svs, $var_count ) = ( 0, 0 );\nmy $orig_vcf_fh = IO::File->new( $input_vcf ) or die \"ERROR: Couldn't open --input-vcf: $input_vcf!\\n\";\nmy $split_vcf_fh = IO::File->new( \"$tmp_dir/$input_name.split.vcf\", \"w\" ) or die \"ERROR: Couldn't open VCF: $tmp_dir/$input_name.split.vcf!\\n\";\n\nwarn \"STATUS: Preprocessing $input_vcf: split SV breakpoints before passing to VEP...\\n\" if( $verbose );\n\nwhile( my $line = $orig_vcf_fh->getline ) {\n    # If the file uses Mac OS 9 newlines, quit with an error\n    ( $line !~ m/\\r$/ ) or die \"ERROR: Your VCF uses CR line breaks, which we can't support. Please use LF or CRLF.\\n\";\n\n    if( $line =~ m/^#/ ) {\n        $split_vcf_fh->print( $line ); # Write header lines unchanged\n        next;\n    }\n\n    chomp( $line );\n    ++$var_count;\n    my @cols = split( \"\\t\", $line );\n    my %info = map {( m/=/ ? ( split( /=/, $_, 2 )) : ( $_, \"1\" ))} split( /\\;/, $cols[7] );\n    if( $info{SVTYPE} ){\n        # Remove SVTYPE tag if REF/ALT alleles are defined, or VEP won't report transcript effects\n        if( $cols[3]=~m/^[ACGTN]+$/i and $cols[4]=~m/^[ACGTN,]+$/i ) {\n            $cols[7]=~s/(SVTYPE=\\w+;|;SVTYPE=\\w+|SVTYPE=\\w+)//;\n            $split_vcf_fh->print( join( \"\\t\", @cols ), \"\\n\" );\n        }\n        # For legit SVs except insertions, split them into two separate breakpoint events\n        elsif( $info{SVTYPE}=~m/^(BND|TRA|DEL|DUP|INV)$/ ) {\n            $split_svs = 1;\n            # Don't tell VEP it's an SV, by removing the SVTYPE tag\n            $cols[7]=~s/(SVTYPE=\\w+;|;SVTYPE=\\w+|SVTYPE=\\w+)//;\n            # Rename two SV specific INFO keys to something friendlier\n            $cols[7]=~s/CT=([35]to[35])/Frame=$1/;\n            $cols[7]=~s/SVMETHOD=([\\w.]+)/Method=$1/;\n            $cols[4] = \"<\" . $info{SVTYPE} . \">\";\n            # Fetch the REF allele at the second breakpoint using samtools faidx\n            my $ref2 = `$samtools faidx $ref_fasta $info{CHR2}:$info{END}-$info{END} | grep -v ^\\\\>`;\n            chomp( $ref2 );\n            $split_vcf_fh->print( join( \"\\t\", $info{CHR2}, $info{END}, $cols[2], ( $ref2 ? $ref2 : $cols[3] ), @cols[4..$#cols] ), \"\\n\" );\n            $split_vcf_fh->print( join( \"\\t\", @cols ), \"\\n\" );\n        }\n        $input_vcf = \"$tmp_dir/$input_name.split.vcf\";\n    }\n    else {\n        $split_vcf_fh->print( join( \"\\t\", @cols ), \"\\n\" );\n    }\n}\n$split_vcf_fh->close;\n$orig_vcf_fh->close;\n\n# Delete the split.vcf created above if we didn't find any variants with the SVTYPE tag\nunlink( \"$tmp_dir/$input_name.split.vcf\" ) if( $input_vcf ne \"$tmp_dir/$input_name.split.vcf\" );\n\n\n\n# Before running annotation, let's pull flanking reference bps for each variant to do some checks\nwarn \"STATUS: Pulling flanking reference bps for checks...\\n\" if( $verbose );\nmy $vcf_fh = IO::File->new( $input_vcf ) or die \"ERROR: Couldn't open --input-vcf: $input_vcf!\\n\";\nmy ( %ref_bps, @ref_regions, %uniq_regions, %flanking_bps );\nwhile( my $line = $vcf_fh->getline ) {\n    # Skip header lines, and pull variant loci to pass to samtools later\n    next if( $line =~ m/^#/ );\n    chomp( $line );\n    my ( $chr, $pos, undef, $ref ) = split( \"\\t\", $line );\n    # Create a region that spans the length of the reference allele and 1bp flanks around it\n    my $region = \"$chr:\" . ( $pos - 1 ) . \"-\" . ( $pos + length( $ref ));\n    $ref_bps{$region} = $ref;\n    push( @ref_regions, $region );\n    $uniq_regions{$region} = 1;\n}\n$vcf_fh->close;\n\n# samtools runs faster when passed many loci at a time, but limited to around 125k args, at least\n# on CentOS 6. If there are too many loci, split them into smaller chunks and run separately\nwarn \"STATUS: Splitting loci into smaller chunks to run separately...\\n\" if( $verbose );\nmy ( $lines, @regions_split ) = ( \"\", ());\nmy @regions = keys %uniq_regions;\nmy $chr_prefix_in_use = ( @regions and $regions[0] =~ m/^chr/ ? 1 : 0 );\npush( @regions_split, [ splice( @regions, 0, $buffer_size ) ] ) while @regions;\nmap{ my $region = join( \" \", sort @{$_} ); $lines .= `$samtools faidx $ref_fasta $region` } @regions_split;\nforeach my $line ( grep( length, split( \">\", $lines ))) {\n    # Carefully split this FASTA entry, properly chomping newlines for long indels\n    my ( $region, $bps ) = split( \"\\n\", $line, 2 );\n    $bps =~ s/\\r|\\n//g;\n    if( $bps ){\n        $bps = uc( $bps );\n        $flanking_bps{$region} = $bps;\n    }\n}\n\n# If flanking_bps is entirely empty, then it's most likely that the user chose the wrong ref-fasta\n# Or it's also possible that an outdated samtools was unable to parse the gzipped FASTA files\n# ::NOTE:: If input had no variants, don't break here, so we can continue to create an empty MAF\n( !@regions_split or %flanking_bps ) or die \"ERROR: You're either using an outdated samtools, or --ref-fasta is not the same genome build as your --input-vcf.\";\n\n# For each variant locus and reference allele in the input VCF, report any problems\nwarn \"STATUS: Reporting any problems on variant loci and reference alleles...\\n\" if( $verbose );\nforeach my $region ( @ref_regions ) {\n    my $ref = $ref_bps{$region};\n    my ( $locus ) = map{ my ( $chr, $pos ) = split( \":\" ); ++$pos; \"$chr:$pos\" } split( \"-\", $region );\n    if( !defined $flanking_bps{$region} ) {\n        warn \"WARNING: Couldn't retrieve bps around $locus from reference FASTA: $ref_fasta\\n\";\n    }\n    elsif( $flanking_bps{$region} !~ m/^[ACGTN]+$/ ) {\n        warn \"WARNING: Retrieved invalid bps \" . $flanking_bps{$region} . \" around $locus from reference FASTA: $ref_fasta\\n\";\n    }\n    elsif( $ref ne substr( $flanking_bps{$region}, 1, length( $ref ))) {\n        warn \"WARNING: Reference allele $ref at $locus doesn't match \" .\n            substr( $flanking_bps{$region}, 1, length( $ref )) . \" (flanking bps: \" .\n            $flanking_bps{$region} . \") from reference FASTA: $ref_fasta\\n\";\n    }\n}\n\n# Annotate variants in given VCF to all possible transcripts, unless user requested to skip VEP\nmy $output_vcf = $input_vcf;\n\n# Define default MAF Header (https://wiki.nci.nih.gov/x/eJaPAQ) with our vcf2maf additions\nmy @maf_header = qw(\n    Hugo_Symbol Entrez_Gene_Id Center NCBI_Build Chromosome Start_Position End_Position Strand\n    Variant_Classification Variant_Type Reference_Allele Tumor_Seq_Allele1 Tumor_Seq_Allele2\n    dbSNP_RS dbSNP_Val_Status Tumor_Sample_Barcode Matched_Norm_Sample_Barcode\n    Match_Norm_Seq_Allele1 Match_Norm_Seq_Allele2 Tumor_Validation_Allele1 Tumor_Validation_Allele2\n    Match_Norm_Validation_Allele1 Match_Norm_Validation_Allele2 Verification_Status\n    Validation_Status Mutation_Status Sequencing_Phase Sequence_Source Validation_Method Score\n    BAM_File Sequencer Tumor_Sample_UUID Matched_Norm_Sample_UUID HGVSc HGVSp HGVSp_Short Transcript_ID\n    Exon_Number t_depth t_ref_count t_alt_count n_depth n_ref_count n_alt_count all_effects\n);\n\n# Add extra annotation columns to the MAF in a consistent order\nmy @ann_cols = qw( Allele Gene Feature Feature_type Consequence cDNA_position CDS_position\n    Protein_position Amino_acids Codons Existing_variation ALLELE_NUM DISTANCE STRAND_VEP SYMBOL\n    SYMBOL_SOURCE HGNC_ID BIOTYPE CANONICAL CCDS ENSP SWISSPROT TREMBL UNIPARC RefSeq SIFT PolyPhen\n    EXON INTRON DOMAINS AF AFR_AF AMR_AF ASN_AF EAS_AF EUR_AF SAS_AF AA_AF EA_AF CLIN_SIG SOMATIC\n    PUBMED MOTIF_NAME MOTIF_POS HIGH_INF_POS MOTIF_SCORE_CHANGE IMPACT PICK VARIANT_CLASS TSL\n    HGVS_OFFSET PHENO MINIMISED GENE_PHENO FILTER flanking_bps vcf_id vcf_qual gnomAD_AF gnomAD_AFR_AF\n    gnomAD_AMR_AF gnomAD_ASJ_AF gnomAD_EAS_AF gnomAD_FIN_AF gnomAD_NFE_AF gnomAD_OTH_AF gnomAD_SAS_AF );\n\n# push any requested custom VEP annotations from the CSQ/ANN section into @ann_cols\nif ($retain_ann) {\n    push @ann_cols, split(',',$retain_ann);\n}\nmy @ann_cols_format; # To store the actual order of VEP data, that may differ between runs\npush( @maf_header, @ann_cols );\n\n# Add original VCF POS column header\npush( @maf_header, \"vcf_pos\" );\n\n# If the user has INFO fields they want to retain, create additional columns for those\nmy @addl_info_cols = ();\nif( $retain_info or $remap_chain or $split_svs ) {\n    # But let's not overwrite existing columns with the same name\n    my %maf_cols = map{ my $c = lc; ( $c, 1 )} @maf_header;\n    @addl_info_cols = grep{ my $c = lc; !$maf_cols{$c}} split( \",\", $retain_info );\n    # If a remap-chain was used, add a column to retain the original chr:pos:ref:alt\n    push( @addl_info_cols, \"REMAPPED_POS\" ) if( $remap_chain );\n    # If we had to split some SVs earlier, add some columns with some useful info about SVs\n    push( @addl_info_cols, qw( Fusion Method Frame CONSENSUS )) if( $split_svs );\n    push( @maf_header, @addl_info_cols );\n}\n\n# If the user has FORMAT fields they want to retain, create additional columns for those\nmy @addl_fmt_cols = ();\nif( $retain_fmt ) {\n    foreach my $fmt_tag ( split( \",\", $retain_fmt )) {\n        # Create 2 columns for tumor/normal, except if a column name is already used\n        my ( $tc, $nc ) = ( \"t_$fmt_tag\", \"n_$fmt_tag\" );\n        my %maf_cols = map{ my $c = lc; ( $c, 1 ) } @maf_header;\n        if(!$maf_cols{lc($tc)}) { push (@addl_fmt_cols, $tc); }\n        if(!$maf_cols{lc($nc)}) { push (@addl_fmt_cols, $nc); }\n    }\n    push( @maf_header, @addl_fmt_cols );\n}\n\n# Locate and load the file mapping ENSG IDs to Entrez IDs\nmy ( $script_dir ) = $0 =~ m/^(.*)\\/vcf2maf/;\n$script_dir = \".\" unless( $script_dir );\n\nmy $entrez_id_file = \"$script_dir/data/ensg_to_entrez_id_map_ensembl_feb2014.tsv\";\nmy %entrez_id_map = ();\nif( -s $entrez_id_file ) {\n    %entrez_id_map = map{chomp; split(\"\\t\")} `grep -hv ^# $entrez_id_file`;\n}\n\n# Parse through each variant in the annotated VCF, pull out CSQ/ANN from the INFO column, and choose\n# one transcript per variant whose annotation will be used in the MAF\nwarn \"STATUS: Parsing variants in annotated VCF...\\n\" if( $verbose );\nmy $maf_fh = IO::File->new( $output_maf, \">\" ) or die \"ERROR: Couldn't open --output-maf: $output_maf!\\n\";\n$maf_fh->print( \"#version 2.4\\n\" . join( \"\\t\", @maf_header ), \"\\n\" ); # Print MAF header\n( -s $output_vcf ) or exit; # Warnings on this were printed earlier, but quit here, only after a blank MAF is created\nmy $annotated_vcf_fh = IO::File->new( $output_vcf ) or die \"ERROR: Couldn't open annotated VCF: $output_vcf!\\n\";\nmy ( $vcf_tumor_idx, $vcf_normal_idx, %sv_pair );\nwhile( my $line = $annotated_vcf_fh->getline ) {\n\n    # Parse out the VEP CSQ/ANN format, which seems to differ between runs\n    if( $line =~ m/^##INFO=<ID=(CSQ|ANN).*: '?([^\"']+)[\"']/ ) {\n        # Use this as the expected column order of VEP annotation, unless we already got it from CSQ\n        @ann_cols_format = map{s/\\s//g; $_} split( /\\|/, $2 ) unless( @ann_cols_format and $1 eq \"ANN\" );\n    }\n    # Skip all other header lines\n    next if( $line =~ m/^##/ );\n\n    chomp( $line );\n    my ( $chrom, $pos, $var_id, $ref, $alt, $var_qual, $filter, $info_line, $format_line, @rest ) = split( \"\\t\", $line );\n\n    # Set ID, QUAL, and FILTER to \".\" unless defined and non-empty\n    $var_id = \".\" unless( defined $var_id and $var_id ne \"\" );\n    $var_qual = \".\" unless( defined $var_qual and $var_qual ne \"\" );\n    $filter = \".\" unless( defined $filter and $filter ne \"\" );\n\n    # If FORMATted genotype fields are available, find the sample with the variant, and matched normal\n    if( $line =~ m/^#CHROM/ ) {\n        if( $format_line and scalar( @rest ) > 0 ) {\n            for( my $i = 0; $i <= $#rest; ++$i ) {\n                $vcf_tumor_idx = $i if( $rest[$i] eq $vcf_tumor_id );\n                $vcf_normal_idx = $i if( $rest[$i] eq $vcf_normal_id );\n            }\n            ( defined $vcf_tumor_idx ) or warn \"WARNING: No genotype column for $vcf_tumor_id in VCF!\\n\";\n            ( defined $vcf_normal_idx ) or warn \"WARNING: No genotype column for $vcf_normal_id in VCF!\\n\";\n        }\n        next;\n    }\n\n    # Parse out the data in the info column, and store into a hash\n    my %info = map {( $_, \"1\" )} grep { !m/=/ } split( /\\;/, $info_line );\n    map { my ( $key, $val ) = split( /=/, $_, 2 ); $info{$key} .= ( $info{$key} ? \",$val\" : $val ) unless( $info{$key} and grep { /^$val$/ } split( \",\", $info{$key} ))} grep { m/=/ } split( /\\;/, $info_line );\n\n    # By default, the variant allele is the first (usually the only) allele listed under ALT. If\n    # there are >1 alleles in ALT, choose the first non-REF allele listed under tumor GT, that is\n    # also not seen under normal GT. If tumor GT is undefined or ambiguous, choose the tumor allele\n    # with the most supporting read depth, if available.\n    my @alleles = ( $ref, split( /,/, $alt ));\n    my $var_allele_idx = 1;\n\n    # Parse out info from the normal genotype field\n    my ( %nrm_info, @nrm_depths );\n    if( defined $vcf_normal_idx ) {\n        my @format_keys = split( /\\:/, $format_line );\n        my $idx = 0;\n        %nrm_info = map {( $format_keys[$idx++], $_ )} split( /\\:/, $rest[$vcf_normal_idx] );\n    }\n\n    # Parse out info from the tumor genotype field\n    my ( %tum_info, @tum_depths );\n    if( defined $vcf_tumor_idx ) {\n        my @format_keys = split( /\\:/, $format_line );\n        my $idx = 0;\n        %tum_info = map {( $format_keys[$idx++], $_ )} split( /\\:/, $rest[$vcf_tumor_idx] );\n\n        # If possible, parse the tumor genotype to identify the variant allele\n        if( defined $tum_info{GT} and $tum_info{GT} ne \".\" and $tum_info{GT} ne \"./.\" ) {\n            my @tum_gt = split( /[\\/|]/, $tum_info{GT} );\n            # Default to the first non-REF allele seen in tumor GT\n            ( $var_allele_idx ) = grep {$_ ne \"0\"} @tum_gt;\n            # If possible, choose the first non-REF tumor allele that is also not in normal GT\n            if( defined $nrm_info{GT} and $nrm_info{GT} ne \".\" and $nrm_info{GT} ne \"./.\" ) {\n                my %nrm_gt = map {( $_, 1 )} split( /[\\/|]/, $nrm_info{GT} );\n                ( $var_allele_idx ) = grep {$_ ne \"0\" and !$nrm_gt{$_}} @tum_gt;\n            }\n            # If GT was unhelpful, default to the first ALT allele and set GT to undefined\n            if( !defined $var_allele_idx or $var_allele_idx !~ m/^\\d+$/ or $var_allele_idx >= scalar( @alleles )) {\n                $var_allele_idx = 1;\n                $tum_info{GT} = \"./.\";\n            }\n        }\n\n        # Standardize tumor AD and DP based on data in the genotype fields\n        FixAlleleDepths( \\@alleles, $var_allele_idx, \\%tum_info );\n        @tum_depths = split( \",\", $tum_info{AD} );\n\n        # If genotype is undefined, use the allele depths collected to choose the major variant allele\n        unless( defined $tum_info{GT} and $tum_info{GT} ne '.' and $tum_info{GT} ne \"./.\" ) {\n            # The first depth listed belongs to the reference allele. Of the rest, find the largest\n            for( my $i = 1; $i <= $#tum_depths; ++$i ) {\n                $var_allele_idx = $i if( $tum_depths[$i] and $tum_depths[$i] > $tum_depths[$var_allele_idx] );\n            }\n            $tum_info{GT} = \"./.\";\n            if( defined $tum_info{DP} and $tum_info{DP} ne '.' and $tum_info{DP} != 0 and defined $tum_depths[$var_allele_idx] ) {\n                my $vaf = $tum_depths[$var_allele_idx] / $tum_info{DP};\n                $tum_info{GT} = ( $vaf < $min_hom_vaf ? \"0/1\" : \"1/1\" );\n            }\n        }\n    }\n\n    # Set the variant allele to whatever we selected above\n    my $var = $alleles[$var_allele_idx];\n\n    # Standardize normal AD and DP based on data in the genotype fields\n    if( defined $vcf_normal_idx ) {\n        FixAlleleDepths( \\@alleles, $var_allele_idx, \\%nrm_info );\n        @nrm_depths = split( \",\", $nrm_info{AD} );\n        $nrm_info{GT} = \"./.\" unless( defined $nrm_info{GT} and $nrm_info{GT} ne '.' );\n    }\n\n    # Figure out the appropriate start/stop loci and variant type/allele to report in the MAF\n    my $start = my $stop = my $var_type = my $inframe = \"\";\n    my ( $ref_length, $var_length ) = ( length( $ref ), length( $var ));\n    # Backup the VCF-style position and REF/ALT alleles, so we can use it later\n    my ( $vcf_pos, $vcf_ref, $vcf_var ) = ( $pos, $ref, $var );\n    # Remove any prefixed reference bps from all alleles, using \"-\" for simple indels\n    while( $ref and $var and substr( $ref, 0, 1 ) eq substr( $var, 0, 1 ) and $ref ne $var ) {\n        ( $ref, $var, @alleles ) = map{$_ = substr( $_, 1 ); ( $_ ? $_ : \"-\" )} ( $ref, $var, @alleles );\n        --$ref_length; --$var_length; ++$pos;\n    }\n    # Handle SNPs, DNPs, TNPs, or anything larger (ONP)\n    if( $ref_length == $var_length ) {\n        ( $start, $stop ) = ( $pos, $pos + $var_length - 1 );\n        my %np_type = qw( 1 SNP 2 DNP 3 TNP );\n        $var_type = ( $var_length > 3 ? \"ONP\" : $np_type{$var_length} );\n    }\n    # Handle all indels, including those complex ones which contain substitutions\n    elsif( $ref_length != $var_length ) {\n        if( $ref_length < $var_length ) { # Handle insertions, and the special case for complex ones\n            ( $start, $stop ) = (( $ref eq \"-\" ? $pos - 1 : $pos ), ( $ref eq \"-\" ? $pos : $pos + $ref_length - 1 ));\n            $var_type = \"INS\";\n        }\n        else { # Handle deletions\n            ( $start, $stop ) = ( $pos, $pos + $ref_length - 1 );\n            $var_type = \"DEL\";\n        }\n        $inframe = ( abs( $ref_length - $var_length ) % 3 == 0 ? 1 : 0 );\n    }\n\n    my @all_effects; # A list of effects of this variant on all possible transcripts\n    my $maf_effect; # A single effect per variant to report in the standard MAF columns\n    my %maf_line = map{( $_, '' )} @maf_header; # Initialize MAF fields with blank strings\n\n    # VEP provides a comma-delimited list of consequences, with pipe-delim details per consequence\n    # It replaces ',' in details with '&'. We'll assume that all '&'s we see, were formerly commas\n    # \"Consequence\" might list multiple effects on the same transcript e.g. missense,splice_region\n    if( $info{CSQ} or $info{ANN} ) {\n\n        my $ann_lines = ( $info{CSQ} ? $info{CSQ} : $info{ANN} );\n        foreach my $ann_line ( split( /,/, $ann_lines )) {\n            my $idx = 0;\n            my %effect = map{s/\\&/,/g; ( $ann_cols_format[$idx++], ( defined $_ ? $_ : '' ))} split( /\\|/, $ann_line );\n\n            # Remove transcript ID from HGVS codon/protein changes, to make it easier on the eye\n            $effect{HGVSc} =~ s/^.*:// if( $effect{HGVSc} );\n            $effect{HGVSp} =~ s/^.*:// if( $effect{HGVSp} );\n\n            # Remove the prefixed HGVSc code in HGVSp, if found\n            $effect{HGVSp} =~ s/^.*\\((p\\.\\S+)\\)/$1/ if( $effect{HGVSp} and $effect{HGVSp} =~ m/^c\\./ );\n\n            # Sort consequences by decreasing order of severity, and pick the most severe one\n            $effect{Consequence} = join( \",\", sort { GetEffectPriority($a) <=> GetEffectPriority($b) } split( \",\", $effect{Consequence} ));\n            ( $effect{One_Consequence} ) = split( \",\", $effect{Consequence} );\n\n            # When VEP fails to provide any value in Consequence, tag it as an intergenic variant\n            $effect{One_Consequence} = \"intergenic_variant\" unless( $effect{Consequence} );\n\n            # Create a shorter HGVS protein format using 1-letter codes\n            if( $effect{HGVSp} ) {\n                my $hgvs_p_short = $effect{HGVSp};\n                while( $hgvs_p_short and my ( $find, $replace ) = each %aa3to1 ) {\n                    eval \"\\$hgvs_p_short =~ s{$find}{$replace}g\";\n                }\n                $effect{HGVSp_Short} = $hgvs_p_short;\n            }\n\n            # Fix HGVSp_Short, CDS_position, and Protein_position for splice acceptor/donor variants\n            if( $effect{One_Consequence} =~ m/^(splice_acceptor_variant|splice_donor_variant)$/ ) {\n                my ( $c_pos ) = $effect{HGVSc} =~ m/^c.(\\d+)/;\n                if( defined $c_pos ) {\n                    $c_pos = 1 if( $c_pos < 1 ); # Handle negative cDNA positions used in 5' UTRs\n                    my $p_pos = sprintf( \"%.0f\", ( $c_pos + $c_pos % 3 ) / 3 );\n                    $effect{HGVSp_Short} = \"p.X\" . $p_pos . \"_splice\";\n                    $effect{CDS_position} =~ s/^-(\\/\\d+)$/$c_pos$1/ if( $effect{CDS_position} );\n                    $effect{Protein_position} =~ s/^-(\\/\\d+)$/$p_pos$1/ if( $effect{Protein_position} )\n                }\n            }\n\n            # Fix HGVSp_Short for Silent mutations, so it mentions the amino-acid and position\n            if( defined $effect{HGVSp_Short} and $effect{HGVSp_Short} eq \"p.=\" ) {\n                my ( $p_pos ) = $effect{Protein_position} =~ m/^(\\d+)(-\\d+)?\\/\\d+$/;\n                my $aa = $effect{Amino_acids};\n                $effect{HGVSp_Short} = \"p.$aa\" . $p_pos . \"=\";\n            }\n\n            # Copy VEP data into MAF fields that don't share the same identifier\n            $effect{Transcript_ID} = $effect{Feature};\n            $effect{Exon_Number} = $effect{EXON};\n            $effect{Hugo_Symbol} = ( $effect{SYMBOL} ? $effect{SYMBOL} : '' );\n\n            # If AF columns from the older VEP are found, rename to the newer ones for consistency\n            my %af_col = qw( GMAF AF AFR_MAF AFR_AF AMR_MAF AMR_AF ASN_MAF ASN_AF EAS_MAF EAS_AF\n                EUR_MAF EUR_AF SAS_MAF SAS_AF AA_MAF AA_AF EA_MAF EA_AF );\n            map { $effect{$af_col{$_}} = $effect{$_} if( defined $effect{$_} )} keys %af_col;\n\n            # If VEP couldn't find this variant in dbSNP/COSMIC/etc., we'll say it's \"novel\"\n            if( $effect{Existing_variation} ) {\n                # ::NOTE:: If seen in a DB other than dbSNP, this field will remain blank\n                $effect{dbSNP_RS} = join( \",\", grep{m/^rs\\d+$/} split( /,/, $effect{Existing_variation} ));\n            }\n            else {\n                $effect{dbSNP_RS} = \"novel\";\n            }\n\n            # Transcript_Length isn't separately reported, but can be parsed out from cDNA_position\n            ( $effect{Transcript_Length} ) = $effect{cDNA_position} =~ m/\\/(\\d+)$/ if( $effect{cDNA_position} );\n            $effect{Transcript_Length} = 0 unless( defined $effect{Transcript_Length} );\n\n            # Skip effects on other ALT alleles. If ALLELE_NUM is undefined (e.g. for INFO:SVTYPE), don't skip any\n            push( @all_effects, \\%effect ) unless( $effect{ALLELE_NUM} and $effect{ALLELE_NUM} != $var_allele_idx );\n        }\n\n        # Sort effects first by transcript biotype, then by severity, and then by longest transcript\n        @all_effects = sort {\n            GetBiotypePriority( $a->{BIOTYPE} ) <=> GetBiotypePriority( $b->{BIOTYPE} ) ||\n            GetEffectPriority( $a->{One_Consequence} ) <=> GetEffectPriority( $b->{One_Consequence} ) ||\n            $b->{Transcript_Length} <=> $a->{Transcript_Length}\n        } @all_effects;\n\n        # Find the highest priority effect with a gene symbol i.e. the worst affected gene\n        my ( $effect_with_gene_name ) = grep { $_->{SYMBOL} } @all_effects;\n        my $maf_gene = $effect_with_gene_name->{SYMBOL} if( $effect_with_gene_name );\n\n        # If that gene has a user-preferred isoform, report the effect on that isoform\n        ( $maf_effect ) = grep { $_->{SYMBOL} and $_->{SYMBOL} eq $maf_gene and $_->{Transcript_ID} and $custom_enst{$_->{Transcript_ID}} } @all_effects;\n\n        # If that gene has no user-preferred isoform, then use the VEP-preferred (canonical) isoform\n        ( $maf_effect ) = grep { $_->{SYMBOL} and $_->{SYMBOL} eq $maf_gene and $_->{CANONICAL} and $_->{CANONICAL} eq \"YES\" } @all_effects unless( $maf_effect );\n\n        # If that gene has no VEP-preferred isoform either, then choose the worst affected user-preferred isoform with a gene symbol\n        ( $maf_effect ) = grep { $_->{SYMBOL} and $_->{Transcript_ID} and $custom_enst{$_->{Transcript_ID}} } @all_effects unless( $maf_effect );\n\n        # If none of the isoforms are user-preferred, then choose the worst affected VEP-preferred isoform with a gene symbol\n        ( $maf_effect ) = grep { $_->{SYMBOL} and $_->{CANONICAL} and $_->{CANONICAL} eq \"YES\" } @all_effects unless( $maf_effect );\n\n        # If we still have nothing selected, then just report the worst effect\n        $maf_effect = $all_effects[0] unless( $maf_effect );\n    }\n\n    # Construct the MAF columns from the $maf_effect hash\n    %maf_line = map{( $_, ( $maf_effect->{$_} ? $maf_effect->{$_} : '' ))} @maf_header;\n    $maf_line{Hugo_Symbol} = $maf_effect->{Transcript_ID} unless( $maf_effect->{Hugo_Symbol} );\n    $maf_line{Hugo_Symbol} = 'Unknown' unless( $maf_effect->{Transcript_ID} );\n    $maf_line{Entrez_Gene_Id} = ( defined $maf_effect->{Gene} && defined $entrez_id_map{$maf_effect->{Gene}} ? $entrez_id_map{$maf_effect->{Gene}} : \"0\" );\n    $maf_line{Center} = $maf_center;\n    $maf_line{NCBI_Build} = $ncbi_build;\n    $maf_line{Chromosome} = $chrom;\n    $maf_line{Start_Position} = $start;\n    $maf_line{End_Position} = $stop;\n    $maf_line{Strand} = '+'; # Per MAF definition, only the positive strand is an accepted value\n    $maf_line{STRAND_VEP} = $maf_effect->{STRAND}; # Renamed to avoid mixup with \"Strand\" above\n    $maf_line{Variant_Classification} = GetVariantClassification( $maf_effect->{One_Consequence}, $var_type, $inframe );\n    $maf_line{Variant_Type} = $var_type;\n    $maf_line{Reference_Allele} = $ref;\n    # ::NOTE:: If tumor genotype is unavailable, then we'll assume it's ref/var heterozygous\n    $maf_line{Tumor_Seq_Allele1} = $ref;\n    $maf_line{Tumor_Seq_Allele2} = $var;\n    if( defined $tum_info{GT} and $tum_info{GT} ne \".\" and $tum_info{GT} ne \"./.\" ) {\n        # ::NOTE:: MAF only supports biallelic sites. Tumor_Seq_Allele2 must always be the $var\n        # picked earlier. For Tumor_Seq_Allele1, pick the first non-var allele in GT (usually $ref)\n        my ( $idx1, $idx2 ) = split( /[\\/|]/, $tum_info{GT} );\n        # If GT was monoploid, then $idx2 will be undefined, and we should set it equal to $idx1\n        $idx2 = $idx1 unless( defined $idx2 );\n        $maf_line{Tumor_Seq_Allele1} = ( $alleles[$idx1] ne $var ? $alleles[$idx1] : $alleles[$idx2] );\n    }\n    # ::NOTE:: If normal genotype is unavailable, then we'll assume it's ref/ref homozygous\n    $maf_line{Match_Norm_Seq_Allele1} = $ref;\n    $maf_line{Match_Norm_Seq_Allele2} = $ref;\n    if( defined $nrm_info{GT} and $nrm_info{GT} ne \".\" and $nrm_info{GT} ne \"./.\" ) {\n        # ::NOTE:: MAF only supports biallelic sites. So choose the first two alleles listed in GT\n        my ( $idx1, $idx2 ) = split( /[\\/|]/, $nrm_info{GT} );\n        # If GT was monoploid, then $idx2 will be undefined, and we should set it equal to $idx1\n        $idx2 = $idx1 unless( defined $idx2 );\n        $maf_line{Match_Norm_Seq_Allele1} = $alleles[$idx1];\n        $maf_line{Match_Norm_Seq_Allele2} = $alleles[$idx2];\n    }\n    $maf_line{Tumor_Sample_Barcode} = $tumor_id;\n    $maf_line{Matched_Norm_Sample_Barcode} = $normal_id;\n    $maf_line{t_depth} = $tum_info{DP} if( defined $tum_info{DP} and $tum_info{DP} ne \".\" );\n    ( $maf_line{t_ref_count}, $maf_line{t_alt_count} ) = @tum_depths[0,$var_allele_idx] if( @tum_depths );\n    $maf_line{n_depth} = $nrm_info{DP} if( defined $nrm_info{DP} and $nrm_info{DP} ne \".\" );\n    ( $maf_line{n_ref_count}, $maf_line{n_alt_count} ) = @nrm_depths[0,$var_allele_idx] if( @nrm_depths );\n\n    # Create a semicolon delimited list summarizing the prioritized effects in @all_effects\n    $maf_line{all_effects} = \"\";\n    foreach my $effect ( @all_effects ) {\n        my $gene_name = $effect->{Hugo_Symbol};\n        my $effect_type = $effect->{One_Consequence};\n        my $protein_change = ( $effect->{HGVSp} ? $effect->{HGVSp} : '' );\n        my $transcript_id = ( $effect->{Transcript_ID} ? $effect->{Transcript_ID} : '' );\n        my $refseq_ids = ( $effect->{RefSeq} ? $effect->{RefSeq} : '' );\n        $maf_line{all_effects} .= \"$gene_name,$effect_type,$protein_change,$transcript_id,$refseq_ids;\" if( $effect_type and $transcript_id );\n    }\n\n    # Copy FILTER from input VCF, and tag calls with high allele freq in any gnomAD subpopulation\n    my $subpop_count = 0;\n    foreach my $subpop ( qw( AFR AMR ASJ EAS FIN NFE SAS )) {\n        if( $maf_line{\"gnomAD_$subpop\\_AF\"} ) {\n            my ( $subpop_af ) = split( \"/\", $maf_line{\"gnomAD_$subpop\\_AF\"} );\n            $subpop_count++ if( $subpop_af > $max_subpop_af );\n        }\n    }\n    # Remove existing common_variant tags from input, so it's redefined by this new criteria\n    $filter = join( \";\", grep{ $_ ne \"common_variant\" } split( /,|;/, $filter ));\n    if( $subpop_count > 0 ) {\n        $filter = (( $filter eq \"PASS\" or $filter eq \".\" or !$filter ) ? \"common_variant\" : \"$filter;common_variant\" );\n    }\n    $maf_line{FILTER} = $filter;\n\n    # Also add the reference allele flanking bps that we generated earlier with samtools\n    my $region = \"$chrom:\" . ( $vcf_pos - 1 ) . \"-\" . ( $vcf_pos + length( $vcf_ref ));\n    $maf_line{flanking_bps} = $flanking_bps{$region};\n\n    # Add ID and QUAL from the input VCF into respective MAF columns\n    $maf_line{vcf_id} = $var_id;\n    $maf_line{vcf_qual} = $var_qual;\n\n    # Add original VCF POS column\n    $maf_line{vcf_pos} = $vcf_pos;\n\n    # If there are additional INFO data to add, then add those\n    foreach my $info_col ( @addl_info_cols ) {\n        $maf_line{$info_col} = ( defined $info{$info_col} ? $info{$info_col} : \"\" );\n    }\n\n    # If there are additional FORMAT data to add, then add those\n    foreach my $fmt_col ( @addl_fmt_cols ) {\n        my $fmt_key = $fmt_col;\n        if ( $fmt_key =~ /^t_/ ) { $fmt_key =~ s/^t_//; $maf_line{$fmt_col} = ( defined $tum_info{$fmt_key} ? $tum_info{$fmt_key} : \"\" ); }\n        if ( $fmt_key =~ /^n_/ ) { $fmt_key =~ s/^n_//; $maf_line{$fmt_col} = ( defined $nrm_info{$fmt_key} ? $nrm_info{$fmt_key} : \"\" ); }\n    }\n\n    # If this is an SV, pair up gene names from separate lines to backfill the Fusion column later\n    if( $split_svs and $var=~m/^<BND|DEL|DUP|INV>$/ ) {\n        my $sv_key = \"$var_id-$tumor_id\";\n        if( $sv_pair{$sv_key} ) {\n            $sv_pair{$sv_key} = $sv_pair{$sv_key} . \"-\" . $maf_line{Hugo_Symbol} . \" fusion\";\n        }\n        else {\n            $sv_pair{$sv_key} = $maf_line{Hugo_Symbol};\n        }\n    }\n\n    # At this point, we've generated all we can about this variant, so write it to the MAF\n    $maf_fh->print( join( \"\\t\", map{( defined $maf_line{$_} ? $maf_line{$_} : \"\" )} @maf_header ) . \"\\n\" );\n}\n$maf_fh->close;\n$annotated_vcf_fh->close;\n\n# If the MAF lists SVs, backfill the Fusion column with gene-pair names\nwarn \"STATUS: For any SVs, backfilling Fusion column with gene-pair names...\\n\" if( $verbose );\nif( $split_svs ) {\n    my $output_name = substr( $output_maf, rindex( $output_maf, \"/\" ) + 1 );\n    $output_name =~ s/(\\.maf)*$//;\n    my $tmp_output_maf = \"$tmp_dir/$output_name.tmp.maf\";\n\n    my $in_maf_fh = IO::File->new( $output_maf ) or die \"ERROR: Couldn't open: $output_maf!\\n\";\n    my $out_maf_fh = IO::File->new( $tmp_output_maf, \">\" ) or die \"ERROR: Couldn't open: $tmp_output_maf!\\n\";\n    my ( $tid_idx, $fusion_idx, $var_id_idx ) = ( 0, 0, 0 );\n    while( my $line = $in_maf_fh->getline ) {\n        chomp( $line );\n        if( $line =~ m/^#/ ) {\n            $out_maf_fh->print( \"$line\\n\" ); # Copy comments unchanged\n        }\n        elsif( $line =~ m/^Hugo_Symbol/ ) {\n            # Copy the header unchanged, after figuring out necessary column indexes\n            foreach( split( /\\t/, $line )) { last if( $_ eq \"Tumor_Sample_Barcode\" ); ++$tid_idx; }\n            foreach( split( /\\t/, $line )) { last if( $_ eq \"Fusion\" ); ++$fusion_idx; }\n            foreach( split( /\\t/, $line )) { last if( $_ eq \"vcf_id\" ); ++$var_id_idx; }\n            $out_maf_fh->print( \"$line\\n\" ); # Copy header unchanged\n        }\n        else {\n            # Write the gene-pair name into the Fusion column if it was backfilled earlier\n            my @cols = split( /\\t/, $line, -1 );\n            my $sv_key = $cols[$var_id_idx] . \"-\" . $cols[$tid_idx];\n            $cols[$fusion_idx] = $sv_pair{$sv_key} if( $sv_pair{$sv_key} );\n            $out_maf_fh->print( join( \"\\t\", @cols ) . \"\\n\" );\n        }\n    }\n    $out_maf_fh->close;\n    $in_maf_fh->close;\n\n    move( $tmp_output_maf, $output_maf );\n}\n\nwarn \"STATUS: Finished! Check results in $output_maf\\n\" if( $verbose );\n\n# Converts Sequence Ontology variant types to MAF variant classifications\nsub GetVariantClassification {\n    my ( $effect, $var_type, $inframe ) = @_;\n    return \"Targeted_Region\" if( not defined $effect or not $effect ); # In case VEP was skipped\n    return \"Splice_Site\" if( $effect =~ /^(splice_acceptor_variant|splice_donor_variant|transcript_ablation|exon_loss_variant)$/ );\n    return \"Nonsense_Mutation\" if( $effect eq 'stop_gained' );\n    return \"Frame_Shift_Del\" if(( $effect eq 'frameshift_variant' or ( $effect eq 'protein_altering_variant' and !$inframe )) and $var_type eq 'DEL' );\n    return \"Frame_Shift_Ins\" if(( $effect eq 'frameshift_variant' or ( $effect eq 'protein_altering_variant' and !$inframe )) and $var_type eq 'INS' );\n    return \"Nonstop_Mutation\" if( $effect eq 'stop_lost' );\n    return \"Translation_Start_Site\" if( $effect =~ /^(initiator_codon_variant|start_lost)$/ );\n    return \"In_Frame_Ins\" if( $effect =~ /inframe_insertion$/ or ( $effect eq 'protein_altering_variant' and $inframe and $var_type eq 'INS' ));\n    return \"In_Frame_Del\" if( $effect =~ /inframe_deletion$/ or ( $effect eq 'protein_altering_variant' and $inframe and $var_type eq 'DEL' ));\n    return \"Missense_Mutation\" if( $effect =~ /^(missense_variant|coding_sequence_variant|conservative_missense_variant|rare_amino_acid_variant)$/ );\n    return \"Intron\" if ( $effect =~ /^(transcript_amplification|intron_variant|INTRAGENIC|intragenic_variant)$/ );\n    return \"Splice_Region\" if( $effect eq 'splice_region_variant' );\n    return \"Silent\" if( $effect =~ /^(incomplete_terminal_codon_variant|synonymous_variant|stop_retained_variant|NMD_transcript_variant)$/ );\n    return \"RNA\" if( $effect =~ /^(mature_miRNA_variant|exon_variant|non_coding_exon_variant|non_coding_transcript_exon_variant|non_coding_transcript_variant|nc_transcript_variant)$/ );\n    return \"5'UTR\" if( $effect =~ /^(5_prime_UTR_variant|5_prime_UTR_premature_start_codon_gain_variant)$/ );\n    return \"3'UTR\" if( $effect eq '3_prime_UTR_variant' );\n    return \"IGR\" if( $effect =~ /^(TF_binding_site_variant|regulatory_region_variant|regulatory_region|intergenic_variant|intergenic_region)$/ );\n    return \"5'Flank\" if( $effect eq 'upstream_gene_variant' );\n    return \"3'Flank\" if ( $effect eq 'downstream_gene_variant' );\n\n    # Annotate everything else simply as a targeted region\n    # TFBS_ablation, TFBS_amplification,regulatory_region_ablation, regulatory_region_amplification,\n    # feature_elongation, feature_truncation\n    return \"Targeted_Region\";\n}\n\n# Fix the AD and DP fields, given data from a FORMATted genotype string\nsub FixAlleleDepths {\n    my ( $alleles_ref, $var_allele_idx, $fmt_info_ref ) = @_;\n    my %fmt_info = %{$fmt_info_ref};\n    my @alleles = @{$alleles_ref};\n    my @depths = ();\n\n    # If AD is defined, then parse out all REF/ALT allele depths, or whatever is in it\n    if( defined $fmt_info{AD} and $fmt_info{AD} ne \".\" ) {\n        @depths = map{( m/^\\d+$/ ? $_ : \"\" )}split( /,/, $fmt_info{AD} );\n    }\n\n    # Handle VarScan VCF lines where AD contains only 1 depth, and REF allele depth is in RD\n    if( scalar( @depths ) == 1 and defined $fmt_info{RD} ) {\n        @depths = map{\"\"} @alleles;\n        $depths[0] = $fmt_info{RD};\n        $depths[$var_allele_idx] = $fmt_info{AD};\n    }\n    # Handle SomaticSniper VCF lines, where allele depths must be extracted from BCOUNT\n    elsif( !defined $fmt_info{AD} and defined $fmt_info{BCOUNT} ) {\n        my %b_idx = ( A=>0, C=>1, G=>2, T=>3 );\n        my @bcount = split( /,/, $fmt_info{BCOUNT} );\n        @depths = map{(( defined $b_idx{$_} and defined $bcount[$b_idx{$_}] ) ? $bcount[$b_idx{$_}] : \"\" )} @alleles;\n    }\n    # Handle VCF SNV lines by Strelka, where allele depths are in AU:CU:GU:TU\n    elsif( !defined $fmt_info{AD} and scalar( grep{defined $fmt_info{$_}} qw/AU CU GU TU/ ) == 4 ) {\n        # Strelka allele depths come in tiers 1,2. We'll use tier1 cuz it's stricter, and DP already is\n        map{( $fmt_info{$_.'U'} ) = split( \",\", $fmt_info{$_.'U'} )} qw( A C G T );\n\n        # If the only ALT allele is N, then set it to the allele with the highest non-ref readcount\n        if( scalar( @alleles ) == 2 and $alleles[1] eq \"N\" ) {\n            my %acgt_depths = map{( defined $fmt_info{$_.'U'} ? ( $_, $fmt_info{$_.'U'} ) : ( $_, \"\" ))} qw( A C G T );\n            my @deepest = sort {$acgt_depths{$b} <=> $acgt_depths{$a}} keys %acgt_depths;\n            ( $alleles[1] ) = ( $deepest[0] ne $alleles[0] ? $deepest[0] : $deepest[1] );\n        }\n        @depths = map{( defined $fmt_info{$_.'U'} ? $fmt_info{$_.'U'} : \"\" )} @alleles;\n    }\n    # Handle VCF Indel lines by Strelka, where variant allele depth is in TIR and reference allele depth in TAR\n    elsif( !defined $fmt_info{AD} and defined $fmt_info{TIR} and defined $fmt_info{TAR}) {\n        @depths = map{\"\"} @alleles;\n        $depths[0] = ( split /,/, $fmt_info{TAR} )[0];\n        $depths[$var_allele_idx] = ( split /,/, $fmt_info{TIR} )[0];\n    }\n    # Handle VCF lines by CaVEMan, where allele depths are in FAZ:FCZ:FGZ:FTZ:RAZ:RCZ:RGZ:RTZ\n    elsif( !defined $fmt_info{AD} and scalar( grep{defined $fmt_info{$_}} qw/FAZ FCZ FGZ FTZ RAZ RCZ RGZ RTZ/ ) == 8 ) {\n        # Create tags for forward+reverse strand reads, and use those to determine REF/ALT depths\n        map{ $fmt_info{$_} = $fmt_info{'F'.$_} + $fmt_info{'R'.$_} } qw( AZ CZ GZ TZ );\n        @depths = map{( defined $fmt_info{$_.'Z'} ? $fmt_info{$_.'Z'} : \"\" )} @alleles;\n    }\n    # Handle VCF lines from the Ion Torrent Suite where ALT depths are in AO and REF depths are in RO\n    elsif( !defined $fmt_info{AD} and defined $fmt_info{AO} and defined $fmt_info{RO} ) {\n        @depths = ( $fmt_info{RO}, map{( m/^\\d+$/ ? $_ : \"\" )}split( /,/, $fmt_info{AO} ));\n    }\n    # Handle VCF lines from Delly where REF/ALT SV junction read counts are in RR/RV respectively\n    elsif( !defined $fmt_info{AD} and defined $fmt_info{RR} and defined $fmt_info{RV} ) {\n        # Reference allele depth and depths for any other ALT alleles must be left undefined\n        @depths = map{\"\"} @alleles;\n        $depths[0] = $fmt_info{RR};\n        $depths[$var_allele_idx] = $fmt_info{RV};\n    }\n    # Handle VCF lines where REF/ALT allele counts must be extracted from DP4\n    elsif( !defined $fmt_info{AD} and defined $fmt_info{DP4} and scalar( split( /,/, $fmt_info{DP4} )) == 4 ) {\n        # Reference allele depth and depths for any other ALT alleles must be left undefined\n        @depths = map{\"\"} @alleles;\n        # DP4 is usually a comma-delimited list for ref-forward, ref-reverse, alt-forward and alt-reverse read counts\n        my @count = split( /,/, $fmt_info{DP4} );\n        $depths[0] = $count[0] + $count[1];\n        $depths[$var_allele_idx] = $count[2] + $count[3];\n    }\n    # Handle VCF lines from cgpPindel, where ALT depth and total depth are in PP:NP:PR:NR\n    elsif( !defined $fmt_info{AD} and scalar( grep{defined $fmt_info{$_}} qw/PP NP PR NR/ ) == 4 ) {\n        # Reference allele depth and depths for any other ALT alleles must be left undefined\n        @depths = map{\"\"} @alleles;\n        $depths[$var_allele_idx] = $fmt_info{PP} + $fmt_info{NP};\n        $fmt_info{DP} = $fmt_info{PR} + $fmt_info{NR};\n    }\n    # Handle VCF lines with ALT allele fraction in FA, which needs to be multiplied by DP to get AD\n    elsif( !defined $fmt_info{AD} and defined $fmt_info{FA} and defined $fmt_info{DP} and $fmt_info{DP} ne '.' ) {\n        # Reference allele depth and depths for any other ALT alleles must be left undefined\n        @depths = map{\"\"} @alleles;\n        $depths[$var_allele_idx] = sprintf( \"%.0f\", $fmt_info{FA} * $fmt_info{DP} );\n    }\n    # Handle VCF lines from mpileup/bcftools where DV contains the ALT allele depth\n    elsif( !defined $fmt_info{AD} and defined $fmt_info{DV} and defined $fmt_info{DP} ) {\n        # Reference allele depth and depths for any other ALT alleles must be left undefined\n        @depths = map{\"\"} @alleles;\n        $depths[$var_allele_idx] = $fmt_info{DV};\n    }\n    # Handle VCF lines where AD contains only 1 value, that we can assume is the variant allele\n    elsif( defined $fmt_info{AD} and @depths and scalar( @depths ) == 1 ) {\n        # Reference allele depth and depths for any other ALT alleles must be left undefined\n        @depths = map{\"\"} @alleles;\n        $depths[$var_allele_idx] = $fmt_info{AD};\n    }\n    # For all other lines where #depths is not equal to #alleles, blank out the depths\n    elsif( @depths and scalar( @depths ) ne scalar( @alleles )) {\n        @depths = map{\"\"} @alleles;\n    }\n\n    # Sanity check that REF/ALT allele depths are lower than the total depth\n    if( defined $fmt_info{DP} and $fmt_info{DP} ne '.' and (( $depths[0] and $depths[0] > $fmt_info{DP} ) or\n        ( $depths[$var_allele_idx] and $depths[$var_allele_idx] > $fmt_info{DP} ) or\n        ( $depths[0] and $depths[$var_allele_idx] and $depths[0] + $depths[$var_allele_idx] > $fmt_info{DP} ))) {\n        $fmt_info{DP} = 0;\n        map{$fmt_info{DP} += $_ if($_ and $_ ne '.')} @depths;\n    }\n\n    # If we have REF/ALT allele depths, but no DP, then set DP equal to the sum of all ADs\n    if(( defined $depths[0] and defined $depths[$var_allele_idx] ) and ( !defined $fmt_info{DP} or $fmt_info{DP} eq '.' )) {\n        $fmt_info{DP} = 0;\n        map{$fmt_info{DP} += $_ if($_ and $_ ne '.')} @depths;\n    }\n\n    # Put all our changes back into the hash/array references that were passed over\n    $fmt_info{AD} = join( \",\", map{( $_ ne \"\" ? $_ : \".\" )} @depths );\n    %{$fmt_info_ref} = %fmt_info;\n    @{$alleles_ref} = @alleles;\n\n    return 1;\n}\n\n__DATA__\n\n=head1 NAME\n\n vcf2maf.pl - Convert a VCF into a MAF by mapping each variant to only one of all possible gene isoforms\n\n=head1 SYNOPSIS\n\n perl vcf2maf.pl --help\n perl vcf2maf.pl --input-vcf WD4086.vcf --output-maf WD4086.maf --tumor-id WD4086 --normal-id NB4086\n\n=head1 OPTIONS\n\n --input-vcf      Path to input file in VCF format\n --output-maf     Path to output MAF file\n --tmp-dir        Folder to retain intermediate VCFs after runtime [Default: Folder containing input VCF]\n --tumor-id       Tumor_Sample_Barcode to report in the MAF [TUMOR]\n --normal-id      Matched_Norm_Sample_Barcode to report in the MAF [NORMAL]\n --vcf-tumor-id   Tumor sample ID used in VCF's genotype columns [--tumor-id]\n --vcf-normal-id  Matched normal ID used in VCF's genotype columns [--normal-id]\n --custom-enst    List of custom ENST IDs that override canonical selection\n --max-subpop-af  Add FILTER tag common_variant if gnomAD reports any subpopulation AFs greater than this [0.0004]\n --species        Ensembl-friendly name of species (e.g. mus_musculus for mouse) [homo_sapiens]\n --maf-center     Variant calling center to report in MAF [.]\n --retain-info    Comma-delimited names of INFO fields to retain as extra columns in MAF []\n --retain-fmt     Comma-delimited names of FORMAT fields to retain as extra columns in MAF []\n --retain-ann     Comma-delimited names of annotations (within the VEP CSQ/ANN) to retain as extra columns in MAF []\n --min-hom-vaf    If GT undefined in VCF, minimum allele fraction to call a variant homozygous [0.7]\n --verbose        Print more things to log progress\n --help           Print a brief help message and quit\n --man            Print the detailed manual\n\n=head1 DESCRIPTION\n\nTo convert a VCF into a MAF, each variant must be mapped to only one of all possible gene transcripts/isoforms that it might affect. This selection of a single effect per variant, is often subjective. So this project is an attempt to make the selection criteria smarter, reproducible, and more configurable.\n\nThis script uses VEP, a variant annotator that maps effects of a variant on all possible genes and transcripts. For more info, see the README.\n\n=head2 Relevant links:\n\n Homepage: https://github.com/ckandoth/vcf2maf\n VCF format: http://samtools.github.io/hts-specs/\n MAF format: https://docs.gdc.cancer.gov/Data/File_Formats/MAF_Format\n VEP: http://ensembl.org/info/docs/tools/vep/index.html\n VEP annotated VCF format: http://ensembl.org/info/docs/tools/vep/vep_formats.html#vcfout\n\n=head1 AUTHORS\n\n Cyriac Kandoth (ckandoth@gmail.com)\n Shweta Chavan (chavan.shweta@gmail.com)\n Zuojian Tang (zuojian.tang@gmail.com)\n Miguel Brown (brownm28@chop.edu) - Modified for Kids First DRC\n\n=head1 LICENSE\n\n Apache-2.0 | Apache License, Version 2.0 | https://www.apache.org/licenses/LICENSE-2.0\n\n=cut\n"
                        }
                    ]
                }
            ],
            "baseCommand": [
                "gunzip",
                "-c"
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "> input_file.vcf && perl vcf2maf.pl --input-vcf input_file.vcf --output-maf $(inputs.output_basename).$(inputs.tool_name).vep.maf"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Use a file with ens tx IDs for each gene to override VEP PICK",
                    "inputBinding": {
                        "position": 7,
                        "prefix": "--custom-enst"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/custom_enst"
                },
                {
                    "type": "File",
                    "doc": "VEP annotated vcf file.",
                    "inputBinding": {
                        "position": 0
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/input_vcf"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Sequencing center of variant called",
                    "default": ".",
                    "inputBinding": {
                        "position": 8,
                        "prefix": "--maf-center"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/maf_center"
                },
                {
                    "type": "string",
                    "inputBinding": {
                        "position": 4,
                        "prefix": "--normal-id"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/normal_id"
                },
                {
                    "type": "string",
                    "id": "#kf_mskcc_vcf2maf.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Genome ref build used, should line up with cache.",
                    "default": "GRCh38",
                    "inputBinding": {
                        "position": 5,
                        "prefix": "--ncbi-build"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/ref_build"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "doc": "Fasta genome assembly with index",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--ref-fasta"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of annotations (within the VEP CSQ/ANN) to retain as extra columns in MAF",
                    "inputBinding": {
                        "position": 6,
                        "prefix": "--retain-ann"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/retain_ann"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with FORMAT fields that you want to keep",
                    "inputBinding": {
                        "position": 6,
                        "prefix": "--retain-fmt"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/retain_fmt"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with INFO fields that you want to keep, i.e. for consensus `MQ,MQ0,CAL,Hotspot`",
                    "inputBinding": {
                        "position": 6,
                        "prefix": "--retain-info"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/retain_info"
                },
                {
                    "type": "string",
                    "id": "#kf_mskcc_vcf2maf.cwl/tool_name"
                },
                {
                    "type": "string",
                    "inputBinding": {
                        "position": 3,
                        "prefix": "--tumor-id"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/tumor_id"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.maf"
                    },
                    "id": "#kf_mskcc_vcf2maf.cwl/output_maf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#normalize_vcf.cwl",
            "doc": "Before consensus calling, left align indel calls, break up multi-allelic calls, but leave mnps intact",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": 8
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/vcfutils:latest"
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-c"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": true,
                    "valueFrom": "set -eo pipefail\nVCF=$(inputs.input_vcf.path)\n${\n    var cmd = \" >&2 echo checking if strip flag given;\";\n    if (inputs.strip_info != null){\n      cmd += \">&2 echo strip flag given; VCF=stripped.vcf;\"\n      cmd += \"bcftools annotate -x \" + inputs.strip_info + \" \" + inputs.input_vcf.path + \" -o $VCF\"\n      cmd += \" || VCF=\" + inputs.input_vcf.path\n    }else{\n      cmd += \" >&2 echo no strip flag given\"\n    }\n    return cmd;\n} && bcftools norm --threads 4 -m \"-any\" $VCF | /vt/vt normalize - -n -r $(inputs.indexed_reference_fasta.path) | bgzip -@ 4 -c >  $(inputs.output_basename).$(inputs.tool_name).bcf_vt_norm.vcf.gz && tabix $(inputs.output_basename).$(inputs.tool_name).bcf_vt_norm.vcf.gz"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#normalize_vcf.cwl/indexed_reference_fasta"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#normalize_vcf.cwl/input_vcf"
                },
                {
                    "type": "string",
                    "id": "#normalize_vcf.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "If given, remove previous annotation information based on INFO file, i.e. to strip VEP info, use INFO/ANN or INFO/CSQ - check vcf",
                    "id": "#normalize_vcf.cwl/strip_info"
                },
                {
                    "type": "string",
                    "id": "#normalize_vcf.cwl/tool_name"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.bcf_vt_norm.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#normalize_vcf.cwl/normalized_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#variant_effect_predictor_105.cwl",
            "label": "VEP v105",
            "doc": "Simplified description of what this tool does:\n  1. Install needed plugins\n  2. Untar cache if it is provided\n  3. Run VEP on input VCF\n  4. BGZIP output VCF\n  5. TABIX output VCF\n\nVEP Parameters:\n  1. input_file: Path to input file\n  2. output_file: Path for output VCF or STDOUT\n  3. stats_file: Path for output stats file\n  4. warning_file: Path for output warnings file\n  5. vcf: Writes output in VCF format\n  6. offline: No database connections will be made, and a cache file or GFF/GTF file is required for annotation\n  7. fork: Number of threads to run on\n  8. ccds: Adds the CCDS transcript identifier\n  9. uniprot: Adds best match accessions for translated protein products from three UniProt-related databases (SWISSPROT, TREMBL and UniParc)\n  10. symbol: Adds the gene symbol (e.g. HGNC)\n  11. numbers: Adds affected exon and intron numbering to to output. Format is Number/Total\n  12. canonical: Adds a flag indicating if the transcript is the canonical transcript for the gene\n  13. protein: Add the Ensembl protein identifier to the output where appropriate\n  14. assembly: Select the assembly version to use if more than one available. If using the cache, you must have the appropriate assembly cache file installed\n  15. dir_cache: Cache directory to use\n  16. cache: Enables use of the cache\n  17. merged: Use the merged Ensembl and RefSeq cache\n  18. hgvs: Add HGVS nomenclature based on Ensembl stable identifiers to the output\n  19. fasta: Specify a FASTA file or a directory containing FASTA files to use to look up reference sequence\n  20. check_existing: Checks for the existence of known variants that are co-located with your input\n  21. af_1kg: Add allele frequency from continental populations (AFR,AMR,EAS,EUR,SAS) of 1000 Genomes Phase 3 to the output\n  22. af_esp: Include allele frequency from NHLBI-ESP populations\n  23. af_gnomad: Include allele frequency from Genome Aggregation Database (gnomAD) exome populations\n  24. plugin: Use named plugin\n  25. custom: Add custom annotation to the output\n\nAn example run of this tool will use a command like this:\n  /bin/bash -c\n  set -eo pipefail\n  perl /opt/vep/src/ensembl-vep/INSTALL.pl\n    --NO_TEST\n    --NO_UPDATE\n    --AUTO p\n    --PLUGINS LoF,ExAC,gnomADc,CADD,dbNSFP,dbscSNV &&\n  tar -xzf /path/to/cache.ext &&\n  /opt/vep/src/ensembl-vep/vep\n    --input_file /path/to/input_vcf.ext\n    --output_file STDOUT\n    --stats_file output_basename-string-value_stats.tool_name-string-value.html\n    --warning_file output_basename-string-value_warnings.tool_name-string-value.txt\n    --vcf\n    --offline\n    --fork $(inputs.cores)\n    --ccds\n    --uniprot\n    --symbol\n    --numbers\n    --canonical\n    --protein\n    --assembly GRCh38\n    --dir_cache $PWD\n    --cache\n    --merged\n    --check_existing\n    --af_1kg\n    --af_esp\n    --af_gnomad\n    --hgvs\n    --fasta /path/to/reference.ext\n    --plugin CADD,/path/to/cadd_snvs.ext,/path/to/cadd_indels.ext\n    --plugin dbNSFP,/path/to/dbnsfp.ext,ALL\n    --plugin dbscSNV,/path/to/dbscsnv.ext\n    --custom /path/to/phylop.ext,PhyloP,bigwig |\n  bgzip -c > output_basename-string-value.tool_name-string-value.vep.vcf.gz &&\n  tabix output_basename-string-value.tool_name-string-value.vep.vcf.gz\n",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${return inputs.ram * 1000}",
                    "coresMin": "$(inputs.cores)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "ensemblorg/ensembl-vep:release_105.0"
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-c"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "'set -eo pipefail\n${\n  var plugins = [\"LoF\",\"gnomADc\"];\n  if (inputs.cadd_indels) {\n    plugins.push(\"CADD\")\n  }\n  if (inputs.dbnsfp) {\n    plugins.push(\"dbNSFP\")\n  }\n  if (inputs.dbscsnv) {\n    plugins.push(\"dbscSNV\")\n  }\n  return \"perl /opt/vep/src/ensembl-vep/INSTALL.pl --NO_TEST --NO_UPDATE --AUTO p --PLUGINS \"+plugins.join(',')+\" &&\"\n} ${if(inputs.cache) {return \"tar -xzf \"+inputs.cache.path} else {return '>&2 echo \"Warning: No cache provided. Some options may be incompatible\"'}} && perl /opt/vep/src/ensembl-vep/vep"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "valueFrom": "--warning_file $(inputs.output_basename)_warnings.$(inputs.tool_name).txt ${\n  if (inputs.run_stats){\n    var arg = \"--stats_file \" + inputs.output_basename + \"_stats.\" + inputs.tool_name + \".html\";\n    return arg;\n  }\n  else{\n    return \"--no_stats\";\n  }\n} ${if(inputs.reference) {return \"--hgvs --hgvsg --fasta \" + inputs.reference.path} else {return \"\"}} ${if(inputs.cache) {return \"--cache --dir_cache .\"} else {return \"\"}} ${if(inputs.cadd_indels && inputs.cadd_snvs) {return \"--plugin CADD,\"+inputs.cadd_snvs.path+\",\"+inputs.cadd_indels.path} else {return \"\"}} ${if(inputs.run_cache_af) {return \"--af_1kg --af_esp --af_gnomad\"} else {return \"\"}} ${if(inputs.dbnsfp) {return \"--plugin dbNSFP,\" + inputs.dbnsfp.path + \",\" + inputs.dbnsfp_fields} else {return \"\"}} ${if(inputs.dbscsnv) {return \"--plugin dbscSNV,\"+inputs.dbscsnv.path} else {return \"\"}} ${if(inputs.intervar) {return \"--custom \"+inputs.intervar.path+\",Intervar,vcf,exact,0,STATUS\"} else {return \"\"}}"
                },
                {
                    "position": 3,
                    "shellQuote": false,
                    "valueFrom": "| bgzip -c -@ ${ return inputs.cores >= 8 ? 4 : 1; } > $(inputs.output_basename).$(inputs.tool_name).vep.vcf.gz && tabix $(inputs.output_basename).$(inputs.tool_name).vep.vcf.gz'"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Identify allele number from VCF input, where 1 = first ALT allele, 2 = second ALT allele etc. Useful when using --minimal.",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--allele_number"
                    },
                    "id": "#variant_effect_predictor_105.cwl/allele_number"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Don't skip input variants that fail validation, e.g. those that fall on unrecognised sequences. Combining --check_ref with --dont_skip will add a CHECK_REF output field when the given reference does not match the underlying reference sequence.",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--allow_non_variant"
                    },
                    "id": "#variant_effect_predictor_105.cwl/allow_non_variant"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Select the assembly version to use if more than one available. If using the cache, you must have the appropriate assembly's cache file installed. If not specified and you have only 1 assembly version installed, this will be chosen by default",
                    "default": "GRCh38",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--assembly"
                    },
                    "id": "#variant_effect_predictor_105.cwl/assembly"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Increase or decrease to balance speed and memory usage",
                    "default": 5000,
                    "inputBinding": {
                        "position": 0,
                        "prefix": "--buffer_size"
                    },
                    "id": "#variant_effect_predictor_105.cwl/buffer_size"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "tar gzipped cache from ensembl/local converted cache",
                    "id": "#variant_effect_predictor_105.cwl/cache"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD indel annotations",
                    "id": "#variant_effect_predictor_105.cwl/cadd_indels"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD SNV annotations",
                    "id": "#variant_effect_predictor_105.cwl/cadd_snvs"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Adds a flag indicating if the transcript is the canonical transcript for the gene.",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--canonical"
                    },
                    "id": "#variant_effect_predictor_105.cwl/canonical"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Adds the CCDS transcript identifer (where available) to the output",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--ccds"
                    },
                    "id": "#variant_effect_predictor_105.cwl/ccds"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "Number of cores to use. May need to increase for really large inputs",
                    "inputBinding": {
                        "position": 0,
                        "prefix": "--fork"
                    },
                    "id": "#variant_effect_predictor_105.cwl/cores"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        },
                        {
                            "pattern": "^.readme.txt",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file, index, and readme file containing dbNSFP annotations",
                    "id": "#variant_effect_predictor_105.cwl/dbnsfp"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with desired fields to annotate. Use ALL to grab all",
                    "id": "#variant_effect_predictor_105.cwl/dbnsfp_fields"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing dbscSNV annotations",
                    "id": "#variant_effect_predictor_105.cwl/dbscsnv"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Adds names of overlapping protein domains to output. Not used by default",
                    "default": true,
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--domains"
                    },
                    "id": "#variant_effect_predictor_105.cwl/domains"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Don't skip input variants that fail validation, e.g. those that fall on unrecognised sequences. Combining --check_ref with --dont_skip will add a CHECK_REF output field when the given reference does not match the underlying reference sequence.",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--dont_skip"
                    },
                    "id": "#variant_effect_predictor_105.cwl/dont_skip"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "shellQuote": false
                    },
                    "doc": "Any additional arguments for this tool. See VEP Documentation for complete list of options. Example input: --clin_sig_allele 1",
                    "id": "#variant_effect_predictor_105.cwl/extra_args"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#variant_effect_predictor_105.cwl/failed/failed",
                            "symbols": [
                                "#variant_effect_predictor_105.cwl/failed/failed/0",
                                "#variant_effect_predictor_105.cwl/failed/failed/1"
                            ]
                        }
                    ],
                    "doc": "When checking for co-located variants, by default VEP will exclude variants that have been flagged as failed. Set this flag to include such variants. 0 is exclude",
                    "default": "1",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--failed"
                    },
                    "id": "#variant_effect_predictor_105.cwl/failed"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "As per --pick_allele, but adds the PICK flag to the chosen block of consequence data and retains others",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--flag_pick_allele"
                    },
                    "id": "#variant_effect_predictor_105.cwl/flag_pick_allele"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Indicates if the overlapped gene is associated with a phenotype, disease or trait",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--gene_phenotype"
                    },
                    "id": "#variant_effect_predictor_105.cwl/gene_phenotype"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#variant_effect_predictor_105.cwl/input_format/input_format",
                            "symbols": [
                                "#variant_effect_predictor_105.cwl/input_format/input_format/ensembl",
                                "#variant_effect_predictor_105.cwl/input_format/input_format/vcf",
                                "#variant_effect_predictor_105.cwl/input_format/input_format/hgvs",
                                "#variant_effect_predictor_105.cwl/input_format/input_format/id",
                                "#variant_effect_predictor_105.cwl/input_format/input_format/region",
                                "#variant_effect_predictor_105.cwl/input_format/input_format/spdi"
                            ]
                        }
                    ],
                    "doc": "Select only a certain type of variants from the input file",
                    "default": "vcf",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--format"
                    },
                    "id": "#variant_effect_predictor_105.cwl/input_format"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VCF file (with associated index) to be annotated",
                    "inputBinding": {
                        "position": 0,
                        "prefix": "--input_file"
                    },
                    "id": "#variant_effect_predictor_105.cwl/input_vcf"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Intervar vcf-formatted file. See docs for custom build instructions",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#variant_effect_predictor_105.cwl/intervar"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Use the merged Ensembl and RefSeq cache. Consequences are flagged with the SOURCE of each transcript used.",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--merged"
                    },
                    "id": "#variant_effect_predictor_105.cwl/merged"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Don't URI escape HGVS strings",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--no_escape"
                    },
                    "id": "#variant_effect_predictor_105.cwl/no_escape"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Adds affected exon and intron numbering to to output. Format is Number/Total.",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--numbers"
                    },
                    "id": "#variant_effect_predictor_105.cwl/numbers"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Enable offline mode. No database connections will be made, and a cache file or GFF/GTF file is required for annotation. Add --refseq to use the refseq cache (if installed)",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--offline"
                    },
                    "id": "#variant_effect_predictor_105.cwl/offline"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": " Writes output in VCF format. Consequences are added in the INFO field of the VCF file, using the key 'CSQ'. Data fields are encoded separated by '|'; the order of fields is written in the VCF header. Output fields in the 'CSQ' INFO field can be selected by using --fields.If the input format was VCF, the file will remain unchanged save for the addition of the CSQ field (unless using any filtering)",
                    "default": true,
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--vcf"
                    },
                    "id": "#variant_effect_predictor_105.cwl/out_vcf_flag"
                },
                {
                    "type": "string",
                    "doc": "String that will be used in the output filenames",
                    "id": "#variant_effect_predictor_105.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Output name of main result file. Use STDOUT to pipe to something else",
                    "default": "STDOUT",
                    "inputBinding": {
                        "position": 0,
                        "prefix": "--output_file"
                    },
                    "id": "#variant_effect_predictor_105.cwl/output_file"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Customise the order of criteria (and the list of criteria) applied when choosing a block of annotation data with one of the following options: --pick, --pick_allele, --per_gene, --pick_allele_gene, --flag_pick, --flag_pick_allele, --flag_pick_allele_gene.",
                    "default": "canonical,tsl,biotype,rank,ccds,length",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--pick_order"
                    },
                    "id": "#variant_effect_predictor_105.cwl/pick_order"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#variant_effect_predictor_105.cwl/polyphen/polyphen",
                            "symbols": [
                                "#variant_effect_predictor_105.cwl/polyphen/polyphen/p",
                                "#variant_effect_predictor_105.cwl/polyphen/polyphen/s",
                                "#variant_effect_predictor_105.cwl/polyphen/polyphen/b"
                            ]
                        }
                    ],
                    "doc": "is a tool which predicts possible impact of an amino acid substitution on the structure and function of a human protein using straightforward physical and comparative considerations. VEP can output the _p_rediction term, _s_core or _b_oth",
                    "default": "b",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--polyphen"
                    },
                    "id": "#variant_effect_predictor_105.cwl/polyphen"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Add the Ensembl protein identifier to the output where appropriate",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--protein"
                    },
                    "id": "#variant_effect_predictor_105.cwl/protein"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Report Pubmed IDs for publications that cite existing variant. Must be used with --cache",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--pubmed"
                    },
                    "id": "#variant_effect_predictor_105.cwl/pubmed"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 32,
                    "doc": "In GB, may need to increase this value depending on the size/complexity of input",
                    "id": "#variant_effect_predictor_105.cwl/ram"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "doc": "Fasta genome assembly with indexes",
                    "id": "#variant_effect_predictor_105.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Look for overlaps with regulatory regions. VEP can also report if a variant falls in a high information position within a transcription factor binding site. Output lines have a Feature type of RegulatoryFeature or MotifFeature",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--regulatory"
                    },
                    "id": "#variant_effect_predictor_105.cwl/regulatory"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the allele frequency flags for cache",
                    "default": true,
                    "id": "#variant_effect_predictor_105.cwl/run_cache_af"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Checks for the existence of known variants that are co-located with your input. By default the alleles are compared and variants on an allele-specific basis - to compare only coordinates, use --no_check_alleles. ",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--check_existing"
                    },
                    "id": "#variant_effect_predictor_105.cwl/run_cache_existing"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Create stats file? Disable for speed",
                    "default": false,
                    "id": "#variant_effect_predictor_105.cwl/run_stats"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#variant_effect_predictor_105.cwl/shift_hgvs/shift_hgvs",
                            "symbols": [
                                "#variant_effect_predictor_105.cwl/shift_hgvs/shift_hgvs/0",
                                "#variant_effect_predictor_105.cwl/shift_hgvs/shift_hgvs/1"
                            ]
                        }
                    ],
                    "doc": "Enable or disable 3' shifting of HGVS notations. HGVS nomenclature requires an ambiguous sequence change to be described at the most 3' possible location. When enabled, this causes 'shifting' to the most 3' possible coordinates (relative to the transcript sequence and strand) before the HGVS notations are calculated; the flag HGVS_OFFSET is set to the number of bases by which the variant has shifted, relative to the input genomic coordinates. If HGVS_OFFSET is equals to 0, no value will be added to HGVS_OFFSET column. To disable the changing of location at transcript level set --shift_hgvs to 0.",
                    "default": "1",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--shift_hgvs"
                    },
                    "id": "#variant_effect_predictor_105.cwl/shift_hgvs"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#variant_effect_predictor_105.cwl/sift/sift",
                            "symbols": [
                                "#variant_effect_predictor_105.cwl/sift/sift/p",
                                "#variant_effect_predictor_105.cwl/sift/sift/s",
                                "#variant_effect_predictor_105.cwl/sift/sift/b"
                            ]
                        }
                    ],
                    "doc": "predicts whether an amino acid substitution affects protein function based on sequence homology and the physical properties of amino acids. VEP can output the _p_rediction term, _s_core or _b_oth",
                    "default": "b",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--sift"
                    },
                    "id": "#variant_effect_predictor_105.cwl/sift"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Refer to the cache dir structure to set this",
                    "default": "homo_sapiens",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--species"
                    },
                    "id": "#variant_effect_predictor_105.cwl/species"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Adds the gene symbol (e.g. HGNC) (where available) to the output. Some gene symbol, e.g. HGNC, are only available in merged cache and therefore should be used with --merged option while using cache to get result.",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--symbol"
                    },
                    "id": "#variant_effect_predictor_105.cwl/symbol"
                },
                {
                    "type": "string",
                    "doc": "Tool name to be used in output filenames",
                    "id": "#variant_effect_predictor_105.cwl/tool_name"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Give cDNA, CDS and protein positions as Position/Length",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--total_length"
                    },
                    "id": "#variant_effect_predictor_105.cwl/total_length"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Adds the transcript support level for this transcript to the output",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--tsl"
                    },
                    "id": "#variant_effect_predictor_105.cwl/tsl"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Adds best match accessions for translated protein products from three UniProt-related databases (SWISSPROT, TREMBL and UniParc) to the output",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--uniprot"
                    },
                    "id": "#variant_effect_predictor_105.cwl/uniprot"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Output the Sequence Ontology variant class",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--variant_class"
                    },
                    "id": "#variant_effect_predictor_105.cwl/variant_class"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Turn on verbose logging for debug purposes",
                    "default": false,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--verbose"
                    },
                    "id": "#variant_effect_predictor_105.cwl/verbose"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Output aligned RefSeq mRNA identifier for transcript",
                    "default": true,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--xref_refseq"
                    },
                    "id": "#variant_effect_predictor_105.cwl/xref_refseq"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.html"
                    },
                    "id": "#variant_effect_predictor_105.cwl/output_html"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "id": "#variant_effect_predictor_105.cwl/output_vcf"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.txt"
                    },
                    "id": "#variant_effect_predictor_105.cwl/warn_txt"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc-somatic-snv-annot-workflow.cwl",
            "label": "Kids First DRC Somatic SNV Annotation Workflow",
            "doc": "# Kids First DRC Somatic Variant Annotation Workflow\nThis is a subworkflow that is part of the Kids First DRC Somatic Variant Workflow that can be run as standalone.\nAnnotation of variant calls helps give context to the possible biological consequences of each variant.\n\n![data service logo](https://github.com/d3b-center/d3b-research-workflows/raw/master/doc/kfdrc-logo-sm.png)\n\nIt does the following things as described below:\n\n1. Normalize VCF\n1. Strip specified `INFO` and `FORMAT` fields (Only if adding a new annotation that clashes with existing)\n1. Annotate with VEP - can be skipped if VEP run previously and downstream tools are to be repeated\n1. Annotated with an additional vcf - optional, recommend using a gnomAD VCF with at least AF\n1. Soft filter on remarkable variant characteristics\n   - KF recommends normal read depth <= 7 and gnomAD AF > 0.001 and gnomAD FILTER == PASS\n   - This output will be considered `protected`\n1. Annotate with hotspots - KF recommends cancer genome hotspots v2, formatting required and explained below\n1. Create MAF output using a modified version of MSKCC's vcf2maf\n1. Hard filter on vcf based on user-specified criteria - this output would be considered `public`\n1. Create MAF output based on `public` vcf\n\n![annot workflow flowchart](../docs/somatic_annotation_wf.png)\n\n## Workflow Description and KF Recommended Inputs\nThe additional gnomAD annotation, hotspot annotation, and soft + hard filtering are part of process called \"Germline Masking.\"\nThe purpose of this is to create outputs that are safe for public consumption by marking and creating a version of outputs deemed a \"germline risk\" based on specified criteria.\nFor KF, based on guidance from the Genomic Data Commons (GDC), this means filtering variants with a normal read depth of <= 7 reads and an AF score greater than 0.001 from a PASS gnomAD record.\nThe gnomAD AF filter is pretty intuitive - gnomAD is a database resource of variants and their estimated prevalence in the human population.\nTherefore, a variant that is higher than the recommended threshold can be seen as a higher risk of being a common and identifiable variant, and a lower risk for being disease-causing.\nAdditionally, this AF score needs to come from a PASS/non-filtered record. Therefore, records that do not have their gnomad_FILTER set to PASS are not considered.\nThe normal depth argument may be less intuitive to some, and an example might help explain its importance:\nYou've got a somatic variant candidate, and the normal-sample reads all support the reference allele.\nHowever,  if there are only ~5 of those reads, then there's a decent chance that it's a germline het variant and you just didn't get lucky enough to see any alt reads in the normal sample.\nA prior understanding that heterozygous germline variant are much more common than somatic variants informs this.\n\n### Recommended reference inputs - all file references can be obtained [here](https://cavatica.sbgenomics.com/u/kfdrc-harmonization/kf-references/)\nSecondary files needed for each reference file will be a sub-bullet point\n - `indexed_reference_fasta`: `Homo_sapiens_assembly38.fasta`\n   - `Homo_sapiens_assembly38.fasta.fai`\n   - `Homo_sapiens_assembly38.dict`\n - `echtvar_anno_zips`: `gnomad.v3.1.1.custom.echtvar.zip`\n - `bcftools_strip_columns`: csv string of columns to strip if needed to avoid conflict, i.e INFO/AF\n - `bcftools_public_filter`: 'FILTER=\"PASS\"|INFO/HotSpotAllele=1'\n - `gatk_filter_name`: [\"NORM_DP_LOW\", \"GNOMAD_AF_HIGH\"]\n - `gatk_filter_expression`: [\"vc.getGenotype('insert_normal_sample_name').getDP() <= 7\", \"gnomad_3_1_1_AF != '.' && gnomad_3_1_1_AF > 0.001 && gnomad_3_1_1_FILTER=='PASS'\"] # NOTE!! Replace `insert_normal_sample_name` with the value you'd use for `input_normal_name`! # NOTE!! If your annotation includes dot values, those values must first be excluded! If they are not, GATK will error trying to convert those values!\n - `vep_cache`: `homo_sapiens_merged_vep_105_indexed_GRCh38.tar.gz`\n - `genomic_hotspots`: `tert.bed` # This file has two common TERT promoter gene hot spots\n - `protein_snv_hotspots`: `kfdrc_protein_snv_cancer_hotspots_20240718.txt` #  Column-name-containing, tab-delimited file(s) containing protein names and amino acid positions corresponding to hotspots. File header contains generation history\n - `protein_indel_hotspots`: `protein_indel_cancer_hotspots_v2.ENS105_liftover.tsv` # A tsv formatted INDEL subset of https://www.cancerhotspots.org/files/hotspots_v2.xls\n - `custom_enst`: `kf_isoform_override.tsv` # As of VEP 104, several genes have had their canonical transcripts redefined. While the VCF will have all possible isoforms, this affects maf file output and may results in representative protein changes that defy historical expectations\n\n### Source-specific inputs\nFor each input, the sub-bullet refers to when to use the suggested input\n - `add_common_fields`\n   - Strelka2 calls: `true`, *exception if already run previously and other downstream tools are being run*\n   - All others: `false`\n - `retain_info` # This is fairly subjective, some useful columns unique from each caller to carry over from VCF to MAF\n   - Strelka2: \"gnomad_3_1_1_AC,gnomad_3_1_1_AN,gnomad_3_1_1_AF,gnomad_3_1_1_nhomalt,gnomad_3_1_1_AC_popmax,gnomad_3_1_1_AN_popmax,gnomad_3_1_1_AF_popmax,gnomad_3_1_1_nhomalt_popmax,gnomad_3_1_1_AC_controls_and_biobanks,gnomad_3_1_1_AN_controls_and_biobanks,gnomad_3_1_1_AF_controls_and_biobanks,gnomad_3_1_1_AF_non_cancer,gnomad_3_1_1_primate_ai_score,gnomad_3_1_1_splice_ai_consequence,gnomad_3_1_1_AF_non_cancer_afr,gnomad_3_1_1_AF_non_cancer_ami,gnomad_3_1_1_AF_non_cancer_asj,gnomad_3_1_1_AF_non_cancer_eas,gnomad_3_1_1_AF_non_cancer_fin,gnomad_3_1_1_AF_non_cancer_mid,gnomad_3_1_1_AF_non_cancer_nfe,gnomad_3_1_1_AF_non_cancer_oth,gnomad_3_1_1_AF_non_cancer_raw,gnomad_3_1_1_AF_non_cancer_sas,gnomad_3_1_1_AF_non_cancer_amr,gnomad_3_1_1_AF_non_cancer_popmax,gnomad_3_1_1_AF_non_cancer_all_popmax,gnomad_3_1_1_FILTER,MQ,MQ0,QSI,HotSpotAllele\"\n   - Mutect2: \"gnomad_3_1_1_AC,gnomad_3_1_1_AN,gnomad_3_1_1_AF,gnomad_3_1_1_nhomalt,gnomad_3_1_1_AC_popmax,gnomad_3_1_1_AN_popmax,gnomad_3_1_1_AF_popmax,gnomad_3_1_1_nhomalt_popmax,gnomad_3_1_1_AC_controls_and_biobanks,gnomad_3_1_1_AN_controls_and_biobanks,gnomad_3_1_1_AF_controls_and_biobanks,gnomad_3_1_1_AF_non_cancer,gnomad_3_1_1_primate_ai_score,gnomad_3_1_1_splice_ai_consequence,gnomad_3_1_1_AF_non_cancer_afr,gnomad_3_1_1_AF_non_cancer_ami,gnomad_3_1_1_AF_non_cancer_asj,gnomad_3_1_1_AF_non_cancer_eas,gnomad_3_1_1_AF_non_cancer_fin,gnomad_3_1_1_AF_non_cancer_mid,gnomad_3_1_1_AF_non_cancer_nfe,gnomad_3_1_1_AF_non_cancer_oth,gnomad_3_1_1_AF_non_cancer_raw,gnomad_3_1_1_AF_non_cancer_sas,gnomad_3_1_1_AF_non_cancer_amr,gnomad_3_1_1_AF_non_cancer_popmax,gnomad_3_1_1_AF_non_cancer_all_popmax,gnomad_3_1_1_FILTER,MBQ,TLOD,HotSpotAllele\"\n   - Lancet: \"gnomad_3_1_1_AC,gnomad_3_1_1_AN,gnomad_3_1_1_AF,gnomad_3_1_1_nhomalt,gnomad_3_1_1_AC_popmax,gnomad_3_1_1_AN_popmax,gnomad_3_1_1_AF_popmax,gnomad_3_1_1_nhomalt_popmax,gnomad_3_1_1_AC_controls_and_biobanks,gnomad_3_1_1_AN_controls_and_biobanks,gnomad_3_1_1_AF_controls_and_biobanks,gnomad_3_1_1_AF_non_cancer,gnomad_3_1_1_primate_ai_score,gnomad_3_1_1_splice_ai_consequence,gnomad_3_1_1_AF_non_cancer_afr,gnomad_3_1_1_AF_non_cancer_ami,gnomad_3_1_1_AF_non_cancer_asj,gnomad_3_1_1_AF_non_cancer_eas,gnomad_3_1_1_AF_non_cancer_fin,gnomad_3_1_1_AF_non_cancer_mid,gnomad_3_1_1_AF_non_cancer_nfe,gnomad_3_1_1_AF_non_cancer_oth,gnomad_3_1_1_AF_non_cancer_raw,gnomad_3_1_1_AF_non_cancer_sas,gnomad_3_1_1_AF_non_cancer_amr,gnomad_3_1_1_AF_non_cancer_popmax,gnomad_3_1_1_AF_non_cancer_all_popmax,gnomad_3_1_1_FILTER,MS,FETS,HotSpotAllele\"\n   - Vardict: \"gnomad_3_1_1_AC,gnomad_3_1_1_AN,gnomad_3_1_1_AF,gnomad_3_1_1_nhomalt,gnomad_3_1_1_AC_popmax,gnomad_3_1_1_AN_popmax,gnomad_3_1_1_AF_popmax,gnomad_3_1_1_nhomalt_popmax,gnomad_3_1_1_AC_controls_and_biobanks,gnomad_3_1_1_AN_controls_and_biobanks,gnomad_3_1_1_AF_controls_and_biobanks,gnomad_3_1_1_AF_non_cancer,gnomad_3_1_1_primate_ai_score,gnomad_3_1_1_splice_ai_consequence,gnomad_3_1_1_AF_non_cancer_afr,gnomad_3_1_1_AF_non_cancer_ami,gnomad_3_1_1_AF_non_cancer_asj,gnomad_3_1_1_AF_non_cancer_eas,gnomad_3_1_1_AF_non_cancer_fin,gnomad_3_1_1_AF_non_cancer_mid,gnomad_3_1_1_AF_non_cancer_nfe,gnomad_3_1_1_AF_non_cancer_oth,gnomad_3_1_1_AF_non_cancer_raw,gnomad_3_1_1_AF_non_cancer_sas,gnomad_3_1_1_AF_non_cancer_amr,gnomad_3_1_1_AF_non_cancer_popmax,gnomad_3_1_1_AF_non_cancer_all_popmax,gnomad_3_1_1_FILTER,MSI,MSILEN,SOR,SSF,HotSpotAllele\"\n   - Consensus: \"gnomad_3_1_1_AC,gnomad_3_1_1_AN,gnomad_3_1_1_AF,gnomad_3_1_1_nhomalt,gnomad_3_1_1_AC_popmax,gnomad_3_1_1_AN_popmax,gnomad_3_1_1_AF_popmax,gnomad_3_1_1_nhomalt_popmax,gnomad_3_1_1_AC_controls_and_biobanks,gnomad_3_1_1_AN_controls_and_biobanks,gnomad_3_1_1_AF_controls_and_biobanks,gnomad_3_1_1_AF_non_cancer,gnomad_3_1_1_primate_ai_score,gnomad_3_1_1_splice_ai_consequence,gnomad_3_1_1_AF_non_cancer_afr,gnomad_3_1_1_AF_non_cancer_ami,gnomad_3_1_1_AF_non_cancer_asj,gnomad_3_1_1_AF_non_cancer_eas,gnomad_3_1_1_AF_non_cancer_fin,gnomad_3_1_1_AF_non_cancer_mid,gnomad_3_1_1_AF_non_cancer_nfe,gnomad_3_1_1_AF_non_cancer_oth,gnomad_3_1_1_AF_non_cancer_raw,gnomad_3_1_1_AF_non_cancer_sas,gnomad_3_1_1_AF_non_cancer_amr,gnomad_3_1_1_AF_non_cancer_popmax,gnomad_3_1_1_AF_non_cancer_all_popmax,gnomad_3_1_1_FILTER,MQ,MQ0,CAL,HotSpotAllele\"\n - `retain_ann` # Similar to above, if run for KF harmonization, recommend the following:\n   - Strelka2: \"HGVSg\"\n   - Mutect2: \"HGVSg\"\n   - Lancet: \"HGVSg\"\n   - Vardict: \"HGVSg\"\n   - Consensus: \"HGVSg\"\n - `bcftools_strip_columns` # if reannotating an old file:\n   - \"FILTER/GNOMAD_AF_HIGH,FILTER/NORM_DP_LOW,INFO/CSQ,INFO/HotSpotAllele\" # recommended if re-annotating from an older VEP cache\n   - \"FILTER/GNOMAD_AF_HIGH,FILTER/NORM_DP_LOW,INFO/HotSpotAllele\" # recommended if repeating hot spot and want to keep VEP\n - `bcftools_prefilter_csv` # if annotating a file with calls you want screen for, use this. i.e `FILTER=\"PASS\"`\n - `disable_norm` # set to `True` if existing input already normalized or of you have justification for skipping this step\n - `disable_vep_annotation` # set to `True` if existing VEP annotation of file is ok\n - `disable_hotspot_annotation` # set to `True` if existing HotSpot annotation is ok\n - `tool_name`:\n   - `Strelka2`: `strelka2_somatic`\n   - `Mutect2`: `mutect2_somatic`\n   - `Lancet`: `lancet_somatic`\n   - `VarDict Java`: `vardict_somatic`\n   - `consensus`: `consensus_somatic`\n - `vep_cores`: `16`\n - `vep_ram`: `32`\n - `vep_buffer`: `5000`\n\n## Workflow outputs\n - `annotated_protected`: `PASS` VCF with annotation pipeline soft `FILTER`-added values, VCF index, and MAF format of VCF\n - `annotated_public_vcf`: Same as `annotated_protected`, hard-filtered to include `PASS` only\n",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
