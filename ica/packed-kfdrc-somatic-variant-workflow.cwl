                    "id": "#kfdrc_strelka2_sub_wf.cwl/annotate"
                },
                {
                    "run": "#gatk_selectvariants.cwl",
                    "label": "GATK Select Strelka2 PASS",
                    "in": [
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/reheadered_vcf",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/gatk_selectvariants_strelka2/input_vcf"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/select_vars_mode",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/gatk_selectvariants_strelka2/mode"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/gatk_selectvariants_strelka2/output_basename"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/tool_name",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/gatk_selectvariants_strelka2/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_strelka2_sub_wf.cwl/gatk_selectvariants_strelka2/pass_vcf"
                    ],
                    "id": "#kfdrc_strelka2_sub_wf.cwl/gatk_selectvariants_strelka2"
                },
                {
                    "run": "#gatk_mergevcfs.cwl",
                    "label": "Merge Strelka2 SNV + Indel",
                    "in": [
                        {
                            "source": [
                                "#kfdrc_strelka2_sub_wf.cwl/strelka2/output_snv",
                                "#kfdrc_strelka2_sub_wf.cwl/strelka2/output_indel"
                            ],
                            "id": "#kfdrc_strelka2_sub_wf.cwl/merge_strelka2_vcf/input_vcfs"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/merge_strelka2_vcf/output_basename"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/reference_dict",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/merge_strelka2_vcf/reference_dict"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/tool_name",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/merge_strelka2_vcf/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_strelka2_sub_wf.cwl/merge_strelka2_vcf/merged_vcf"
                    ],
                    "id": "#kfdrc_strelka2_sub_wf.cwl/merge_strelka2_vcf"
                },
                {
                    "run": "#bcftools_reheader_samples_index.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/merge_strelka2_vcf/merged_vcf",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/input_vcf"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/input_normal_name",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/new_normal_name"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/input_tumor_name",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/new_tumor_name"
                        },
                        {
                            "valueFrom": "NORMAL",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/old_normal_name"
                        },
                        {
                            "valueFrom": "TUMOR",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/old_tumor_name"
                        },
                        {
                            "valueFrom": "$(inputs.input_vcf.basename)\n",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/output_filename"
                        },
                        {
                            "valueFrom": "$(1 == 1)\n",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/tbi"
                        }
                    ],
                    "out": [
                        "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples/reheadered_vcf"
                    ],
                    "id": "#kfdrc_strelka2_sub_wf.cwl/rename_strelka_samples"
                },
                {
                    "run": "#strelka2.cwl",
                    "label": "Run Strelka2",
                    "in": [
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/strelka2_cores",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/cores"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/exome_flag",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/exome_flag"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/extra_arg",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/extra_arg"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/hg38_strelka_bed",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/hg38_strelka_bed"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/input_normal_aligned",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/input_normal_aligned"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/input_tumor_aligned",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/input_tumor_aligned"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/manta_small_indels",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/manta_small_indels"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/reference"
                        },
                        {
                            "source": "#kfdrc_strelka2_sub_wf.cwl/use_manta_small_indels",
                            "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2/use_manta_small_indels"
                        }
                    ],
                    "out": [
                        "#kfdrc_strelka2_sub_wf.cwl/strelka2/output_snv",
                        "#kfdrc_strelka2_sub_wf.cwl/strelka2/output_indel"
                    ],
                    "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc_vardict_sub_wf.cwl",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "SubworkflowFeatureRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Set to true if input is a strelka2 vcf that hasn't had common fields added",
                    "default": false,
                    "id": "#kfdrc_vardict_sub_wf.cwl/add_common_fields"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Will hard filter final result to create a public version",
                    "default": "FILTER=\"PASS\"|INFO/HotSpotAllele=1",
                    "id": "#kfdrc_vardict_sub_wf.cwl/bcftools_public_filter"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of columns to strip if needed to avoid conflict, i.e INFO/AF",
                    "id": "#kfdrc_vardict_sub_wf.cwl/bcftools_strip_columns"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "doc": "Bed file intervals passed on from and outside pre-processing step",
                    "id": "#kfdrc_vardict_sub_wf.cwl/bed_invtl_split"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD indel annotations",
                    "id": "#kfdrc_vardict_sub_wf.cwl/cadd_indels"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD SNV annotations",
                    "id": "#kfdrc_vardict_sub_wf.cwl/cadd_snvs"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "id": "#kfdrc_vardict_sub_wf.cwl/cpus"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Use a file with ens tx IDs for each gene to override VEP PICK",
                    "id": "#kfdrc_vardict_sub_wf.cwl/custom_enst"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        },
                        {
                            "pattern": "^.readme.txt",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file, index, and readme file containing dbNSFP annotations",
                    "id": "#kfdrc_vardict_sub_wf.cwl/dbnsfp"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with desired fields to annotate. Use ALL to grab all",
                    "default": "SIFT4G_pred,Polyphen2_HDIV_pred,Polyphen2_HVAR_pred,LRT_pred,MutationTaster_pred,MutationAssessor_pred,FATHMM_pred,PROVEAN_pred,VEST4_score,VEST4_rankscore,MetaSVM_pred,MetaLR_pred,MetaRNN_pred,M-CAP_pred,REVEL_score,REVEL_rankscore,PrimateAI_pred,DEOGEN2_pred,BayesDel_noAF_pred,ClinPred_pred,LIST-S2_pred,Aloft_pred,fathmm-MKL_coding_pred,fathmm-XF_coding_pred,Eigen-phred_coding,Eigen-PC-phred_coding,phyloP100way_vertebrate,phyloP100way_vertebrate_rankscore,phastCons100way_vertebrate,phastCons100way_vertebrate_rankscore,TWINSUK_AC,TWINSUK_AF,ALSPAC_AC,ALSPAC_AF,UK10K_AC,UK10K_AF,gnomAD_exomes_controls_AC,gnomAD_exomes_controls_AN,gnomAD_exomes_controls_AF,gnomAD_exomes_controls_nhomalt,gnomAD_exomes_controls_POPMAX_AC,gnomAD_exomes_controls_POPMAX_AN,gnomAD_exomes_controls_POPMAX_AF,gnomAD_exomes_controls_POPMAX_nhomalt,gnomAD_genomes_flag,gnomAD_genomes_AC,gnomAD_genomes_AN,gnomAD_genomes_AF,gnomAD_genomes_nhomalt,gnomAD_genomes_POPMAX_AC,gnomAD_genomes_POPMAX_AN,gnomAD_genomes_POPMAX_AF,gnomAD_genomes_POPMAX_nhomalt,gnomAD_genomes_controls_and_biobanks_AC,gnomAD_genomes_controls_and_biobanks_AN,gnomAD_genomes_controls_and_biobanks_AF,gnomAD_genomes_controls_and_biobanks_nhomalt,clinvar_id,clinvar_clnsig,clinvar_trait,clinvar_review,clinvar_hgvs,clinvar_var_source,clinvar_MedGen_id,clinvar_OMIM_id,clinvar_Orphanet_id,Interpro_domain,GTEx_V8_gene,GTEx_V8_tissue",
                    "id": "#kfdrc_vardict_sub_wf.cwl/dbnsfp_fields"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Disable Hotspot Annotation and skip this task.",
                    "default": false,
                    "id": "#kfdrc_vardict_sub_wf.cwl/disable_hotspot_annotation"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Disable VEP Annotation and skip this task.",
                    "default": false,
                    "id": "#kfdrc_vardict_sub_wf.cwl/disable_vep_annotation"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Annotation ZIP files for echtvar anno",
                    "id": "#kfdrc_vardict_sub_wf.cwl/echtvar_anno_zips"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "Array of filter expressions to establish criteria to tag variants with. See https://gatk.broadinstitute.org/hc/en-us/articles/360036730071-VariantFiltration, recommend: \"vc.getGenotype('\" + inputs.input_normal_name + \"').getDP() <= 7\"), \"AF > 0.001\"]",
                    "id": "#kfdrc_vardict_sub_wf.cwl/gatk_filter_expression"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "Array of names for each filter tag to add, recommend: [\"NORM_DP_LOW\", \"GNOMAD_AF_HIGH\"]",
                    "id": "#kfdrc_vardict_sub_wf.cwl/gatk_filter_name"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Tab-delimited BED formatted file(s) containing hg38 genomic positions corresponding to hotspots",
                    "id": "#kfdrc_vardict_sub_wf.cwl/genomic_hotspots"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        },
                        {
                            "pattern": "^.dict",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/indexed_reference_fasta"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/input_normal_aligned"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_vardict_sub_wf.cwl/input_normal_name"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/input_tumor_aligned"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_vardict_sub_wf.cwl/input_tumor_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Sequencing center of variant called",
                    "default": ".",
                    "id": "#kfdrc_vardict_sub_wf.cwl/maf_center"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Set to true if merged cache used",
                    "default": true,
                    "id": "#kfdrc_vardict_sub_wf.cwl/merged"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Min variant allele frequency for vardict to consider.  Recommend 0.05",
                    "default": 0.05,
                    "id": "#kfdrc_vardict_sub_wf.cwl/min_vaf"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "If `SM:` sample name in the align file is different than `input_normal_name`, you **must** provide it here",
                    "id": "#kfdrc_vardict_sub_wf.cwl/old_normal_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "If `SM:` sample name in the align file is different than `input_tumor_name`, you **must** provide it here",
                    "id": "#kfdrc_vardict_sub_wf.cwl/old_tumor_name"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_vardict_sub_wf.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Padding to add to input intervals, recommend 0 if intervals already padded, 150 if not",
                    "default": 150,
                    "id": "#kfdrc_vardict_sub_wf.cwl/padding"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Column-name-containing, tab-delimited file(s) containing protein names and amino acid position ranges corresponding to hotspots",
                    "id": "#kfdrc_vardict_sub_wf.cwl/protein_indel_hotspots"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Column-name-containing, tab-delimited file(s) containing protein names and amino acid positions corresponding to hotspots",
                    "id": "#kfdrc_vardict_sub_wf.cwl/protein_snv_hotspots"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "In GB",
                    "id": "#kfdrc_vardict_sub_wf.cwl/ram"
                },
                {
                    "type": "File",
                    "id": "#kfdrc_vardict_sub_wf.cwl/reference_dict"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of annotations (within the VEP CSQ/ANN) to retain as extra columns in MAF",
                    "id": "#kfdrc_vardict_sub_wf.cwl/retain_ann"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with FORMAT fields that you want to keep",
                    "id": "#kfdrc_vardict_sub_wf.cwl/retain_fmt"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with INFO fields that you want to keep",
                    "default": "MSI,MSILEN,SOR,SSF,HotSpotAllele",
                    "id": "#kfdrc_vardict_sub_wf.cwl/retain_info"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the allele frequency flags for cache",
                    "id": "#kfdrc_vardict_sub_wf.cwl/run_cache_af"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the check_existing flag for cache",
                    "id": "#kfdrc_vardict_sub_wf.cwl/run_cache_existing"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_vardict_sub_wf.cwl/select_vars_mode/select_vars_mode",
                            "symbols": [
                                "#kfdrc_vardict_sub_wf.cwl/select_vars_mode/select_vars_mode/gatk",
                                "#kfdrc_vardict_sub_wf.cwl/select_vars_mode/select_vars_mode/grep"
                            ]
                        }
                    ],
                    "doc": "Choose 'gatk' for SelectVariants tool, or 'grep' for grep expression",
                    "default": "gatk",
                    "id": "#kfdrc_vardict_sub_wf.cwl/select_vars_mode"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to describe what tool was run as part of file name",
                    "default": "vardict_somatic",
                    "id": "#kfdrc_vardict_sub_wf.cwl/tool_name"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Increase or decrease to balance speed and memory usage",
                    "id": "#kfdrc_vardict_sub_wf.cwl/vep_buffer_size"
                },
                {
                    "type": "File",
                    "doc": "tar gzipped cache from ensembl/local converted cache",
                    "id": "#kfdrc_vardict_sub_wf.cwl/vep_cache"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of cores to use. May need to increase for really large inputs",
                    "id": "#kfdrc_vardict_sub_wf.cwl/vep_cores"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "In GB, may need to increase this value depending on the size/complexity of input",
                    "id": "#kfdrc_vardict_sub_wf.cwl/vep_ram"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputSource": "#kfdrc_vardict_sub_wf.cwl/pickvalue_workaround/output_file",
                    "id": "#kfdrc_vardict_sub_wf.cwl/vardict_prepass_vcf"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc_vardict_sub_wf.cwl/annotate/annotated_protected",
                    "id": "#kfdrc_vardict_sub_wf.cwl/vardict_protected_outputs"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc_vardict_sub_wf.cwl/annotate/annotated_public",
                    "id": "#kfdrc_vardict_sub_wf.cwl/vardict_public_outputs"
                }
            ],
            "steps": [
                {
                    "run": "#kfdrc-somatic-snv-annot-workflow.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/add_common_fields",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/add_common_fields"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/bcftools_public_filter",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/bcftools_public_filter"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/bcftools_strip_columns",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/bcftools_strip_columns"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/cadd_indels",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/cadd_indels"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/cadd_snvs",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/cadd_snvs"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/custom_enst",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/custom_enst"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/dbnsfp",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/dbnsfp"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/dbnsfp_fields",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/dbnsfp_fields"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/disable_hotspot_annotation",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/disable_hotspot_annotation"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/disable_vep_annotation",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/disable_vep_annotation"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/echtvar_anno_zips",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/echtvar_anno_zips"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/gatk_filter_expression",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/gatk_filter_expression"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/gatk_filter_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/gatk_filter_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/genomic_hotspots",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/genomic_hotspots"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/indexed_reference_fasta"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/input_normal_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/input_normal_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/input_tumor_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/input_tumor_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/gatk_selectvariants_vardict/pass_vcf",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/input_vcf"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/maf_center",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/maf_center"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/merged",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/merged"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/output_basename"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/protein_indel_hotspots",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/protein_indel_hotspots"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/protein_snv_hotspots",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/protein_snv_hotspots"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/retain_ann",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/retain_ann"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/retain_fmt",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/retain_fmt"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/retain_info",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/retain_info"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/run_cache_af",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/run_cache_af"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/run_cache_existing",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/run_cache_existing"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/tool_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/tool_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/vep_buffer_size",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/vep_buffer_size"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/vep_cache",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/vep_cache"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/vep_cores",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/vep_cores"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/vep_ram",
                            "id": "#kfdrc_vardict_sub_wf.cwl/annotate/vep_ram"
                        }
                    ],
                    "out": [
                        "#kfdrc_vardict_sub_wf.cwl/annotate/annotated_protected",
                        "#kfdrc_vardict_sub_wf.cwl/annotate/annotated_public"
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/annotate"
                },
                {
                    "run": "#bcbio_filter_vardict_somatic.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/pickvalue_workaround/output_file",
                            "id": "#kfdrc_vardict_sub_wf.cwl/bcbio_filter_fp_somatic/input_vcf"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_vardict_sub_wf.cwl/bcbio_filter_fp_somatic/output_basename"
                        }
                    ],
                    "out": [
                        "#kfdrc_vardict_sub_wf.cwl/bcbio_filter_fp_somatic/filtered_vcf"
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/bcbio_filter_fp_somatic"
                },
                {
                    "run": "#gatk_selectvariants.cwl",
                    "label": "GATK Select Vardict PASS",
                    "in": [
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/bcbio_filter_fp_somatic/filtered_vcf",
                            "id": "#kfdrc_vardict_sub_wf.cwl/gatk_selectvariants_vardict/input_vcf"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/select_vars_mode",
                            "id": "#kfdrc_vardict_sub_wf.cwl/gatk_selectvariants_vardict/mode"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_vardict_sub_wf.cwl/gatk_selectvariants_vardict/output_basename"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/tool_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/gatk_selectvariants_vardict/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_vardict_sub_wf.cwl/gatk_selectvariants_vardict/pass_vcf"
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/gatk_selectvariants_vardict"
                },
                {
                    "run": "#clt_file_to_file.cwl",
                    "in": [
                        {
                            "source": [
                                "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/reheadered_vcf",
                                "#kfdrc_vardict_sub_wf.cwl/sort_merge_vardict_vcf/merged_vcf"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_vardict_sub_wf.cwl/pickvalue_workaround/input_file"
                        }
                    ],
                    "out": [
                        "#kfdrc_vardict_sub_wf.cwl/pickvalue_workaround/output_file"
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/pickvalue_workaround"
                },
                {
                    "run": "#bcftools_reheader_samples_index.cwl",
                    "when": "$(inputs.old_tumor_name != null && inputs.old_normal_name != null)",
                    "in": [
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/sort_merge_vardict_vcf/merged_vcf",
                            "id": "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/input_vcf"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/input_normal_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/new_normal_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/input_tumor_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/new_tumor_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/old_normal_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/old_normal_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/old_tumor_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/old_tumor_name"
                        },
                        {
                            "valueFrom": "$(inputs.input_vcf.basename)\n",
                            "id": "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/output_filename"
                        },
                        {
                            "valueFrom": "$(1 == 1)\n",
                            "id": "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/tbi"
                        }
                    ],
                    "out": [
                        "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples/reheadered_vcf"
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/rename_vcf_samples"
                },
                {
                    "run": "#gatk_sortvcf.cwl",
                    "label": "GATK Sort & merge vardict",
                    "in": [
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/vardict/vardict_vcf",
                            "id": "#kfdrc_vardict_sub_wf.cwl/sort_merge_vardict_vcf/input_vcfs"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_vardict_sub_wf.cwl/sort_merge_vardict_vcf/output_basename"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/reference_dict",
                            "id": "#kfdrc_vardict_sub_wf.cwl/sort_merge_vardict_vcf/reference_dict"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/tool_name",
                            "id": "#kfdrc_vardict_sub_wf.cwl/sort_merge_vardict_vcf/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_vardict_sub_wf.cwl/sort_merge_vardict_vcf/merged_vcf"
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/sort_merge_vardict_vcf"
                },
                {
                    "run": "#vardictjava.cwl",
                    "hints": [
                        {
                            "class": "https://sevenbridges.comAWSInstanceType",
                            "value": "c5.4xlarge"
                        }
                    ],
                    "in": [
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/bed_invtl_split",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/bed"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/cpus",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/cpus"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/input_normal_aligned",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/input_normal_bam"
                        },
                        {
                            "source": [
                                "#kfdrc_vardict_sub_wf.cwl/old_normal_name",
                                "#kfdrc_vardict_sub_wf.cwl/input_normal_name"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/input_normal_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/input_tumor_aligned",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/input_tumor_bam"
                        },
                        {
                            "source": [
                                "#kfdrc_vardict_sub_wf.cwl/old_tumor_name",
                                "#kfdrc_vardict_sub_wf.cwl/input_tumor_name"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/input_tumor_name"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/min_vaf",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/min_vaf"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/output_basename"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/padding",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/padding"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/ram",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/ram"
                        },
                        {
                            "source": "#kfdrc_vardict_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_vardict_sub_wf.cwl/vardict/reference"
                        }
                    ],
                    "scatter": [
                        "#kfdrc_vardict_sub_wf.cwl/vardict/bed"
                    ],
                    "out": [
                        "#kfdrc_vardict_sub_wf.cwl/vardict/vardict_vcf"
                    ],
                    "id": "#kfdrc_vardict_sub_wf.cwl/vardict"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#prepare_regions.cwl",
            "doc": "Workflow for variable interval manipulation. This workflow will do the\nfollowing:\n1. If calling_padding provided, pad the calling regions\n2. If supplement_vcfs provided, concat those records to 1\n3. If blacklist_regions provided, subtract those regions from 2\n4. If scatter_count > 0, scatter 3's regions into <scatter_count> files\n\nAny or all of these steps can be skipped. If the user only wishes to apply a\nblacklist and scatter, step 3 will be applied to the calling regions.\n\nThe final return of the workflow are:\n- processed regions in BED and INTERVALLIST formats\n- if scattering, the scattered regions in BED and INTERVALLIST formats\n",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "StepInputExpressionRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "BED or INTERVALLIST file containing a set of genomic regions to remove from the calling regions.",
                    "id": "#prepare_regions.cwl/blacklist_regions"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 1000000,
                    "doc": "If set to a positive value will create a new interval list with the original intervals broken up at integer multiples of this value. Set to 0 to NOT break up intervals.",
                    "id": "#prepare_regions.cwl/break_bands_at_multiples_of"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Padding to add to the calling intervals.",
                    "id": "#prepare_regions.cwl/calling_padding"
                },
                {
                    "type": "File",
                    "doc": "BED or INTERVALLIST file containing a set of genomic regions.",
                    "id": "#prepare_regions.cwl/calling_regions"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Reference sequence dictionary, or BAM/VCF/IntervalList from which a dictionary can be extracted. Required if calling_regions are in a BED file.",
                    "id": "#prepare_regions.cwl/reference_dict"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 50,
                    "doc": "Total number of scatter intervals and beds to make",
                    "id": "#prepare_regions.cwl/scatter_count"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#prepare_regions.cwl/subdivision_mode/subdivision_mode",
                            "symbols": [
                                "#prepare_regions.cwl/subdivision_mode/subdivision_mode/INTERVAL_SUBDIVISION",
                                "#prepare_regions.cwl/subdivision_mode/subdivision_mode/BALANCING_WITHOUT_INTERVAL_SUBDIVISION",
                                "#prepare_regions.cwl/subdivision_mode/subdivision_mode/BALANCING_WITHOUT_INTERVAL_SUBDIVISION_WITH_OVERFLOW",
                                "#prepare_regions.cwl/subdivision_mode/subdivision_mode/INTERVAL_COUNT",
                                "#prepare_regions.cwl/subdivision_mode/subdivision_mode/INTERVAL_COUNT_WITH_DISTRIBUTED_REMAINDER"
                            ]
                        }
                    ],
                    "default": "BALANCING_WITHOUT_INTERVAL_SUBDIVISION_WITH_OVERFLOW",
                    "doc": "The mode used to scatter the interval list:\n- INTERVAL_SUBDIVISION (Scatter the interval list into similarly sized interval\n  lists (by base count), breaking up intervals as needed.)\n- BALANCING_WITHOUT_INTERVAL_SUBDIVISION (Scatter the interval list into\n  similarly sized interval lists (by base count), but without breaking up\n  intervals.)\n- BALANCING_WITHOUT_INTERVAL_SUBDIVISION_WITH_OVERFLOW (Scatter the interval\n  list into similarly sized interval lists (by base count), but without\n  breaking up intervals. Will overflow current interval list so that the\n  remaining lists will not have too many bases to deal with.)\n- INTERVAL_COUNT (Scatter the interval list into similarly sized interval lists\n  (by interval count, not by base count). Resulting interval lists will contain\n  the same number of intervals except for the last, which contains the\n  remainder.)\n- INTERVAL_COUNT_WITH_DISTRIBUTED_REMAINDER (Scatter the interval list into\n  similarly sized interval lists (by interval count, not by base count).\n  Resulting interval lists will contain similar number of intervals.)\n",
                    "id": "#prepare_regions.cwl/subdivision_mode"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        },
                        {
                            "pattern": ".csi",
                            "required": false
                        }
                    ],
                    "doc": "Supplemental variant calls in BCF/VCF(.GZ) format with associated index to add to the calling regions.",
                    "id": "#prepare_regions.cwl/supplement_vcfs"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputSource": "#prepare_regions.cwl/gatk_intervallisttobed_prescatter/outbed",
                    "id": "#prepare_regions.cwl/prescatter_bed"
                },
                {
                    "type": "File",
                    "outputSource": "#prepare_regions.cwl/gatk_intervallisttobed_prescatter/outbedgz",
                    "id": "#prepare_regions.cwl/prescatter_bedgz"
                },
                {
                    "type": "File",
                    "outputSource": "#prepare_regions.cwl/clt_pass_interval/outfile",
                    "id": "#prepare_regions.cwl/prescatter_intervallist"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputSource": "#prepare_regions.cwl/gatk_intervallisttobed_scatter/outbed",
                    "id": "#prepare_regions.cwl/scattered_beds"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputSource": "#prepare_regions.cwl/gatk_intervallisttools_scatter/output",
                    "id": "#prepare_regions.cwl/scattered_intervallists"
                }
            ],
            "steps": [
                {
                    "run": "#clt_pass_file.cwl",
                    "in": [
                        {
                            "source": [
                                "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/output",
                                "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/output",
                                "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/output",
                                "#prepare_regions.cwl/gatk_bedtointervallist_calling/output",
                                "#prepare_regions.cwl/calling_regions"
                            ],
                            "valueFrom": "$([].concat(self.filter(function(e) { return e != null })[0])[0])\n",
                            "id": "#prepare_regions.cwl/clt_pass_interval/infile"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/clt_pass_interval/outfile"
                    ],
                    "id": "#prepare_regions.cwl/clt_pass_interval"
                },
                {
                    "run": "#gatk_bedtointervallist.cwl",
                    "when": "$(inputs.input_bed != null && inputs.input_bed.basename.search(/(bed|bed.gz)$/) != -1)",
                    "in": [
                        {
                            "source": "#prepare_regions.cwl/blacklist_regions",
                            "id": "#prepare_regions.cwl/gatk_bedtointervallist_blacklist/input_bed"
                        },
                        {
                            "valueFrom": "$(inputs.input_bed != null ? inputs.input_bed.basename.replace(/(.bed|.bed.gz)$/,\".interval_list\") : null)\n",
                            "id": "#prepare_regions.cwl/gatk_bedtointervallist_blacklist/output_filename"
                        },
                        {
                            "source": "#prepare_regions.cwl/reference_dict",
                            "id": "#prepare_regions.cwl/gatk_bedtointervallist_blacklist/reference_dict"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/gatk_bedtointervallist_blacklist/output"
                    ],
                    "id": "#prepare_regions.cwl/gatk_bedtointervallist_blacklist"
                },
                {
                    "run": "#gatk_bedtointervallist.cwl",
                    "when": "$(inputs.input_bed.basename.search(/(bed|bed.gz)$/) != -1)",
                    "in": [
                        {
                            "source": "#prepare_regions.cwl/calling_regions",
                            "id": "#prepare_regions.cwl/gatk_bedtointervallist_calling/input_bed"
                        },
                        {
                            "valueFrom": "$(inputs.input_bed.basename.replace(/(.bed|.bed.gz)$/,\".interval_list\"))",
                            "id": "#prepare_regions.cwl/gatk_bedtointervallist_calling/output_filename"
                        },
                        {
                            "source": "#prepare_regions.cwl/reference_dict",
                            "id": "#prepare_regions.cwl/gatk_bedtointervallist_calling/reference_dict"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/gatk_bedtointervallist_calling/output"
                    ],
                    "id": "#prepare_regions.cwl/gatk_bedtointervallist_calling"
                },
                {
                    "run": "#gatk_intervallisttobed.cwl",
                    "in": [
                        {
                            "source": "#prepare_regions.cwl/clt_pass_interval/outfile",
                            "id": "#prepare_regions.cwl/gatk_intervallisttobed_prescatter/input_intervallist"
                        },
                        {
                            "valueFrom": "$(inputs.input_intervallist.nameroot).bed",
                            "id": "#prepare_regions.cwl/gatk_intervallisttobed_prescatter/output_filename"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/gatk_intervallisttobed_prescatter/outbed",
                        "#prepare_regions.cwl/gatk_intervallisttobed_prescatter/outbedgz"
                    ],
                    "id": "#prepare_regions.cwl/gatk_intervallisttobed_prescatter"
                },
                {
                    "run": "#gatk_intervallisttobed.cwl",
                    "when": "$(inputs.input_intervallist != null)",
                    "scatter": [
                        "#prepare_regions.cwl/gatk_intervallisttobed_scatter/input_intervallist"
                    ],
                    "in": [
                        {
                            "source": "#prepare_regions.cwl/gatk_intervallisttools_scatter/output",
                            "default": [],
                            "id": "#prepare_regions.cwl/gatk_intervallisttobed_scatter/input_intervallist"
                        },
                        {
                            "valueFrom": "$(inputs.input_intervallist.nameroot).bed",
                            "id": "#prepare_regions.cwl/gatk_intervallisttobed_scatter/output_filename"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/gatk_intervallisttobed_scatter/outbed",
                        "#prepare_regions.cwl/gatk_intervallisttobed_scatter/outbedgz"
                    ],
                    "id": "#prepare_regions.cwl/gatk_intervallisttobed_scatter"
                },
                {
                    "run": "#gatk_intervallisttools.cwl",
                    "when": "$(inputs.run_step != null)",
                    "in": [
                        {
                            "valueFrom": "$(1 == 1)",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/include_filtered"
                        },
                        {
                            "source": [
                                "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/output",
                                "#prepare_regions.cwl/gatk_bedtointervallist_calling/output",
                                "#prepare_regions.cwl/calling_regions",
                                "#prepare_regions.cwl/supplement_vcfs"
                            ],
                            "valueFrom": "$(self[3] != null ? self[3].concat(self.filter(function(e) { return e != null})[0]) : null)\n",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/input"
                        },
                        {
                            "source": "#prepare_regions.cwl/calling_regions",
                            "valueFrom": "$(self.basename.replace(/(.bed|.bed.gz|.interval_list)$/,\".supplemented.interval_list\"))",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/outrun_step"
                        },
                        {
                            "source": "#prepare_regions.cwl/supplement_vcfs",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/run_step"
                        },
                        {
                            "valueFrom": "$(1 == 1)",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/unique"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/output",
                        "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/count_output"
                    ],
                    "id": "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement"
                },
                {
                    "run": "#gatk_intervallisttools.cwl",
                    "when": "$(inputs.padding != null)",
                    "in": [
                        {
                            "source": [
                                "#prepare_regions.cwl/gatk_bedtointervallist_calling/output",
                                "#prepare_regions.cwl/calling_regions"
                            ],
                            "valueFrom": "$([].concat(self.filter(function(e) { return e != null })[0]))\n",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/input"
                        },
                        {
                            "source": "#prepare_regions.cwl/calling_regions",
                            "valueFrom": "$(self.basename.replace(/(.bed|.bed.gz|.interval_list)$/,\".padded.interval_list\"))\n",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/output_name"
                        },
                        {
                            "source": "#prepare_regions.cwl/calling_padding",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/padding"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/output",
                        "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/count_output"
                    ],
                    "id": "#prepare_regions.cwl/gatk_intervallisttools_pad_calling"
                },
                {
                    "run": "#gatk_intervallisttools.cwl",
                    "when": "$(inputs.scatter_count > 0)",
                    "in": [
                        {
                            "source": "#prepare_regions.cwl/break_bands_at_multiples_of",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_scatter/break_bands_at_multiples_of"
                        },
                        {
                            "source": [
                                "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/output",
                                "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/output",
                                "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/output",
                                "#prepare_regions.cwl/gatk_bedtointervallist_calling/output",
                                "#prepare_regions.cwl/calling_regions"
                            ],
                            "valueFrom": "$([].concat(self.filter(function(e) { return e != null })[0]))\n",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_scatter/input"
                        },
                        {
                            "source": "#prepare_regions.cwl/scatter_count",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_scatter/scatter_count"
                        },
                        {
                            "source": "#prepare_regions.cwl/subdivision_mode",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_scatter/subdivision_mode"
                        },
                        {
                            "valueFrom": "$(1 == 1)",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_scatter/unique"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/gatk_intervallisttools_scatter/output",
                        "#prepare_regions.cwl/gatk_intervallisttools_scatter/count_output"
                    ],
                    "id": "#prepare_regions.cwl/gatk_intervallisttools_scatter"
                },
                {
                    "run": "#gatk_intervallisttools.cwl",
                    "when": "$(inputs.run_step.some(function(e) { return e != null }))",
                    "in": [
                        {
                            "valueFrom": "SUBTRACT",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/action"
                        },
                        {
                            "source": [
                                "#prepare_regions.cwl/gatk_intervallisttools_concat_supplement/output",
                                "#prepare_regions.cwl/gatk_intervallisttools_pad_calling/output",
                                "#prepare_regions.cwl/gatk_bedtointervallist_calling/output",
                                "#prepare_regions.cwl/calling_regions"
                            ],
                            "valueFrom": "$([].concat(self.filter(function(e) { return e != null })[0]))\n",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/input"
                        },
                        {
                            "source": "#prepare_regions.cwl/calling_regions",
                            "valueFrom": "$(self.basename.replace(/(.bed|.bed.gz|.interval_list)$/,\".blacklisted.interval_list\"))",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/output_name"
                        },
                        {
                            "source": [
                                "#prepare_regions.cwl/gatk_bedtointervallist_blacklist/output",
                                "#prepare_regions.cwl/blacklist_regions"
                            ],
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/run_step"
                        },
                        {
                            "source": [
                                "#prepare_regions.cwl/gatk_bedtointervallist_blacklist/output",
                                "#prepare_regions.cwl/blacklist_regions"
                            ],
                            "valueFrom": "$([].concat(self.filter(function(e) { return e != null })[0]))\n",
                            "id": "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/second_input"
                        }
                    ],
                    "out": [
                        "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/output",
                        "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist/count_output"
                    ],
                    "id": "#prepare_regions.cwl/gatk_intervallisttools_subtract_blacklist"
                }
            ],
            "hints": [
                {
                    "class": "https://sevenbridges.comAWSInstanceType",
                    "value": "c5.2xlarge"
                }
            ],
            "https://sevenbridges.comlicense": "Apache License 2.0",
            "https://sevenbridges.compublisher": "KFDRC"
        },
        {
            "class": "CommandLineTool",
            "id": "#aa_classifier.cwl",
            "doc": "This tools takes output from amplicon architect and classifies them",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "jluebeck/prepareaa:v0.1203.10"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 4000,
                    "coresMin": 8
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        "$(inputs.data_repo)",
                        {
                            "entryname": "setup_vars.sh",
                            "entry": "export AA_DATA_REPO=$(inputs.data_repo.path)"
                        }
                    ]
                },
                {
                    "class": "EnvVarRequirement",
                    "envDef": [
                        {
                            "envValue": "/home/programs/AmpliconArchitect-master/src",
                            "envName": "AA_SRC"
                        }
                    ]
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": ". ./setup_vars.sh && /home/programs/AmpliconClassifier-main/amplicon_classifier.py"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "doc": "AA cycles file",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--cycles"
                    },
                    "id": "#aa_classifier.cwl/cycles"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#aa_classifier.cwl/data_ref_version/wgs_mode",
                            "symbols": [
                                "#aa_classifier.cwl/data_ref_version/wgs_mode/GRCh38",
                                "#aa_classifier.cwl/data_ref_version/wgs_mode/hg19",
                                "#aa_classifier.cwl/data_ref_version/wgs_mode/GRCh37",
                                "#aa_classifier.cwl/data_ref_version/wgs_mode/mm10",
                                "#aa_classifier.cwl/data_ref_version/wgs_mode/GRCm38"
                            ]
                        }
                    ],
                    "doc": "Genome version in data repo to use",
                    "default": "GRCh38",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--ref"
                    },
                    "id": "#aa_classifier.cwl/data_ref_version"
                },
                {
                    "type": "Directory",
                    "doc": "Un-tarred reference obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/",
                    "id": "#aa_classifier.cwl/data_repo"
                },
                {
                    "type": "File",
                    "doc": "AA graph file",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--graph"
                    },
                    "id": "#aa_classifier.cwl/graph"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*_amplicon_classification_profiles.tsv"
                    },
                    "id": "#aa_classifier.cwl/amplicon_classification_profiles"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*_gene_list.tsv"
                    },
                    "id": "#aa_classifier.cwl/gene_list"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#amplicon_architect.cwl",
            "doc": "This tool prepares input for amplicon architect anaylsis",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "jluebeck/prepareaa:v0.1203.10"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": "$(inputs.threads)"
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entry": "$(inputs.data_repo)",
                            "writable": true
                        },
                        {
                            "entryname": "setup_vars.sh",
                            "entry": "export AA_DATA_REPO=$(inputs.data_repo.basename) \\\n&& mkdir licenses && cp $(inputs.mosek_license_file.path) licenses \\\n&& export MOSEKLM_LICENSE_FILE=$PWD/licenses;\nif [ ${ return inputs.ref_cache ? \"REF_CACHE_YES\" : null; } != null ];\nthen\ntar -xzf ${ return inputs.ref_cache ? inputs.ref_cache.path : ''; } && export REF_CACHE=\"$PWD/ref/cache/%2s/%2s/%s\"\nfi"
                        }
                    ]
                },
                {
                    "class": "EnvVarRequirement",
                    "envDef": [
                        {
                            "envValue": "/home/programs/AmpliconArchitect-master/src",
                            "envName": "AA_SRC"
                        }
                    ]
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": ". ./setup_vars.sh && cp $(inputs.coverage_stats.path) $AA_DATA_REPO/coverage.stats"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "&& /home/programs/AmpliconArchitect-master/src/AmpliconArchitect.py"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "doc": "Bed file from prepare-aa",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--bed"
                    },
                    "id": "#amplicon_architect.cwl/aa_bed"
                },
                {
                    "type": "File",
                    "doc": "tumor bam file",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--bam"
                    },
                    "id": "#amplicon_architect.cwl/bam"
                },
                {
                    "type": "File",
                    "doc": "Coverage stats file generated by prepare-aa",
                    "id": "#amplicon_architect.cwl/coverage_stats"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#amplicon_architect.cwl/data_ref_version/wgs_mode",
                            "symbols": [
                                "#amplicon_architect.cwl/data_ref_version/wgs_mode/GRCh38",
                                "#amplicon_architect.cwl/data_ref_version/wgs_mode/hg19",
                                "#amplicon_architect.cwl/data_ref_version/wgs_mode/GRCh37",
                                "#amplicon_architect.cwl/data_ref_version/wgs_mode/mm10",
                                "#amplicon_architect.cwl/data_ref_version/wgs_mode/GRCm38"
                            ]
                        }
                    ],
                    "doc": "Genome version in data repo to use",
                    "default": "GRCh38",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--ref"
                    },
                    "id": "#amplicon_architect.cwl/data_ref_version"
                },
                {
                    "type": "Directory",
                    "doc": "Un-tarred reference obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/",
                    "id": "#amplicon_architect.cwl/data_repo"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Recommended for anaylsis",
                    "default": 10,
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--downsample"
                    },
                    "id": "#amplicon_architect.cwl/downsample"
                },
                {
                    "type": "File",
                    "doc": "This tool uses some software that requires a license file. You can get a personal or institutional one from https://www.mosek.com/license/request/.",
                    "id": "#amplicon_architect.cwl/mosek_license_file"
                },
                {
                    "type": "string",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--out"
                    },
                    "id": "#amplicon_architect.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "For cram input, provide tar ball of output of running misc/seq_cache_populate.pl from samtools on the reference fasta",
                    "id": "#amplicon_architect.cwl/ref_cache"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Num threads to use",
                    "default": 8,
                    "id": "#amplicon_architect.cwl/threads"
                }
            ],
            "outputs": [
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*_cycles.txt"
                    },
                    "id": "#amplicon_architect.cwl/cycles"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*_graph.txt"
                    },
                    "id": "#amplicon_architect.cwl/graph"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*_summary.txt"
                    },
                    "id": "#amplicon_architect.cwl/summary"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*.pdf"
                    },
                    "id": "#amplicon_architect.cwl/sv_pdf"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputBinding": {
                        "glob": "*.png"
                    },
                    "id": "#amplicon_architect.cwl/sv_png"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#annotsv.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/annotsv:3.1.1"
                },
                {
                    "class": "InlineJavascriptRequirement",
                    "expressionLib": [
                        "\nvar setMetadata = function(file, metadata) {\n    if (!('metadata' in file))\n        file['metadata'] = metadata;\n    else {\n        for (var key in metadata) {\n            file['metadata'][key] = metadata[key];\n        }\n    }\n    return file\n};\n\nvar inheritMetadata = function(o1, o2) {\n    var commonMetadata = {};\n    if (!Array.isArray(o2)) {\n        o2 = [o2]\n    }\n    for (var i = 0; i < o2.length; i++) {\n        var example = o2[i]['metadata'];\n        for (var key in example) {\n            if (i == 0)\n                commonMetadata[key] = example[key];\n            else {\n                if (!(commonMetadata[key] == example[key])) {\n                    delete commonMetadata[key]\n                }\n            }\n        }\n    }\n    if (!Array.isArray(o1)) {\n        o1 = setMetadata(o1, commonMetadata)\n    } else {\n        for (var i = 0; i < o1.length; i++) {\n            o1[i] = setMetadata(o1[i], commonMetadata)\n        }\n    }\n    return o1;\n};"
                    ]
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "prefix": "",
                    "shellQuote": false,
                    "valueFrom": "tar -xf $(inputs.annotations_dir_tgz.path) --use-compress-program=pigz && AnnotSV -annotationsDir ./AnnotSV\n"
                },
                {
                    "position": 99,
                    "prefix": "",
                    "shellQuote": false,
                    "valueFrom": "1>&2\n"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/annotation_mode/annotaiton_mode",
                            "symbols": [
                                "#annotsv.cwl/annotation_mode/annotaiton_mode/both",
                                "#annotsv.cwl/annotation_mode/annotaiton_mode/full",
                                "#annotsv.cwl/annotation_mode/annotaiton_mode/split"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-annotationMode",
                        "position": 1
                    },
                    "doc": "Description of the types of lines produced by AnnotSV",
                    "id": "#annotsv.cwl/annotation_mode"
                },
                {
                    "type": "File",
                    "doc": "TAR.GZ'd Directory containing annotations",
                    "id": "#annotsv.cwl/annotations_dir_tgz"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "inputBinding": {
                        "prefix": "-benignAF",
                        "position": 1
                    },
                    "doc": "Allele frequency threshold to select the benign SV in the data sources",
                    "id": "#annotsv.cwl/benign_af"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "inputBinding": {
                        "prefix": "-candidateGenesFile",
                        "position": 1
                    },
                    "doc": "Path of a file containing the candidate genes of the user (gene names can be space-separated, tabulation-separated, or line-break-separated)",
                    "id": "#annotsv.cwl/candidate_genes_file",
                    "https://sevenbridges.comfileTypes": "BED, CSV, TSV, TXT"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/candidate_genes_filtering/candidate_genes_filtering",
                            "symbols": [
                                "#annotsv.cwl/candidate_genes_filtering/candidate_genes_filtering/0",
                                "#annotsv.cwl/candidate_genes_filtering/candidate_genes_filtering/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-candidateGenesFiltering",
                        "position": 1
                    },
                    "doc": "To select only the SV annotations ('split' and 'full') overlapping a gene from the candidateGenesFile",
                    "id": "#annotsv.cwl/candidate_genes_filtering"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-candidateSnvIndelFiles",
                        "position": 1
                    },
                    "doc": "Path of the filtered VCF input file(s) with SNV/indel coordinates for compound heterozygotes report (optional)",
                    "id": "#annotsv.cwl/candidate_snv_indel_files",
                    "https://sevenbridges.comfileTypes": "VCF, VCF.GZ"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string"
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-candidateSnvIndelSamples",
                        "position": 1
                    },
                    "doc": "To specifiy the sample names from the VCF files defined from the -candidateSnvIndelFiles option",
                    "id": "#annotsv.cwl/candidate_snv_indel_samples"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/genome_build/genome_build",
                            "symbols": [
                                "#annotsv.cwl/genome_build/genome_build/GRCh37",
                                "#annotsv.cwl/genome_build/genome_build/GRCh38",
                                "#annotsv.cwl/genome_build/genome_build/mm9",
                                "#annotsv.cwl/genome_build/genome_build/mm10"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-genomeBuild",
                        "position": 1
                    },
                    "doc": "Genome build used",
                    "id": "#annotsv.cwl/genome_build"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string"
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-hpo",
                        "position": 1
                    },
                    "doc": "HPO term(s) describing the phenotype of the individual being investigated. (e.g. HP:0001156)",
                    "id": "#annotsv.cwl/hpo"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/include_ci/include_ci",
                            "symbols": [
                                "#annotsv.cwl/include_ci/include_ci/0",
                                "#annotsv.cwl/include_ci/include_ci/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-includeCI",
                        "position": 1
                    },
                    "doc": "To expand the 'start' and 'end' SV positions with the VCF confidence intervals (CIPOS, CIEND) around the breakpoints",
                    "id": "#annotsv.cwl/include_ci"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/metrics/metrics",
                            "symbols": [
                                "#annotsv.cwl/metrics/metrics/us",
                                "#annotsv.cwl/metrics/metrics/fr"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-metrics",
                        "position": 1
                    },
                    "doc": "Changing numerical values from frequencies to us or fr metrics (e.g. 0.2 or 0,2)",
                    "id": "#annotsv.cwl/metrics"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "prefix": "-minTotalNumber",
                        "position": 1
                    },
                    "doc": "Minimum number of individuals tested to consider a benign SV for the ranking. Range values: [100-1000]",
                    "id": "#annotsv.cwl/min_total_number"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "default": ".",
                    "inputBinding": {
                        "prefix": "-outputDir",
                        "position": 1
                    },
                    "doc": "String representing path to directory where outputs will be placed",
                    "id": "#annotsv.cwl/output_dir"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "prefix": "-outputFile",
                        "position": 1
                    },
                    "doc": "Name for output file",
                    "id": "#annotsv.cwl/output_file"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "prefix": "-overlap",
                        "position": 1
                    },
                    "doc": "Minimum overlap (%) between user features (User BED) and the annotated SV to be reported. Range values: [0-100]",
                    "id": "#annotsv.cwl/overlap"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/overwrite/overwrite",
                            "symbols": [
                                "#annotsv.cwl/overwrite/overwrite/0",
                                "#annotsv.cwl/overwrite/overwrite/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-overwrite",
                        "position": 1
                    },
                    "doc": "To overwrite existing output results",
                    "id": "#annotsv.cwl/overwrite"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "prefix": "-promoterSize",
                        "position": 1
                    },
                    "doc": "Number of bases upstream from the transcription start site",
                    "id": "#annotsv.cwl/promoter_size"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "inputBinding": {
                        "prefix": "-rankFiltering",
                        "position": 1
                    },
                    "doc": "To select the SV of a user-defined specific class (from 1 to 5). Values: use comma separated class values, or use a dash to denote a range of values (e.g.: '3,4,5' or '3-5').",
                    "id": "#annotsv.cwl/rank_filtering"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/re_report/re_report",
                            "symbols": [
                                "#annotsv.cwl/re_report/re_report/0",
                                "#annotsv.cwl/re_report/re_report/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-REreport",
                        "position": 1
                    },
                    "doc": "Create a report to link the annotated SV and the overlapped regulatory elements (coordinates and sources)",
                    "id": "#annotsv.cwl/re_report"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/re_select_1/re_select_1",
                            "symbols": [
                                "#annotsv.cwl/re_select_1/re_select_1/0",
                                "#annotsv.cwl/re_select_1/re_select_1/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-REselect1",
                        "position": 1
                    },
                    "doc": "To report only the morbid, HI, TS, candidate and phenotype matched genes",
                    "id": "#annotsv.cwl/re_select_1"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/re_select_2/re_select_2",
                            "symbols": [
                                "#annotsv.cwl/re_select_2/re_select_2/0",
                                "#annotsv.cwl/re_select_2/re_select_2/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-REselect2",
                        "position": 1
                    },
                    "doc": "To report only the genes not present in 'Gene_name'",
                    "id": "#annotsv.cwl/re_select_2"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/reciprocal/reciprocal",
                            "symbols": [
                                "#annotsv.cwl/reciprocal/reciprocal/0",
                                "#annotsv.cwl/reciprocal/reciprocal/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-reciprocal",
                        "position": 1
                    },
                    "doc": "Use of a reciprocal overlap between SV and user features (only for annotations with features overlapping the SV)",
                    "id": "#annotsv.cwl/reciprocal"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "prefix": "-samplesidBEDcol",
                        "position": 1
                    },
                    "doc": "Number of the column reporting the samples ID for which the SV was called (if the input SV file is a BED)",
                    "id": "#annotsv.cwl/samples_id_bed_col"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-snvIndelFiles",
                        "position": 1
                    },
                    "doc": "VCF input file(s) with SNV/indel coordinates used for false positive discovery. Use counts of the homozygous and heterozygous variants",
                    "id": "#annotsv.cwl/snv_indel_files",
                    "https://sevenbridges.comfileTypes": "VCF, VCF.GZ"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/snv_indel_pass/snv_indel_pass",
                            "symbols": [
                                "#annotsv.cwl/snv_indel_pass/snv_indel_pass/0",
                                "#annotsv.cwl/snv_indel_pass/snv_indel_pass/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-snvIndelPASS",
                        "position": 1
                    },
                    "doc": "To only use variants from VCF input files that passed all filters during the calling (FILTER column value equal to PASS)",
                    "id": "#annotsv.cwl/snv_indel_pass"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "string"
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-snvIndelSamples",
                        "position": 1
                    },
                    "doc": "To specify the sample names from the VCF files defined from the -snvIndelFiles option",
                    "id": "#annotsv.cwl/snv_indel_samples"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-SVinputFile",
                        "position": 1
                    },
                    "doc": "Path of the input file (VCF or BED) with SV coordinates. Gzipped VCF file is supported",
                    "id": "#annotsv.cwl/sv_input_file",
                    "https://sevenbridges.comfileTypes": "BED, VCF, VCF.GZ"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/sv_input_info/sv_input_info",
                            "symbols": [
                                "#annotsv.cwl/sv_input_info/sv_input_info/0",
                                "#annotsv.cwl/sv_input_info/sv_input_info/1"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-SVinputInfo",
                        "position": 1
                    },
                    "doc": "To extract the additional SV input fields and insert the data in the outputfile",
                    "id": "#annotsv.cwl/sv_input_info"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "prefix": "-SVminSize",
                        "position": 1
                    },
                    "doc": "SV minimum size (in bp)",
                    "id": "#annotsv.cwl/sv_min_size"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "prefix": "-svtBEDcol",
                        "position": 1
                    },
                    "doc": "Number of the column describing the SV type (DEL, DUP) if the input SV file is a BED",
                    "id": "#annotsv.cwl/svt_bed_col"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#annotsv.cwl/tx/tx",
                            "symbols": [
                                "#annotsv.cwl/tx/tx/RefSeq",
                                "#annotsv.cwl/tx/tx/ENSEMBL"
                            ]
                        }
                    ],
                    "inputBinding": {
                        "prefix": "-tx",
                        "position": 1
                    },
                    "doc": "Origin of the transcripts (RefSeq or ENSEMBL)",
                    "id": "#annotsv.cwl/tx"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "inputBinding": {
                        "prefix": "-txFile",
                        "position": 1
                    },
                    "doc": "file containing a list of preferred genes transcripts to be used in priority during the annotation (Preferred genes transcripts names should be tab or space separated)",
                    "id": "#annotsv.cwl/tx_file",
                    "https://sevenbridges.comfileTypes": "BED, CSV, TSV, TXT"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.annotated.tsv",
                        "outputEval": "$(inheritMetadata(self, inputs.sv_input_file))"
                    },
                    "id": "#annotsv.cwl/annotated_calls"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.unannotated.tsv",
                        "outputEval": "$(inheritMetadata(self, inputs.sv_input_file))"
                    },
                    "id": "#annotsv.cwl/unannotated_calls"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#awk_chrlen_builder.cwl",
            "doc": "This tool is an awk command that does the following: - Create a list of chromosome names from the input_intervals - Print any matching chromosome names from the reference_fai into a temp_chrs TSV - IF an input_variants file is provided:\n  - Convert the file to a VCF\n  - Create a list of chromosome names from the VCF\n  - Print any matching chromosome names from the temp_chrs TSV\n- Otherwise rename the temp_chrs TSV and return it\nThe reason for the optional step is that BAF calling in ControlFREEC will fail if a chromosome has no germline variants. Thus it is necessary to remove those chrs from the calling set entirely.",
            "requirements": [
                {
                    "class": "DockerRequirement",
                    "dockerPull": "staphb/bcftools:1.20"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "coresMin": "$(inputs.cpu)",
                    "ramMin": "$(inputs.ram * 1000)"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entryname": "build_chrlen.sh",
                            "entry": "#!/usr/bin/env bash\n\nset -ex\n\nawk -F'\\t' 'NR==FNR && $1 !~ /^@/ { out[$1]=1; next } { if (out[$1]==1) print $0 }' $(inputs.input_intervals.path) $(inputs.reference_fai.path) > temp_chrs.tsv\n\nif [ -s $(inputs.input_variants == null ? inputs.input_variants : inputs.input_variants.path) ]\nthen\n  bcftools view --no-header $(inputs.input_variants == null ? inputs.input_variants : inputs.input_variants.path) > temp_recs.vcf\n  awk -F'\\t' 'NR==FNR && $1 !~ /^@/ { out[$1]=1; next } { if (out[$1]==1) print $0 }' temp_recs.vcf temp_chrs.tsv > chrlen.tsv\nelse\n  mv temp_chrs.tsv chrlen.tsv\nfi\n"
                        }
                    ]
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "/bin/bash build_chrlen.sh\n"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "id": "#awk_chrlen_builder.cwl/cpu"
                },
                {
                    "type": "File",
                    "doc": "Intervals over which to perform calling.",
                    "id": "#awk_chrlen_builder.cwl/input_intervals"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        }
                    ],
                    "doc": "Germline Variants file",
                    "id": "#awk_chrlen_builder.cwl/input_variants"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "id": "#awk_chrlen_builder.cwl/ram"
                },
                {
                    "type": "File",
                    "doc": "FAI index for the FASTA on which the intervals are based.",
                    "id": "#awk_chrlen_builder.cwl/reference_fai"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "chrlen.tsv"
                    },
                    "id": "#awk_chrlen_builder.cwl/chrlen"
                }
            ]
        },
        {
            "id": "#awk_min_seg_length.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "$(inputs.ram * 1000)",
                    "coresMin": "$(inputs.cpu)"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "ubuntu:20.04"
                }
            ],
            "class": "CommandLineTool",
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "awk -F'\\t' -v min=$(inputs.default_min_len) '$1 ~ /chr/ && $3-$2 < min {min = $3-$2} END {print min}' $(inputs.input_file.path) > value.txt"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 1,
                    "doc": "CPUs to allocate to this task.",
                    "id": "#awk_min_seg_length.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 150,
                    "id": "#awk_min_seg_length.cwl/default_min_len"
                },
                {
                    "type": "File",
                    "id": "#awk_min_seg_length.cwl/input_file"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 2,
                    "doc": "GB of RAM to allocate to this task.",
                    "id": "#awk_min_seg_length.cwl/ram"
                }
            ],
            "outputs": [
                {
                    "type": "int",
                    "outputBinding": {
                        "glob": "value.txt",
                        "loadContents": true,
                        "outputEval": "$(parseInt(self[0].contents))"
                    },
                    "id": "#awk_min_seg_length.cwl/output"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#bcbio_filter_vardict_somatic.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 8000,
                    "coresMin": 4
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/bcbio_vardict_filter"
                }
            ],
            "baseCommand": [
                "python"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "/bcbio_vardict_filter.py $(inputs.input_vcf.path) | grep -E \"^#|STATUS=StrongSomatic\" > $(inputs.output_basename).bcbio_vardict_fp_somatic_filter.vcf\nbgzip $(inputs.output_basename).bcbio_vardict_fp_somatic_filter.vcf && tabix $(inputs.output_basename).bcbio_vardict_fp_somatic_filter.vcf.gz"
                }
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#bcbio_filter_vardict_somatic.cwl/input_vcf"
                },
                {
                    "type": "string",
                    "id": "#bcbio_filter_vardict_somatic.cwl/output_basename"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#bcbio_filter_vardict_somatic.cwl/filtered_vcf"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#bcftools_reheader_samples_index.cwl",
            "doc": "This tool is for renaming the sample names in a somatic BCF/VCF.GZ. That is,\nany BCF/VCF.GZ that has two samples: tumor and normal.\n\nThis tool goes about the renaming in two ways:\n\n1. If BOTH old_normal_name and old_tumor_name are provided, it will construct a\nsample_list file that has the lines \"old_normal_name new_normal_name\" and\n\"old_tumor_name new_tumor_name\". This sample_list file will then be fed to\nreheader and can be used to replace the samples named old_normal_name with\nnew_normal_name and old_tumor_name with new_tumor_name. This is directed,\nspecific replacement. If the old names do not match any samples in the VCF,\nnothing will be changed.\n\n2. If either old_normal_name or old_tumor_name is missing, this tool will\nassume that first sample in the VCF is the normal sample and replace it with\nnew_normal_name. It will assume the second sample in the VCF is the tumor\nsample and replace it with new_tumor_name. This approach is VERY DANGEROUS!\nOnly use this approach if you are absolutely sure that the sample order is\nFIXED and the first sample will ALWAYS BE NORMAL!\n\nThe resulting output is then indexed using BCFtools index.\n",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "staphb/bcftools:1.17"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 1000,
                    "coresMin": 1
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entryname": "sample_list.txt",
                            "entry": "$(inputs.old_normal_name != null && inputs.old_tumor_name != null ? inputs.old_normal_name + \" \" : \"\")$(inputs.new_normal_name)\n$(inputs.old_tumor_name != null && inputs.old_normal_name != null ? inputs.old_tumor_name + \" \" : \"\")$(inputs.new_tumor_name)\n"
                        }
                    ]
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "bcftools reheader --samples sample_list.txt"
                },
                {
                    "position": 10,
                    "prefix": "&&",
                    "shellQuote": false,
                    "valueFrom": "bcftools index"
                },
                {
                    "position": 19,
                    "shellQuote": false,
                    "valueFrom": "$(inputs.output_filename)"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--csi"
                    },
                    "doc": "generate CSI-format index for VCF/BCF files [default]",
                    "id": "#bcftools_reheader_samples_index.cwl/csi"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--force"
                    },
                    "doc": "overwrite index if it already exists",
                    "id": "#bcftools_reheader_samples_index.cwl/force"
                },
                {
                    "type": "File",
                    "inputBinding": {
                        "position": 9
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        },
                        {
                            "pattern": ".csi",
                            "required": false
                        }
                    ],
                    "doc": "Somatic BCF/VCF.GZ file to be reheadered with new normal and tumor sample names. Must have only two samples with the first sample being normal and the second sample being tumor",
                    "id": "#bcftools_reheader_samples_index.cwl/input_vcf"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--min-shift"
                    },
                    "doc": "set minimal interval size for CSI indices to 2^INT [14]",
                    "id": "#bcftools_reheader_samples_index.cwl/min_shift"
                },
                {
                    "type": "string",
                    "doc": "New normal sample name. Used to replace either the old_normal_name or the first sample in the input_vcf",
                    "id": "#bcftools_reheader_samples_index.cwl/new_normal_name"
                },
                {
                    "type": "string",
                    "doc": "New tumor sample name. Used to replace either the old_tumor_name or the second sample in the input_vcf",
                    "id": "#bcftools_reheader_samples_index.cwl/new_tumor_name"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--nrecords"
                    },
                    "doc": "print number of records based on existing index file",
                    "id": "#bcftools_reheader_samples_index.cwl/nrecords"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Name of the normal sample in the input_vcf. Will be replaced by the new_normal_name.",
                    "id": "#bcftools_reheader_samples_index.cwl/old_normal_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Name of the tumor sample in the input_vcf. Will be replaced by the new_tumor_name.",
                    "id": "#bcftools_reheader_samples_index.cwl/old_tumor_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "default": "reheadered.vcf.gz",
                    "inputBinding": {
                        "prefix": "--output",
                        "position": 2
                    },
                    "doc": "Output name for the reheadered VCF.",
                    "id": "#bcftools_reheader_samples_index.cwl/output_filename"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--stats"
                    },
                    "doc": "print per contig stats based on existing index file",
                    "id": "#bcftools_reheader_samples_index.cwl/stats"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "position": 12,
                        "prefix": "--tbi"
                    },
                    "doc": "generate TBI-format index for VCF files",
                    "id": "#bcftools_reheader_samples_index.cwl/tbi"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": false
                        },
                        {
                            "pattern": ".csi",
                            "required": false
                        }
                    ],
                    "outputBinding": {
                        "glob": "$(inputs.output_filename)"
                    },
                    "id": "#bcftools_reheader_samples_index.cwl/reheadered_vcf"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#bedtools_intersect.cwl",
            "doc": "Intersect VCF with bedtools intersect, i.e. for WXS filter germline on unpadded intervals to ensure accurate CNV calls",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 8000,
                    "coresMin": 4
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "pgc-images.sbgenomics.com/d3b-bixu/vcfutils:latest"
                }
            ],
            "baseCommand": [
                "/bin/bash",
                "-c"
            ],
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "set -eo pipefail\n${\n    var cmd = \" >&2 echo checking if skip intersect flag given;\";\n    var out_vcf = inputs.output_basename + \".bed_intersect.vcf\";\n    if (inputs.input_vcf == null){\n      return \"echo No vcf provided, skipping >&2 && exit 0;\"\n    }\n    if (inputs.flag != \"N\"){\n      cmd += \"bedtools intersect -a \" + (inputs.input_vcf ? inputs.input_vcf.path : \"\") + \" -b \" + inputs.input_bed_file.path + \" -header -wa > \" + out_vcf + \" && \";\n      cmd +=  \"bgzip \" + out_vcf + \" && tabix \" + out_vcf + \".gz;\";\n    }else{\n      cmd += \" >&2 echo Value N given, passing through vcf; cp \" + (inputs.input_vcf ? inputs.input_vcf.path : \"\") + \" \" + out_vcf + \".gz;\"\n      cmd += \"tabix \" + out_vcf + \".gz;\"\n    }\n    return cmd;\n}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "If N, skip and pass through vcf without intersect",
                    "id": "#bedtools_intersect.cwl/flag"
                },
                {
                    "type": "File",
                    "id": "#bedtools_intersect.cwl/input_bed_file"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "doc": "Input VCF file. Skips if not provided.",
                    "id": "#bedtools_intersect.cwl/input_vcf"
                },
                {
                    "type": "string",
                    "id": "#bedtools_intersect.cwl/output_basename"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.bed_intersect.vcf.gz"
                    },
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi"
                        }
                    ],
                    "id": "#bedtools_intersect.cwl/intersected_vcf"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#clt_file_to_file.cwl",
            "doc": "\"This is a simple tool to get around a technical limitation of cavatica.\nThe pickValue feature works within tools, and `outputSource`, but will not work in `outputSource`\nwhen used in the context of a sub-workflow. This tool gets around that limitation.\"\n",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "baseCommand": [
                "echo",
                "done"
            ],
            "inputs": [
                {
                    "type": "File",
                    "id": "#clt_file_to_file.cwl/input_file"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "outputEval": "$(inputs.input_file)\n"
                    },
                    "id": "#clt_file_to_file.cwl/output_file"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#clt_flatten_file_list.cwl",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "baseCommand": [
                "echo",
                "done"
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "id": "#clt_flatten_file_list.cwl/input_list"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputBinding": {
                        "outputEval": "${\n  var flatten = function flatten(ary) {\n      var ret = [];\n      if (ary != null){\n        for(var i = 0; i < ary.length; i++) {\n            if(Array.isArray(ary[i])) {\n                ret = ret.concat(flatten(ary[i]));\n            } else {\n                ret.push(ary[i]);\n            }\n        }\n      }\n      return ret;\n  }\n  var flatin = flatten(inputs.input_list);\n  return flatin;\n}\n"
                    },
                    "id": "#clt_flatten_file_list.cwl/output"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#clt_pass_file.cwl",
            "doc": "Given a file return that file. Used to simplify some pickvalue scenarios.\n",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "coresMin": "$(inputs.cpu)",
                    "ramMin": "$(inputs.ram * 1000)"
                }
            ],
            "baseCommand": [
                "echo",
                "done"
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 1,
                    "doc": "CPUs to allocate to this task.",
                    "id": "#clt_pass_file.cwl/cpu"
                },
                {
                    "type": "File",
                    "id": "#clt_pass_file.cwl/infile"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 2,
                    "doc": "RAM (in GB) to allocate to this task.",
                    "id": "#clt_pass_file.cwl/ram"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "outputEval": "$(inputs.infile)\n"
                    },
                    "id": "#clt_pass_file.cwl/outfile"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#cns_to_aa_bed.cwl",
            "doc": "Basic tool to convert the raw .cns output from CNVkit for use in prepare_aa",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "jluebeck/prepareaa:v0.1203.10"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 8000,
                    "coresMin": 4
                }
            ],
            "baseCommand": [
                "/home/programs/PrepareAA-master/scripts/convert_cns_to_bed.py"
            ],
            "inputs": [
                {
                    "type": "File",
                    "doc": "CNVkit raw cns file to convert",
                    "inputBinding": {
                        "position": 1,
                        "prefix": "--cns_file"
                    },
                    "id": "#cns_to_aa_bed.cwl/input_cns"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*_ESTIMATED_PLOIDY_CORRECTED_CN.bed"
                    },
                    "id": "#cns_to_aa_bed.cwl/aa_cns_bed"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#cnvkit_access.cwl",
            "doc": "Calculate the sequence-accessible coordinates in chromosomes from the given\nreference genome, output as a BED file.\n\nMany fully sequenced genomes, including the human genome, contain large regions\nof DNA that are inaccessable to sequencing. (These are mainly the centromeres,\ntelomeres, and highly repetitive regions.) In the reference genome sequence\nthese regions are filled in with large stretches of \u201cN\u201d characters. These\nregions cannot be mapped by resequencing, so CNVkit avoids them when\ncalculating the antitarget bin locations.\n\nThe access command computes the locations of the accessible sequence regions\nfor a given reference genome based on these masked-out sequences, treating long\nspans of \u2018N\u2019 characters as the inaccessible regions and outputting the\ncoordinates of the regions between them.\n\nOther known unmappable, variable, or poorly sequenced regions can be excluded\nwith the -x/--exclude option. This option can be used more than once to exclude\nseveral BED files listing different sets of regions.\n",
            "requirements": [
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "etal/cnvkit:0.9.3"
                },
                {
                    "class": "ResourceRequirement",
                    "coresMin": "$(inputs.cpu)",
                    "ramMin": "$(inputs.ram * 1000)"
                }
            ],
            "baseCommand": [
                "cnvkit.py",
                "access"
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 8,
                    "doc": "CPUs to allocate to this task.",
                    "id": "#cnvkit_access.cwl/cpu"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--exclude"
                    },
                    "doc": "Additional regions to exclude, in BED format. Can be used multiple times.",
                    "id": "#cnvkit_access.cwl/exclude"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--min-gap-size"
                    },
                    "doc": "Minimum gap size between accessible sequence regions. Regions separated by less than this distance will be joined together.",
                    "id": "#cnvkit_access.cwl/min_gap_size"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "default": "access.bed",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--output"
                    },
                    "doc": "Name for output BED file.",
                    "id": "#cnvkit_access.cwl/output_filename"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "doc": "GB of RAM to allocate to this task.",
                    "id": "#cnvkit_access.cwl/ram"
                },
                {
                    "type": "File",
                    "inputBinding": {
                        "position": 9
                    },
                    "doc": "Reference FASTA",
                    "id": "#cnvkit_access.cwl/reference_fasta"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "$(inputs.output_filename)"
                    },
                    "id": "#cnvkit_access.cwl/bed"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#cnvkit_batch.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "images.sbgenomics.com/milos_nikolic/cnvkit:0.9.3"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 32000,
                    "coresMin": "$(inputs.threads)"
                }
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "ln -s $(inputs.input_sample.path) .; ln -s $(inputs.input_sample.secondaryFiles[0].path) ./$(inputs.input_sample.basename).bai\n${ \n    var cmd = \"\";\n    if (inputs.input_control != null) {\n        cmd = \"ln -s \" + inputs.input_control.path + \" .; ln -s \" + inputs.input_control.secondaryFiles[0].path + \" ./\" + inputs.input_control.basename + \".bai\"\n    }\n    return cmd;\n}\ncnvkit.py batch -p $(inputs.threads) ${\n    var cmd = \"\";\n    if (inputs.wgs_mode == 'Y') {\n        cmd = \" -m wgs \";\n    }\n    return cmd;\n} $(inputs.access != null ? \"--access \" + inputs.access.path : \"\") $(inputs.input_sample.path) ${\n    var cmd = \"\";\n    if (inputs.capture_regions != null && inputs.wgs_mode != 'Y') {\n        cmd = \"--targets \" + inputs.capture_regions.path;\n    }\n    return cmd;\n} ${\n  if (inputs.cnvkit_cnn == null){\n    var arg = \"--output-reference \" + inputs.output_basename + \"_cnvkit_reference.cnn --fasta \" + inputs.reference.path + \" --annotate \" + inputs.annotation_file.path;\n    if (inputs.input_control != null) {\n        arg += \" --normal \" + inputs.input_control.path;\n    }\n  }\n  else{\n    var arg = \"--reference \" + inputs.cnvkit_cnn.path;\n    var msex = ['m','y','male','Male']\n    if (msex.indexOf(inputs.sex) >= 0){\n      arg += \" --male-reference\";\n    }\n  }\n  return arg;\n} --diagram  --scatter\ncnvkit.py call $(inputs.input_sample.nameroot).cns ${\n  var arg = \"\";\n  if (inputs.b_allele_vcf != null){\n    arg = \"--vcf \" + inputs.b_allele_vcf.path;\n  }\n  return arg;\n} ${\n  var arg = \"--sample-sex \" + inputs.sex;\n  var msex = ['m','y','male','Male']\n  if (msex.indexOf(inputs.sex) >= 0){\n    arg += \" --male-reference\";\n  }\n  return arg;\n} -o $(inputs.output_basename).call.cns\n      \nln -s $(inputs.output_basename).call.cns $(inputs.tumor_sample_name).cns\ncnvkit.py export seg $(inputs.tumor_sample_name).cns -o $(inputs.output_basename).call.seg\nrm $(inputs.tumor_sample_name).cns\ncnvkit.py metrics $(inputs.input_sample.nameroot).cnr -s $(inputs.input_sample.nameroot).cns -o $(inputs.output_basename).metrics.txt\ncnvkit.py gainloss $(inputs.input_sample.nameroot).cnr -o $(inputs.output_basename).gainloss.txt\nmv $(inputs.input_sample.nameroot).cnr $(inputs.output_basename).cnr\nmv $(inputs.input_sample.nameroot)-diagram.pdf $(inputs.output_basename).diagram.pdf\nmv $(inputs.input_sample.nameroot)-scatter.pdf $(inputs.output_basename).scatter.pdf"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Regions of accessible sequence on chromosomes (.bed), as output by the 'access' command.",
                    "id": "#cnvkit_batch.cwl/access"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "refFlat.txt file,  needed if cnv kit cnn not already built",
                    "id": "#cnvkit_batch.cwl/annotation_file"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "b allele germline vcf, if available",
                    "id": "#cnvkit_batch.cwl/b_allele_vcf"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "target regions for WES",
                    "id": "#cnvkit_batch.cwl/capture_regions"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "If running using an existing .cnn, supply here",
                    "id": "#cnvkit_batch.cwl/cnvkit_cnn"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "normal bam file",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": "bai",
                            "required": false
                        }
                    ],
                    "id": "#cnvkit_batch.cwl/input_control"
                },
                {
                    "type": "File",
                    "doc": "tumor bam file",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": "bai",
                            "required": false
                        }
                    ],
                    "id": "#cnvkit_batch.cwl/input_sample"
                },
                {
                    "type": "string",
                    "id": "#cnvkit_batch.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "fasta file, needed if cnv kit cnn not already built",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#cnvkit_batch.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#cnvkit_batch.cwl/sex/sex",
                            "symbols": [
                                "#cnvkit_batch.cwl/sex/sex/x",
                                "#cnvkit_batch.cwl/sex/sex/y"
                            ]
                        }
                    ],
                    "doc": "Sex, for simplicity x for female y for male",
                    "default": "x",
                    "id": "#cnvkit_batch.cwl/sex"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
                    "id": "#cnvkit_batch.cwl/threads"
                },
                {
                    "type": "string",
                    "id": "#cnvkit_batch.cwl/tumor_sample_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "for WGS mode, input Y. leave blank for hybrid mode",
                    "id": "#cnvkit_batch.cwl/wgs_mode"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.call.cns"
                    },
                    "id": "#cnvkit_batch.cwl/output_calls"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_reference.cnn"
                    },
                    "doc": "Output if starting from cnn scratch.  Should not appear if an existing .cnn was given as input.",
                    "id": "#cnvkit_batch.cwl/output_cnn"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.cnr"
                    },
                    "id": "#cnvkit_batch.cwl/output_cnr"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "$(inputs.input_sample.nameroot).cns"
                    },
                    "id": "#cnvkit_batch.cwl/output_cns"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.diagram.pdf"
                    },
                    "id": "#cnvkit_batch.cwl/output_diagram"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.gainloss.txt"
                    },
                    "id": "#cnvkit_batch.cwl/output_gainloss"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.metrics.txt"
                    },
                    "id": "#cnvkit_batch.cwl/output_metrics"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.scatter.pdf"
                    },
                    "id": "#cnvkit_batch.cwl/output_scatter"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.seg"
                    },
                    "id": "#cnvkit_batch.cwl/output_seg"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#cnvkit_batch_only.cwl",
            "doc": "This tools is a bit more restrictive than the cnvkit_batch.cwl, meant to be run to get needed .cns file when needed",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "images.sbgenomics.com/milos_nikolic/cnvkit:0.9.3"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 32000,
                    "coresMin": "$(inputs.threads)"
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        "$(inputs.input_sample)",
                        "$(inputs.input_control)"
                    ]
                }
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "cnvkit.py batch ${\n  if (inputs.cnvkit_cnn == null){\n    return \"--output-reference \" + inputs.output_basename + \"_cnvkit_reference.cnn\";\n  }\n  else{\n      return \"\";\n  }\n}"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "refFlat.txt file, needed if cnv kit cnn not already built",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--annotate"
                    },
                    "id": "#cnvkit_batch_only.cwl/annotation_file"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "target regions for WES",
                    "inputBinding": {
                        "prefix": "--targets",
                        "position": 2
                    },
                    "id": "#cnvkit_batch_only.cwl/capture_regions"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "If running using an existing .cnn, supply here",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--reference"
                    },
                    "id": "#cnvkit_batch_only.cwl/cnvkit_cnn"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "prefix": "--diagram",
                        "position": 2
                    },
                    "doc": "Create an ideogram of copy ratios on chromosomes as a PDF.",
                    "id": "#cnvkit_batch_only.cwl/diagram_plot"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "normal bam file - can skip in .cnn file supplied",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--normal"
                    },
                    "id": "#cnvkit_batch_only.cwl/input_control"
                },
                {
                    "type": "File",
                    "doc": "tumor bam file",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".bai",
                            "required": false
                        }
                    ],
                    "inputBinding": {
                        "position": 1
                    },
                    "id": "#cnvkit_batch_only.cwl/input_sample"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Is the input male?",
                    "default": false,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--male-reference"
                    },
                    "id": "#cnvkit_batch_only.cwl/male_input_flag"
                },
                {
                    "type": "string",
                    "id": "#cnvkit_batch_only.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "fasta file, needed if cnv kit cnn not already built",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "inputBinding": {
                        "position": 2,
                        "prefix": "--fasta"
                    },
                    "id": "#cnvkit_batch_only.cwl/reference"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#cnvkit_batch_only.cwl/run_mode/wgs_mode",
                            "symbols": [
                                "#cnvkit_batch_only.cwl/run_mode/wgs_mode/wgs",
                                "#cnvkit_batch_only.cwl/run_mode/wgs_mode/hybrid",
                                "#cnvkit_batch_only.cwl/run_mode/wgs_mode/amplicon"
                            ]
                        }
                    ],
                    "doc": "Choose rum method",
                    "default": "wgs",
                    "inputBinding": {
                        "position": 2,
                        "prefix": "-m"
                    },
                    "id": "#cnvkit_batch_only.cwl/run_mode"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "inputBinding": {
                        "prefix": "--scatter",
                        "position": 2
                    },
                    "doc": "Create a whole-genome copy ratio profile as a PDF scatter plot.",
                    "id": "#cnvkit_batch_only.cwl/scatter_plot"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Num threads to use",
                    "default": 16,
                    "inputBinding": {
                        "position": 2,
                        "prefix": "-p"
                    },
                    "id": "#cnvkit_batch_only.cwl/threads"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_reference.cnn"
                    },
                    "doc": "Output if starting from cnn scratch. Should not appear if an existing .cnn was given as input.",
                    "id": "#cnvkit_batch_only.cwl/output_cnn"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.cnr"
                    },
                    "id": "#cnvkit_batch_only.cwl/output_cnr"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.cns"
                    },
                    "id": "#cnvkit_batch_only.cwl/output_cns"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*-diagram.pdf"
                    },
                    "id": "#cnvkit_batch_only.cwl/output_diagram"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*-scatter.pdf"
                    },
                    "id": "#cnvkit_batch_only.cwl/output_scatter"
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#cnvkit_export_theta2.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "images.sbgenomics.com/milos_nikolic/cnvkit:0.9.3"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 16000,
                    "coresMin": 4
                }
            ],
            "baseCommand": [
                "cnvkit.py",
                "export",
                "theta"
            ],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "-r $(inputs.reference_cnn.path) -v $(inputs.paired_vcf.path) -i $(inputs.tumor_ID) -n $(inputs.normal_ID) $(inputs.tumor_cns.path)"
                }
            ],
            "inputs": [
                {
                    "type": "string",
                    "id": "#cnvkit_export_theta2.cwl/normal_ID"
                },
                {
                    "type": "File",
                    "id": "#cnvkit_export_theta2.cwl/paired_vcf"
                },
                {
                    "type": "File",
                    "id": "#cnvkit_export_theta2.cwl/reference_cnn"
                },
                {
                    "type": "string",
                    "id": "#cnvkit_export_theta2.cwl/tumor_ID"
                },
                {
                    "type": "File",
                    "id": "#cnvkit_export_theta2.cwl/tumor_cns"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.call.interval_count"
                    },
                    "id": "#cnvkit_export_theta2.cwl/call_interval_count"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.call.normal.snp_formatted.txt"
                    },
                    "id": "#cnvkit_export_theta2.cwl/call_normal_snp"
                },
                {
                    "type": "File",
                    "outputBinding": {
                        "glob": "*.call.tumor.snp_formatted.txt"
                    },
                    "id": "#cnvkit_export_theta2.cwl/call_tumor_snp"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#cnvkit_import_theta2.cwl",
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "images.sbgenomics.com/milos_nikolic/cnvkit:0.9.3"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": 8000,
                    "coresMin": 4
                }
            ],
            "baseCommand": [],
            "arguments": [
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "${\n  if (inputs.theta2_n2_results == null){\n    return \"echo Theta 2 input is null, skipping purity adjustment >&2; exit 0;\"\n  }\n  else{\n    return \"echo running Theta 2;\";\n  }\n}\ncnvkit.py import-theta $(inputs.tumor_cns.path) $(inputs.theta2_n2_results != null ? inputs.theta2_n2_results.path : \"\") -d ./\nmv $(inputs.tumor_cns.basename.replace('.call.cns','')).call-1.cns ${return inputs.output_basename}.theta2.total.cns\nln -s ${return inputs.output_basename}.theta2.total.cns ${return inputs.tumor_sample_name}.cns\ncnvkit.py export seg ${return inputs.tumor_sample_name}.cns -o ${return inputs.output_basename}.theta2.total.seg\nrm ${return inputs.tumor_sample_name}.cns\ncnvkit.py import-theta $(inputs.tumor_cns.path) $(inputs.theta2_best_results != null ? inputs.theta2_best_results.path : \"\") -d ./\nmv $(inputs.tumor_cns.basename.replace('.call.cns','')).call-1.cns ${return inputs.output_basename}.theta2.subclone1.cns\nln -s ${return inputs.output_basename}.theta2.subclone1.cns ${return inputs.tumor_sample_name}.cns\ncnvkit.py export seg ${return inputs.tumor_sample_name}.cns -o ${return inputs.output_basename}.theta2.subclone1.seg\nrm ${return inputs.tumor_sample_name}.cns\nSC2=${return inputs.output_basename}.call-2.cns;\nif [ -f \"$SC2\" ]; then\n    mv ${return inputs.output_basename}.call-2.cns ${return inputs.output_basename}.theta2.subclone2.cns;\n    ln -s ${return inputs.output_basename}.theta2.subclone2.cns ${return inputs.tumor_sample_name}.cns;\n    cnvkit.py export seg ${return inputs.tumor_sample_name}.cns -o ${return inputs.output_basename}.theta2.subclone2.seg;\n    rm ${return inputs.tumor_sample_name}.cns;\nelse\n  echo \"second subclone file not found. Skipping!\" >&2;\nfi"
                }
            ],
            "inputs": [
                {
                    "type": "string",
                    "id": "#cnvkit_import_theta2.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "id": "#cnvkit_import_theta2.cwl/theta2_best_results"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "id": "#cnvkit_import_theta2.cwl/theta2_n2_results"
                },
                {
                    "type": "File",
                    "id": "#cnvkit_import_theta2.cwl/tumor_cns"
                },
                {
                    "type": "string",
                    "id": "#cnvkit_import_theta2.cwl/tumor_sample_name"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.theta2.total.cns"
                    },
                    "id": "#cnvkit_import_theta2.cwl/theta2_adjusted_cns"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.theta2.total.seg"
                    },
                    "id": "#cnvkit_import_theta2.cwl/theta2_adjusted_seg"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputBinding": {
                        "glob": "*.theta2.subclone*.cns"
                    },
                    "id": "#cnvkit_import_theta2.cwl/theta2_subclone_cns"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputBinding": {
                        "glob": "*.theta2.subclone*.seg"
                    },
                    "id": "#cnvkit_import_theta2.cwl/theta2_subclone_seg"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "CommandLineTool",
            "id": "#control-freec-11-6-sbg.cwl",
            "baseCommand": [],
            "inputs": [
                {
                    "id": "#control-freec-11-6-sbg.cwl/GC_content_profile",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "GC content profile",
                    "doc": "GC-content profile for a given window-size.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comfileTypes": "CNP"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/bed_graph_output",
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "label": "Bed Graph output",
                    "doc": "Set \"BedGraphOutput=TRUE\" if you want an additional output in BedGraph format for the UCSC genome browser.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "FALSE"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/break_point_threshold",
                    "type": [
                        "null",
                        "float"
                    ],
                    "label": "Break point threshold",
                    "doc": "Positive value of threshold for segmentation of normalized profiles. The closer it is to zero, the more breakpoints will be called. Its recommended value is between 0.1 and 1.2.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "0.8"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/break_point_type",
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "symbols": [
                                "#control-freec-11-6-sbg.cwl/break_point_type/break_point_type/0",
                                "#control-freec-11-6-sbg.cwl/break_point_type/break_point_type/1",
                                "#control-freec-11-6-sbg.cwl/break_point_type/break_point_type/2",
                                "#control-freec-11-6-sbg.cwl/break_point_type/break_point_type/3",
                                "#control-freec-11-6-sbg.cwl/break_point_type/break_point_type/4"
                            ],
                            "name": "#control-freec-11-6-sbg.cwl/break_point_type/break_point_type"
                        }
                    ],
                    "label": "Break point type",
                    "doc": "Desired behavior in the ambiguous regions (poly-N or low mappability regions between two different copy number values). 0: the \"unknown\" region is attached to the \"known\" region on the right  1: make a separate fragment of this \u201cunknown\u201d region and then attaches it to the left or to the right region choosing the longer one  2: make a separate fragment of this \u201cunknown\u201d region and then attaches it to the left or to the right region but the \u201cploidy\u201d copy number has a priority  3: make a separate fragment of this \u201cunknown\u201d region and then attaches it to the left or to the right region choosing the longer one but this \u201cknown\u201d region should make at least half-size of the \u201cunknown\u201d region  4: make a separate fragment of this \u201cunknown\u201d region and do not assign any copy number to this region at all",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "2"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/capture_regions",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "Capture regions",
                    "doc": "Capture regions in .bed format; sorted .bed file should contain the following colomns: chr   0-based start   1-based end.",
                    "https://sevenbridges.comcategory": "Target",
                    "https://sevenbridges.comfileTypes": "BED"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/chr_len",
                    "type": "File",
                    "label": "Chromosomes length file",
                    "doc": "Chromosome length file in a tab-delimited format.",
                    "https://sevenbridges.comcategory": "File Input",
                    "https://sevenbridges.comfileTypes": "TXT, LEN, SIZES"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/coeff_var",
                    "type": [
                        "null",
                        "float"
                    ],
                    "label": "Coefficient of variation",
                    "doc": "Coefficient of variation to evaluate necessary window size.",
                    "https://sevenbridges.comtoolDefaultValue": "0.05"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/contamination",
                    "type": [
                        "null",
                        "float"
                    ],
                    "label": "Contamination",
                    "doc": "A priori known value of tumor sample contamiantion by normal cells. Set \"contaminationAdjustment=TRUE\" to correct for the contamination.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "0"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/contamination_adjustment",
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "label": "Contamination adjustment",
                    "doc": "Set TRUE to correct for contamination by normal cells. If \"contamination\" is not provided, it will automatically evaluate the level of contamination.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "FALSE"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/degree",
                    "type": [
                        "null",
                        "float"
                    ],
                    "label": "Degree",
                    "doc": "Degree of polynomial.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "3&4 (GC-content based normalization, WGS) or 1 (control-read-count-based normalization, WES)"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/force_GC_content_normalization",
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "symbols": [
                                "#control-freec-11-6-sbg.cwl/force_GC_content_normalization/force_GC_content_normalization/0",
                                "#control-freec-11-6-sbg.cwl/force_GC_content_normalization/force_GC_content_normalization/1",
                                "#control-freec-11-6-sbg.cwl/force_GC_content_normalization/force_GC_content_normalization/2"
                            ],
                            "name": "#control-freec-11-6-sbg.cwl/force_GC_content_normalization/force_GC_content_normalization"
                        }
                    ],
                    "label": "Force GC content normalization",
                    "doc": "Set 1 or 2 to correct the Read Count (RC) for GC-content bias and low mappability even when you have a control sample. 0: simply model \"sample RC ~ Control RC\"  1: normalize the sample and the control RC using GC-content and then calculate the ratio \"Sample RC/contol RC\" 2: model \"sample RC ~ Control RC\" bias, and then normalize for GC-content.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "WGS: 0, WES: 1"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/gem_mappability_file",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "GEM mappability file",
                    "doc": "Mappability file in GEM format.",
                    "https://sevenbridges.comcategory": "File Input",
                    "https://sevenbridges.comfileTypes": "GEM"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/intercept",
                    "type": [
                        "null",
                        "float"
                    ],
                    "label": "Intercept",
                    "doc": "Intercept of polynomial.",
                    "https://sevenbridges.comcategory": "Execution",
                    "https://sevenbridges.comtoolDefaultValue": "1 - with GC-content, 0 - with a control dataset"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/mate_copynumber_file_control",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "Mate copy number file control",
                    "doc": "Raw copy number profile for a given window-size (higher priority than mateFile)  (don't need to provide a mateFile if mateCopyNumberFile is provided).",
                    "https://sevenbridges.comcategory": "Control",
                    "https://sevenbridges.comfileTypes": "CPN"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/mate_copynumber_file_sample",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "Mate copy number file sample",
                    "doc": "Raw copy number profile for a given window-size (higher priority than mateFile)  (don't need to provide a mateFile if mateCopyNumberFile is provided).",
                    "https://sevenbridges.comcategory": "Sample",
                    "https://sevenbridges.comfileTypes": "CPN"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/mate_file_control",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "Mate file Control",
                    "doc": "Mapped reads (can be single end reads, mate-pairs or paired-end reads).",
                    "https://sevenbridges.comcategory": "Control",
                    "https://sevenbridges.comfileTypes": "SAM, BAM, PILEUP, PILEUP.GZ"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/mate_file_sample",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "Mate file Sample",
                    "doc": "Mapped reads (can be single end reads, mate-pairs or paired-end reads).",
                    "https://sevenbridges.comcategory": "Sample",
                    "https://sevenbridges.comfileTypes": "SAM, BAM, PILEUP, PILEUP.GZ"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/mate_orientation_control",
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "symbols": [
                                "#control-freec-11-6-sbg.cwl/mate_orientation_control/mate_orientation_control/0",
                                "#control-freec-11-6-sbg.cwl/mate_orientation_control/mate_orientation_control/RF",
                                "#control-freec-11-6-sbg.cwl/mate_orientation_control/mate_orientation_control/FR",
                                "#control-freec-11-6-sbg.cwl/mate_orientation_control/mate_orientation_control/FF"
                            ],
                            "name": "#control-freec-11-6-sbg.cwl/mate_orientation_control/mate_orientation_control"
                        }
                    ],
                    "label": "Mate orientation control",
                    "doc": "Format of reads (in mateFile). 0 (for single ends), RF (Illumina mate-pairs),  FR (Illumina paired-ends), FF (SOLiD mate-pairs).",
                    "https://sevenbridges.comcategory": "Control"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/mate_orientation_sample",
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "symbols": [
                                "#control-freec-11-6-sbg.cwl/mate_orientation_sample/mate_orientation_sample/0",
                                "#control-freec-11-6-sbg.cwl/mate_orientation_sample/mate_orientation_sample/RF",
                                "#control-freec-11-6-sbg.cwl/mate_orientation_sample/mate_orientation_sample/FR",
                                "#control-freec-11-6-sbg.cwl/mate_orientation_sample/mate_orientation_sample/FF"
                            ],
                            "name": "#control-freec-11-6-sbg.cwl/mate_orientation_sample/mate_orientation_sample"
                        }
                    ],
                    "label": "Mate orientation sample",
                    "doc": "Format of reads (in mateFile). 0 (for single ends), RF (Illumina mate-pairs),  FR (Illumina paired-ends), FF (SOLiD mate-pairs).",
                    "https://sevenbridges.comcategory": "Sample"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/max_expected_GC",
                    "type": [
                        "null",
                        "float"
                    ],
                    "label": "Maximum expected GC",
                    "doc": "Maximal exptected value of the GC-content for the prior evaluation of \"Read Count ~ GC-content\" dependancy.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "0.55 (change only if you run Control-FREEC on a bacterial genome)"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/max_threads",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Maximum threads",
                    "doc": "Number of threads (multi-threading mode).",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "8"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/min_CNA_length",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Minimum CNA length",
                    "doc": "Minimal number of consecutive windows to call a CNA.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "WES: 3, WGS: 1"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/min_expected_GC",
                    "type": [
                        "null",
                        "float"
                    ],
                    "label": "Minimal exptected GC",
                    "doc": "Minimal expected value of the GC-content for the prior evaluation of \"Read Count ~ GC-content\" dependency.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "0.35 (change only if you run Control-FREEC on a bacterial genome)"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/min_map_per_w",
                    "type": [
                        "null",
                        "float"
                    ],
                    "label": "Minimum mappability per window",
                    "doc": "Only windows with fraction of mappable positions higher than or equal to this threshold will be considered  (if \"gemMappabilityFile\" is not provided, one uses the percentage of non-N letters per window).",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "0.85"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/min_subclone_presence",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Minimal subclone presence",
                    "doc": "Detects subclones present in x% of cell population",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "100 (meaning \"do not look for subclones\"). Suggested: 20 (or 0.2) for WGS and 30 (or 0.3) for WES."
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/mini_pileup_control",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "Mini pileup Control",
                    "doc": "Mini pileup file created from the corresponding BAM file dring a previous run of Control-FREEC - providing this file will significantly speed up the whole process.",
                    "https://sevenbridges.comcategory": "Control",
                    "https://sevenbridges.comfileTypes": "PILEUP"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/mini_pileup_sample",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "Mini pileup Sample",
                    "doc": "Mini pileup file created from the corresponding BAM file dring a previous run of Control-FREEC - providing this file will significantly speed up the whole process.",
                    "https://sevenbridges.comcategory": "Sample",
                    "https://sevenbridges.comfileTypes": "PILEUP"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/minimal_coverage_per_position",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Minimal coverage per position",
                    "doc": "Minimal read coverage for a position to be considered in BAF analysis.",
                    "https://sevenbridges.comcategory": "BAF",
                    "https://sevenbridges.comtoolDefaultValue": "0"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/minimal_quality_per_position",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Minimal quality per position",
                    "doc": "Minimal sequencing quality for a position to be considered in BAF analysis. Default: 0; using this option can slow down reading of pileup files.",
                    "https://sevenbridges.comcategory": "BAF",
                    "https://sevenbridges.comtoolDefaultValue": "0"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/noisy_data",
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "label": "Noisy data",
                    "doc": "Set TRUE for target resequencing data (e.g., exome-seq) to avoid false positive predictions due to nonuniform capture.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "FALSE"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/ploidy",
                    "type": {
                        "type": "array",
                        "items": "int"
                    },
                    "label": "Ploidy",
                    "doc": "Genome ploidy. In case of doubt, you can set different values and Control-FREEC will select the one that explains most observed CNAs (eg. 2,3,4)",
                    "https://sevenbridges.comcategory": "General"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/print_NA",
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "label": "Print NA",
                    "doc": "Set FALSE to avoid printing \"-1\" to the _ratio.txt files Useful for exome-seq or targeted sequencing data.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "TRUE"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/read_cnt_threshold",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Read count threshold",
                    "doc": "Threshold on the minimal number of reads per window in the control sample Useful for exome-seq or targeted sequencing data.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "10; recommended value >=50 for for exome data"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/reference",
                    "type": "File",
                    "label": "Reference file",
                    "doc": "Reference file that will be divided as needed to separate chromosomes and contigs.",
                    "https://sevenbridges.comcategory": "BAF",
                    "https://sevenbridges.comfileTypes": "FA, FASTA"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/sex",
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "symbols": [
                                "#control-freec-11-6-sbg.cwl/sex/sex/XX",
                                "#control-freec-11-6-sbg.cwl/sex/sex/XY"
                            ],
                            "name": "#control-freec-11-6-sbg.cwl/sex/sex"
                        }
                    ],
                    "label": "Sex",
                    "doc": "Sample sex.",
                    "https://sevenbridges.comcategory": "General"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/shift_in_quality",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Shift in quality",
                    "doc": "Basis for Phred quality. Default: 0; usually 33 or 64; see fastq quality.",
                    "https://sevenbridges.comcategory": "BAF",
                    "https://sevenbridges.comtoolDefaultValue": "0"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/snp_file",
                    "type": [
                        "null",
                        "File"
                    ],
                    "label": "Known SNPs",
                    "doc": "Known SNPs.",
                    "https://sevenbridges.comcategory": "BAF",
                    "https://sevenbridges.comfileTypes": "TXT, VCF"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/step",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Step",
                    "doc": "Step (used only when \"window\" is specified - Ex: 10000).",
                    "https://sevenbridges.comcategory": "General"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/telocentromeric",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Telocentromeric",
                    "doc": "Length of pre-telomeric and pre-centromeric regions: Control-FREEC will not output small CNAs and LOH found within these regions (they are likely to be false because of mappability/genome assembly issues) 50000 is OK for human/mouse genomes. Use smaller values for yeasts and flies.",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "50000"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/total_memory",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Total memory [MB]",
                    "doc": "Total amount of memory in MB reserved on the instance.",
                    "https://sevenbridges.comcategory": "Execution"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/unique_match",
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "label": "Unique match",
                    "doc": "Use a mappability profile to correct read counts (in this case a mappability file must be provided with \"gemMappabilityFile\").",
                    "https://sevenbridges.comcategory": "General",
                    "https://sevenbridges.comtoolDefaultValue": "FALSE"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/window",
                    "type": [
                        "null",
                        "int"
                    ],
                    "label": "Window",
                    "doc": "explicit window size (higher priority than coefficientOfVariation)"
                }
            ],
            "outputs": [
                {
                    "id": "#control-freec-11-6-sbg.cwl/GC_profile",
                    "doc": "GC profile output file.",
                    "label": "GC profile",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "${\n    return \"GC_profile.targetedRegions.cnp\"\n}",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}\n"
                    },
                    "https://sevenbridges.comfileTypes": "CNP"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/cnvs",
                    "doc": "File with coordinates of predicted copy number alterations.",
                    "label": "CNVs output",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_CNVs",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}\n\n"
                    },
                    "https://sevenbridges.comfileTypes": "TXT"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/cnvs_pvalue",
                    "doc": "File with coordinates of predicted copy number alterations with p-values.",
                    "label": "CNVs with p-value",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.p.value.txt",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}\n"
                    },
                    "https://sevenbridges.comfileTypes": "TXT"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/config_script",
                    "doc": "Configuration script used for running.",
                    "label": "Configuration script used for running",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "config.txt",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}\n"
                    },
                    "https://sevenbridges.comfileTypes": "TXT"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/control_cpn",
                    "doc": "Control CPN file to be used in the future for more efficient computation.",
                    "label": "Control CPN",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_control.cpn",
                        "outputEval": "${  if (inputs.mate_file_control){\n    return inheritMetadata(self, inputs.mate_file_control)\n}\n}"
                    },
                    "https://sevenbridges.comfileTypes": "CPN"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/control_pileup",
                    "doc": "Mini Pileup created for BAF calculation. It is used to speed up consequent runs with the same samples.",
                    "label": "Control Pileup",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "${\n    if (inputs.mate_file_control) {\n\n        return inputs.mate_file_control.path.split('/').pop() + '_minipileup.pileup'\n\n    }\n}",
                        "outputEval": "${\n    if (inputs.mate_file_control){\n    return inheritMetadata(self, inputs.mate_file_control)\n}\n}"
                    },
                    "https://sevenbridges.comfileTypes": "PILEUP"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/info_txt",
                    "doc": "Parsable file with information about FREEC run.",
                    "label": "Info TXT",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_info.txt",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}\n"
                    },
                    "https://sevenbridges.comfileTypes": "TXT"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/pngs",
                    "doc": "Visalized normalized copy number profile with predicted CNAs as well as BAF profile (if dbSNP is provided)",
                    "label": "Copy number profile",
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputBinding": {
                        "glob": "*png"
                    },
                    "https://sevenbridges.comfileTypes": "PNG"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/ratio",
                    "doc": "File with ratios and predicted copy number alterations for each window.",
                    "label": "Ratio",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_ratio.txt",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}\n"
                    },
                    "https://sevenbridges.comfileTypes": "TXT"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/ratio_BedGraph",
                    "doc": "File with ratios in BedGraph format for visualization in the UCSC genome browser",
                    "label": "Ratio BedGraph",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*.BedGraph",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}\n"
                    },
                    "https://sevenbridges.comfileTypes": "BEDGRAPH"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/sample_BAF",
                    "doc": "File with B-allele frequencies for each possibly heterozygous SNP position",
                    "label": "BAF sample file",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_BAF.txt",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}\n"
                    },
                    "https://sevenbridges.comfileTypes": "TXT"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/sample_cpn",
                    "doc": "Sample CPN file to be used in the future for more efficient computation.",
                    "label": "Sample CPN",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "*_sample.cpn",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}"
                    },
                    "https://sevenbridges.comfileTypes": "CPN"
                },
                {
                    "id": "#control-freec-11-6-sbg.cwl/sample_pileup",
                    "doc": "Mini Pileup created for BAF calculation. It is used to speed up consequent runs with the same samples.",
                    "label": "Sample Pileup",
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputBinding": {
                        "glob": "${\n    if (inputs.mate_file_sample) {\n\n        return inputs.mate_file_sample.path.split('/').pop() + '_minipileup.pileup'\n    }\n}",
                        "outputEval": "${\n    return inheritMetadata(self, inputs.mate_file_sample)\n\n}"
                    },
                    "https://sevenbridges.comfileTypes": "PILEUP"
                }
            ],
            "doc": "Control-FREEC analyzes copy-number variants and allelic imbalances in exome and whole-genome DNA sequencing.\n\nThis tool automatically computes, normalizes and segments copy number and beta allele frequency (BAF) profiles, then calls copy number alterations and LOH. [1]\n\n*A list of **all inputs and parameters** with corresponding descriptions can be found at the bottom of the page.*\n### Common Use Cases\n\n* The **chrLenFile** input is required and can be found in Public Reference Files as **Homo\\_sapiens\\_assembly38.fasta.sizes**, **ucsc.hg19.fasta.sizes** and **human\\_g1k\\_v37\\_decoy.fasta.sizes**.\n\n* The **ploidy** parameter is required. In case of doubt, different values can be set and Control-FREEC will select the one that explains the most observed CNVs.\n\n* Normal and control sample can be provided through two possible inputs:\n     * **mateFile**, a file with mapped reads\n     * **mateCopyNumberFile**, a raw copy number file created for both normal and control sample, provided through **mateFile** in a first run, and can be reused in the future runs for more efficient computation.\n\n\n\n* **A control (matched normal) sample is optional for whole genome sequencing data but mandatory for whole exome or targeted sequencing data.**\n\n* Similar to **mateCopyNumberFile**, a **Mini pileup Sample** and **Mini pileup Control** files can be created in the first run, if the **Known SNPs** file is provided. Consequently, by providing these files as inputs in future tasks, execution time will decrease significantly.\n\n* If a **mateFile** is specified, the **mateOrientation** parameter must be set.\n\n* In order to create a **BAF profile**, one of the following options must be implemented:\n    * **mateFile** + **Known SNPs** \n    * **mateCopyNumberFile** + **mateFile** + **KnownSNPs**\n    * **mateCopyNumberFile** + **miniPileup** + **KnownSNPs**\n\n### Changes Introduced by Seven Bridges\n\n* Based on the input parameters, a config file is created in order to properly run Control-FREEC.\n\n### Common Issues and Important Notes\n\n* **A control (matched normal) sample is optional for whole genome sequencing data but mandatory for whole exome or targeted sequencing data.**\n\n* A **gemMappabilityFile** can be used only in the mode without a control sample.\n\n* If a **mateFile** is specified, the **mateOrientation** parameter must be set.\n\n* Currently, there is an issue with creating a **BAF sample file** with the b37 notation. The genotypes for CNV regions are, however, created.\n\n\n### Performance Benchmarking\n\nThe instance set for this tool is the AWS c4.2xlarge instance with 8 vCPUs, 15 GiB of RAM and 1 TB of EBS (disk space).\n|     BAM size in GB    | Type |  Instance  | Duration | Cost ($) |\n|:--------------------:|:----:|:----------:|:--------:|:--------:|\n|         2x12 (Normal-Tumor)         |  WES | c4.2xlarge |  1h 52m  |    0.8   |\n|   100 (Tumor-only)   |  WGS | c4.2xlarge |  17h 43m |     7    |\n| 2x100 (Normal-Tumor) |  WGS | c4.2xlarge |   1d 8h  |    13    |\n|   100 (Tumor-only)   |  WGS | c4.8xlarge |  6h 30m |     10    |\n| 2x100 (Normal-Tumor) |  WGS | c4.8xlarge |   11h  |    18    |\n\nAn instance with more resources can be obtained by providing inputs for **Maximum threads** and **Total memory [MB]**.\n\n*Cost can be significantly reduced by using **spot instances**. Visit the [Knowledge Center](https://docs.sevenbridges.com/docs/about-spot-instances) for more details.*  \n\n###References\n[1] [Control-FREEC: Prediction of copy number alterations and loss of heterozygosity using deep-sequencing data](http://boevalab.com/FREEC/tutorial.html#install)",
            "label": "Control-FREEC 11.6",
            "arguments": [
                {
                    "position": 0,
                    "shellQuote": false,
                    "valueFrom": "${\n    // script for splitting the genome fasta into chromosomes\n    return 'python split_fasta.py ' + inputs.reference.path\n\n}"
                },
                {
                    "position": 1,
                    "shellQuote": false,
                    "valueFrom": "&&"
                },
                {
                    "position": 2,
                    "shellQuote": false,
                    "valueFrom": "1>&2 /opt/controlfreec/FREEC/src/freec"
                },
                {
                    "position": 3,
                    "shellQuote": false,
                    "valueFrom": "-conf"
                },
                {
                    "position": 4,
                    "shellQuote": false,
                    "valueFrom": "config.txt"
                },
                {
                    "position": 5,
                    "shellQuote": false,
                    "valueFrom": "&&"
                },
                {
                    "position": 6,
                    "shellQuote": false,
                    "valueFrom": "${\n\n\n\n\n    if (inputs.mate_file_sample) {\n        var filepath = inputs.mate_file_sample.path\n        var filename = filepath.split(\"/\").pop()\n    } else {\n        var filepath = (inputs.mate_copynumber_file_sample ? inputs.mate_copynumber_file_sample.path : \"\")\n        var filename = filepath.split(\"/\").pop()\n    }\n\n    var CNVs = filename + \"_CNVs\"\n    var ratio = filename + \"_ratio\" + \".txt\"\n\n\n    return \"cat assess_significance.R | 1>&2 R --slave --args \" + CNVs + \" \" + ratio\n}"
                },
                {
                    "position": 7,
                    "shellQuote": false,
                    "valueFrom": "&&"
                },
                {
                    "position": 8,
                    "shellQuote": false,
                    "valueFrom": "${\n    return \"line=$(cat *info.txt | grep Output_Ploidy | sed -E 's/.+([0-9]+)/\\\\1/')\"\n}"
                },
                {
                    "position": 9,
                    "shellQuote": false,
                    "valueFrom": "&&"
                },
                {
                    "position": 10,
                    "shellQuote": false,
                    "valueFrom": "${\n    return \"cat makeGraph.R | 1>&2 R --slave --args\"\n}"
                },
                {
                    "position": 11,
                    "shellQuote": false,
                    "valueFrom": "$line"
                },
                {
                    "position": 12,
                    "shellQuote": false,
                    "valueFrom": "${\n    if (inputs.mate_file_sample) {\n        var filepath = inputs.mate_file_sample.path\n        var filename = filepath.split(\"/\").pop()\n    } else {\n        var filepath = (inputs.mate_copynumber_file_sample ? inputs.mate_copynumber_file_sample.path : \"\")\n        var filename = filepath.split(\"/\").pop()\n    }\n\n    var ratio = filename + \"_ratio\" + \".txt\"\n\n    return ratio\n}"
                },
                {
                    "position": 13,
                    "shellQuote": false,
                    "valueFrom": "${\n\n    var new_filename = \"\"\n\n    if (inputs.snp_file) {\n\n        var sufix = \"_BAF\"\n        var sufix_ext = \".txt\"\n\n        if (inputs.mate_file_sample) {\n            var filepath = inputs.mate_file_sample.path\n            var filename = filepath.split(\"/\").pop()\n        } else {\n            var filepath = (inputs.mate_copynumber_file_sample ? inputs.mate_copynumber_file_sample.path : \"\")\n            var filename = filepath.split(\"/\").pop()\n        }\n\n\n        new_filename = filename + sufix + sufix_ext\n\n    }\n\n    return new_filename\n}"
                },
                {
                    "position": 114,
                    "shellQuote": false,
                    "valueFrom": "${ //conversion of file names\n    var com = ''\n    if (inputs.mate_file_control) {\n        if (inputs.mate_file_control.path.split('.').pop() != 'pileup') {\n            com += '&& mv sample.pileup '\n\n        }\n    }\n    return ''\n\n\n}"
                }
            ],
            "requirements": [
                {
                    "class": "ShellCommandRequirement"
                },
                {
                    "class": "ResourceRequirement",
                    "ramMin": "${\n    if (inputs.total_memory) {\n        return inputs.total_memory\n    } else {\n        return 15000\n    }\n}",
                    "coresMin": "${\n    if (inputs.max_threads) {\n        return inputs.max_threads\n    } else {\n        return 8\n    }\n}"
                },
                {
                    "class": "DockerRequirement",
                    "dockerPull": "images.sbgenomics.com/vojislav_varjacic/control-freec-11-6:v1"
                },
                {
                    "class": "InitialWorkDirRequirement",
                    "listing": [
                        {
                            "entryname": "config.txt",
                            "writable": true,
                            "entry": "${\n\n    // The function returns the concatenated line for config file\n    function makeline(content, p1, p2) {\n        if (p2 != null) {\n            if (p2.path != null) {\n                p2 = p2.path\n            }\n            content = content.concat(p1)\n            content = content.concat(\" = \")\n            content = content.concat(p2)\n            content = content.concat(\"\\n\")\n        }\n        return content\n\n    }\n\n    // General section\n    var content = \"[general]\\n\\n\"\n    content = makeline(content, \"BedGraphOutput\", inputs.bed_graph_output)\n    content = content.concat(\"bedtools = /opt/bedtools2/bin/bedtools\\n\")\n    content = makeline(content, \"chrLenFile\", inputs.chr_len)\n    content = makeline(content, \"breakPointThreshold\", inputs.break_point_threshold)\n    content = makeline(content, \"breakPointType\", inputs.break_point_type)\n    content = makeline(content, \"chrFiles\", \".\")\n    content = makeline(content, \"coefficientOfVariation\", inputs.coeff_var)\n\n    if (inputs.capture_regions) {\n        content = content.concat(\"window = 0\\n\")\n    } else {\n        content = makeline(content, \"window\", inputs.window)\n    }\n\n    content = makeline(content, \"contamination\", inputs.contamination)\n    content = makeline(content, \"contaminationAdjustment\", inputs.contamination_adjustment)\n    content = makeline(content, \"degree\", inputs.degree)\n    content = makeline(content, \"forceGCcontentNormalization\", inputs.force_GC_content_normalization)\n    content = makeline(content, \"GCcontentProfile\", inputs.GC_content_profile)\n    content = makeline(content, \"gemMappabilityFile\", inputs.gem_mappability_file)\n    content = makeline(content, \"intercept\", inputs.intercept)\n    content = makeline(content, \"minCNAlength\", inputs.min_CNA_length)\n    content = makeline(content, \"minMappabilityPerWindow\", inputs.min_map_per_w)\n    content = makeline(content, \"minExpectedGC\", inputs.min_expected_GC)\n    content = makeline(content, \"maxExpectedGC\", inputs.max_expected_GC)\n    content = makeline(content, \"minimalSubclonePresence\", inputs.min_subclone_presence)\n    if (inputs.max_threads) {\n        content = makeline(content, \"maxThreads\", inputs.max_threads)\n        content = makeline(content, \"SambambaThreads\", inputs.max_threads)\n    } else {\n        content = content.concat(\"maxThreads = 8\\n\")\n        content = content.concat(\"SambambaThreads = 8\\n\")\n    }\n    content = makeline(content, \"noisyData\", inputs.noisy_data)\n    content = makeline(content, \"ploidy\", inputs.ploidy.toString())\n    content = makeline(content, \"printNA\", inputs.print_NA)\n    content = makeline(content, \"readCountThreshold\", inputs.read_cnt_threshold)\n    content = content.concat(\"sambamba = /opt/sambamba_0.5.9/sambamba_v0.5.9\\n\")\n\n    content = content.concat(\"samtools = /opt/samtools-1.3.1/samtools\\n\")\n    content = makeline(content, \"sex\", inputs.sex)\n    content = makeline(content, \"step\", inputs.step)\n    content = makeline(content, \"telocentromeric\", inputs.telocentromeric)\n    content = makeline(content, \"uniqueMatch\", inputs.unique_match)\n\n\n    // Sample section\n\n    content = content.concat(\"\\n[sample]\\n\\n\")\n    content = makeline(content, \"mateFile\", inputs.mate_file_sample)\n    content = makeline(content, \"mateCopyNumberFile\", inputs.mate_copynumber_file_sample)\n    content = makeline(content, \"miniPileup\", inputs.mini_pileup_sample)\n    if (inputs.mate_file_sample) {\n        if (inputs.mate_file_sample.path.split('.').pop() == \"gz\") {\n            content = makeline(content, \"inputFormat\", inputs.mate_file_sample.path.split('.').slice(-2, -1)[0])\n        } else {\n            content = makeline(content, \"inputFormat\", inputs.mate_file_sample.path.split('.').pop())\n        }\n        content = makeline(content, \"mateOrientation\", inputs.mate_orientation_sample)\n    }\n\n\n    // Control section\n\n    content = content.concat(\"\\n[control]\\n\\n\")\n    content = makeline(content, \"mateFile\", inputs.mate_file_control)\n    content = makeline(content, \"mateCopyNumberFile\", inputs.mate_copynumber_file_control)\n    content = makeline(content, \"miniPileup\", inputs.mini_pileup_control)\n    if (inputs.mate_file_control) {\n        content = makeline(content, \"inputFormat\", inputs.mate_file_control.path.split('.').pop())\n        content = makeline(content, \"mateOrientation\", inputs.mate_orientation_sample)\n    }\n\n\n\n\n    // BAF section\n\n    content = content.concat(\"\\n[BAF]\\n\\n\")\n    content = makeline(content, \"minimalCoveragePerPosition\", inputs.minimal_coverage_per_position)\n    content = makeline(content, \"minimalQualityPerPosition\", inputs.minimal_quality_per_position)\n    content = makeline(content, \"shiftInQuality\", inputs.shift_in_quality)\n    if (inputs.snp_file) {\n        content = makeline(content, \"SNPfile\", inputs.snp_file)\n        if (inputs.mate_file_sample) {\n            if ((inputs.mate_file_sample.path.split('.').pop().toUpperCase() != 'PILEUP') &&\n                (inputs.mate_file_sample.path.split('.').slice(-2, -1)[0].toUpperCase() != 'PILEUP')) {\n                content = makeline(content, \"makePileup\", inputs.snp_file)\n                content = makeline(content, \"fastaFile\", inputs.reference)\n            }\n        }\n    }\n\n    // Target section\n\n    content = content.concat(\"\\n[target]\\n\\n\")\n    content = makeline(content, \"captureRegions\", inputs.capture_regions)\n\n    return content\n}"
                        },
                        {
                            "entryname": "split_fasta.py",
                            "entry": "import sys\n\nwith open(sys.argv[1], \"r\") as f:\n    fasta = f.readlines()\n\nref_lines = {}\nfor i in range(0, len(fasta)):\n    if fasta[i][0] == \">\":\n        chrom = fasta[i].split()[0].split(\">\")[1]\n        print(\"Reading chromosome: \" + chrom)\n        ref_lines[chrom] = [fasta[i]]\n    else:\n        ref_lines[chrom].append(fasta[i])\n\nfor chromosome, lines in ref_lines.items():\n    print(\"Creating \" + chromosome + \".fasta\")\n    with open(chromosome + \".fasta\", \"w\") as chr_fasta:\n        for line in lines:\n            chr_fasta.write(line)",
                            "writable": false
                        },
                        {
                            "entryname": "assess_significance.R",
                            "entry": "#!/usr/bin/env Rscript\n\nlibrary(rtracklayer)\n\nargs <- commandArgs()\n\ndataTable <-read.table(args[5], header=TRUE);\nratio<-data.frame(dataTable)\n\ndataTable <- read.table(args[4], header=FALSE)\ncnvs<- data.frame(dataTable) \n\nratio$Ratio[which(ratio$Ratio==-1)]=NA\n\ncnvs.bed=GRanges(cnvs[,1],IRanges(cnvs[,2],cnvs[,3]))  \nratio.bed=GRanges(ratio$Chromosome,IRanges(ratio$Start,ratio$Start),score=ratio$Ratio)\n\noverlaps <- subsetByOverlaps(ratio.bed,cnvs.bed)\nnormals <- setdiff(ratio.bed,cnvs.bed)\nnormals <- subsetByOverlaps(ratio.bed,normals)\n\n#mu <- mean(score(normals),na.rm=TRUE)\n#sigma<- sd(score(normals),na.rm=TRUE)\n\n#hist(score(normals),n=500,xlim=c(0,2))\n#hist(log(score(normals)),n=500,xlim=c(-1,1))\n\n#shapiro.test(score(normals)[which(!is.na(score(normals)))][5001:10000])\n#qqnorm (score(normals)[which(!is.na(score(normals)))],ylim=(c(0,10)))\n#qqline(score(normals)[which(!is.na(score(normals)))], col = 2)\n\n#shapiro.test(log(score(normals))[which(!is.na(score(normals)))][5001:10000])\n#qqnorm (log(score(normals))[which(!is.na(score(normals)))],ylim=(c(-6,10)))\n#qqline(log(score(normals))[which(!is.na(score(normals)))], col = 2)\n\nnumberOfCol=length(cnvs)\n\nfor (i in c(1:length(cnvs[,1]))) {\n  values <- score(subsetByOverlaps(ratio.bed,cnvs.bed[i]))\n  #wilcox.test(values,mu=mu)\n  W <- function(values,normals){resultw <- try(wilcox.test(values,score(normals)), silent = TRUE)\n\tif(class(resultw)==\"try-error\") return(list(\"statistic\"=NA,\"parameter\"=NA,\"p.value\"=NA,\"null.value\"=NA,\"alternative\"=NA,\"method\"=NA,\"data.name\"=NA)) else resultw}\n  KS <- function(values,normals){resultks <- try(ks.test(values,score(normals)), silent = TRUE)\n\tif(class(resultks)==\"try-error\") return(list(\"statistic\"=NA,\"p.value\"=NA,\"alternative\"=NA,\"method\"=NA,\"data.name\"=NA)) else resultks}\n  #resultks <- try(KS <- ks.test(values,score(normals)), silent = TRUE)\n  #\tif(class(resultks)==\"try-error\") NA) else resultks\n  cnvs[i,numberOfCol+1]=W(values,normals)$p.value\n  cnvs[i,numberOfCol+2]=KS(values,normals)$p.value\n  }\n\nif (numberOfCol==5) {\n  names(cnvs)=c(\"chr\",\"start\",\"end\",\"copy number\",\"status\",\"WilcoxonRankSumTestPvalue\",\"KolmogorovSmirnovPvalue\")  \n}\nif (numberOfCol==7) {\n  names(cnvs)=c(\"chr\",\"start\",\"end\",\"copy number\",\"status\",\"genotype\",\"uncertainty\",\"WilcoxonRankSumTestPvalue\",\"KolmogorovSmirnovPvalue\")  \n}\nif (numberOfCol==9) {\n  names(cnvs)=c(\"chr\",\"start\",\"end\",\"copy number\",\"status\",\"genotype\",\"uncertainty\",\"somatic/germline\",\"precentageOfGermline\",\"WilcoxonRankSumTestPvalue\",\"KolmogorovSmirnovPvalue\")  \n}\nwrite.table(cnvs, file=paste(args[4],\".p.value.txt\",sep=\"\"),sep=\"\\t\",quote=F,row.names=F)",
                            "writable": false
                        },
                        {
                            "entryname": "makeGraph.R",
                            "entry": "#!/usr/bin/env Rscript\n\nargs <- commandArgs()\n\ndataTable <-read.table(args[5], header=TRUE);\n\nratio<-data.frame(dataTable)\nploidy <- type.convert(args[4])\n\n\npng(filename = paste(args[5],\".log2.png\",sep = \"\"), width = 1180, height = 1180,\n    units = \"px\", pointsize = 20, bg = \"white\", res = NA)\nplot(1:10)\nop <- par(mfrow = c(5,5))\n\nfor (i in c(1:22,'X','Y')) {\n\ttt <- which(ratio$Chromosome==i)\n\tif (length(tt)>0) {\n\t plot(ratio$Start[tt],log2(ratio$Ratio[tt]),xlab = paste (\"position, chr\",i),ylab = \"normalized copy number profile (log2)\",pch = \".\",col = colors()[88])\n\t tt <- which(ratio$Chromosome==i  & ratio$CopyNumber>ploidy )\n\t points(ratio$Start[tt],log2(ratio$Ratio[tt]),pch = \".\",col = colors()[136])\n\t\n\t\n\ttt <- which(ratio$Chromosome==i  & ratio$CopyNumber<ploidy & ratio$CopyNumber!= -1)\n\t points(ratio$Start[tt],log2(ratio$Ratio[tt]),pch = \".\",col = colors()[461])\n\t tt <- which(ratio$Chromosome==i)\n\t \n\t #UNCOMMENT HERE TO SEE THE PREDICTED COPY NUMBER LEVEL:\n\t #points(ratio$Start[tt],log2(ratio$CopyNumber[tt]/ploidy), pch = \".\", col = colors()[24],cex=4)\n\t \n\t}\n\ttt <- which(ratio$Chromosome==i)\n\t\n\t#UNCOMMENT HERE TO SEE THE EVALUATED MEDIAN LEVEL PER SEGMENT:\n\tpoints(ratio$Start[tt],log2(ratio$MedianRatio[tt]), pch = \".\", col = colors()[463],cex=4)\n\t\n}\n\ndev.off()\n\n\npng(filename = paste(args[5],\".png\",sep = \"\"), width = 1180, height = 1180,\n    units = \"px\", pointsize = 20, bg = \"white\", res = NA)\nplot(1:10)\nop <- par(mfrow = c(5,5))\n\nmaxLevelToPlot <- 3\nfor (i in c(1:length(ratio$Ratio))) {\n\tif (ratio$Ratio[i]>maxLevelToPlot) {\n\t\tratio$Ratio[i]=maxLevelToPlot;\n\t}\n}\n\n\nfor (i in c(1:22,'X','Y')) {\n\ttt <- which(ratio$Chromosome==i)\n\tif (length(tt)>0) {\n\t plot(ratio$Start[tt],ratio$Ratio[tt]*ploidy,ylim = c(0,maxLevelToPlot*ploidy),xlab = paste (\"position, chr\",i),ylab = \"normalized copy number profile\",pch = \".\",col = colors()[88])\n\t tt <- which(ratio$Chromosome==i  & ratio$CopyNumber>ploidy )\n\t points(ratio$Start[tt],ratio$Ratio[tt]*ploidy,pch = \".\",col = colors()[136])\n\t\n\ttt <- which(ratio$Chromosome==i  & ratio$Ratio==maxLevelToPlot & ratio$CopyNumber>ploidy)\t\n\tpoints(ratio$Start[tt],ratio$Ratio[tt]*ploidy,pch = \".\",col = colors()[136],cex=4)\n\t \n\ttt <- which(ratio$Chromosome==i  & ratio$CopyNumber<ploidy & ratio$CopyNumber!= -1)\n\t points(ratio$Start[tt],ratio$Ratio[tt]*ploidy,pch = \".\",col = colors()[461])\n\t tt <- which(ratio$Chromosome==i)\n\t \n\t #UNCOMMENT HERE TO SEE THE PREDICTED COPY NUMBER LEVEL:\n\t #points(ratio$Start[tt],ratio$CopyNumber[tt], pch = \".\", col = colors()[24],cex=4)\n\t \n\t}\n\ttt <- which(ratio$Chromosome==i)\n\t\n\t#UNCOMMENT HERE TO SEE THE EVALUATED MEDIAN LEVEL PER SEGMENT:\n\tpoints(ratio$Start[tt],ratio$MedianRatio[tt]*ploidy, pch = \".\", col = colors()[463],cex=4)\n\t\n}\n\ndev.off()\n\n\n\n\nif (length(args)>5) {\n\tdataTable <-read.table(args[6], header=TRUE);\n\tBAF<-data.frame(dataTable)\n\n\tpng(filename = paste(args[6],\".png\",sep = \"\"), width = 1180, height = 1180,\n\t    units = \"px\", pointsize = 20, bg = \"white\", res = NA)\n\tplot(1:10)\n\top <- par(mfrow = c(5,5))\n\n\tfor (i in c(1:22,'X','Y')) {\n\t    tt <- which(BAF$Chromosome==i)\n\t    if (length(tt)>0){\n\t\tlBAF <-BAF[tt,]\n\t\tplot(lBAF$Position,lBAF$BAF,ylim = c(-0.1,1.1),xlab = paste (\"position, chr\",i),ylab = \"BAF\",pch = \".\",col = colors()[1])\n\n\t\ttt <- which(lBAF$A==0.5)\t\t\n\t\tpoints(lBAF$Position[tt],lBAF$BAF[tt],pch = \".\",col = colors()[92])\n\t\ttt <- which(lBAF$A!=0.5 & lBAF$A>=0)\n\t\tpoints(lBAF$Position[tt],lBAF$BAF[tt],pch = \".\",col = colors()[62])\n\t\ttt <- 1\n\t\tpres <- 1\n\n\t\tif (length(lBAF$A)>4) {\n\t\t\tfor (j in c(2:(length(lBAF$A)-pres-1))) {\n\t\t\t\tif (lBAF$A[j]==lBAF$A[j+pres]) {\t\n\t\t\t\t\ttt[length(tt)+1] <- j \n\t\t\t\t}\n\t\t\t}\n\t\t\tpoints(lBAF$Position[tt],lBAF$A[tt],pch = \".\",col = colors()[24],cex=4)\n\t\t\tpoints(lBAF$Position[tt],lBAF$B[tt],pch = \".\",col = colors()[24],cex=4)\t\n\t\t}\n\n\t\ttt <- 1\n\t\tpres <- 1\n\t\tif (length(lBAF$FittedA)>4) {\n\t\t\tfor (j in c(2:(length(lBAF$FittedA)-pres-1))) {\n\t\t\t\tif (lBAF$FittedA[j]==lBAF$FittedA[j+pres]) {\t\n\t\t\t\t\ttt[length(tt)+1] <- j \n\t\t\t\t}\n\t\t\t}\n\t\t\tpoints(lBAF$Position[tt],lBAF$FittedA[tt],pch = \".\",col = colors()[463],cex=4)\n\t\t\tpoints(lBAF$Position[tt],lBAF$FittedB[tt],pch = \".\",col = colors()[463],cex=4)\t\n\t\t}\n\n\t   }\n\n\t}\n\tdev.off()\n\n}",
                            "writable": false
                        }
                    ]
                },
                {
                    "class": "InlineJavascriptRequirement",
                    "expressionLib": [
                        "var updateMetadata = function(file, key, value) {\n    file['metadata'][key] = value;\n    return file;\n};\n\n\nvar setMetadata = function(file, metadata) {\n    if (!('metadata' in file)) {\n        file['metadata'] = {}\n    }\n    for (var key in metadata) {\n        file['metadata'][key] = metadata[key];\n    }\n    return file\n};\n\nvar inheritMetadata = function(o1, o2) {\n    var commonMetadata = {};\n    if (!Array.isArray(o2)) {\n        o2 = [o2]\n    }\n    for (var i = 0; i < o2.length; i++) {\n        var example = o2[i]['metadata'];\n        for (var key in example) {\n            if (i == 0)\n                commonMetadata[key] = example[key];\n            else {\n                if (!(commonMetadata[key] == example[key])) {\n                    delete commonMetadata[key]\n                }\n            }\n        }\n    }\n    if (!Array.isArray(o1)) {\n        o1 = setMetadata(o1, commonMetadata)\n    } else {\n        for (var i = 0; i < o1.length; i++) {\n            o1[i] = setMetadata(o1[i], commonMetadata)\n        }\n    }\n    return o1;\n};\n\nvar toArray = function(file) {\n    return [].concat(file);\n};\n\nvar groupBy = function(files, key) {\n    var groupedFiles = [];\n    var tempDict = {};\n    for (var i = 0; i < files.length; i++) {\n        var value = files[i]['metadata'][key];\n        if (value in tempDict)\n            tempDict[value].push(files[i]);\n        else tempDict[value] = [files[i]];\n    }\n    for (var key in tempDict) {\n        groupedFiles.push(tempDict[key]);\n    }\n    return groupedFiles;\n};\n\nvar orderBy = function(files, key, order) {\n    var compareFunction = function(a, b) {\n        if (a['metadata'][key].constructor === Number) {\n            return a['metadata'][key] - b['metadata'][key];\n        } else {\n            var nameA = a['metadata'][key].toUpperCase();\n            var nameB = b['metadata'][key].toUpperCase();\n            if (nameA < nameB) {\n                return -1;\n            }\n            if (nameA > nameB) {\n                return 1;\n            }\n            return 0;\n        }\n    };\n\n    files = files.sort(compareFunction);\n    if (order == undefined || order == \"asc\")\n        return files;\n    else\n        return files.reverse();\n};"
                    ]
                }
            ],
            "successCodes": [
                0
            ],
            "temporaryFailCodes": [
                1
            ],
            "https://sevenbridges.comcategories": [
                "Copy-Number-Analysis"
            ],
            "https://sevenbridges.comcmdPreview": "python split_fasta.py pat/sbgpro/path/to/reference.ext && /opt/controlfreec/FREEC-11.5/src/freec -conf config.txt && cat assess_significance.R | R --slave --args chr_19.noDup0.pileup.gz_CNVs chr_19.noDup0.pileup.gz_ratio.txt && line=$(cat *info.txt | grep Output_Ploidy | sed -E 's/.+([0-9]+)/\\1/') && cat makeGraph.R | R --slave --args $line chr_19.noDup0.pileup.gz_ratio.txt chr_19.noDup0.pileup.gz_BAF.txt",
            "https://sevenbridges.comimage_url": null,
