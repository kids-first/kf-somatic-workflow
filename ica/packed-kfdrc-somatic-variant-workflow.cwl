            "hints": [
                {
                    "class": "https://sevenbridges.commaxNumberOfParallelInstances",
                    "value": 2
                }
            ],
            "https://sevenbridges.comlicense": "Apache License 2.0",
            "https://sevenbridges.compublisher": "KFDRC",
            "https://sevenbridges.comcategories": [
                "BAM",
                "CNV",
                "COUNTS",
                "CRAM",
                "FUNCOTATOR",
                "HDF5",
                "NORMAL",
                "PON",
                "SEG",
                "SOMATIC",
                "TUMOR"
            ],
            "https://sevenbridges.comlinks": [
                {
                    "id": "#v0.2.0",
                    "label": "github-release"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc_lancet_sub_wf.cwl",
            "doc": "Lancet sub workflow, meant to be wrapped",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "SubworkflowFeatureRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Set to true if input is a strelka2 vcf that hasn't had common fields added",
                    "default": false,
                    "id": "#kfdrc_lancet_sub_wf.cwl/add_common_fields"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Will hard filter final result to create a public version",
                    "default": "FILTER=\"PASS\"|INFO/HotSpotAllele=1",
                    "id": "#kfdrc_lancet_sub_wf.cwl/bcftools_public_filter"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of columns to strip if needed to avoid conflict, i.e INFO/AF",
                    "id": "#kfdrc_lancet_sub_wf.cwl/bcftools_strip_columns"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "doc": "Bed file intervals passed on from and outside pre-processing step",
                    "id": "#kfdrc_lancet_sub_wf.cwl/bed_invtl_split"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD indel annotations",
                    "id": "#kfdrc_lancet_sub_wf.cwl/cadd_indels"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD SNV annotations",
                    "id": "#kfdrc_lancet_sub_wf.cwl/cadd_snvs"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Use a file with ens tx IDs for each gene to override VEP PICK",
                    "id": "#kfdrc_lancet_sub_wf.cwl/custom_enst"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        },
                        {
                            "pattern": "^.readme.txt",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file, index, and readme file containing dbNSFP annotations",
                    "id": "#kfdrc_lancet_sub_wf.cwl/dbnsfp"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with desired fields to annotate. Use ALL to grab all",
                    "default": "SIFT4G_pred,Polyphen2_HDIV_pred,Polyphen2_HVAR_pred,LRT_pred,MutationTaster_pred,MutationAssessor_pred,FATHMM_pred,PROVEAN_pred,VEST4_score,VEST4_rankscore,MetaSVM_pred,MetaLR_pred,MetaRNN_pred,M-CAP_pred,REVEL_score,REVEL_rankscore,PrimateAI_pred,DEOGEN2_pred,BayesDel_noAF_pred,ClinPred_pred,LIST-S2_pred,Aloft_pred,fathmm-MKL_coding_pred,fathmm-XF_coding_pred,Eigen-phred_coding,Eigen-PC-phred_coding,phyloP100way_vertebrate,phyloP100way_vertebrate_rankscore,phastCons100way_vertebrate,phastCons100way_vertebrate_rankscore,TWINSUK_AC,TWINSUK_AF,ALSPAC_AC,ALSPAC_AF,UK10K_AC,UK10K_AF,gnomAD_exomes_controls_AC,gnomAD_exomes_controls_AN,gnomAD_exomes_controls_AF,gnomAD_exomes_controls_nhomalt,gnomAD_exomes_controls_POPMAX_AC,gnomAD_exomes_controls_POPMAX_AN,gnomAD_exomes_controls_POPMAX_AF,gnomAD_exomes_controls_POPMAX_nhomalt,gnomAD_genomes_flag,gnomAD_genomes_AC,gnomAD_genomes_AN,gnomAD_genomes_AF,gnomAD_genomes_nhomalt,gnomAD_genomes_POPMAX_AC,gnomAD_genomes_POPMAX_AN,gnomAD_genomes_POPMAX_AF,gnomAD_genomes_POPMAX_nhomalt,gnomAD_genomes_controls_and_biobanks_AC,gnomAD_genomes_controls_and_biobanks_AN,gnomAD_genomes_controls_and_biobanks_AF,gnomAD_genomes_controls_and_biobanks_nhomalt,clinvar_id,clinvar_clnsig,clinvar_trait,clinvar_review,clinvar_hgvs,clinvar_var_source,clinvar_MedGen_id,clinvar_OMIM_id,clinvar_Orphanet_id,Interpro_domain,GTEx_V8_gene,GTEx_V8_tissue",
                    "id": "#kfdrc_lancet_sub_wf.cwl/dbnsfp_fields"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Disable Hotspot Annotation and skip this task.",
                    "default": false,
                    "id": "#kfdrc_lancet_sub_wf.cwl/disable_hotspot_annotation"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Disable VEP Annotation and skip this task.",
                    "default": false,
                    "id": "#kfdrc_lancet_sub_wf.cwl/disable_vep_annotation"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Annotation ZIP files for echtvar anno",
                    "id": "#kfdrc_lancet_sub_wf.cwl/echtvar_anno_zips"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "Array of filter expressions to establish criteria to tag variants with. See https://gatk.broadinstitute.org/hc/en-us/articles/360036730071-VariantFiltration, recommend: \"vc.getGenotype('\" + inputs.input_normal_name + \"').getDP() <= 7\"), \"AF > 0.001\"]",
                    "id": "#kfdrc_lancet_sub_wf.cwl/gatk_filter_expression"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "Array of names for each filter tag to add, recommend: [\"NORM_DP_LOW\", \"GNOMAD_AF_HIGH\"]",
                    "id": "#kfdrc_lancet_sub_wf.cwl/gatk_filter_name"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Tab-delimited BED formatted file(s) containing hg38 genomic positions corresponding to hotspots",
                    "id": "#kfdrc_lancet_sub_wf.cwl/genomic_hotspots"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        },
                        {
                            "pattern": "^.dict",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_lancet_sub_wf.cwl/indexed_reference_fasta"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_lancet_sub_wf.cwl/input_normal_aligned"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_lancet_sub_wf.cwl/input_normal_name"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_lancet_sub_wf.cwl/input_tumor_aligned"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_lancet_sub_wf.cwl/input_tumor_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Sequencing center of variant called",
                    "default": ".",
                    "id": "#kfdrc_lancet_sub_wf.cwl/maf_center"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Set to true if merged cache used",
                    "default": true,
                    "id": "#kfdrc_lancet_sub_wf.cwl/merged"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "If `SM:` sample name in the align file is different than `input_normal_name`, you **must** provide it here",
                    "id": "#kfdrc_lancet_sub_wf.cwl/old_normal_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "If `SM:` sample name in the align file is different than `input_tumor_name`, you **must** provide it here",
                    "id": "#kfdrc_lancet_sub_wf.cwl/old_tumor_name"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_lancet_sub_wf.cwl/output_basename"
                },
                {
                    "type": "int",
                    "doc": "If WGS (less likely), default 25, if exome+, recommend half window size, 0 if pure exome or panel",
                    "id": "#kfdrc_lancet_sub_wf.cwl/padding"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Column-name-containing, tab-delimited file(s) containing protein names and amino acid position ranges corresponding to hotspots",
                    "id": "#kfdrc_lancet_sub_wf.cwl/protein_indel_hotspots"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Column-name-containing, tab-delimited file(s) containing protein names and amino acid positions corresponding to hotspots",
                    "id": "#kfdrc_lancet_sub_wf.cwl/protein_snv_hotspots"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 12,
                    "doc": "Adjust in rare circumstances in which 12 GB is not enough.",
                    "id": "#kfdrc_lancet_sub_wf.cwl/ram"
                },
                {
                    "type": "File",
                    "id": "#kfdrc_lancet_sub_wf.cwl/reference_dict"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of annotations (within the VEP CSQ/ANN) to retain as extra columns in MAF",
                    "id": "#kfdrc_lancet_sub_wf.cwl/retain_ann"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with FORMAT fields that you want to keep",
                    "id": "#kfdrc_lancet_sub_wf.cwl/retain_fmt"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with INFO fields that you want to keep",
                    "default": "MS,FETS,HotSpotAllele",
                    "id": "#kfdrc_lancet_sub_wf.cwl/retain_info"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the allele frequency flags for cache",
                    "id": "#kfdrc_lancet_sub_wf.cwl/run_cache_af"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the check_existing flag for cache",
                    "id": "#kfdrc_lancet_sub_wf.cwl/run_cache_existing"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_lancet_sub_wf.cwl/select_vars_mode/select_vars_mode",
                            "symbols": [
                                "#kfdrc_lancet_sub_wf.cwl/select_vars_mode/select_vars_mode/gatk",
                                "#kfdrc_lancet_sub_wf.cwl/select_vars_mode/select_vars_mode/grep"
                            ]
                        }
                    ],
                    "doc": "Choose 'gatk' for SelectVariants tool, or 'grep' for grep expression",
                    "default": "gatk",
                    "id": "#kfdrc_lancet_sub_wf.cwl/select_vars_mode"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to describe what tool was run as part of file name",
                    "default": "lancet_somatic",
                    "id": "#kfdrc_lancet_sub_wf.cwl/tool_name"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Increase or decrease to balance speed and memory usage",
                    "id": "#kfdrc_lancet_sub_wf.cwl/vep_buffer_size"
                },
                {
                    "type": "File",
                    "doc": "tar gzipped cache from ensembl/local converted cache",
                    "id": "#kfdrc_lancet_sub_wf.cwl/vep_cache"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of cores to use. May need to increase for really large inputs",
                    "id": "#kfdrc_lancet_sub_wf.cwl/vep_cores"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "In GB, may need to increase this value depending on the size/complexity of input",
                    "id": "#kfdrc_lancet_sub_wf.cwl/vep_ram"
                },
                {
                    "type": "int",
                    "doc": "window size for lancet.  default is 600, recommend 500 for WGS, 600 for exome+",
                    "id": "#kfdrc_lancet_sub_wf.cwl/window"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputSource": "#kfdrc_lancet_sub_wf.cwl/pickvalue_workaround/output_file",
                    "id": "#kfdrc_lancet_sub_wf.cwl/lancet_prepass_vcf"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc_lancet_sub_wf.cwl/annotate/annotated_protected",
                    "id": "#kfdrc_lancet_sub_wf.cwl/lancet_protected_outputs"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc_lancet_sub_wf.cwl/annotate/annotated_public",
                    "id": "#kfdrc_lancet_sub_wf.cwl/lancet_public_outputs"
                }
            ],
            "steps": [
                {
                    "run": "#kfdrc-somatic-snv-annot-workflow.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_lancet_sub_wf.cwl/add_common_fields",
                            "id": "#kfdrc_lancet_sub_wf.cwl/annotate/add_common_fields"
                        },
                        {
                            "source": "#kfdrc_lancet_sub_wf.cwl/bcftools_public_filter",
                            "id": "#kfdrc_lancet_sub_wf.cwl/annotate/bcftools_public_filter"
                        },
                        {
                            "source": "#kfdrc_lancet_sub_wf.cwl/bcftools_strip_columns",
                            "id": "#kfdrc_lancet_sub_wf.cwl/annotate/bcftools_strip_columns"
                        },
                        {
                            "source": "#kfdrc_lancet_sub_wf.cwl/cadd_indels",
                            "id": "#kfdrc_lancet_sub_wf.cwl/annotate/cadd_indels"
                        },
                        {
                            "source": "#kfdrc_lancet_sub_wf.cwl/cadd_snvs",
                            "id": "#kfdrc_lancet_sub_wf.cwl/annotate/cadd_snvs"
                        },
                        {
                            "source": "#kfdrc_lancet_sub_wf.cwl/custom_enst",
                            "id": "#kfdrc_lancet_sub_wf.cwl/annotate/custom_enst"
