                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/model_segments_tumor/allele_fraction_parameters_begin",
                                "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/model_segments_tumor/copy_ratio_legacy_segments",
