                {
                    "run": "#prepare_regions.cwl",
                    "when": "$(inputs.wgs_or_wxs == 'WGS' && inputs.run_tool)",
                    "in": [
                        {
                            "source": "#blacklist_regions",
                            "id": "#prepare_regions_lancet_wgs/blacklist_regions"
