                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#/vardict/vardict_public_outputs",
                    "id": "#vardict_public_outputs"
                }
            ],
            "steps": [
                {
                    "run": "#kfdrc_production_amplicon_architect.cwl",
                    "when": "$(inputs.run_amplicon_architect)",
                    "in": [
                        {
                            "source": "#aa_data_ref_version",
                            "id": "#amplicon_architect/aa_data_ref_version"
                        },
                        {
                            "source": "#aa_data_repo",
                            "id": "#amplicon_architect/aa_data_repo"
                        },
                        {
                            "source": "#/cnvkit/cnvkit_cns",
                            "id": "#amplicon_architect/cnvkit_cns"
                        },
                        {
                            "source": "#cnvkit_sex",
                            "valueFrom": "$(self == 'y' ? true : null)",
                            "id": "#amplicon_architect/male_input_flag"
                        },
                        {
                            "source": "#mosek_license_file",
                            "id": "#amplicon_architect/mosek_license_file"
                        },
                        {
                            "source": "#output_basename",
                            "id": "#amplicon_architect/output_basename"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "id": "#amplicon_architect/reference"
                        },
                        {
                            "source": "#/runtime_validator/run_amplicon_architect",
                            "id": "#amplicon_architect/run_amplicon_architect"
                        },
                        {
                            "source": [
                                "#/samtools_cram2bam_plus_calmd_tumor/bam_file",
                                "#input_tumor_aligned"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#amplicon_architect/tumor_align_file"
                        },
                        {
                            "source": "#wgs_or_wxs",
                            "id": "#amplicon_architect/wgs_or_wxs"
                        }
                    ],
                    "out": [
                        "#/amplicon_architect/aa_cnv_seeds",
                        "#/amplicon_architect/aa_summary",
                        "#/amplicon_architect/aa_cycles",
                        "#/amplicon_architect/aa_graph",
                        "#/amplicon_architect/aa_sv_png",
                        "#/amplicon_architect/aa_classification_profiles",
                        "#/amplicon_architect/aa_gene_list"
                    ],
                    "id": "#amplicon_architect"
                },
                {
                    "run": "#bedtools_intersect.cwl",
                    "when": "$(inputs.run_tool.some(function(e) { return e }))",
                    "in": [
                        {
                            "source": "#/runtime_validator/out_i_flag",
                            "id": "#bedtools_intersect_germline/flag"
                        },
                        {
                            "source": "#/prepare_regions_unpadded_cnv/prescatter_bed",
                            "id": "#bedtools_intersect_germline/input_bed_file"
                        },
                        {
                            "source": "#b_allele",
                            "id": "#bedtools_intersect_germline/input_vcf"
                        },
                        {
                            "source": "#output_basename",
                            "id": "#bedtools_intersect_germline/output_basename"
                        },
                        {
                            "source": [
                                "#/runtime_validator/run_controlfreec",
                                "#/runtime_validator/run_cnvkit"
                            ],
                            "id": "#bedtools_intersect_germline/run_tool"
                        }
                    ],
                    "out": [
                        "#/bedtools_intersect_germline/intersected_vcf"
                    ],
                    "id": "#bedtools_intersect_germline"
                },
                {
                    "run": "#clt_flatten_file_list.cwl",
                    "in": [
                        {
                            "source": "#/theta2_purity/theta2_subclonal_results",
                            "pickValue": "all_non_null",
                            "id": "#clt_flatten_subclonal_results/input_list"
                        }
                    ],
                    "out": [
                        "#/clt_flatten_subclonal_results/output"
                    ],
                    "id": "#clt_flatten_subclonal_results"
                },
                {
                    "run": "#kfdrc_cnvkit_sub_wf.cwl",
                    "when": "$(inputs.run_cnvkit)",
                    "in": [
                        {
                            "source": "#cnvkit_annotation_file",
                            "id": "#cnvkit/annotation_file"
                        },
                        {
                            "source": "#/gatk_filter_germline/filtered_pass_vcf",
                            "id": "#cnvkit/b_allele_vcf"
                        },
                        {
                            "source": "#cnv_blacklist_regions",
                            "id": "#cnvkit/blacklist_regions"
                        },
                        {
                            "source": "#/prepare_regions_unpadded_cnv/prescatter_bed",
                            "id": "#cnvkit/capture_regions"
                        },
                        {
                            "source": [
                                "#/samtools_cram2bam_plus_calmd_normal/bam_file",
                                "#input_normal_aligned"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#cnvkit/input_normal_aligned"
                        },
                        {
                            "source": [
                                "#/samtools_cram2bam_plus_calmd_tumor/bam_file",
                                "#input_tumor_aligned"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#cnvkit/input_tumor_aligned"
                        },
                        {
                            "source": "#input_normal_name",
                            "id": "#cnvkit/normal_sample_name"
                        },
                        {
                            "source": "#output_basename",
                            "id": "#cnvkit/output_basename"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "id": "#cnvkit/reference"
                        },
