                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "id": "#vardict/indexed_reference_fasta"
                        },
                        {
                            "source": [
                                "#/samtools_cram2bam_plus_calmd_normal/bam_file",
                                "#input_normal_aligned"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#vardict/input_normal_aligned"
                        },
                        {
                            "source": "#input_normal_name",
                            "id": "#vardict/input_normal_name"
                        },
                        {
                            "source": [
                                "#/samtools_cram2bam_plus_calmd_tumor/bam_file",
                                "#input_tumor_aligned"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#vardict/input_tumor_aligned"
                        },
                        {
                            "source": "#input_tumor_name",
                            "id": "#vardict/input_tumor_name"
                        },
                        {
                            "source": "#maf_center",
                            "id": "#vardict/maf_center"
                        },
                        {
                            "source": "#merged",
                            "id": "#vardict/merged"
                        },
                        {
                            "source": "#vardict_min_vaf",
                            "id": "#vardict/min_vaf"
                        },
                        {
                            "source": "#old_normal_name",
                            "id": "#vardict/old_normal_name"
                        },
                        {
                            "source": "#old_tumor_name",
                            "id": "#vardict/old_tumor_name"
                        },
                        {
                            "source": "#output_basename",
                            "id": "#vardict/output_basename"
                        },
                        {
                            "source": "#/runtime_validator/out_vardict_padding",
                            "id": "#vardict/padding"
                        },
                        {
                            "source": "#protein_indel_hotspots",
                            "id": "#vardict/protein_indel_hotspots"
                        },
                        {
                            "source": "#protein_snv_hotspots",
                            "id": "#vardict/protein_snv_hotspots"
                        },
                        {
                            "source": "#vardict_ram",
                            "id": "#vardict/ram"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "valueFrom": "$(self.secondaryFiles.filter(function(e) { return e.basename.search(/.dict$/) != -1 })[0])\n",
                            "id": "#vardict/reference_dict"
                        },
                        {
                            "source": "#vardict_retain_ann",
                            "id": "#vardict/retain_ann"
                        },
                        {
                            "source": "#vardict_retain_fmt",
                            "id": "#vardict/retain_fmt"
                        },
                        {
                            "source": "#vardict_retain_info",
                            "id": "#vardict/retain_info"
                        },
                        {
                            "source": "#run_cache_af",
                            "id": "#vardict/run_cache_af"
                        },
                        {
                            "source": "#run_cache_existing",
                            "id": "#vardict/run_cache_existing"
                        },
                        {
                            "source": "#/runtime_validator/run_vardict",
                            "id": "#vardict/run_vardict"
                        },
                        {
                            "source": "#select_vars_mode",
                            "id": "#vardict/select_vars_mode"
                        },
                        {
                            "source": "#vep_buffer_size",
                            "id": "#vardict/vep_buffer_size"
                        },
                        {
                            "source": "#vep_cache",
                            "id": "#vardict/vep_cache"
                        },
                        {
                            "source": "#vep_cores",
                            "id": "#vardict/vep_cores"
                        },
                        {
                            "source": "#vep_ram",
                            "id": "#vardict/vep_ram"
                        }
                    ],
                    "out": [
                        "#/vardict/vardict_prepass_vcf",
                        "#/vardict/vardict_protected_outputs",
                        "#/vardict/vardict_public_outputs"
                    ],
                    "id": "#vardict"
                }
            ],
            "hints": [
                {
                    "class": "https://sevenbridges.commaxNumberOfParallelInstances",
                    "value": 6
                }
            ],
            "https://sevenbridges.comlicense": "Apache License 2.0",
            "https://sevenbridges.compublisher": "KFDRC",
            "https://sevenbridges.comcategories": [
                "AMPLICONARCHITECT",
                "BAM",
                "CNV",
                "CNVKIT",
                "CONTROLFREEC",
                "CRAM",
                "ECDNA",
                "FUNCOTATOR",
                "GATK",
                "INDEL",
                "LANCET",
                "MAF",
                "MANTA",
                "MUTECT2",
                "SNV",
                "SOMATIC",
                "STRELKA2",
                "SV",
                "THETA2",
                "VARDICT",
                "VCF",
                "VEP"
            ],
            "https://sevenbridges.comlinks": [
                {
                    "id": "#v5.2.1",
                    "label": "github-release"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc_production_amplicon_architect.cwl",
            "label": "Kids First DRC Amplicon Architect Workflow",
            "doc": "# Kids First DRC Amplicon Architect(AA) Workflow (WIP)\nThis is an extra-chromosomal DNA (ecDNA) pipeline designed to detect ecDNA candidates.\nBriefly, chromosomal fragments in tumor cells break off to form circular DNA.\nThis DNA acts sort of like a plasmid/mtDNA in that it is not beholden to the usual rules of cell division and can have massive copy numbers in each cell.\nThe tools for this pipeline were derived from https://github.com/jluebeck/AmpliconArchitect, related publication: https://www.nature.com/articles/s41467-018-08200-y\n\n## Workflow: `workflow/kfdrc_production_amplicon_architect.cwl`\nThis workflow allows you to run amplicon architect with various levels of \"input readiness,\" geared toward working with outputs from the Kids First Somatic Workflow. It requires copy number info and the preferred method (by Kids First DRC) as input is from CNVkit. Given that the following perquisites must be fulfilled:\n - You have `.cns` output (_not_ `.call.cns`) readily available from a previous run\n - **OR** You have `.cnn` output from a previous run, allowing CNVkit to be run while skipping normal reference and annotation, saving time and money\n - You have the normal alignment (bam or cram) file. In this case, CNVkit will start from scratch\nA rough run time estimate put this at about 4 hours and $1.40 in cost using spot instances on CAVATICA when CNVkit has already been run, to about 8 hours and $2.88 in cost. Run time varies if prepare step has candidates (and number of candidates) and availability of CNVkit inputs.\n### Inputs (critical):\n - `aa_data_repo`: Reference tar ball obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/\n - `aa_data_ref_version`: enum, \"GRCh38\", \"hg19\", \"GRCh37\", \"mm10\", \"GRCm38\". Genome version in data repo to use. Should match `data_repo` downloaded.\n`tumor_align_file`: \"Tumor read alignment file. Can be cram or bam\", secondaryFiles: [ '^.bai?', '.crai?' ] }\noutput_basename: { type: string, doc: \"File name prefix for steps that require it\" }\nmosek_license_file: { type: File, doc: \"This tool uses some software that requires a license file. You can get a personal or institutional one from https://www.mosek.com/license/request/.\" }\n### Input (if cram input or .cnn not available):\n - `reference`: Reference fasta file\n### Input (if `.cns` file available):\n - `cnvkit_cns`: .cns file from previous CNVkit run, if available. DO NOT USE .call.cns\n### Input (if `.cnn` file available **and** `.cns` file _not_ available)\n - `cnvkit_cnn`:If running using an existing .cnn, supply here\n### Input (if no CNVkit inputs available):\n - `normal_align_file`: Normal read alignment file. Can be cram or bam\n - `annotation_file`: refFlat.txt file, needed if cnv kit cnn not already built\n - `male_input_flag`: Boolean flag indicating if input is male or not\n### Outputs:\n - `aa_cnv_seeds`: Bed file with candidate regions to search\n - `aa_summary`: Summary for all amplicons detected by AA\n - `aa_cycles`: Text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n - `graph`: A text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n - `sv_pdf`: PDF image file displaying the SV view of AA\n - `sv_png`: PNG image file displaying the SV view of AA\n - `amplicon_classification_profiles`: Abstract classification of the amplicon\n - `gene_list`: Genes present on amplicons with each classification\n - `ecDNA_cts`: Not yet defined\n\n\n## Tools\n### Dockerfiles:\n - `images.sbgenomics.com/milos_nikolic/cnvkit:0.9.3`: Optional, to create a \"raw\" (not .call.cns) .cns file.\n - `jluebeck/prepareaa:v0.1203.10`: Contains all software required to run pre-processing and processing steps\n\n### `tools/cnvkit_batch_only.cwl`\nModified version of somatic workflow `tools/cnvkit_batch.cwl` to truly run the batch step in a limited capacity.\nOther CN callers can be used, but since KF uses this natively, but does not output `.cns` calls, it is necessary to run on legacy samples until this workflow is part of production.\n#### Inputs (critical):\n - `input_sample`: tumor bam file\n - `run_mode`: enum with choices: [\"wgs\", \"hybrid\", \"amplicon\"], _currently AA works only with WGS_\n - `male_input_flag`: boolean, set to true if reference is male\n - `output_basename`: string\n If `.cnn` file available:\n - `cnvkit_cnn`: `.cnn` file from a previous run \n If `.cnn` is unavailable:\n - `input_control`: input normal file\n - `reference`: fasta file and index\n - `annotation_file`: refFlat.txt file\n#### Outputs (critical):\n - `output_cns`: `.cns` file needed for AA\n\n### `tools/cns_to_aa_bed.cwl`\nConverts `.cns` file to bed, adding \"crude ploidy estimates\".\nAgain, it is recommended that `.cns` be used, not `.call.cns`\n#### Inputs:\n - `input_cns`: Raw `.cns` output\n#### Outputs:\n - `aa_cns_bed`: Outputs two bed files. May restrict to one later once I understand better\n   - `_ESTIMATED_PLOIDY_CORRECTED_CN.bed`: currently used for subsequent steps\n   - `_uncorr_CN.bed`: currently not used, keep until I understand better\n\n**Note, while the tools below can use cram input, processing is slower by about 16%**\n### `tools/prepare_aa.cwl`\nThis tool uses the bed file regions to analyze input bam/cram file for amplicon candidates.\nIt is also capable of performing the functionality of the next two steps if the flags are given\n#### Inputs (critical):\n - `data_repo`: Reference tar ball obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/\n - `data_ref_version`: enum, \"GRCh38\", \"hg19\", \"GRCh37\", \"mm10\", \"GRCm38\". Genome version in data repo to use. Should match `data_repo` downloaded.\n - `sorted_bam`: Input bam/cram\n - `sample`: Output prefix name\n - `cnv_bed`: Converted CNVkit cns-to-bed file\n - `ref_cache`: _For cram input_, provide tar ball of output of running misc/seq_cache_populate.pl from samtools on the reference fasta\n#### Additional inputs (`run_aa` flag given):\n - `run_aa` Flag to run amplicon architect right after prepare_aa - set to True to do so\n - `mosek_license_file`: This tool uses some software that requires a license file. You can get a personal or institutional one from https://www.mosek.com/license/request/\n#### Additional inputs (`run_ac` flag given):\n - `run_aa` Flag to run amplicon classifier right after amplicon architect - set to True to do so\n#### Outputs:\n - `aa_cnv_seeds`: Bed files with seed intervals to search for viable ecDNA amplicons\n - `coverage_stats`: Coverage stats file to provide for running AA\n#### Additional outputs (`run_aa` flag given):\n - `summary`: summary for all amplicons detected by AA\n - `cycles`: text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n - `graph`: A text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n - `sv_pdf`: PDF image file displaying the SV view of AA\n#### Additional outputs (`run_ac` flag given):\n - `amplicon_classification_profiles`: abstract classification of the amplicon\n - `gene_list`: genes present on amplicons with each classification\n - `ecDNA_cts`: not yet defined\n\n### `tools/amplicon_architect.cwl`\nThis ties up all the prep work and outputs ecDNA candidates based on the seed regions provided\n#### Inputs (critical):\n - `data_repo`: Reference tar ball obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/\n - `data_ref_version`: enum, \"GRCh38\", \"hg19\", \"GRCh37\", \"mm10\", \"GRCm38\". Genome version in data repo to use. Should match `data_repo` downloaded.\n - `bam`: Input bam/cram\n - `downsample`: Recommended for anaylsis, recommended value be 10\n - `output_basename`: output file name prefix\n - `aa_bed`: Bed file from prepare-aa\n - `coverage_stats`: Coverage stats file generated by prepare-aa\n - `ref_cache`: _For cram input_, provide tar ball of output of running misc/seq_cache_populate.pl from samtools on the reference fasta\n - `mosek_license_file`: This tool uses some software that requires a license file. You can get a personal or institutional one from https://www.mosek.com/license/request/\n ### Outputs:\n - `summary`: summary for all amplicons detected by AA\n - `cycles`: text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n - `graph`: A text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n - `sv_png`: PNG image file displaying the SV view of AA\n\n### `tools/aa_classifier.cwl`\nThis tool classifies Amplicon Architect output to detect types of focal amplifications present\n#### Inputs (critical):\n - `data_repo`: Reference tar ball obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/\n - `data_ref_version`: enum, \"GRCh38\", \"hg19\", \"GRCh37\", \"mm10\", \"GRCm38\". Genome version in data repo to use. Should match `data_repo` downloaded.\n - `cycles`: text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n - `graph`: A text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts\n#### Outputs:\n - `amplicon_classification_profiles`: abstract classification of the amplicon\n - `gene_list`: genes present on amplicons with each classification\n - `ecDNA_cts`: not yet defined\n",
            "requirements": [
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                },
                {
                    "class": "ScatterFeatureRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version/aa_data_ref_version",
                            "symbols": [
                                "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version/aa_data_ref_version/GRCh38",
                                "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version/aa_data_ref_version/hg19",
                                "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version/aa_data_ref_version/GRCh37",
                                "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version/aa_data_ref_version/mm10",
                                "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version/aa_data_ref_version/GRCm38"
                            ]
                        }
                    ],
                    "doc": "Genome version in data repo to use",
                    "default": "GRCh38",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version"
                },
                {
                    "type": "File",
                    "doc": "Reference tar ball obtained from https://datasets.genepattern.org/?prefix=data/module_support_files/AmpliconArchitect/",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_data_repo"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "refFlat.txt file, needed if cnv kit cnn not already built",
                    "id": "#kfdrc_production_amplicon_architect.cwl/annotation_file"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "If running using an existing .cnn, supply here",
                    "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_cnn"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": ".cns file from previous CNVkit run, if available. DO NOT USE .call.cns",
                    "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_cns"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Is the input male?",
                    "default": false,
                    "id": "#kfdrc_production_amplicon_architect.cwl/male_input_flag"
                },
                {
                    "type": "File",
                    "doc": "This tool uses some software that requires a license file. You can get a personal or institutional one from https://www.mosek.com/license/request/.",
                    "id": "#kfdrc_production_amplicon_architect.cwl/mosek_license_file"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Normal read alignment file. Can cram or bam",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        }
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/normal_align_file"
                },
                {
                    "type": "string",
                    "doc": "File name prefix for steps that require it",
                    "id": "#kfdrc_production_amplicon_architect.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "fasta file, needed if cram input or cnv kit cnn not already built",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": null
                        }
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/reference"
                },
                {
                    "type": "File",
                    "doc": "Tumor read alignment file. Can be cram or bam",
                    "secondaryFiles": [
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        }
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/tumor_align_file"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "abstract classification of the amplicon",
                    "outputSource": "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/amplicon_classification_profiles",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_classification_profiles"
                },
                {
                    "type": "File",
                    "doc": "Bed file with candidate regions to search",
                    "outputSource": "#kfdrc_production_amplicon_architect.cwl/prepare_aa/aa_cnv_seeds",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_cnv_seeds"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "doc": "text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts",
                    "outputSource": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/cycles",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_cycles"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "genes present on amplicons with each classification",
                    "outputSource": "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/gene_list",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_gene_list"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "doc": "A text file for each amplicon listing the edges in the breakpoint graph, their categorization (sequence, discordant, concordant, source) and their copy counts",
                    "outputSource": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/graph",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_graph"
                },
                {
                    "type": "File",
                    "doc": "summary for all amplicons detected by AA",
                    "outputSource": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/summary",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_summary"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "doc": "PNG image file displaying the SV view of AA",
                    "outputSource": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/sv_png",
                    "id": "#kfdrc_production_amplicon_architect.cwl/aa_sv_png"
                }
            ],
            "steps": [
                {
                    "run": "#amplicon_architect.cwl",
                    "hints": [
                        {
                            "class": "https://sevenbridges.comAWSInstanceType",
                            "value": "c5.2xlarge"
                        }
                    ],
                    "in": [
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/prepare_aa/aa_cnv_seeds",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/aa_bed"
                        },
                        {
                            "source": [
                                "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_tumor_cram_to_bam/bam_file",
                                "#kfdrc_production_amplicon_architect.cwl/tumor_align_file"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/bam"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/prepare_aa/coverage_stats",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/coverage_stats"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/data_ref_version"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/untar_data_repo/output",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/data_repo"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/mosek_license_file",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/mosek_license_file"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/output_basename",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/output_basename"
                        }
                    ],
                    "out": [
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/summary",
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/cycles",
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/graph",
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/sv_pdf",
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/sv_png"
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect"
                },
                {
                    "run": "#aa_classifier.cwl",
                    "hints": [
                        {
                            "class": "https://sevenbridges.comAWSInstanceType",
                            "value": "c5.2xlarge"
                        }
                    ],
                    "in": [
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/cycles",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/cycles"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/data_ref_version"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/untar_data_repo/output",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/data_repo"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/amplicon_architect/graph",
                            "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/graph"
                        }
                    ],
                    "scatter": [
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/cycles",
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/graph"
                    ],
                    "scatterMethod": "dotproduct",
                    "out": [
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/amplicon_classification_profiles",
                        "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier/gene_list"
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/amplicon_classifier"
                },
                {
                    "run": "#cns_to_aa_bed.cwl",
                    "in": [
                        {
                            "source": [
                                "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/output_cns",
                                "#kfdrc_production_amplicon_architect.cwl/cnvkit_cns"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_production_amplicon_architect.cwl/cns_to_aa_bed/input_cns"
                        }
                    ],
                    "out": [
                        "#kfdrc_production_amplicon_architect.cwl/cns_to_aa_bed/aa_cns_bed"
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/cns_to_aa_bed"
                },
                {
                    "run": "#cnvkit_batch_only.cwl",
                    "when": "$(inputs.cnvkit_cnn != null || inputs.input_control != null)",
                    "in": [
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/annotation_file",
                            "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/annotation_file"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/cnvkit_cnn",
                            "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/cnvkit_cnn"
                        },
                        {
                            "source": [
                                "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_normal_cram_to_bam/bam_file",
                                "#kfdrc_production_amplicon_architect.cwl/normal_align_file"
                            ],
                            "valueFrom": "$(self[0] != null ? self[0] : self[1])\n",
                            "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/input_control"
                        },
                        {
                            "source": [
                                "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_tumor_cram_to_bam/bam_file",
                                "#kfdrc_production_amplicon_architect.cwl/tumor_align_file"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/input_sample"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/male_input_flag",
                            "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/male_input_flag"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/output_basename",
                            "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/output_basename"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/reference",
                            "valueFrom": "$(inputs.cnvkit_cnn == null ? self : null)",
                            "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/reference"
                        }
                    ],
                    "out": [
                        "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/output_cnr",
                        "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/output_cns",
                        "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/output_scatter",
                        "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/output_diagram",
                        "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch/output_cnn"
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/cnvkit_batch"
                },
                {
                    "run": "#prepare_aa.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/cns_to_aa_bed/aa_cns_bed",
                            "id": "#kfdrc_production_amplicon_architect.cwl/prepare_aa/cnv_bed"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/aa_data_ref_version",
                            "id": "#kfdrc_production_amplicon_architect.cwl/prepare_aa/data_ref_version"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/untar_data_repo/output",
                            "id": "#kfdrc_production_amplicon_architect.cwl/prepare_aa/data_repo"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/output_basename",
                            "id": "#kfdrc_production_amplicon_architect.cwl/prepare_aa/sample"
                        },
                        {
                            "source": [
                                "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_tumor_cram_to_bam/bam_file",
                                "#kfdrc_production_amplicon_architect.cwl/tumor_align_file"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_production_amplicon_architect.cwl/prepare_aa/sorted_bam"
                        }
                    ],
                    "out": [
                        "#kfdrc_production_amplicon_architect.cwl/prepare_aa/aa_cnv_seeds",
                        "#kfdrc_production_amplicon_architect.cwl/prepare_aa/coverage_stats"
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/prepare_aa"
                },
                {
                    "run": "#samtools_calmd.cwl",
                    "when": "$(inputs.input_reads != null && inputs.input_reads.nameext == \".cram\")",
                    "in": [
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/normal_align_file",
                            "id": "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_normal_cram_to_bam/input_reads"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/reference",
                            "id": "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_normal_cram_to_bam/reference"
                        }
                    ],
                    "out": [
                        "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_normal_cram_to_bam/bam_file"
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_normal_cram_to_bam"
                },
                {
                    "run": "#samtools_calmd.cwl",
                    "when": "$(inputs.input_reads.nameext == \".cram\")",
                    "in": [
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/tumor_align_file",
                            "id": "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_tumor_cram_to_bam/input_reads"
                        },
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/reference",
                            "id": "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_tumor_cram_to_bam/reference"
                        }
                    ],
                    "out": [
                        "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_tumor_cram_to_bam/bam_file"
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/samtools_calmd_tumor_cram_to_bam"
                },
                {
                    "run": "#untar_gzip.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_production_amplicon_architect.cwl/aa_data_repo",
                            "id": "#kfdrc_production_amplicon_architect.cwl/untar_data_repo/input_tar"
                        },
                        {
                            "valueFrom": "${return \"data_repo\"}",
                            "id": "#kfdrc_production_amplicon_architect.cwl/untar_data_repo/out_dir_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_production_amplicon_architect.cwl/untar_data_repo/output"
                    ],
                    "id": "#kfdrc_production_amplicon_architect.cwl/untar_data_repo"
                }
            ],
            "hints": [
                {
                    "class": "https://sevenbridges.commaxNumberOfParallelInstances",
                    "value": 3
                }
            ],
            "https://sevenbridges.comlicense": "Apache License 2.0",
            "https://sevenbridges.compublisher": "KFDRC"
        }
    ],
    "cwlVersion": "v1.2"
}