                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#cfree_mate_orientation_control/mate_orientation_control",
                            "symbols": [
                                "#/cfree_mate_orientation_control/mate_orientation_control/0",
                                "#/cfree_mate_orientation_control/mate_orientation_control/FR",
                                "#/cfree_mate_orientation_control/mate_orientation_control/RF",
