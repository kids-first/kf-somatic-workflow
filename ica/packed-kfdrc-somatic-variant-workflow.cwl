                        }
                    ],
                    "doc": "Column-name-containing, tab-delimited file(s) containing protein names and amino acid position ranges corresponding to hotspots",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/protein_indel_hotspots"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Column-name-containing, tab-delimited file(s) containing protein names and amino acid positions corresponding to hotspots",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/protein_snv_hotspots"
                },
                {
                    "type": "File",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/reference_dict"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of annotations (within the VEP CSQ/ANN) to retain as extra columns in MAF",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/retain_ann"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with FORMAT fields that you want to keep",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/retain_fmt"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with INFO fields that you want to keep",
                    "default": "MBQ,TLOD,HotSpotAllele",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/retain_info"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the allele frequency flags for cache",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/run_cache_af"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the check_existing flag for cache",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/run_cache_existing"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_mutect2_sub_wf.cwl/select_vars_mode/select_vars_mode",
                            "symbols": [
                                "#kfdrc_mutect2_sub_wf.cwl/select_vars_mode/select_vars_mode/gatk",
                                "#kfdrc_mutect2_sub_wf.cwl/select_vars_mode/select_vars_mode/grep"
                            ]
                        }
                    ],
                    "doc": "Choose 'gatk' for SelectVariants tool, or 'grep' for grep expression",
                    "default": "gatk",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/select_vars_mode"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to describe what tool was run as part of file name",
                    "default": "mutect2_somatic",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/tool_name"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Increase or decrease to balance speed and memory usage",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/vep_buffer_size"
                },
                {
                    "type": "File",
                    "doc": "tar gzipped cache from ensembl/local converted cache",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/vep_cache"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Number of cores to use. May need to increase for really large inputs",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/vep_cores"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "In GB, may need to increase this value depending on the size/complexity of input",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/vep_ram"
                }
            ],
            "outputs": [
                {
                    "type": "File",
                    "outputSource": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/stats_table",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filtered_stats"
                },
                {
                    "type": "File",
                    "outputSource": "#kfdrc_mutect2_sub_wf.cwl/pickvalue_workaround/output_file",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filtered_vcf"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc_mutect2_sub_wf.cwl/annotate/annotated_protected",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_protected_outputs"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "File"
                    },
                    "outputSource": "#kfdrc_mutect2_sub_wf.cwl/annotate/annotated_public",
                    "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_public_outputs"
                }
            ],
            "steps": [
                {
                    "run": "#kfdrc-somatic-snv-annot-workflow.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/add_common_fields",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/add_common_fields"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/bcftools_public_filter",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/bcftools_public_filter"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/bcftools_strip_columns",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/bcftools_strip_columns"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/cadd_indels",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/cadd_indels"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/cadd_snvs",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/cadd_snvs"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/custom_enst",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/custom_enst"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/dbnsfp",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/dbnsfp"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/dbnsfp_fields",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/dbnsfp_fields"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/disable_hotspot_annotation",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/disable_hotspot_annotation"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/disable_vep_annotation",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/disable_vep_annotation"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/echtvar_anno_zips",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/echtvar_anno_zips"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/gatk_filter_expression",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/gatk_filter_expression"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/gatk_filter_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/gatk_filter_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/genomic_hotspots",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/genomic_hotspots"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/indexed_reference_fasta"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/input_normal_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/input_normal_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/input_tumor_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/input_tumor_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/gatk_selectvariants_mutect2/pass_vcf",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/input_vcf"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/maf_center",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/maf_center"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/merged",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/merged"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/output_basename"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/protein_indel_hotspots",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/protein_indel_hotspots"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/protein_snv_hotspots",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/protein_snv_hotspots"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/retain_ann",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/retain_ann"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/retain_fmt",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/retain_fmt"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/retain_info",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/retain_info"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/run_cache_af",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/run_cache_af"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/run_cache_existing",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/run_cache_existing"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/tool_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/tool_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/vep_buffer_size",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/vep_buffer_size"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/vep_cache",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/vep_cache"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/vep_cores",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/vep_cores"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/vep_ram",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/annotate/vep_ram"
                        }
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/annotate/annotated_protected",
                        "#kfdrc_mutect2_sub_wf.cwl/annotate/annotated_public"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/annotate"
                },
                {
                    "run": "#gatk_filtermutectcalls.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/contamination_table",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/contamination_table"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/filtermutectcalls_memory",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/max_memory"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_stats/merged_stats",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/mutect_stats"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_vcf/merged_vcf",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/mutect_vcf"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/f1r2_bias",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/ob_priors"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/output_basename"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/reference"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/segmentation_table",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/segmentation_table"
                        }
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/stats_table",
                        "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/filtered_vcf"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf"
                },
                {
                    "run": "#gatk_selectvariants.cwl",
                    "label": "GATK Select PASS",
                    "in": [
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/pickvalue_workaround/output_file",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/gatk_selectvariants_mutect2/input_vcf"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/select_vars_mode",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/gatk_selectvariants_mutect2/mode"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/gatk_selectvariants_mutect2/output_basename"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/tool_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/gatk_selectvariants_mutect2/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/gatk_selectvariants_mutect2/pass_vcf"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/gatk_selectvariants_mutect2"
                },
                {
                    "run": "#gatk_mergemutectstats.cwl",
                    "label": "Merge mutect2 stats",
                    "in": [
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/mutect2/mutect_stats",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_stats/input_stats"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_stats/output_basename"
                        }
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_stats/merged_stats"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_stats"
                },
                {
                    "run": "#gatk_mergevcfs.cwl",
                    "label": "Merge mutect2 vcf",
                    "in": [
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/mutect2/mutect2_vcf",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_vcf/input_vcfs"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_vcf/output_basename"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/reference_dict",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_vcf/reference_dict"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/tool_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_vcf/tool_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_vcf/merged_vcf"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/merge_mutect2_vcf"
                },
                {
                    "run": "#gatk_Mutect2.cwl",
                    "hints": [
                        {
                            "class": "https://sevenbridges.comAWSInstanceType",
                            "value": "c5.9xlarge"
                        }
                    ],
                    "in": [
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/af_only_gnomad_vcf",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2/af_only_gnomad_vcf"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/exome_flag",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2/exome_flag"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/input_normal_aligned",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2/input_normal_aligned"
                        },
                        {
                            "source": [
                                "#kfdrc_mutect2_sub_wf.cwl/old_normal_name",
                                "#kfdrc_mutect2_sub_wf.cwl/input_normal_name"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2/input_normal_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/input_tumor_aligned",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2/input_tumor_aligned"
                        },
                        {
                            "source": [
                                "#kfdrc_mutect2_sub_wf.cwl/old_tumor_name",
                                "#kfdrc_mutect2_sub_wf.cwl/input_tumor_name"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2/input_tumor_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/bed_invtl_split",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2/interval_list"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2/reference"
                        }
                    ],
                    "scatter": [
                        "#kfdrc_mutect2_sub_wf.cwl/mutect2/interval_list"
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/mutect2/mutect2_vcf",
                        "#kfdrc_mutect2_sub_wf.cwl/mutect2/f1r2_counts",
                        "#kfdrc_mutect2_sub_wf.cwl/mutect2/mutect_stats"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2"
                },
                {
                    "run": "#kfdrc_mutect2_filter_support_subwf.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/exac_common_vcf",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/exac_common_vcf"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/mutect2/f1r2_counts",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/f1r2_counts"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/getpileup_memory",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/getpileup_memory"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/indexed_reference_fasta",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/indexed_reference_fasta"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/input_normal_aligned",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/input_normal_aligned"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/input_tumor_aligned",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/input_tumor_aligned"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/learnorientation_memory",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/learnorientation_memory"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/output_basename"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/reference_dict",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/reference_dict"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/bed_invtl_split",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/wgs_calling_interval_list"
                        }
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/contamination_table",
                        "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/segmentation_table",
                        "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support/f1r2_bias"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/mutect2_filter_support"
                },
                {
                    "run": "#clt_file_to_file.cwl",
                    "in": [
                        {
                            "source": [
                                "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/reheadered_vcf",
                                "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/filtered_vcf"
                            ],
                            "pickValue": "first_non_null",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/pickvalue_workaround/input_file"
                        }
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/pickvalue_workaround/output_file"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/pickvalue_workaround"
                },
                {
                    "run": "#bcftools_reheader_samples_index.cwl",
                    "when": "$(inputs.old_tumor_name != null && inputs.old_normal_name != null)",
                    "in": [
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/filter_mutect2_vcf/filtered_vcf",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/input_vcf"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/input_normal_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/new_normal_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/input_tumor_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/new_tumor_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/old_normal_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/old_normal_name"
                        },
                        {
                            "source": "#kfdrc_mutect2_sub_wf.cwl/old_tumor_name",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/old_tumor_name"
                        },
                        {
                            "valueFrom": "$(inputs.input_vcf.basename)\n",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/output_filename"
                        },
                        {
                            "valueFrom": "$(1 == 1)\n",
                            "id": "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/tbi"
                        }
                    ],
                    "out": [
                        "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples/reheadered_vcf"
                    ],
                    "id": "#kfdrc_mutect2_sub_wf.cwl/rename_vcf_samples"
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc_run_theta2_sub_wf.cwl",
            "doc": "This workflow is normally run as a subworkflow and takes existing cnvkit results and adjusts them based on calculated tumor purity.",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "SubworkflowFeatureRequirement"
                },
                {
                    "class": "InlineJavascriptRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Filter expression if vcf has non-PASS combined calls, use as-needed",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/combined_exclude_expression"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Filter expression if vcf has non-PASS combined calls, use as-needed",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/combined_include_expression"
                },
                {
                    "type": [
                        "null",
                        "float"
                    ],
                    "doc": "Minimum fraction of genome with copy umber alterations.  Default is 0.05, recommend 0.01",
                    "default": 0.01,
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/min_theta2_frac"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/normal_sample_name"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/output_basename"
                },
                {
                    "type": "File",
                    "doc": "Combined somatic and germline call file. VarDict input recommended.",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/paired_vcf"
                },
                {
                    "type": "File",
                    "doc": "CNVkit output cnn file",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/reference_cnn"
                },
                {
                    "type": "File",
                    "doc": "CNVkit output cns file",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/tumor_cns"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/tumor_sample_name"
                }
            ],
            "outputs": [
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputSource": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_adjusted_cns",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/theta2_adjusted_cns"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "outputSource": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_adjusted_seg",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/theta2_adjusted_seg"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputSource": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_subclone_cns",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/theta2_subclonal_cns"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputSource": [
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n3_graph",
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n2_results",
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/best_results"
                    ],
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/theta2_subclonal_results"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "outputSource": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_subclone_seg",
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/theta2_subclone_seg"
                }
            ],
            "steps": [
                {
                    "run": "#bcftools_filter_vcf.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/combined_exclude_expression",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/bcftools_filter_combined_vcf/exclude_expression"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/combined_include_expression",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/bcftools_filter_combined_vcf/include_expression"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/paired_vcf",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/bcftools_filter_combined_vcf/input_vcf"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/bcftools_filter_combined_vcf/output_basename"
                        }
                    ],
                    "out": [
                        "#kfdrc_run_theta2_sub_wf.cwl/bcftools_filter_combined_vcf/filtered_vcf"
                    ],
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/bcftools_filter_combined_vcf"
                },
                {
                    "run": "#cnvkit_export_theta2.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/normal_sample_name",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/normal_ID"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/bcftools_filter_combined_vcf/filtered_vcf",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/paired_vcf"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/reference_cnn",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/reference_cnn"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/tumor_sample_name",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/tumor_ID"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/tumor_cns",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/tumor_cns"
                        }
                    ],
                    "out": [
                        "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/call_interval_count",
                        "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/call_tumor_snp",
                        "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/call_normal_snp"
                    ],
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2"
                },
                {
                    "run": "#cnvkit_import_theta2.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/output_basename"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/best_results",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_best_results"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n2_results",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_n2_results"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/tumor_cns",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/tumor_cns"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/tumor_sample_name",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/tumor_sample_name"
                        }
                    ],
                    "out": [
                        "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_adjusted_cns",
                        "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_adjusted_seg",
                        "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_subclone_cns",
                        "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2/theta2_subclone_seg"
                    ],
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_import_theta2"
                },
                {
                    "run": "#theta2_purity.cwl",
                    "in": [
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/call_interval_count",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/interval_count"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/min_theta2_frac",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/min_frac"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/call_normal_snp",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/normal_snp"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/output_basename",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/output_basename"
                        },
                        {
                            "source": "#kfdrc_run_theta2_sub_wf.cwl/cnvkit_export_theta2/call_tumor_snp",
                            "id": "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/tumor_snp"
                        }
                    ],
                    "out": [
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n2_graph",
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n2_results",
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n2_withBounds",
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n3_graph",
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n3_results",
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/n3_withBounds",
                        "#kfdrc_run_theta2_sub_wf.cwl/run_theta2/best_results"
                    ],
                    "id": "#kfdrc_run_theta2_sub_wf.cwl/run_theta2"
                }
            ],
            "hints": [
                {
                    "class": "LoadListingRequirement",
                    "loadListing": "deep_listing"
                },
                {
                    "class": "NetworkAccess",
                    "networkAccess": true
                }
            ]
        },
        {
            "class": "Workflow",
            "id": "#kfdrc_strelka2_sub_wf.cwl",
            "requirements": [
                {
                    "class": "ScatterFeatureRequirement"
                },
                {
                    "class": "MultipleInputFeatureRequirement"
                },
                {
                    "class": "SubworkflowFeatureRequirement"
                }
            ],
            "inputs": [
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Set to true if input is a strelka2 vcf that hasn't had common fields added",
                    "default": true,
                    "id": "#kfdrc_strelka2_sub_wf.cwl/add_common_fields"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Will hard filter final result to create a public version",
                    "default": "FILTER=\"PASS\"|INFO/HotSpotAllele=1",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/bcftools_public_filter"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of columns to strip if needed to avoid conflict, i.e INFO/AF",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/bcftools_strip_columns"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD indel annotations",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/cadd_indels"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file and index containing CADD SNV annotations",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/cadd_snvs"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "doc": "Use a file with ens tx IDs for each gene to override VEP PICK",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/custom_enst"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": null
                        },
                        {
                            "pattern": "^.readme.txt",
                            "required": null
                        }
                    ],
                    "doc": "VEP-formatted plugin file, index, and readme file containing dbNSFP annotations",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/dbnsfp"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with desired fields to annotate. Use ALL to grab all",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/dbnsfp_fields"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Disable Hotspot Annotation and skip this task.",
                    "default": false,
                    "id": "#kfdrc_strelka2_sub_wf.cwl/disable_hotspot_annotation"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Disable VEP Annotation and skip this task.",
                    "default": false,
                    "id": "#kfdrc_strelka2_sub_wf.cwl/disable_vep_annotation"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Annotation ZIP files for echtvar anno",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/echtvar_anno_zips"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "set to 'Y' for exome mode",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/exome_flag"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Add special options to config file, i.e. --max-input-depth 1000",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/extra_arg"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "Array of filter expressions to establish criteria to tag variants with. See https://gatk.broadinstitute.org/hc/en-us/articles/360036730071-VariantFiltration, recommend: \"vc.getGenotype('\" + inputs.input_normal_name + \"').getDP() <= 7\"), \"AF > 0.001\"]",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/gatk_filter_expression"
                },
                {
                    "type": {
                        "type": "array",
                        "items": "string"
                    },
                    "doc": "Array of names for each filter tag to add, recommend: [\"NORM_DP_LOW\", \"GNOMAD_AF_HIGH\"]",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/gatk_filter_name"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Tab-delimited BED formatted file(s) containing hg38 genomic positions corresponding to hotspots",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/genomic_hotspots"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": true
                        }
                    ],
                    "id": "#kfdrc_strelka2_sub_wf.cwl/hg38_strelka_bed"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".fai",
                            "required": true
                        },
                        {
                            "pattern": "^.dict",
                            "required": true
                        }
                    ],
                    "id": "#kfdrc_strelka2_sub_wf.cwl/indexed_reference_fasta"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "doc": "normal BAM or CRAM",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/input_normal_aligned"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/input_normal_name"
                },
                {
                    "type": "File",
                    "secondaryFiles": [
                        {
                            "pattern": ".bai",
                            "required": false
                        },
                        {
                            "pattern": "^.bai",
                            "required": false
                        },
                        {
                            "pattern": ".crai",
                            "required": false
                        },
                        {
                            "pattern": "^.crai",
                            "required": false
                        }
                    ],
                    "doc": "tumor BAM or CRAM",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/input_tumor_aligned"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/input_tumor_name"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "Sequencing center of variant called",
                    "default": ".",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/maf_center"
                },
                {
                    "type": [
                        "null",
                        "File"
                    ],
                    "secondaryFiles": [
                        {
                            "pattern": ".tbi",
                            "required": true
                        }
                    ],
                    "id": "#kfdrc_strelka2_sub_wf.cwl/manta_small_indels"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Set to true if merged cache used",
                    "default": true,
                    "id": "#kfdrc_strelka2_sub_wf.cwl/merged"
                },
                {
                    "type": "string",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/output_basename"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Column-name-containing, tab-delimited file(s) containing protein names and amino acid position ranges corresponding to hotspots",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/protein_indel_hotspots"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "array",
                            "items": "File"
                        }
                    ],
                    "doc": "Column-name-containing, tab-delimited file(s) containing protein names and amino acid positions corresponding to hotspots",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/protein_snv_hotspots"
                },
                {
                    "type": "File",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/reference_dict"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string of annotations (within the VEP CSQ/ANN) to retain as extra columns in MAF",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/retain_ann"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with FORMAT fields that you want to keep",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/retain_fmt"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "csv string with INFO fields that you want to keep",
                    "default": "MQ,MQ0,QSI,HotSpotAllele",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/retain_info"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the allele frequency flags for cache",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/run_cache_af"
                },
                {
                    "type": [
                        "null",
                        "boolean"
                    ],
                    "doc": "Run the check_existing flag for cache",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/run_cache_existing"
                },
                {
                    "type": [
                        "null",
                        {
                            "type": "enum",
                            "name": "#kfdrc_strelka2_sub_wf.cwl/select_vars_mode/select_vars_mode",
                            "symbols": [
                                "#kfdrc_strelka2_sub_wf.cwl/select_vars_mode/select_vars_mode/gatk",
                                "#kfdrc_strelka2_sub_wf.cwl/select_vars_mode/select_vars_mode/grep"
                            ]
                        }
                    ],
                    "doc": "Choose 'gatk' for SelectVariants tool, or 'grep' for grep expression",
                    "default": "gatk",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/select_vars_mode"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Adjust number of cores used to run strelka2",
                    "default": 16,
                    "id": "#kfdrc_strelka2_sub_wf.cwl/strelka2_cores"
                },
                {
                    "type": [
                        "null",
                        "string"
                    ],
                    "doc": "String to describe what tool was run as part of file name",
                    "default": "strelka2_somatic",
                    "id": "#kfdrc_strelka2_sub_wf.cwl/tool_name"
