                    "id": "#vardict_min_vaf"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "doc": "Padding to add to input intervals, recommend 0 if intervals already padded such as in WXS, 150 if not such as in WGS",
                    "id": "#vardict_padding"
                },
                {
                    "type": [
                        "null",
                        "int"
                    ],
                    "default": 16,
