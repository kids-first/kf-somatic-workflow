                        {
                            "source": [
                                "#/strelka2/strelka2_protected_outputs",
                                "#/mutect2/mutect2_protected_outputs",
                                "#lancet_input_vcf"
                            ],
                            "valueFrom": "$(self.filter(function(e) { return e != null }).map(function(e) { return e.filter(function(i) { return i.basename.search(/(.vcf|.vcf.gz)$/) != -1 }) }).reduce(function(a,c) { return a.concat(c) }, []))\n",
                            "id": "#prepare_regions_lancet_wgs/supplement_vcfs"
                        },
                        {
                            "source": "#wgs_or_wxs",
                            "id": "#prepare_regions_lancet_wgs/wgs_or_wxs"
                        }
                    ],
                    "out": [
                        "#/prepare_regions_lancet_wgs/prescatter_intervallist",
                        "#/prepare_regions_lancet_wgs/prescatter_bed",
                        "#/prepare_regions_lancet_wgs/prescatter_bedgz",
                        "#/prepare_regions_lancet_wgs/scattered_intervallists",
                        "#/prepare_regions_lancet_wgs/scattered_beds"
                    ],
                    "id": "#prepare_regions_lancet_wgs"
                },
                {
                    "run": "#prepare_regions.cwl",
                    "when": "$(inputs.wgs_or_wxs == 'WXS' && inputs.run_tool.some(function(e) { return e }))",
                    "in": [
                        {
                            "source": "#blacklist_regions",
                            "id": "#prepare_regions_padded/blacklist_regions"
                        },
                        {
                            "valueFrom": "$(0)",
                            "id": "#prepare_regions_padded/break_bands_at_multiples_of"
                        },
                        {
                            "valueFrom": "$(100)",
                            "id": "#prepare_regions_padded/calling_padding"
                        },
                        {
                            "source": "#calling_regions",
                            "id": "#prepare_regions_padded/calling_regions"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "valueFrom": "$(self.secondaryFiles.filter(function(e) { return e.basename.search(/.dict$/) != -1 })[0])\n",
                            "id": "#prepare_regions_padded/reference_dict"
                        },
                        {
                            "source": [
                                "#/runtime_validator/run_mutect2",
                                "#/runtime_validator/run_strelka2",
                                "#/runtime_validator/run_vardict",
                                "#/runtime_validator/run_manta",
                                "#/runtime_validator/run_lancet"
                            ],
                            "id": "#prepare_regions_padded/run_tool"
                        },
                        {
                            "valueFrom": "$(50)",
                            "id": "#prepare_regions_padded/scatter_count"
                        },
                        {
                            "source": "#wgs_or_wxs",
                            "id": "#prepare_regions_padded/wgs_or_wxs"
                        }
                    ],
                    "out": [
                        "#/prepare_regions_padded/prescatter_intervallist",
                        "#/prepare_regions_padded/prescatter_bed",
                        "#/prepare_regions_padded/prescatter_bedgz",
                        "#/prepare_regions_padded/scattered_intervallists",
                        "#/prepare_regions_padded/scattered_beds"
                    ],
                    "id": "#prepare_regions_padded"
                },
                {
                    "run": "#prepare_regions.cwl",
                    "when": "$(inputs.wgs_or_wxs == 'WGS' && inputs.run_tool.some(function(e) { return e }))",
                    "in": [
                        {
                            "source": "#blacklist_regions",
                            "id": "#prepare_regions_unpadded/blacklist_regions"
                        },
                        {
                            "valueFrom": "$(80000000)",
                            "id": "#prepare_regions_unpadded/break_bands_at_multiples_of"
                        },
                        {
                            "source": "#calling_regions",
                            "id": "#prepare_regions_unpadded/calling_regions"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "valueFrom": "$(self.secondaryFiles.filter(function(e) { return e.basename.search(/.dict$/) != -1 })[0])\n",
                            "id": "#prepare_regions_unpadded/reference_dict"
                        },
                        {
                            "source": [
                                "#/runtime_validator/run_mutect2",
                                "#/runtime_validator/run_strelka2",
                                "#/runtime_validator/run_vardict",
                                "#/runtime_validator/run_manta"
                            ],
                            "id": "#prepare_regions_unpadded/run_tool"
                        },
                        {
                            "valueFrom": "$(50)",
                            "id": "#prepare_regions_unpadded/scatter_count"
                        },
                        {
                            "source": "#wgs_or_wxs",
                            "id": "#prepare_regions_unpadded/wgs_or_wxs"
                        }
                    ],
                    "out": [
                        "#/prepare_regions_unpadded/prescatter_intervallist",
                        "#/prepare_regions_unpadded/prescatter_bed",
                        "#/prepare_regions_unpadded/prescatter_bedgz",
                        "#/prepare_regions_unpadded/scattered_intervallists",
                        "#/prepare_regions_unpadded/scattered_beds"
                    ],
                    "id": "#prepare_regions_unpadded"
                },
                {
                    "run": "#prepare_regions.cwl",
                    "when": "$(inputs.run_tool.some(function(e) { return e }))",
                    "in": [
                        {
                            "source": "#cnv_blacklist_regions",
                            "id": "#prepare_regions_unpadded_cnv/blacklist_regions"
                        },
                        {
                            "source": "#calling_regions",
                            "id": "#prepare_regions_unpadded_cnv/calling_regions"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "valueFrom": "$(self.secondaryFiles.filter(function(e) { return e.basename.search(/.dict$/) != -1 })[0])\n",
                            "id": "#prepare_regions_unpadded_cnv/reference_dict"
                        },
                        {
                            "source": [
                                "#/runtime_validator/run_controlfreec",
                                "#/runtime_validator/run_cnvkit"
                            ],
                            "id": "#prepare_regions_unpadded_cnv/run_tool"
                        },
                        {
                            "valueFrom": "$(0)",
                            "id": "#prepare_regions_unpadded_cnv/scatter_count"
                        }
                    ],
                    "out": [
                        "#/prepare_regions_unpadded_cnv/prescatter_intervallist",
                        "#/prepare_regions_unpadded_cnv/prescatter_bed",
                        "#/prepare_regions_unpadded_cnv/prescatter_bedgz",
                        "#/prepare_regions_unpadded_cnv/scattered_intervallists",
                        "#/prepare_regions_unpadded_cnv/scattered_beds"
                    ],
                    "id": "#prepare_regions_unpadded_cnv"
                },
                {
                    "run": "#prepare_regions.cwl",
                    "when": "$(inputs.wgs_or_wxs == 'WGS' && inputs.run_tool)",
                    "in": [
                        {
                            "valueFrom": "$(20000)",
                            "id": "#prepare_regions_unpadded_minibands/break_bands_at_multiples_of"
                        },
                        {
                            "source": "#/prepare_regions_unpadded/prescatter_intervallist",
                            "id": "#prepare_regions_unpadded_minibands/calling_regions"
                        },
                        {
                            "source": "#/runtime_validator/run_vardict",
                            "id": "#prepare_regions_unpadded_minibands/run_tool"
                        },
                        {
                            "valueFrom": "$(50)",
                            "id": "#prepare_regions_unpadded_minibands/scatter_count"
                        },
                        {
                            "source": "#wgs_or_wxs",
                            "id": "#prepare_regions_unpadded_minibands/wgs_or_wxs"
                        }
                    ],
                    "out": [
                        "#/prepare_regions_unpadded_minibands/prescatter_intervallist",
                        "#/prepare_regions_unpadded_minibands/prescatter_bed",
                        "#/prepare_regions_unpadded_minibands/prescatter_bedgz",
                        "#/prepare_regions_unpadded_minibands/scattered_intervallists",
                        "#/prepare_regions_unpadded_minibands/scattered_beds"
                    ],
                    "id": "#prepare_regions_unpadded_minibands"
                },
                {
                    "run": "#runtime_validator.cwl",
                    "in": [
                        {
                            "source": "#run_amplicon_architect",
                            "id": "#runtime_validator/amplicon_architect"
                        },
                        {
                            "source": "#b_allele",
                            "valueFrom": "$(self != null)\n",
                            "id": "#runtime_validator/b_allele_present"
                        },
                        {
                            "source": "#run_cnvkit",
                            "id": "#runtime_validator/cnvkit"
                        },
                        {
                            "source": "#cnvkit_wgs_mode",
                            "id": "#runtime_validator/cnvkit_wgs_mode"
                        },
                        {
                            "source": "#run_controlfreec",
                            "id": "#runtime_validator/controlfreec"
                        },
                        {
                            "source": "#exome_flag",
                            "id": "#runtime_validator/exome_flag"
                        },
                        {
                            "source": "#run_gatk_cnv",
                            "id": "#runtime_validator/gatk_cnv"
                        },
                        {
                            "source": "#i_flag",
                            "id": "#runtime_validator/i_flag"
                        },
                        {
                            "source": "#wgs_or_wxs",
                            "valueFrom": "$(self == 'WGS')\n",
                            "id": "#runtime_validator/is_wgs"
                        },
                        {
                            "source": "#run_lancet",
                            "id": "#runtime_validator/lancet"
                        },
                        {
                            "source": "#lancet_padding",
                            "id": "#runtime_validator/lancet_padding"
                        },
                        {
                            "source": "#lancet_window",
                            "id": "#runtime_validator/lancet_window"
                        },
                        {
                            "source": "#run_manta",
                            "id": "#runtime_validator/manta"
                        },
                        {
                            "source": "#mosek_license_file",
                            "valueFrom": "$(self != null)\n",
                            "id": "#runtime_validator/mosek_present"
                        },
                        {
                            "source": "#run_mutect2",
                            "id": "#runtime_validator/mutect2"
                        },
                        {
                            "source": "#count_panel_of_normals",
                            "valueFrom": "$(self != null)\n",
                            "id": "#runtime_validator/pon_present"
                        },
                        {
                            "source": "#lancet_input_vcf",
                            "valueFrom": "$(self != null)",
                            "id": "#runtime_validator/preexisting_vcf"
                        },
                        {
                            "source": "#run_strelka2",
                            "id": "#runtime_validator/strelka2"
                        },
                        {
                            "source": "#run_theta2",
                            "id": "#runtime_validator/theta2"
                        },
                        {
                            "source": "#run_vardict",
                            "id": "#runtime_validator/vardict"
                        },
                        {
                            "source": "#vardict_padding",
                            "id": "#runtime_validator/vardict_padding"
                        }
                    ],
                    "out": [
                        "#/runtime_validator/out_wgs",
                        "#/runtime_validator/run_vardict",
                        "#/runtime_validator/run_mutect2",
                        "#/runtime_validator/run_strelka2",
                        "#/runtime_validator/run_lancet",
                        "#/runtime_validator/run_controlfreec",
                        "#/runtime_validator/run_cnvkit",
                        "#/runtime_validator/run_amplicon_architect",
                        "#/runtime_validator/run_theta2",
                        "#/runtime_validator/run_manta",
                        "#/runtime_validator/run_gatk_cnv",
                        "#/runtime_validator/out_exome_flag",
                        "#/runtime_validator/out_cnvkit_wgs_mode",
                        "#/runtime_validator/out_i_flag",
                        "#/runtime_validator/out_lancet_padding",
                        "#/runtime_validator/out_lancet_window",
                        "#/runtime_validator/out_vardict_padding"
                    ],
                    "id": "#runtime_validator"
                },
                {
                    "run": "#samtools_calmd.cwl",
                    "when": "$(inputs.run_tool.some(function(e) { return e }) && (inputs.input_reads.basename.search(/.cram$/) != -1 || inputs.run_anyway) )",
                    "in": [
                        {
                            "source": "#input_normal_aligned",
                            "id": "#samtools_cram2bam_plus_calmd_normal/input_reads"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "id": "#samtools_cram2bam_plus_calmd_normal/reference"
                        },
                        {
                            "source": "#run_calmd_bam",
                            "id": "#samtools_cram2bam_plus_calmd_normal/run_anyway"
                        },
                        {
                            "source": [
                                "#/runtime_validator/run_vardict",
                                "#/runtime_validator/run_lancet",
                                "#/runtime_validator/run_controlfreec",
                                "#/runtime_validator/run_cnvkit"
                            ],
                            "id": "#samtools_cram2bam_plus_calmd_normal/run_tool"
                        },
                        {
                            "valueFrom": "${return 16;}",
                            "id": "#samtools_cram2bam_plus_calmd_normal/threads"
                        }
                    ],
                    "out": [
                        "#/samtools_cram2bam_plus_calmd_normal/bam_file"
                    ],
                    "id": "#samtools_cram2bam_plus_calmd_normal"
                },
                {
                    "run": "#samtools_calmd.cwl",
                    "when": "$(inputs.run_tool.some(function(e) { return e }) && (inputs.input_reads.basename.search(/.cram$/) != -1 || inputs.run_anyway) )",
                    "in": [
                        {
                            "source": "#input_tumor_aligned",
                            "id": "#samtools_cram2bam_plus_calmd_tumor/input_reads"
                        },
                        {
                            "source": "#indexed_reference_fasta",
                            "id": "#samtools_cram2bam_plus_calmd_tumor/reference"
                        },
                        {
                            "source": "#run_calmd_bam",
                            "id": "#samtools_cram2bam_plus_calmd_tumor/run_anyway"
                        },
                        {
                            "source": [
                                "#/runtime_validator/run_vardict",
                                "#/runtime_validator/run_lancet",
                                "#/runtime_validator/run_controlfreec",
                                "#/runtime_validator/run_cnvkit"
                            ],
                            "id": "#samtools_cram2bam_plus_calmd_tumor/run_tool"
                        },
                        {
                            "valueFrom": "${return 16;}",
                            "id": "#samtools_cram2bam_plus_calmd_tumor/threads"
                        }
                    ],
                    "out": [
                        "#/samtools_cram2bam_plus_calmd_tumor/bam_file"
                    ],
                    "id": "#samtools_cram2bam_plus_calmd_tumor"
                },
                {
                    "run": "#kfdrc_strelka2_sub_wf.cwl",
                    "when": "$(inputs.run_strelka2)",
                    "in": [
                        {
                            "source": "#bcftools_public_filter",
                            "id": "#strelka2/bcftools_public_filter"
