                            "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/tar_outputs_normal/input_files"
                        },
                        {
                            "source": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/model_segments_normal/modeled_segments",
                            "valueFrom": "$(self ? self.nameroot.split('.')[0]+\".normal.gatk_cnv.tar.gz\" : null)\n",
                            "id": "#kfdrc_gatk_cnv_somatic_pair_wf.cwl/tar_outputs_normal/output_file"
